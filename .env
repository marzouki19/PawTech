# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted files with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific local overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION ENVIRONMENT VARIABLES IN THIS FILE.
#
# Instead, use .env.production.local or .env.local on production servers.
#
# https://symfony.com/doc/current/configuration.html#configuring-the-database

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
