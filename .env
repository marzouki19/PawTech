###> symfony/messenger ###
# Choose one of the transports below
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
###< symfony/messenger ###

###> symfony/mercure ###
# The URL of the Mercure hub (the URL where the .well-known/mercure endpoint is reachable)
MERCURE_URL=http://127.0.0.1:8000/.well-known/mercure
# The public URL of the Mercure hub (must be accessible from the browser)
MERCURE_PUBLIC_URL=http://127.0.0.1:8000/.well-known/mercure
# The secret used to sign the JWT tokens
MERCURE_JWT_SECRET=ChangeThisToASecureRandomString123456789
###< symfony/mercure ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###
