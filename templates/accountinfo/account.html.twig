{% extends 'base.html.twig' %}

{% block title %}Account Information{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 relative">
  <!-- Home Button -->
  <a href="{{ path('app_home') }}" class="absolute top-8 right-8 px-5 py-2 rounded-lg bg-blue-600 text-white font-bold shadow hover:bg-blue-700 flex items-center gap-2 z-20">
    <i class="fas fa-home"></i> Home
  </a>
  <div class="max-w-6xl mx-auto flex gap-8 py-12">
    <!-- Sidebar Navigation -->
    <aside class="w-72 bg-white rounded-2xl shadow-lg p-8 flex flex-col gap-4">
      <h2 class="text-xl font-bold mb-6 tracking-tight text-gray-900">Settings</h2>
      <nav class="flex flex-col gap-2">
        <a href="#" class="py-3 px-4 rounded-lg bg-orange-50 font-semibold text-orange-700 flex items-center gap-2"><i class="fas fa-user-circle"></i> Profile</a>
        <a href="#password-section" id="sidebar-security" class="py-3 px-4 rounded-lg text-gray-700 hover:bg-orange-100 flex items-center gap-2"><i class="fas fa-shield-alt text-orange-500"></i> Security & Privacy</a>
      </nav>
    </aside>
    <!-- Main Content -->
    <div class="flex-1">
      <div class="bg-white rounded-3xl shadow-2xl p-8 flex flex-col gap-8">
        <div class="mb-8 flex flex-col items-center">
          <div class="h-32 w-full rounded-3xl bg-gradient-to-r from-gray-100 via-orange-100 to-orange-200 mb-[-4rem]"></div>
          <div class="relative -mt-20 flex flex-col items-center w-full">
            <div class="group relative w-40 h-40 rounded-full overflow-hidden bg-gray-100 ring-8 ring-orange-100 transition-all duration-300 shadow-lg mb-4">
              <input type="file" id="image" accept="image/*" class="hidden" onchange="previewImage(event)"
                     data-image-name="{{ form.user_face.vars.full_name }}" data-image-id="{{ form.user_face.vars.id }}">
              {% set avatarSrc = null %}
              {% if user.userFace %}
                {% set avatarSrc = user.userFace starts with 'data:image' ? user.userFace : 'data:image/png;base64,' ~ user.userFace %}
              {% elseif user.userImage %}
                {% set avatarSrc = asset(user.userImage) ~ '?v=' ~ random() %}
              {% endif %}
              {% if avatarSrc %}
                <img id="preview-img" src="{{ avatarSrc }}" alt="Avatar" class="absolute inset-0 w-full h-full object-cover object-center rounded-full" style="aspect-ratio: 1/1;" />
              {% else %}
                <img id="preview-img" src="" alt="Avatar" class="absolute inset-0 w-full h-full object-cover object-center rounded-full hidden" style="aspect-ratio: 1/1;" />
                <div id="avatar-fallback" class="w-full h-full flex items-center justify-center text-5xl font-bold text-gray-400">
                  {{ user.prenom|default('U')|first|upper }}
                </div>
              {% endif %}
              <label for="image" class="absolute inset-0 flex flex-col items-center justify-center bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer z-10" onclick="document.getElementById('image').click()">
                <i class="fas fa-pen text-white text-3xl mb-2"></i>
                <span class="text-white text-base font-semibold">Edit Image</span>
              </label>
            </div>
            <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight mb-1">Profile</h1>
            <p class="text-gray-500 text-base mb-4">Update your photo and personal details.</p>
            <div class="flex gap-2">
              <button type="button" class="px-6 py-2 rounded-lg bg-gray-200 text-gray-700 text-base font-semibold hover:bg-gray-300">Cancel</button>
              <button type="submit" form="profile-form" class="px-6 py-2 rounded-lg bg-orange-600 text-white text-base font-semibold hover:bg-orange-700">Save</button>
            </div>
          </div>
        </div>
        <!-- Profile Details Form -->
        <div class="w-full flex justify-center">
          <div class="w-full max-w-2xl bg-gray-50 rounded-2xl shadow p-8 border border-orange-100">
            {{ form_start(form, {'attr': {'id': 'profile-form', 'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">First name</label>
                {{ form_widget(form.prenom, {'attr': {'class': 'w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
                <span class="text-red-600">{{ form_errors(form.prenom) }}</span>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Last name</label>
                {{ form_widget(form.nom, {'attr': {'class': 'w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
                <span class="text-red-600">{{ form_errors(form.nom) }}</span>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                {{ form_widget(form.email, {'attr': {'class': 'w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
                <span class="text-red-600">{{ form_errors(form.email) }}</span>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                {{ form_widget(form.telephone, {'attr': {'class': 'w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
                <span class="text-red-600">{{ form_errors(form.telephone) }}</span>
              </div>
            </div>
            <div class="flex justify-end mt-6">
              <button type="submit" class="px-6 py-2 rounded-lg bg-orange-600 text-white text-base font-semibold hover:bg-orange-700">Save Changes</button>
            </div>
            {{ form_widget(form._token) }}
            {{ form_end(form, {'render_rest': false}) }}
          </div>
        </div>
        <!-- Password & Security Section (hidden by default, revealed by anchor) -->
        <div id="password-section" class="mt-16 flex justify-center scroll-mt-24 hidden" tabindex="-1">
          <div class="w-full max-w-2xl bg-white rounded-3xl shadow-xl p-10 border border-orange-100">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 flex items-center justify-center rounded-full bg-orange-100">
                <i class="fas fa-lock text-orange-600 text-3xl"></i>
              </div>
              <div>
                <div class="text-2xl font-bold text-gray-900">Password & Security</div>
                <div class="text-gray-500 text-base">Change your password and manage security settings</div>
              </div>
            </div>
            <form method="post" class="bg-gray-50 rounded-2xl p-8 border border-orange-100 shadow">
              <div class="mb-6">
                <label class="block text-base font-medium text-gray-700 mb-2">Current Password</label>
                <input type="password" name="current_password" class="w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500 text-lg" required />
              </div>
              <div class="mb-6">
                <label class="block text-base font-medium text-gray-700 mb-2">New Password</label>
                <input type="password" name="new_password" class="w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500 text-lg" required />
              </div>
              <div class="mb-8">
                <label class="block text-base font-medium text-gray-700 mb-2">Confirm New Password</label>
                <input type="password" name="confirm_new_password" class="w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500 text-lg" required />
              </div>
              <div class="flex justify-end gap-4">
                <button type="reset" class="px-6 py-3 rounded-lg bg-gray-200 text-gray-700 text-lg font-semibold hover:bg-gray-300">Cancel</button>
                <button type="submit" class="px-6 py-3 rounded-lg bg-orange-600 text-white text-lg font-semibold hover:bg-orange-700">Change Password</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  function previewImage(event) {
    const fileInput = event.target;
    const file = fileInput.files[0];
    const preview = document.getElementById('preview-img');
    const fallback = document.getElementById('avatar-fallback');
    const base64Input = getImageBase64Input();

    if (!file || !preview || !base64Input) {
      return;
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      preview.src = e.target.result;
      preview.classList.remove('hidden');
      if (fallback) fallback.classList.add('hidden');
      base64Input.value = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  function getImageBase64Input() {
    let input = document.getElementById('avatar-base64');
    if (input) return input;

    const fileInput = document.getElementById('image');
    if (!fileInput) return null;

    input = document.createElement('input');
    input.type = 'hidden';
    input.id = 'avatar-base64';
    input.name = fileInput.dataset.imageName || '';
    if (fileInput.dataset.imageId) {
      input.setAttribute('data-image-id', fileInput.dataset.imageId);
    }
    document.getElementById('profile-form')?.appendChild(input);
    return input;
  }

  (function() {
    getImageBase64Input();

    // Password section navigation and reveal
    var sidebarSecurity = document.getElementById('sidebar-security');
    var passwordSection = document.getElementById('password-section');
    if (sidebarSecurity && passwordSection) {
      sidebarSecurity.addEventListener('click', function(e) {
        e.preventDefault();
        passwordSection.classList.remove('hidden');
        setTimeout(function() {
          passwordSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
          passwordSection.focus();
        }, 100);
      });
      // Hide password section if user clicks outside of it
      document.addEventListener('mousedown', function(event) {
        if (!passwordSection.contains(event.target) && !sidebarSecurity.contains(event.target)) {
          passwordSection.classList.add('hidden');
        }
      });
    }
  })();
</script>
{% endblock %}
