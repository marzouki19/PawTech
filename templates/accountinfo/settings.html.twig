{% extends 'base.html.twig' %}

{% block title %}Account Information{% endblock %}

{% block body %}
<div class="min-h-[70vh] bg-gradient-to-b from-orange-50 via-white to-white">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-extrabold text-gray-900">Account Information</h1>
        <p class="text-sm text-gray-500">Update your personal details and profile photo.</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="{{ path('app_settings') }}" class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700">
          <span class="w-2 h-2 rounded-full bg-blue-600"></span>
          Profile Settings
        </a>
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-gray-900">
          <i class="fas fa-home"></i>
          Back to Home
        </a>
      </div>
    </div>

    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="mb-4 rounded-xl bg-green-50 text-green-700 px-4 py-3 text-sm shadow-sm">
          {{ message }}
        </div>
      {% endfor %}
    {% endfor %}

    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'grid grid-cols-1 lg:grid-cols-3 gap-6'}}) }}
      <div class="lg:col-span-1 bg-white rounded-2xl shadow-md p-6">
        <div class="flex flex-col items-center text-center">
          <div class="w-28 h-28 rounded-full overflow-hidden bg-gray-100 ring-4 ring-orange-100">
            {% if user.userImage %}
              <img id="avatar-preview" src="{{ user.userImage }}" alt="Avatar" class="w-full h-full object-cover" />
            {% else %}
              <img id="avatar-preview" src="" alt="Avatar" class="w-full h-full object-cover hidden" />
              <div id="avatar-fallback" class="w-full h-full flex items-center justify-center text-3xl font-bold text-gray-400">
                {{ user.prenom|default('U')|first|upper }}
              </div>
            {% endif %}
          </div>
          <p class="mt-4 text-sm text-gray-600">This photo appears on your account.</p>
          <label class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-orange-500 text-white text-sm font-medium hover:bg-orange-600 cursor-pointer">
            <i class="fas fa-camera"></i>
            Change photo
            {{ form_widget(form.user_image, {'attr': {'id': 'avatar-input', 'class': 'hidden'}}) }}
          </label>
          <p class="text-xs text-gray-400 mt-2">PNG/JPG up to 2MB.</p>
          {{ form_errors(form.user_image) }}
        </div>
      </div>

      <div class="lg:col-span-2 bg-white rounded-2xl shadow-md p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700">First name</label>
            {{ form_widget(form.prenom, {'attr': {'class': 'mt-1 w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
            {{ form_errors(form.prenom) }}
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Last name</label>
            {{ form_widget(form.nom, {'attr': {'class': 'mt-1 w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
            {{ form_errors(form.nom) }}
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Email</label>
            {{ form_widget(form.email, {'attr': {'class': 'mt-1 w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
            {{ form_errors(form.email) }}
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Phone</label>
            {{ form_widget(form.telephone, {'attr': {'class': 'mt-1 w-full rounded-lg border-gray-200 focus:border-orange-500 focus:ring-orange-500'}}) }}
            {{ form_errors(form.telephone) }}
          </div>
        </div>

        <div class="mt-6 flex items-center justify-between">
          <p class="text-xs text-gray-400">Last updated: {{ "now"|date("d M Y, H:i") }}</p>
          <button type="submit" class="px-5 py-2.5 rounded-lg bg-orange-500 text-white font-semibold hover:bg-orange-600">Save changes</button>
        </div>
      </div>
    {{ form_end(form) }}
  </div>
</div>
<script>
  (function() {
    var input = document.getElementById('avatar-input');
    var preview = document.getElementById('avatar-preview');
    var fallback = document.getElementById('avatar-fallback');

    if (!input || !preview) return;

    input.addEventListener('change', function(e) {
      var file = e.target.files && e.target.files[0];
      if (!file) return;

      var reader = new FileReader();
      reader.onload = function(ev) {
        preview.src = ev.target.result;
        preview.classList.remove('hidden');
        if (fallback) fallback.classList.add('hidden');
      };
      reader.readAsDataURL(file);
    });
  })();
</script>
{% endblock %}
