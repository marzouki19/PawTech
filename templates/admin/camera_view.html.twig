/**
 * Refresh stream display to show latest frames without interrupting continuity
 * This updates the HLS player to load the latest segments
 */
function refreshStreamDisplay() {
    showStreamStatus('Refreshing display...', 'info');
    
    fetch(`/admin/cameras/${cameraId}/control`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ action: 'stream_refresh' })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Reload the HLS stream without stopping - this gets the latest segments
            if (player) {
                const streamUrl = data.streamUrl || '{{ camera.hlsStreamUrl ?: camera.fullStreamUrl }}';
                // Update the source with a cache-busting query to get latest segments
                player.src({
                    src: streamUrl + '?t=' + new Date().getTime(),
                    type: 'application/x-mpegURL'
                });
                player.play();
            }
            // Also refresh the fallback image
            const fallback = document.getElementById('camera-fallback');
            if (fallback) {
                fallback.src = '{{ camera.fullSnapshotUrl }}?t=' + new Date().getTime();
            }
            showStreamStatus('Display refreshed', 'success');
        } else {
            showStreamStatus('Refresh failed: ' + (data.message || 'Unknown error'), 'error');
        }
    })
    .catch(error => {
        console.error('Refresh error:', error);
        showStreamStatus('Refresh error: ' + error.message, 'error');
    });
}

/**
 * Start the video stream (initiates FFmpeg transcoding)
 */
function startStream() {
