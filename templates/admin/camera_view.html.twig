            `).join('');
        } else {
            container.innerHTML = '<p class="text-gray-500 text-sm">No recent activity</p>';
        }
    })
    .catch(error => {
        document.getElementById('recent-activity').innerHTML = '<p class="text-gray-500 text-sm">Error loading activity</p>';
    });

// Auto-refresh snapshot every 5 seconds
setInterval(() => {
    const fallback = document.getElementById('camera-fallback');
    if (fallback) {
        fallback.src = '{{ camera.fullSnapshotUrl }}?t=' + new Date().getTime();
    }
}, 5000);
</script>
{% endblock %}
