/**
 * Initialize PTZ control buttons with hold-to-move functionality
 * Adds mousedown/mouseup/touchstart/touchend event listeners
 */
function initPTZButtons() {
    const ptzButtons = document.querySelectorAll('[data-ptz-action]');
    
    ptzButtons.forEach(button => {
        const action = button.getAttribute('data-ptz-action');
        
        // Mouse events for desktop
        button.addEventListener('mousedown', (e) => {
            e.preventDefault(); // Prevent text selection
            startPTZMovement(action);
        });
        
        button.addEventListener('mouseup', () => {
            stopPTZMovement();
        });
        
        button.addEventListener('mouseleave', () => {
            stopPTZMovement();
        });
        
        // Touch events for mobile/tablet
        button.addEventListener('touchstart', (e) => {
            e.preventDefault();
            startPTZMovement(action);
        }, { passive: false });
        
        button.addEventListener('touchend', () => {
            stopPTZMovement();
        });
        
        button.addEventListener('touchcancel', () => {
            stopPTZMovement();
        });
    });
}

/**
 * Start continuous PTZ movement
 * Sends initial command and sets up interval to refresh before timeout
 * @param {string} action - PTZ action (ptz_up, ptz_down, ptz_left, ptz_right, zoom_in, zoom_out)
 */
function startPTZMovement(action) {
    // Stop any existing movement first
    if (ptzInterval) {
        clearInterval(ptzInterval);
        ptzInterval = null;
    }
    
    ptzCurrentAction = action;
    
    // Send initial PTZ command with timeout
    ptzControl(action, null, PTZ_TIMEOUT_SECONDS);
    
    // Set up interval to refresh command before timeout expires
    // This ensures continuous movement as long as button is held
    ptzInterval = setInterval(() => {
        if (ptzCurrentAction) {
            ptzControl(ptzCurrentAction, null, PTZ_TIMEOUT_SECONDS);
        }
    }, PTZ_REFRESH_INTERVAL);
}

/**
 * Stop PTZ movement immediately
 * Sends Stop command to halt all PTZ movement
 */
function stopPTZMovement() {
    // Clear the refresh interval
    if (ptzInterval) {
        clearInterval(ptzInterval);
        ptzInterval = null;
    }
    
    // Only send stop if there was an active movement
    if (ptzCurrentAction) {
        ptzControl('ptz_stop');
        ptzCurrentAction = null;
    }
}

/**
 * PTZ Control function
 * @param {string} action - PTZ action (ptz_up, ptz_down, ptz_left, ptz_right, zoom_in, zoom_out, ptz_stop, ptz_home)
 * @param {number|null} preset - Optional preset number
 * @param {number} timeout - Optional timeout in seconds for hold-to-move
 */
function ptzControl(action, preset = null, timeout = null) {
    console.log('PTZ Control called:', action, 'timeout:', timeout);
    
    const data = { action: action };
    if (preset) {
        data.preset = preset;
    }
    // Pass timeout to backend for hold-to-move functionality
    if (timeout) {
        data.timeout = timeout;
    }
    
    fetch(`/admin/cameras/${cameraId}/control`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        console.log('PTZ Response status:', response.status);
        return response.json();
    })
    .then(data => {
        console.log('PTZ Response data:', data);
        // Show feedback
        if (data.success) {
            // Visual feedback
        } else if (data.error) {
            console.error('PTZ Error:', data.error);
        }
    })
    .catch(error => {
        console.error('PTZ Request failed:', error);
    });
}

