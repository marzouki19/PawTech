/**
 * Start VLC stream for computer vision processing
 */
function startVlcStream() {
    showStreamStatus('Starting VLC stream for CV...', 'info');
    
    fetch(`/admin/cameras/${cameraId}/control`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ action: 'vlc_start' })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            document.getElementById('vlc-status').innerHTML = '<span class="text-green-500">●</span> VLC running on port ' + (8080 + cameraId);
            showStreamStatus('VLC stream started for CV processing', 'success');
            
            // Auto-switch to VLC mode after starting
            setTimeout(() => {
                // Hide Video.js, show MJPEG image
                document.getElementById('camera-stream').classList.add('hidden');
                const vlcImg = document.getElementById('vlc-stream');
                vlcImg.classList.remove('hidden');
                
                // Set the VLC URL for MJPEG streaming
                const vlcPort = 8080 + cameraId;
                vlcImg.src = `http://localhost:${vlcPort}/stream.jpg?t=${new Date().getTime()}`;
                
                // Start polling for fresh frames
                if (window.vlcInterval) clearInterval(window.vlcInterval);
                window.vlcInterval = setInterval(() => {
                    vlcImg.src = `http://localhost:${vlcPort}/stream.jpg?t=${new Date().getTime()}`;
                }, 100); // 10fps for smooth playback
                
                // Update mode
                currentStreamMode = 'vlc';
                document.getElementById('btn-vlc').className = 'flex-1 bg-purple-600 hover:bg-purple-500 py-2 rounded-lg transition text-center text-sm font-medium';
                document.getElementById('btn-hls').className = 'flex-1 bg-gray-700 hover:bg-gray-600 py-2 rounded-lg transition text-center text-sm font-medium';
                document.getElementById('stream-mode-desc').textContent = 'VLC: Low-latency for AI/ML processing';
                
            }, 3000);
        } else {
            document.getElementById('vlc-status').innerHTML = '<span class="text-red-500">●</span> VLC failed to start';
            showStreamStatus('Failed to start VLC: ' + (data.error || data.message || 'Unknown error'), 'error');
        }
    })
    .catch(error => {
        console.error('VLC start error:', error);
        document.getElementById('vlc-status').innerHTML = '<span class="text-red-500">●</span> VLC error';
        showStreamStatus('VLC start error: ' + error.message, 'error');
    });
}

