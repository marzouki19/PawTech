<style>
    .form-error ul { margin: 0; padding-left: 1.25rem; list-style: disc; }
    .form-error li { color: #dc2626; font-size: 0.875rem; font-weight: 600; }
</style>

{{ form_start(form, {'attr': {'id': form_id|default('adoption-form'), 'novalidate': 'novalidate', 'class': 'space-y-6'}}) }}
<div class="space-y-5">
    <div>
        {{ form_label(form.user, 'Applicant', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.user.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
        {{ form_widget(form.user, {'attr': {'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.user.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
        <div class="form-error mt-2">{{ form_errors(form.user) }}</div>
    </div>

    <div>
        {{ form_label(form.dog, 'Dog', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.dog.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
        {{ form_widget(form.dog, {'attr': {'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.dog.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
        <div class="form-error mt-2">{{ form_errors(form.dog) }}</div>
    </div>

    <div>
        {{ form_label(form.createdAt, 'Application Date', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.createdAt.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
        {{ form_widget(form.createdAt, {'attr': {'max': 'now'|date('Y-m-d\\TH:i'), 'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.createdAt.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
        <div class="form-error mt-2">{{ form_errors(form.createdAt) }}</div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
            {{ form_label(form.applicantAge, 'Applicant Age', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.applicantAge.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
            {{ form_widget(form.applicantAge, {'attr': {'min': 18, 'max': 120, 'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.applicantAge.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
            <div class="form-error mt-2">{{ form_errors(form.applicantAge) }}</div>
        </div>
        <div>
            {{ form_label(form.familySize, 'Family Size', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.familySize.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
            {{ form_widget(form.familySize, {'attr': {'min': 1, 'max': 20, 'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.familySize.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
            <div class="form-error mt-2">{{ form_errors(form.familySize) }}</div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
            {{ form_label(form.income, 'Income (TND)', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.income.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
            {{ form_widget(form.income, {'attr': {'min': '0', 'max': '1000000', 'step': '0.01', 'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.income.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
            <div class="form-error mt-2">{{ form_errors(form.income) }}</div>
        </div>
        <div>
            {{ form_label(form.hoursAwayPerDay, 'Hours Away / Day', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.hoursAwayPerDay.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
            {{ form_widget(form.hoursAwayPerDay, {'attr': {'min': 0, 'max': 24, 'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.hoursAwayPerDay.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
            <div class="form-error mt-2">{{ form_errors(form.hoursAwayPerDay) }}</div>
        </div>
    </div>

    <div>
        {{ form_label(form.housingType, 'Housing Type', {'label_attr': {'class': 'block text-xs font-semibold mb-1 ' ~ (form.housingType.vars.errors|length ? 'text-red-600' : 'text-gray-700')}}) }}
        {{ form_widget(form.housingType, {'attr': {'class': 'w-full rounded-lg border px-3 py-2 text-sm transition ' ~ (form.housingType.vars.errors|length ? 'border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200' : 'border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200')}}) }}
        <div class="form-error mt-2">{{ form_errors(form.housingType) }}</div>
    </div>

    <div class="flex items-center gap-3 pt-1">
        {{ form_widget(form.hasYard, {'attr': {'class': 'h-4 w-4 rounded border-gray-300 text-paw-orange focus:ring-paw-orange'}}) }}
        {{ form_label(form.hasYard, 'Has yard', {'label_attr': {'class': 'text-sm text-gray-700'}}) }}
        <div class="form-error">{{ form_errors(form.hasYard) }}</div>
    </div>
</div>

<div class="flex flex-wrap items-center justify-between gap-3 mt-8 pt-6 border-t border-gray-200">
    <a href="{{ path('app_adoption_index') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 transition">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Back to list
    </a>
    <button type="submit" class="px-8 py-3 bg-orange-500 hover:bg-orange-600 text-white rounded-lg font-semibold shadow-lg hover:shadow-xl transition-all duration-200">
        {{ button_label|default('Save Adoption') }}
    </button>
</div>
{{ form_end(form) }}
