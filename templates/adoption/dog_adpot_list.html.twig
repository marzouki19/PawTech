{% extends 'layout.html.twig' %}

{% block title %}Dog Adoption Requests | PawTech{% endblock %}

{% set active = 'adoption' %}
{% set page_title = 'Dog Adoption Requests' %}

{% block main %}
<div x-data="{
    deleteModalOpen: false,
    dogInfoModalOpen: false,
    autoAdoptModalOpen: false,
    autoAdoptResultModalOpen: false,
    autoAdoptLoading: false,
    autoAdoptError: '',
    autoAdoptResult: null,
    autoAdoptEndpoint: '{{ path('app_adoption_auto_adopt_match', {'id': dog.id}) }}',
    deleteAction: '',
    deleteToken: '',
    deleteLabel: '',
    openDelete(action, token, label) {
        this.deleteAction = action;
        this.deleteToken = token;
        this.deleteLabel = label;
        this.deleteModalOpen = true;
    },
    async runAutoAdopt() {
        this.autoAdoptLoading = true;
        this.autoAdoptError = '';
        try {
            const response = await fetch(this.autoAdoptEndpoint, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({})
            });
            const data = await response.json();
            if (!response.ok || !data.ok) {
                throw new Error(data.message || 'AUTO ADOPT failed.');
            }
            this.autoAdoptResult = data;
            this.autoAdoptModalOpen = false;
            this.autoAdoptResultModalOpen = true;
        } catch (error) {
            this.autoAdoptError = error.message || 'AUTO ADOPT failed.';
        } finally {
            this.autoAdoptLoading = false;
        }
    }
}">
<div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <a href="{{ path('app_adoption_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-gray-600 hover:text-gray-800 mb-2">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    Back to dogs grid
                </a>
                <h1 class="text-2xl font-bold text-gray-900">Adoption Requests for {{ dog.name }}</h1>
                <p class="mt-1 text-sm text-gray-600">Breed: {{ dog.breed }} | Status: {{ dog.adoptionStatus }}</p>
            </div>
            <div class="flex items-center gap-3">
                <div class="text-sm text-gray-600">Total requests: <span class="font-semibold text-gray-900">{{ adoptions|length }}</span></div>
                <button type="button"
                        @click="autoAdoptModalOpen = true"
                        class="px-4 py-2 rounded-lg border border-green-200 text-sm font-semibold text-green-700 hover:bg-green-50">
                    AUTO ADOPT
                </button>
                <button type="button"
                        @click="dogInfoModalOpen = true"
                        class="px-4 py-2 rounded-lg border border-blue-200 text-sm font-semibold text-blue-600 hover:bg-blue-50">
                    Dog Information
                </button>
            </div>
        </div>
    </div>

    {% if adoptions is empty %}
        <div class="rounded-2xl border border-dashed border-gray-200 p-12 text-center bg-white">
            <p class="text-sm font-semibold text-gray-600">No adoption requests found for this dog.</p>
        </div>
    {% else %}
        <div class="space-y-4">
            {% for adoption in adoptions %}
                <div class="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
                    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                        <div>
                            <p class="text-sm text-gray-500">Request #{{ adoption.id }} - {{ adoption.createdAt ? adoption.createdAt|date('d/m/Y H:i') : '-' }}</p>
                            <h3 class="text-lg font-semibold text-gray-900 mt-1">{{ adoption.user ? adoption.user.fullName : '-' }}</h3>
                            <p class="text-sm text-gray-500">{{ adoption.user ? adoption.user.email : '-' }}</p>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
                            <div><span class="text-gray-500">Age:</span> <span class="font-semibold">{{ adoption.applicantAge }}</span></div>
                            <div><span class="text-gray-500">Income:</span> <span class="font-semibold">{{ adoption.income|number_format(2, ',', ' ') }} TND</span></div>
                            <div><span class="text-gray-500">Housing:</span> <span class="font-semibold">{{ adoption.housingType|title }}</span></div>
                            <div><span class="text-gray-500">Yard:</span> <span class="font-semibold">{{ adoption.hasYard ? 'Yes' : 'No' }}</span></div>
                            <div><span class="text-gray-500">Family:</span> <span class="font-semibold">{{ adoption.familySize }}</span></div>
                            <div><span class="text-gray-500">Hours Away:</span> <span class="font-semibold">{{ adoption.hoursAwayPerDay }} h</span></div>
                        </div>
                        <div class="flex items-center gap-3">
                            <a href="{{ path('app_adoption_show', {'id': adoption.id}) }}" class="px-4 py-2 rounded-lg border border-gray-200 text-sm font-semibold text-gray-700 hover:bg-gray-50">View</a>
                            <a href="{{ path('app_adoption_edit', {'id': adoption.id}) }}" class="px-4 py-2 rounded-lg border border-orange-200 text-sm font-semibold text-orange-600 hover:bg-orange-50">Edit</a>
                            <button type="button"
                                    class="px-4 py-2 rounded-lg border border-red-200 text-sm font-semibold text-red-600 hover:bg-red-50"
                                    @click="openDelete('{{ path('app_adoption_delete', {'id': adoption.id}) }}', '{{ csrf_token('delete' ~ adoption.id) }}', 'Request #{{ adoption.id }}')">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<div x-show="dogInfoModalOpen"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
     @click.self="dogInfoModalOpen = false"
     @keydown.escape.window="dogInfoModalOpen = false"
     style="display: none;"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 scale-100"
     x-transition:leave-end="opacity-0 scale-95">
    <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Dog Information</h2>
                    <p class="mt-1 text-sm text-gray-600">Complete profile for {{ dog.name }}</p>
                </div>
                <button @click="dogInfoModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="px-8 py-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="rounded-xl bg-gray-100 overflow-hidden h-56">
                    {% if dog.image %}
                        {% set rawImage = dog.image|trim %}
                        {% if rawImage starts with 'data:image' %}
                            {% set imageSrc = rawImage %}
                        {% elseif rawImage starts with 'http://' or rawImage starts with 'https://' %}
                            {% set imageSrc = rawImage %}
                        {% elseif rawImage starts with 'uploads/' or rawImage starts with 'images/' %}
                            {% set imageSrc = asset(rawImage) %}
                        {% else %}
                            {% set imageSrc = 'data:image/webp;base64,' ~ rawImage %}
                        {% endif %}
                        <img src="{{ imageSrc }}" alt="{{ dog.name }}" class="h-full w-full object-cover">
                    {% else %}
                        <div class="flex h-full w-full items-center justify-center text-6xl font-bold text-gray-300">{{ dog.name|slice(0, 1)|upper }}</div>
                    {% endif %}
                </div>
                <dl class="grid grid-cols-1 gap-3 text-sm">
                    <div><dt class="text-gray-500">Name</dt><dd class="font-semibold text-gray-900">{{ dog.name }}</dd></div>
                    <div><dt class="text-gray-500">Breed</dt><dd class="font-semibold text-gray-900">{{ dog.breed ?: '-' }}</dd></div>
                    <div><dt class="text-gray-500">Age</dt><dd class="font-semibold text-gray-900">{{ dog.age is not null ? dog.age ~ ' years' : '-' }}</dd></div>
                    <div><dt class="text-gray-500">Gender</dt><dd class="font-semibold text-gray-900">{{ dog.gender ?: '-' }}</dd></div>
                    <div><dt class="text-gray-500">Size</dt><dd class="font-semibold text-gray-900">{{ dog.size ?: '-' }}</dd></div>
                    <div><dt class="text-gray-500">Weight</dt><dd class="font-semibold text-gray-900">{{ dog.weight is not null ? dog.weight ~ ' kg' : '-' }}</dd></div>
                    <div><dt class="text-gray-500">Health</dt><dd class="font-semibold text-gray-900">{{ dog.healthStatus ?: '-' }}</dd></div>
                    <div><dt class="text-gray-500">Adoption Status</dt><dd class="font-semibold text-gray-900">{{ dog.adoptionStatus ?: '-' }}</dd></div>
                    <div><dt class="text-gray-500">Arrival Date</dt><dd class="font-semibold text-gray-900">{{ dog.arrivalDate ? dog.arrivalDate|date('d/m/Y') : '-' }}</dd></div>
                    <div><dt class="text-gray-500">Microchip Number</dt><dd class="font-semibold text-gray-900">{{ dog.microchipNumber ?: '-' }}</dd></div>
                </dl>
            </div>
            <div class="flex justify-end mt-6">
                <button type="button" @click="dogInfoModalOpen = false"
                        class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<div x-show="autoAdoptModalOpen"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
     @click.self="autoAdoptModalOpen = false"
     @keydown.escape.window="autoAdoptModalOpen = false"
     style="display: none;"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 scale-100"
     x-transition:leave-end="opacity-0 scale-95">
    <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Auto Adopt</h2>
                    <p class="mt-1 text-sm text-gray-600">Are you sure you want to use AUTOADOPT §</p>
                </div>
                <button @click="autoAdoptModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="px-8 py-6">
            <p x-show="autoAdoptError" class="mb-4 text-sm text-red-600" x-text="autoAdoptError"></p>
            <div class="flex justify-end gap-3">
                <button type="button"
                        @click="autoAdoptModalOpen = false"
                        class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                    Cancel
                </button>
                <button type="button"
                        @click="runAutoAdopt()"
                        :disabled="autoAdoptLoading"
                        class="px-6 py-2.5 rounded-lg bg-green-600 text-sm font-semibold text-white shadow hover:bg-green-700">
                    <span x-show="!autoAdoptLoading">Confirm</span>
                    <span x-show="autoAdoptLoading">Processing...</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div x-show="autoAdoptResultModalOpen"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
     @click.self="autoAdoptResultModalOpen = false"
     @keydown.escape.window="autoAdoptResultModalOpen = false"
     style="display: none;"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 scale-100"
     x-transition:leave-end="opacity-0 scale-95">
    <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">AUTO ADOPT Results</h2>
                    <p class="mt-1 text-sm text-gray-600">
                        Dog #<span x-text="autoAdoptResult ? autoAdoptResult.dog_id : '{{ dog.id }}'"></span> -
                        Matches found: <span class="font-semibold" x-text="autoAdoptResult ? autoAdoptResult.matches_found : 0"></span>
                    </p>
                </div>
                <button @click="autoAdoptResultModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="px-8 py-6">
            <template x-if="!autoAdoptResult || !autoAdoptResult.users_ranked || autoAdoptResult.users_ranked.length === 0">
                <p class="text-sm text-gray-600">No matching users found.</p>
            </template>
            <div class="space-y-3" x-show="autoAdoptResult && autoAdoptResult.users_ranked && autoAdoptResult.users_ranked.length > 0">
                <template x-for="(entry, idx) in (autoAdoptResult ? autoAdoptResult.users_ranked : [])" :key="idx">
                    <div class="rounded-xl border border-gray-200 p-4 flex items-center justify-between">
                        <div>
                            <p class="text-sm text-gray-500">User</p>
                            <p class="font-semibold text-gray-900" x-text="entry.name"></p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm text-gray-500">Accuracy</p>
                            <p class="font-bold text-green-700" x-text="entry.accuracy.toFixed(2) + '%'"></p>
                        </div>
                    </div>
                </template>
            </div>
            <div class="flex justify-end mt-6">
                <button type="button" @click="autoAdoptResultModalOpen = false"
                        class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<div x-show="deleteModalOpen"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
     @click.self="deleteModalOpen = false"
     @keydown.escape.window="deleteModalOpen = false"
     style="display: none;"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 scale-100"
     x-transition:leave-end="opacity-0 scale-95">
    <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Delete Adoption Request</h2>
                    <p class="mt-1 text-sm text-gray-600">Are you sure you want to delete <span class="font-semibold" x-text="deleteLabel"></span>?</p>
                </div>
                <button @click="deleteModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="px-8 py-6">
            <form method="post" :action="deleteAction">
                <input type="hidden" name="_token" :value="deleteToken">
                <input type="hidden" name="dog_id" value="{{ dog.id }}">
                <div class="flex justify-end gap-3">
                    <button type="button" @click="deleteModalOpen = false"
                            class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                        Cancel
                    </button>
                    <button type="submit"
                            class="px-6 py-2.5 rounded-lg bg-red-600 text-sm font-semibold text-white shadow hover:bg-red-700">
                        Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
{% endblock %}
