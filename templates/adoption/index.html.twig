{% extends 'layout.html.twig' %}

{% block title %}Adoption Dogs | PawTech{% endblock %}

{% set active = 'adoption' %}
{% set page_title = 'Adoption Dogs' %}

{% block main %}
<div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
        <div class="flex items-start justify-between gap-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Dogs With Adoption Requests</h1>
                <p class="mt-1 text-sm text-gray-600">Choose a dog to view all its adoption requests.</p>
            </div>
            <div class="text-sm text-gray-600">Total dogs: <span class="font-semibold text-gray-900">{{ total_dogs }}</span></div>
        </div>
    </div>

    {% if dog_cards is empty %}
        <div class="rounded-2xl border border-dashed border-gray-200 p-12 text-center bg-white">
            <p class="text-sm font-semibold text-gray-600">No adoption requests found yet.</p>
            <p class="text-xs text-gray-400">When requests exist, dogs will appear here.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {% for item in dog_cards %}
                {% set dog = item.dog %}
                <a href="{{ path('app_adoption_dog_adpot_list', {'id': dog.id}) }}"
                   class="group overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:shadow-lg">
                    <div class="relative h-40 bg-gray-100">
                        {% if dog.image %}
                            {% set rawImage = dog.image|trim %}
                            {% if rawImage starts with 'data:image' %}
                                {% set imageSrc = rawImage %}
                            {% elseif rawImage starts with 'http://' or rawImage starts with 'https://' %}
                                {% set imageSrc = rawImage %}
                            {% elseif rawImage starts with 'uploads/' or rawImage starts with 'images/' %}
                                {% set imageSrc = asset(rawImage) %}
                            {% else %}
                                {% set imageSrc = 'data:image/webp;base64,' ~ rawImage %}
                            {% endif %}
                            <img src="{{ imageSrc }}" alt="{{ dog.name }}" class="h-full w-full object-cover">
                        {% else %}
                            <div class="flex h-full w-full items-center justify-center text-5xl font-bold text-gray-300">{{ dog.name|slice(0, 1)|upper }}</div>
                        {% endif %}
                        <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700">{{ dog.breed }}</span>
                    </div>
                    <div class="p-5">
                        <div class="flex items-center justify-between">
                            <h3 class="text-lg font-semibold text-gray-900">{{ dog.name }}</h3>
                            <span class="text-xs font-semibold text-gray-500">#{{ dog.id }}</span>
                        </div>
                        <p class="text-sm text-gray-500">{{ dog.gender }} - {{ dog.age }} years</p>
                        <div class="mt-4 flex items-center justify-between text-sm">
                            <span class="font-semibold text-gray-700">Requests:</span>
                            <span class="inline-flex items-center rounded-full bg-orange-100 px-2.5 py-0.5 text-xs font-semibold text-orange-700">{{ item.requests_count }}</span>
                        </div>
                        <div class="mt-2 text-xs text-gray-500">
                            Last request: {{ item.last_request_at ? item.last_request_at|date('d/m/Y H:i') : '-' }}
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
