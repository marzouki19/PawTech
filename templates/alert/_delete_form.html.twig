<form method="post" action="{{ path('app_admin_alerts_delete', {id: alert.id}) }}" onsubmit="return confirm('Are you sure you want to delete this alert?');" class="inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ alert.id) }}">
    <button class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
        Delete
    </button>
</form>
