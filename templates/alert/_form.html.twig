{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'space-y-6'}}) }}

{% if not form.vars.valid %}
    <div id="form-error-popup" class="fixed top-4 right-4 z-50 max-w-sm w-full bg-red-50 border border-red-200 text-red-700 rounded-lg shadow-lg p-4">
        <div class="font-semibold mb-1">Erreur de saisie</div>
        <div class="text-sm space-y-1">
            {{ form_errors(form) }}
        </div>
    </div>
    <script>
        setTimeout(function () {
            var el = document.getElementById('form-error-popup');
            if (el) { el.style.display = 'none'; }
        }, 4000);
    </script>
{% endif %}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="form-group">
            <label for="{{ form.type.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.type) }}
            </label>
            {{ form_widget(form.type, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white'}}) }}
            {{ form_errors(form.type, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.statut.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.statut) }}
            </label>
            {{ form_widget(form.statut, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white'}}) }}
            {{ form_errors(form.statut, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.prioritee.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.prioritee) }}
            </label>
            {{ form_widget(form.prioritee, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Priority'}}) }}
            {{ form_errors(form.prioritee, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.date.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.date) }}
            </label>
            {{ form_widget(form.date, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white'}}) }}
            {{ form_errors(form.date, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.userId.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.userId) }}
            </label>
            {{ form_widget(form.userId, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'User ID'}}) }}
            {{ form_errors(form.userId, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.station.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.station) }}
            </label>
            {{ form_widget(form.station, {'attr': {'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white'}}) }}
            {{ form_errors(form.station, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
        <div class="form-group md:col-span-2">
            <label for="{{ form.message.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                {{ form_label(form.message) }}
            </label>
            {{ form_widget(form.message, {'attr': {'rows': 4, 'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Alert message'}}) }}
            {{ form_errors(form.message, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>
    </div>
</div>

<div class="flex items-center justify-between pt-4">
    <a href="{{ path('app_admin_alerts') }}" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 hover:text-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to list
    </a>
    <button type="submit" class="inline-flex items-center px-6 py-2.5 text-sm font-medium text-white bg-orange-500 rounded-lg hover:bg-orange-600 focus:ring-4 focus:ring-orange-200 transition-all shadow-md hover:shadow-lg">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        {{ button_label|default('Save') }}
    </button>
</div>

{{ form_end(form) }}
