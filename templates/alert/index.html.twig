{% extends 'layout.html.twig' %}

{% block title %}Alerts | PawTech{% endblock %}

{% set active = 'alerts' %}
{% set page_title = 'Alerts' %}

{# Calculate records here so they're available in both main and javascripts blocks #}
{% set total_records = alerts|length %}
{% set unread_records = alerts|filter(a => a.statut == 'unread')|length %}
{% set read_records = alerts|filter(a => a.statut == 'read')|length %}
{% set technical_records = alerts|filter(a => a.type == 'TECHNICAL')|length %}
{% set health_records = alerts|filter(a => a.type == 'HEALTH_ALERT')|length %}
{% set danger_records = alerts|filter(a => a.type == 'DANGER_DOG')|length %}

{% block main %}
<div>
    <div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
        <!-- Page Header -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="flex items-start gap-4 flex-1">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-orange-100">
                        <svg class="h-6 w-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2.2 0 00-2.2-2H5a2.2 0 00-2.2 2v3.172c0 .97.386 1.887 1.04 2.521L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                    </div>
                    <div>
                        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                            <a href="#" class="hover:text-gray-700 transition">Dashboard</a>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            <span class="text-gray-900 font-medium">Alerts</span>
                        </nav>
                        <h1 class="text-2xl font-bold text-gray-900">Alert Management</h1>
                        <p class="mt-1 text-sm text-gray-600 max-w-xl">Track and manage technical, danger, and health alerts.</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 mt-4 lg:mt-0">
                    <a href="{{ path('app_admin_alerts_new') }}"
                       class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Alert
                    </a>
                </div>
            </div>
        </div>

        <!-- FILTERS INLINE WITH SEARCH BAR -->
        <div class="flex flex-col gap-2 mb-8">
            <div class="flex flex-1 items-center gap-4 max-w-5xl">
                <!-- Filters -->
                <span class="text-sm font-semibold text-gray-700">Filters:</span>
                <div class="relative">
                    <select id="typeFilter" 
                            class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                        <option value="">All Types</option>
                        <option value="TECHNICAL">Technical</option>
                        <option value="HEALTH_ALERT">Health</option>
                        <option value="DANGER_DOG">Danger Dog</option>
                    </select>
                </div>
                <div class="relative">
                    <select id="statutFilter" 
                            class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                        <option value="">All Status</option>
                        <option value="unread">Unread</option>
                        <option value="read">Read</option>
                    </select>
                </div>
                <div class="flex gap-2">
                    <button type="button" 
                            id="applyFilters"
                            class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors min-w-[120px]">
                        Apply Filters
                    </button>
                    <button type="button" 
                            id="clearFilters"
                            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors min-w-[120px]">
                        Clear Filters
                    </button>
                </div>
                <!-- Search -->
                <input type="text" 
                    id="search" 
                    placeholder="Search alerts by message..."
                    class="w-full min-w-[250px] rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
            </div>
        </div>

        <!-- Overview Stats -->
        <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total Alerts</p>
                <p class="mt-2 text-2xl font-bold text-gray-900">{{ total_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Unread</p>
                <p class="mt-2 text-2xl font-bold text-orange-600">{{ unread_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Read</p>
                <p class="mt-2 text-2xl font-bold text-green-600">{{ read_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Technical</p>
                <p class="mt-2 text-2xl font-bold text-gray-600">{{ technical_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Health</p>
                <p class="mt-2 text-2xl font-bold text-red-600">{{ health_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Danger Dog</p>
                <p class="mt-2 text-2xl font-bold text-blue-600">{{ danger_records }}</p>
            </div>
        </div>

        <!-- Alerts Table -->
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[8%]">ID</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[12%]">Type</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[25%]">Message</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[10%]">Priority</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[12%]">Status</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[10%]">Station</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[15%]">Date</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 w-[18%]">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="all">
                        {% if alerts is empty %}
                            <tr>
                                <td colspan="8" class="px-6 py-12 text-center">
                                    <p class="text-sm font-semibold text-gray-600">No alerts registered yet.</p>
                                    <p class="text-xs text-gray-400">Click "Add Alert" to create the first record.</p>
                                </td>
                            </tr>
                        {% else %}
                            {% for alert in alerts %}
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 text-sm font-semibold text-gray-900">#{{ alert.id }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ alert.type }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <span class="block truncate max-w-[200px]">{{ alert.message }}</span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ alert.prioritee }}</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold
                                            {% if alert.statut == 'read' %}bg-green-100 text-green-700
                                            {% else %}bg-orange-100 text-orange-700{% endif %}">
                                            {{ alert.statut }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        {% if alert.station %}
                                            #{{ alert.station.id }}
                                        {% else %}
                                            <span class="text-gray-400">-</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">{{ alert.date ? alert.date|date('d/m/Y H:i', app_timezone) : '' }}</td>
                                    <td class="px-6 py-4 text-right text-sm">
                                        <a href="{{ path('app_admin_alerts_show', {'id': alert.id}) }}"
                                           class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                        <a href="{{ path('app_admin_alerts_edit', {'id': alert.id}) }}"
                                           class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                        <button
                                                type="button"
                                                class="ml-4 text-red-600 hover:text-red-700 font-semibold open-delete-btn"
                                                data-delete-action="{{ path('app_admin_alerts_delete', {'id': alert.id}) }}"
                                                data-delete-token="{{ csrf_token('delete' ~ alert.id) }}"
                                                data-delete-label="#{{ alert.id }}">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                    <tbody id="filtertab" style="display: none;"></tbody>
                    <tbody id="searchtab" style="display: none;"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div id="delete-modal"
         class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900">Delete Alert</h2>
                        <p class="mt-1 text-sm text-gray-600">Are you sure you want to delete alert <span class="font-semibold" id="delete-label"></span>?</p>
                    </div>
                    <button type="button" class="text-gray-400 hover:text-gray-600 transition-colors delete-modal-close">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="px-8 py-6">
                <form method="post" id="delete-form">
                    <input type="hidden" name="_token" id="delete-token" value="">
                    <div class="flex justify-end gap-3">
                        <button type="button"
                                class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50 delete-modal-close">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-6 py-2.5 rounded-lg bg-red-600 text-sm font-semibold text-white shadow hover:bg-red-700">
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
$(document).ready(function() {
    function openDeleteModal(action, token, label) {
        $('#delete-form').attr('action', action);
        $('#delete-token').val(token);
        $('#delete-label').text(label);
        $('#delete-modal').removeClass('hidden').addClass('flex');
    }

    function closeDeleteModal() {
        $('#delete-modal').removeClass('flex').addClass('hidden');
    }

    $(document).on('click', '.open-delete-btn', function() {
        const $btn = $(this);
        openDeleteModal(
            $btn.data('delete-action'),
            $btn.data('delete-token'),
            $btn.data('delete-label')
        );
    });

    $(document).on('click', '.delete-modal-close', function() {
        closeDeleteModal();
    });

    $('#delete-modal').on('click', function(e) {
        if (e.target === this) {
            closeDeleteModal();
        }
    });

    $(document).on('keydown', function(e) {
        if (e.key === 'Escape') {
            closeDeleteModal();
        }
    });

    // Apply Filters
    $('#applyFilters').on('click', function() {
        const type = $('#typeFilter').val()?.trim();
        const statut = $('#statutFilter').val()?.trim();
        const search = $('#search').val()?.trim();

        const params = new URLSearchParams();

        if (type) params.set('type', type);
        if (statut) params.set('statut', statut);
        if (search) params.set('search', search);

        let url = "{{ path('app_admin_alerts') }}";
        if (params.toString()) {
            url += '?' + params.toString();
        }

        window.location.href = url;
    });

    // Clear Filters
    $('#clearFilters').on('click', function() {
        window.location.href = "{{ path('app_admin_alerts') }}";
    });

    // Search
    $("#search").on("keyup", function() {
        const value = $(this).val().trim();

        if (!value) {
            $('#all').show();
            $('#searchtab').hide().empty();
            return;
        }

        $.ajax({
            url: "{{ path('app_admin_alerts_search') }}",
            type: "GET",
            data: { searchValue: value },
            dataType: "json",
            success: function(alerts) {
                const $searchBody = $('#searchtab');
                $searchBody.empty();
                $('#all').hide();
                $('#filtertab').hide();

                if (alerts?.length > 0) {
                    alerts.forEach(alert => {
                        const statusClass = alert.statut === 'read' 
                            ? 'bg-green-100 text-green-700' 
                            : 'bg-orange-100 text-orange-700';
                        
                        const stationId = alert.station_id ? '#' + alert.station_id : '-';
                        const deleteLabel = '#' + alert.id;

                        const row = `
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm font-semibold text-gray-900">#${alert.id}</td>
                                <td class="px-6 py-4 text-sm text-gray-600">${alert.type}</td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    <span class="block truncate max-w-[200px]">${alert.message}</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">${alert.prioritee}</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold ${statusClass}">
                                        ${alert.statut}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">${stationId}</td>
                                <td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">${alert.date}</td>
                                <td class="px-6 py-4 text-right text-sm">
                                    <a href="${alert.show_url}" class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                    <a href="${alert.edit_url}" class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                    <button
                                        type="button"
                                        class="ml-4 text-red-600 hover:text-red-700 font-semibold open-delete-btn"
                                        data-delete-action="${alert.delete_url}"
                                        data-delete-token="${alert.delete_token}"
                                        data-delete-label="${deleteLabel}">
                                        Delete
                                    </button>
                                </td>
                            </tr>`;

                        $searchBody.append(row);
                    });
                    $searchBody.show();
                } else {
                    $searchBody.html(`
                        <tr><td colspan="8" class="px-6 py-12 text-center">
                            <p class="text-sm font-semibold text-gray-600">No alerts found for "${value}"</p>
                        </td></tr>
                    `).show();
                }
            },
            error: function(xhr, status, err) {
                console.error("Search failed:", status, err, xhr.responseText);
                alert("Error searching alerts – check console");
            }
        });
    });

    // Check URL params for active filters
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('type') || urlParams.get('statut') || urlParams.get('search')) {
        if (urlParams.get('type')) $('#typeFilter').val(urlParams.get('type'));
        if (urlParams.get('statut')) $('#statutFilter').val(urlParams.get('statut'));
        if (urlParams.get('search')) $('#search').val(urlParams.get('search'));
    }

    // Keep alerts page live without requiring manual refresh.
    // Skip refresh while user is typing in search.
    const autoRefreshMs = 8000;
    setInterval(function() {
        if (document.hidden) return;
        const activeElement = document.activeElement;
        const searchFocused = activeElement && activeElement.id === 'search';
        if (searchFocused) return;
        if ($('#search').val()?.trim()) return;
        if ($('#delete-modal').hasClass('flex')) return;
        window.location.reload();
    }, autoRefreshMs);
});
</script>
{% endblock %}
