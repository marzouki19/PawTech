{% extends 'layout.html.twig' %}

{% block title %}Alert Details | PawTech{% endblock %}

{% block main %}
<div class="mb-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Alert #{{ alert.id }}</h1>
            <p class="text-gray-500 text-sm mt-1">Details for this alert</p>
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ path('app_admin_alerts_edit', {id: alert.id}) }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-orange-600 bg-orange-50 rounded-lg hover:bg-orange-100 transition-colors">Edit</a>
            {{ include('alert/_delete_form.html.twig', {alert: alert}) }}
        </div>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <p class="text-xs uppercase text-gray-500">Type</p>
            <p class="text-sm font-medium text-gray-900">{{ alert.type }}</p>
        </div>
        <div>
            <p class="text-xs uppercase text-gray-500">Status</p>
            <p class="text-sm font-medium text-gray-900">{{ alert.statut }}</p>
        </div>
        <div>
            <p class="text-xs uppercase text-gray-500">Priority</p>
            <p class="text-sm font-medium text-gray-900">{{ alert.prioritee }}</p>
        </div>
        <div>
            <p class="text-xs uppercase text-gray-500">Date</p>
            <p class="text-sm font-medium text-gray-900">{{ alert.date ? alert.date|date('d/m/Y H:i') : '' }}</p>
        </div>
        <div>
            <p class="text-xs uppercase text-gray-500">User ID</p>
            <p class="text-sm font-medium text-gray-900">{{ alert.userId }}</p>
        </div>
        <div>
            <p class="text-xs uppercase text-gray-500">Station</p>
            <p class="text-sm font-medium text-gray-900">{{ alert.station ? alert.station.code : '' }}</p>
        </div>
    </div>
    <div>
        <p class="text-xs uppercase text-gray-500">Message</p>
        <p class="text-sm text-gray-800 mt-1">{{ alert.message }}</p>
    </div>
</div>

<div class="mt-6">
    <a href="{{ path('app_admin_alerts') }}" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 hover:text-gray-800 transition-colors">Back to list</a>
</div>
{% endblock %}
