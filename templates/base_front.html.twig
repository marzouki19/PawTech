<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}PawTech - Pet Shop{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}">

        {# Tailwind via CDN for rapid development.
           Later you can replace this with a compiled Tailwind build if you prefer. #}
        <script src="https://cdn.tailwindcss.com"></script>
        
        {# Font Awesome for icons #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        
        {# Video.js for HLS streaming #}
        <link href="https://cdnjs.cloudflare.com/ajax/libs/video.js/8.10.0/video-js.min.css" rel="stylesheet">
        <script src="https://cdnjs.cloudflare.com/ajax/libs/video.js/8.10.0/video.min.js"></script>
        
        {# Custom styles for dropdown and animations #}
        <style>
            .dropdown {
                position: relative;
            }
            
            .dropdown-menu {
                display: none;
                position: absolute;
                right: 0;
                top: 100%;
                margin-top: 0.5rem;
                min-width: 200px;
                background-color: white;
                border-radius: 0.5rem;
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
                z-index: 50;
            }
            
            .dropdown:hover .dropdown-menu,
            .dropdown:focus-within .dropdown-menu {
                display: block;
            }
            
            .user-avatar {
                background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
            }
            
            .animate-fade-in {
                animation: fadeIn 0.3s ease-in-out;
            }
            
            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(-10px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .form-error-list,
            .form-error-message,
            .form-errors,
            .form-error {
                color: #ef4444;
                font-size: 0.875rem;
                margin-top: 0.25rem;
            }

            .form-error-list {
                list-style: none;
                padding-left: 0;
            }

            .form-error-list li + li {
                margin-top: 0.25rem;
            }

            input[aria-invalid="true"]:not([type="checkbox"]):not([type="radio"]),
            select[aria-invalid="true"],
            textarea[aria-invalid="true"] {
                border-color: #ef4444 !important;
                background-color: #fef2f2 !important;
                box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.15);
            }

            /* ============================================
               ADMIN DASHBOARD RESPONSIVE STYLES
               ============================================ */

            /* Prevent vertical scroll - key fix */
            html, body {
                overflow-x: hidden;
                max-width: 100vw;
            }

            .main-content {
                width: 100%;
                max-width: 100vw;
                overflow-x: hidden;
            }

            .container {
                max-width: 100%;
                overflow-x: hidden;
            }

            .shadow-lg {
                max-width: 100%;
                overflow: hidden;
            }

            .grid {
                overflow: hidden;
            }

            /* Header responsive */
            .admin-header .flex.items-center.justify-between {
                flex-wrap: wrap;
                gap: 1rem;
            }

            .admin-header .flex.items-center.gap-4 {
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            /* Mobile header buttons */
            @media (max-width: 575.98px) {
                .admin-header .bg-white\/20 {
                    padding: 0.5rem 0.75rem;
                    font-size: 0.875rem;
                }
            }

            /* Hide non-essential on small screens */
            @media (max-width: 767.98px) {
                .hide-mobile {
                    display: none !important;
                }
            }

            @media (min-width: 768px) {
                .hide-mobile {
                    display: inline-flex !important;
                }
            }

            /* Stats cards - Mobile first */
            .stats-grid {
                display: grid;
                gap: 1rem;
                grid-template-columns: 1fr;
            }

            @media (min-width: 576px) and (max-width: 767.98px) {
                .stats-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (min-width: 992px) {
                .stats-grid {
                    grid-template-columns: repeat(4, 1fr);
                }
            }

            .stats-card {
                padding: 1rem !important;
            }

            .stats-card .text-3xl {
                font-size: 1.5rem !important;
            }

            .stats-card .w-12.h-12 {
                width: 2.5rem;
                height: 2.5rem;
            }

            @media (min-width: 768px) {
                .stats-card {
                    padding: 1.5rem !important;
                }

                .stats-card .text-3xl {
                    font-size: 1.875rem !important;
                }

                .stats-card .w-12.h-12 {
                    width: 3rem;
                    height: 3rem;
                }
            }

            /* Table responsive */
            .table-responsive-container {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                margin: 0 -1rem;
                padding: 0 1rem;
            }

            .table-responsive-container table {
                min-width: 500px;
            }

            @media (max-width: 767.98px) {
                .table-responsive-container .hide-on-mobile {
                    display: none;
                }
            }

            @media (max-width: 575.98px) {
                .table-responsive-container .hide-on-xs {
                    display: none;
                }

                .table-responsive-container td,
                .table-responsive-container th {
                    padding: 0.5rem 0.25rem !important;
                    font-size: 0.75rem;
                }
            }

            /* Grid layouts */
            .main-content-grid {
                display: grid;
                gap: 1.5rem;
            }

            @media (max-width: 991.98px) {
                .main-content-grid {
                    grid-template-columns: 1fr;
                }
            }

            @media (min-width: 992px) {
                .main-content-grid {
                    grid-template-columns: repeat(3, 1fr);
                }

                .main-content-grid > .lg\:col-span-2 {
                    grid-column: span 2;
                }
            }

            /* Camera grid */
            .camera-grid {
                display: grid;
                gap: 1rem;
                grid-template-columns: 1fr;
            }

            @media (min-width: 576px) and (max-width: 767.98px) {
                .camera-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (min-width: 768px) {
                .camera-grid {
                    grid-template-columns: repeat(3, 1fr);
                }
            }

            /* Detections grid */
            .detections-grid {
                display: grid;
                gap: 1rem;
                grid-template-columns: 1fr;
            }

            @media (min-width: 576px) and (max-width: 767.98px) {
                .detections-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (min-width: 768px) {
                .detections-grid {
                    grid-template-columns: repeat(3, 1fr);
                }
            }

            /* Charts grid */
            .charts-grid {
                display: grid;
                gap: 1.5rem;
                grid-template-columns: 1fr;
            }

            @media (min-width: 992px) {
                .charts-grid {
                    grid-template-columns: repeat(2, 1fr);
                }

                .charts-grid .lg\:col-span-2 {
                    grid-column: span 2;
                }
            }

            /* Map responsive */
            .map-container {
                width: 100%;
                height: 100%;
                min-height: 250px;
            }

            @media (min-width: 576px) and (max-width: 991.98px) {
                .map-container {
                    height: 50vh;
                }
            }

            @media (min-width: 992px) {
                .map-container {
                    height: 600px;
                }
            }

            /* Map page grid */
            .map-page-grid {
                display: grid;
                gap: 1rem;
            }

            @media (max-width: 991.98px) {
                .map-page-grid {
                    grid-template-columns: 1fr !important;
                }

                .map-page-grid > div:first-child {
                    order: 2;
                }

                .map-page-grid > div:last-child {
                    order: 1;
                }
            }

            .map-sidebar {
                display: grid;
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            @media (min-width: 576px) and (max-width: 991.98px) {
                .map-sidebar {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (min-width: 992px) {
                .map-sidebar {
                    grid-template-columns: 1fr;
                }
            }

            /* Filters */
            .filters-container {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                align-items: center;
            }

            @media (max-width: 767.98px) {
                .filters-container {
                    flex-direction: column;
                    align-items: stretch;
                }

                .filters-container > div {
                    width: 100%;
                }

                .filters-container select {
                    width: 100%;
                }

                .filters-container button {
                    width: 100%;
                    margin-left: 0 !important;
                    margin-top: 0.5rem;
                }
            }

            /* Quick actions */
            .quick-actions-grid {
                display: grid;
                gap: 0.75rem;
                grid-template-columns: 1fr;
            }

            @media (min-width: 576px) {
                .quick-actions-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            /* Card responsive */
            .card {
                break-inside: avoid;
                margin-bottom: 1rem;
            }

            @media (max-width: 575.98px) {
                .card {
                    padding: 1rem !important;
                    margin-bottom: 0.75rem;
                }
            }

            /* Alert cards */
            .alert-card {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }

            @media (min-width: 576px) {
                .alert-card {
                    flex-direction: row;
                    align-items: flex-start;
                }
            }

            /* Health alert item */
            .health-alert-item {
                padding: 0.75rem;
            }

            @media (min-width: 576px) {
                .health-alert-item {
                    padding: 1.5rem;
                }
            }

            /* Alert list item */
            .alert-list-item {
                padding: 0.75rem;
            }

            @media (min-width: 576px) {
                .alert-list-item {
                    padding: 1rem;
                }
            }

            /* Camera preview */
            .camera-preview {
                height: auto !important;
                min-height: 140px;
            }

            @media (min-width: 576px) {
                .camera-preview {
                    height: 192px;
                }
            }

            /* Flex utilities */
            .flex-col-mobile {
                flex-direction: column;
            }

            @media (min-width: 768px) {
                .flex-col-mobile {
                    flex-direction: row;
                }
            }

            .flex-wrap-mobile {
                flex-wrap: wrap;
            }

            @media (min-width: 768px) {
                .flex-wrap-mobile {
                    flex-wrap: nowrap;
                }
            }

            /* Text utilities */
            .text-2xl {
                font-size: 1.5rem;
            }

            @media (min-width: 768px) {
                .text-2xl {
                    font-size: 1.875rem;
                }
            }

            /* Show/hide utilities */
            .show-mobile-only {
                display: flex;
            }

            @media (min-width: 576px) {
                .show-mobile-only {
                    display: none;
                }
            }

            /* Whitespace */
            .whitespace-nowrap {
                white-space: nowrap;
            }
        </style>

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
