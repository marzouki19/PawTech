{% extends 'layout.html.twig' %}

{% block title %}Categories | PawTech{% endblock %}

{% set active = 'eshop_categories' %}
{% set page_title = 'Categories' %}

{# Calculate records here so they're available in both main and javascripts blocks #}
{% set total_records = categories|length %}
{% set empty_records = categories|filter(c => c.produits|length == 0)|length %}
{% set small_records = categories|filter(c => c.produits|length >= 1 and c.produits|length <= 5)|length %}
{% set large_records = categories|filter(c => c.produits|length >= 6)|length %}

{% block main %}
<div>
    <div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
        <!-- Page Header -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="flex items-start gap-4 flex-1">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100">
                        <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                    </div>
                    <div>
                        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                            <a href="#" class="hover:text-gray-700 transition">Dashboard</a>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            <span class="text-gray-900 font-medium">Categories</span>
                        </nav>
                        <h1 class="text-2xl font-bold text-gray-900">Category Management</h1>
                        <p class="mt-1 text-sm text-gray-600 max-w-xl">Organize your e-shop products by categories to improve navigation and customer experience.</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 mt-4 lg:mt-0">
                    <a href="{{ path('app_eshop_categorie_new') }}"
                       class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Category
                    </a>
                </div>
            </div>
        </div>

        <!-- FILTERS INLINE WITH SEARCH BAR -->
        <div class="flex flex-col gap-2 mb-8">
            <div class="flex flex-1 items-center gap-4 max-w-5xl">
                <!-- Filters -->
                <span class="text-sm font-semibold text-gray-700">Filters:</span>
                <div class="relative">
                    <select id="productCountFilter" 
                            class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                        <option value="">All Product Counts</option>
                        <option value="empty">No products</option>
                        <option value="1-5">1-5 products</option>
                        <option value="6+">6+ products</option>
                    </select>
                </div>
                <div class="flex gap-2">
                    <button type="button" 
                            id="applyFilters"
                            class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors min-w-[120px]">
                        Apply Filters
                    </button>
                    <button type="button" 
                            id="clearFilters"
                            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors min-w-[120px]">
                        Clear Filters
                    </button>
                </div>
                <!-- Search -->
                <form method="get" action="{{ path('app_eshop_categorie_index') }}" class="relative flex-1 min-w-[200px]">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                  </span>
                  <input 
                    name="search" 
                    type="search" 
                    value="{{ app.request.query.get('search', '') }}" 
                    placeholder="Search categories by name..." 
                    class="w-full pl-10 pr-10 py-2 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none"
                    onkeydown="if(event.key === 'Enter') this.form.submit()">
                  
                  {% if app.request.query.get('search') %}
                    <a href="{{ path('app_eshop_categorie_index', app.request.query.all|filter((v, k) => k != 'search')) }}" 
                       class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                       title="Clear search">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </a>
                  {% endif %}
                  
                  {% if app.request.query.get('product_count') %}
                    <input type="hidden" name="product_count" value="{{ app.request.query.get('product_count') }}">
                  {% endif %}
                </form>
            </div>
            {% set has_active_filter = app.request.query.get('product_count') or app.request.query.get('search') %}
            {% if has_active_filter %}
            <div class="flex items-center gap-2 flex-wrap">
                <span class="text-sm text-gray-600">Active filters:</span>
                {% if app.request.query.get('product_count') %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
                        Products: 
                        {% if app.request.query.get('product_count') == 'empty' %}No products{% endif %}
                        {% if app.request.query.get('product_count') == '1-5' %}1-5 products{% endif %}
                        {% if app.request.query.get('product_count') == '6+' %}6+ products{% endif %}
                        <a href="{{ path('app_eshop_categorie_index', {search: app.request.query.get('search')}) }}" class="text-blue-500 hover:text-blue-700">&times;</a>
                    </span>
                {% endif %}
                {% if app.request.query.get('search') %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-700">
                        Search: "{{ app.request.query.get('search') }}"
                        <a href="{{ path('app_eshop_categorie_index', {product_count: app.request.query.get('product_count')}) }}" class="text-yellow-500 hover:text-yellow-700">&times;</a>
                    </span>
                {% endif %}
            </div>
            {% endif %}
        </div>

        <!-- Overview Stats -->
        <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total Categories</p>
                <p class="mt-2 text-2xl font-bold text-gray-900">{{ total_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">No Products</p>
                <p class="mt-2 text-2xl font-bold text-gray-600">{{ empty_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">1-5 Products</p>
                <p class="mt-2 text-2xl font-bold text-yellow-600">{{ small_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">6+ Products</p>
                <p class="mt-2 text-2xl font-bold text-green-600">{{ large_records }}</p>
            </div>
        </div>

        <!-- Categories Table -->
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[50%]">Category</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 w-[25%]">Products</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 w-[25%]">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="all">
                        {% if categories is empty %}
                            <tr>
                                <td colspan="3" class="px-6 py-12 text-center">
                                    <p class="text-sm font-semibold text-gray-600">No categories registered yet.</p>
                                    <p class="text-xs text-gray-400">Click "Add Category" to create the first record.</p>
                                </td>
                            </tr>
                        {% else %}
                            {% for categorie in categories %}
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-100">
                                                <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm font-semibold text-gray-900">{{ categorie.nom }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold
                                            {% if categorie.produits|length == 0 %}bg-gray-100 text-gray-700
                                            {% elseif categorie.produits|length <= 5 %}bg-yellow-100 text-yellow-700
                                            {% else %}bg-green-100 text-green-700{% endif %}">
                                            {{ categorie.produits|length }} product{{ categorie.produits|length != 1 ? 's' : '' }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right text-sm">
                                        <a href="{{ path('app_eshop_categorie_show', {'id': categorie.id}) }}"
                                           class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                        <a href="{{ path('app_eshop_categorie_edit', {'id': categorie.id}) }}"
                                           class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                        <button type="button"
                                                class="ml-4 text-red-600 hover:text-red-700 font-semibold"
                                                onclick="openDeleteModal('{{ path('app_eshop_categorie_delete', {'id': categorie.id}) }}', '{{ csrf_token('delete' ~ categorie.id) }}', '{{ categorie.nom|e('js') }}')">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                    <tbody id="filtertab" style="display: none;"></tbody>
                    <tbody id="searchtab" style="display: none;"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div id="delete-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm" style="display: none;">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900">Delete Category</h2>
                        <p class="mt-1 text-sm text-gray-600">Are you sure you want to delete <span id="delete-label" class="font-semibold"></span>?</p>
                    </div>
                    <button onclick="closeDeleteModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="px-8 py-6">
                <form id="delete-form" method="post">
                    <input type="hidden" name="_token" id="delete-token">
                    <div class="flex justify-end gap-3">
                        <button type="button" onclick="closeDeleteModal()"
                                class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-6 py-2.5 rounded-lg bg-red-600 text-sm font-semibold text-white shadow hover:bg-red-700">
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    function openDeleteModal(action, token, label) {
        document.getElementById('delete-form').action = action;
        document.getElementById('delete-token').value = token;
        document.getElementById('delete-label').textContent = label;
        document.getElementById('delete-modal').style.display = 'flex';
    }
    
    function closeDeleteModal() {
        document.getElementById('delete-modal').style.display = 'none';
    }
    
    document.getElementById('delete-modal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeDeleteModal();
        }
    });
    
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeDeleteModal();
        }
    });
    </script>
</div>

{% endblock %}
