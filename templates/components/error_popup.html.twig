<!-- ========================================
     Error Popup Component
     Usage: Include this in your template and control 
     via JavaScript by adding/removing 'active' class
     ======================================== -->

<!-- Error Popup Overlay -->
<div id="error-popup-overlay" class="error-popup-overlay" role="dialog" aria-modal="true" aria-labelledby="error-title" aria-describedby="error-message">
    
    <!-- Error Popup Card -->
    <div class="error-popup" id="error-popup">
        
        <!-- Close Button -->
        <button type="button" class="error-close-btn" id="error-close-btn" aria-label="Close error message">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        
        <!-- Header Section -->
        <div class="error-popup-header">
            
            <!-- Error Icon -->
            <div class="error-icon-wrapper">
                <svg class="error-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            
            <!-- Error Content -->
            <div class="error-content">
                <h3 class="error-title" id="error-title">Stream Error</h3>
                <p class="error-message" id="error-message">Failed to start stream: TypeError: Failed to fetch</p>
                <span class="error-type" id="error-type">TypeError</span>
            </div>
        </div>
        
        <!-- Body Section -->
        <div class="error-popup-body">
            
            <!-- Expandable Details Toggle -->
            <button type="button" class="error-details-toggle" id="error-details-toggle" aria-expanded="false">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
                <span>View technical details</span>
            </button>
            
            <!-- Expandable Details Content -->
            <div class="error-details-content" id="error-details-content">
                <pre class="error-details-text" id="error-details-text">Failed to start stream: TypeError: Failed to fetch</pre>
            </div>
        </div>
        
        <!-- Footer Section -->
        <div class="error-popup-footer">
            <button type="button" class="error-btn error-btn-secondary" id="error-retry-btn">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Try Again
            </button>
            <button type="button" class="error-btn error-btn-primary" id="error-dismiss-btn">
                Dismiss
            </button>
        </div>
    </div>
</div>

<!-- ========================================
     JavaScript for Error Popup Functionality
     ======================================== -->
<script>
(function() {
    'use strict';
    
    // DOM Elements
    const overlay = document.getElementById('error-popup-overlay');
    const popup = document.getElementById('error-popup');
    const closeBtn = document.getElementById('error-close-btn');
    const dismissBtn = document.getElementById('error-dismiss-btn');
    const retryBtn = document.getElementById('error-retry-btn');
    const detailsToggle = document.getElementById('error-details-toggle');
    const detailsContent = document.getElementById('error-details-content');
    
    // Default error data
    let currentError = {
        title: 'Stream Error',
        message: 'Failed to start stream: TypeError: Failed to fetch',
        type: 'TypeError',
        details: 'Failed to start stream: TypeError: Failed to fetch'
    };
    
    /**
     * Show the error popup with optional custom error data
     * @param {Object} errorData - Optional custom error data
     */
    function showErrorPopup(errorData) {
        // Merge custom data with defaults
        if (errorData) {
            currentError = { ...currentError, ...errorData };
        }
        
        // Update popup content
        document.getElementById('error-title').textContent = currentError.title;
        document.getElementById('error-message').textContent = currentError.message;
        document.getElementById('error-type').textContent = currentError.type;
        document.getElementById('error-details-text').textContent = currentError.details;
        
        // Show overlay with animation
        overlay.classList.add('active');
        
        // Trap focus for accessibility
        trapFocus(overlay);
        
        // Add shake animation for emphasis
        popup.classList.add('shake');
        setTimeout(() => popup.classList.remove('shake'), 500);
    }
    
    /**
     * Hide the error popup
     */
    function hideErrorPopup() {
        overlay.classList.remove('active');
        
        // Reset details toggle
        detailsToggle.classList.remove('expanded');
        detailsContent.classList.remove('expanded');
        detailsToggle.setAttribute('aria-expanded', 'false');
    }
    
    /**
     * Toggle error details expansion
     */
    function toggleDetails() {
        const isExpanded = detailsToggle.classList.toggle('expanded');
        detailsContent.classList.toggle('expanded');
        detailsToggle.setAttribute('aria-expanded', isExpanded.toString());
    }
    
    /**
     * Simple focus trap for accessibility
     */
    function trapFocus(element) {
        const focusableElements = element.querySelectorAll(
            'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        
        const firstFocusable = focusableElements[0];
        const lastFocusable = focusableElements[focusableElements.length - 1];
        
        // Focus first element
        setTimeout(() => firstFocusable?.focus(), 100);
        
        // Handle tab key
        element.addEventListener('keydown', function(e) {
            if (e.key === 'Tab') {
                if (e.shiftKey) {
                    if (document.activeElement === firstFocusable) {
                        e.preventDefault();
                        lastFocusable?.focus();
                    }
                } else {
                    if (document.activeElement === lastFocusable) {
                        e.preventDefault();
                        firstFocusable?.focus();
                    }
                }
            }
            
            // Close on Escape
            if (e.key === 'Escape') {
                hideErrorPopup();
            }
        });
    }
    
    // Event Listeners
    closeBtn?.addEventListener('click', hideErrorPopup);
    dismissBtn?.addEventListener('click', hideErrorPopup);
    detailsToggle?.addEventListener('click', toggleDetails);
    
    // Retry button - dispatch custom event for integration
    retryBtn?.addEventListener('click', function() {
        hideErrorPopup();
        // Dispatch custom event that can be handled by your stream logic
        window.dispatchEvent(new CustomEvent('stream:retry', { 
            detail: currentError,
            bubbles: true 
        }));
    });
    
    // Close on overlay click (outside popup)
    overlay?.addEventListener('click', function(e) {
        if (e.target === overlay) {
            hideErrorPopup();
        }
    });
    
    // Close on Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && overlay?.classList.contains('active')) {
            hideErrorPopup();
        }
    });
    
    // Expose global functions for showing error popup
    window.showErrorPopup = showErrorPopup;
    window.hideErrorPopup = hideErrorPopup;
    
    // Auto-show example (remove this in production - for demo only)
    // Uncomment the line below to test the popup on page load
    // setTimeout(() => showErrorPopup(), 500);
    
})();
</script>
