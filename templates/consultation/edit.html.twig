{% extends 'layout.html.twig' %}

{% block title %}Modifier Consultation | PawTech{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Modifier Consultation</h1>
        <p class="text-gray-600 mt-2">Mettez à jour les informations de la consultation</p>
    </div>

    <div class="bg-white rounded-xl shadow-md p-6">
        {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.date, 'Date et heure *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none transition' ~ (form.date.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.date) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.date) }}
                    </div>
                {% endif %}
            </div>
            
            <div>
                {{ form_label(form.type, 'Type *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(form.type, {'attr': {'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none transition' ~ (form.type.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.type) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.type) }}
                    </div>
                {% endif %}
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.chien, 'Chien *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(form.chien, {'attr': {'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none transition' ~ (form.chien.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.chien) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.chien) }}
                    </div>
                {% endif %}
            </div>
            
            <div>
                {{ form_label(form.user, 'User *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}  <!-- CHANGÉ: veterinaire → user -->
                {{ form_widget(form.user, {'attr': {'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none transition' ~ (form.user.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}  <!-- CHANGÉ: veterinaire → user -->
                {% if form_errors(form.user) %}  <!-- CHANGÉ: veterinaire → user -->
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.user) }}  <!-- CHANGÉ: veterinaire → user -->
                    </div>
                {% endif %}
            </div>
        </div>
        
        <div>
            {{ form_label(form.diagnostic, 'Diagnostic *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
            {{ form_widget(form.diagnostic, {'attr': {'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none transition' ~ (form.diagnostic.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
            {% if form_errors(form.diagnostic) %}
                <div class="mt-1 flex items-center text-sm text-red-600">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    {{ form_errors(form.diagnostic) }}
                </div>
            {% endif %}
        </div>
        
        <div>
            {{ form_label(form.traitement, 'Traitement', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
            {{ form_widget(form.traitement, {'attr': {'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none transition' ~ (form.traitement.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
            {% if form_errors(form.traitement) %}
                <div class="mt-1 flex items-center text-sm text-red-600">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    {{ form_errors(form.traitement) }}
                </div>
            {% endif %}
        </div>
        
        <div class="pt-6 flex justify-end gap-4 border-t border-gray-200">
            <a href="{{ path('app_consultation_index') }}" class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition">
                Annuler
            </a>
            {{ form_widget(form.save, {'label': 'Enregistrer les modifications'}) }}
        </div>
        
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}