{% extends 'layout.html.twig' %}

{% block main %}
<div class="bg-white rounded-xl shadow p-6 max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Add New Consultation</h2>
    
    {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
    
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.date, 'Date et heure *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.date.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.date) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.date) }}
                    </div>
                {% endif %}
            </div>
            
            <div>
                {{ form_label(form.type, 'Type *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.type, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.type.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.type) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.type) }}
                    </div>
                {% endif %}
            </div>
            
            <div class="md:col-span-2">
                {{ form_label(form.dog, 'dog *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.dog, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.dog.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.dog) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.dog) }}
                    </div>
                {% endif %}
            </div>
            
            <div class="md:col-span-2">
                {{ form_label(form.user, 'User *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}  <!-- CHANGÉ: veterinaire → user -->
                {{ form_widget(form.user, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.user.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}  <!-- CHANGÉ: veterinaire → user -->
                {% if form_errors(form.user) %}  <!-- CHANGÉ: veterinaire → user -->
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.user) }}  <!-- CHANGÉ: veterinaire → user -->
                    </div>
                {% endif %}
            </div>
            
            <div class="md:col-span-2">
                {{ form_label(form.diagnostic, 'Diagnostic *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.diagnostic, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.diagnostic.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.diagnostic) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.diagnostic) }}
                    </div>
                {% endif %}
            </div>
            
            <div class="md:col-span-2">
                {{ form_label(form.traitement, 'Traitement', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.traitement, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.traitement.vars.errors|length ? ' border-red-500 focus:ring-red-500 focus:border-red-500' : '')}}) }}
                {% if form_errors(form.traitement) %}
                    <div class="mt-1 flex items-center text-sm text-red-600">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                        </svg>
                        {{ form_errors(form.traitement) }}
                    </div>
                {% endif %}
            </div>
        </div>
        
        <div class="pt-6 flex justify-end gap-3">
            <a href="{{ path('app_consultation_index') }}" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
                Cancel
            </a>
            {{ form_widget(form.save) }}
        </div>
        
    {{ form_end(form) }}
</div>
{% endblock %}