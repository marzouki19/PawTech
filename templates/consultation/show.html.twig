{% extends 'base.html.twig' %}

{% block title %}Consultation{% endblock %}

{% block body %}
    <h1>Consultation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ consultation.id }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ consultation.date ? consultation.date|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ consultation.type }}</td>
            </tr>
            <tr>
                <th>Diagnostic</th>
                <td>{{ consultation.diagnostic }}</td>
            </tr>
            <tr>
                <th>Traitement</th>
                <td>{{ consultation.traitement }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_consultationentity_index') }}">back to list</a>

    <a href="{{ path('app_consultationentity_edit', {'id': consultation.id}) }}">edit</a>

    {{ include('consultationentity/_delete_form.html.twig') }}
{% endblock %}
