{% extends 'layout.html.twig' %}

{% block title %}Dashboard | PawTech{% endblock %}

{% block main %}
  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 xl:col-span-8 space-y-6">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="h-[420px] bg-gray-100 flex items-center justify-center text-gray-400">
          Map widget placeholder
        </div>
        <div class="px-6 py-4 flex items-center justify-between text-sm text-gray-500">
          <div class="flex items-center gap-6">
            <span class="inline-flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-500"></span> Dogs</span>
            <span class="inline-flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-600"></span> Station</span>
            <span class="inline-flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-500"></span> Product</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 lg:col-span-6 bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
          <h3 class="text-lg font-semibold text-paw-orange mb-4">Total sales</h3>
          <div class="h-52 bg-gray-50 rounded-xl flex items-center justify-center text-gray-400">Chart placeholder</div>
        </div>
        <div class="col-span-12 lg:col-span-6 bg-gray-200/70 rounded-2xl border border-gray-200"></div>
      </div>
    </div>

    <div class="col-span-12 xl:col-span-4 space-y-6">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-800">Upcoming schedule</h3>
          <select class="px-3 py-2 border border-gray-200 rounded-lg bg-white text-gray-700">
            <option>Monthly</option>
          </select>
        </div>
        <div class="h-64 bg-gray-50 rounded-xl flex items-center justify-center text-gray-400">Calendar placeholder</div>
        <div class="mt-6">
          <h4 class="font-semibold text-gray-800 mb-3">Details</h4>
          <div class="space-y-4">
            {% for i in 1..3 %}
              <div class="flex items-center gap-4">
                <div class="w-1 self-stretch rounded bg-paw-orange"></div>
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <span class="font-semibold text-gray-800">08.30AM</span>
                    <span class="text-gray-500 text-sm">Health checkup</span>
                  </div>
                  <div class="text-gray-800 font-medium">Health adoption 20</div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

