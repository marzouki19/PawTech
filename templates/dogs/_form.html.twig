{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'space-y-6'}}) }}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="form-group">
            <label for="{{ form.name.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                {{ form_label(form.name) }}
            </label>
            {% set name_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Enter dog name'} %}
            {% if not form.name.vars.valid %}{% set name_attr = name_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
            {{ form_widget(form.name, {'attr': name_attr, 'errors': false}) }}
            {{ form_errors(form.name, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.age.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                {{ form_label(form.age) }}
            </label>
            {% set age_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Enter age'} %}
            {% if not form.age.vars.valid %}{% set age_attr = age_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
            {{ form_widget(form.age, {'attr': age_attr, 'errors': false}) }}
            {{ form_errors(form.age, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
        </div>
        <div class="form-group">
            <label for="{{ form.breed.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                {{ form_label(form.breed) }}
            </label>
            {% set breed_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Enter breed'} %}
            {% if not form.breed.vars.valid %}{% set breed_attr = breed_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
