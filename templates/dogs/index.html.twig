{% extends 'layout.html.twig' %}

{% block title %}Dogs | PawTech{% endblock %}

{% set active = 'dogs' %}
{% set page_title = 'Dogs' %}

{# Calculate records here so they're available in both main and javascripts blocks #}
{% set total_records = dogs|length %}
{% set available_records = dogs|filter(d => d.adoptionStatus == 'Available')|length %}
{% set reserved_records = dogs|filter(d => d.adoptionStatus == 'Reserved')|length %}
{% set adopted_records = dogs|filter(d => d.adoptionStatus == 'Adopted')|length %}

{% block main %}
<div x-data="{
    searchQuery: '',
    showGridOnly: false,
    deleteModalOpen: false,
    deleteAction: '',
    deleteToken: '',
    deleteLabel: '',
    openDelete(action, token, label) {
        this.deleteAction = action;
        this.deleteToken = token;
        this.deleteLabel = label;
        this.deleteModalOpen = true;
    }
}">
    <div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
        <!-- Page Header -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="flex items-start gap-4 flex-1">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100">
                        <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23H5.904M14.25 9h2.25M5.904 18.75c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 01-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 10.203 4.167 9.75 5 9.75h1.053c.472 0 .745.556.5.96a8.958 8.958 0 00-1.302 4.665c0 1.194.232 2.333.654 3.375z" />
                        </svg>
                    </div>
                    <div>
                        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                            <a href="#" class="hover:text-gray-700 transition">Dashboard</a>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            <span class="text-gray-900 font-medium">Dogs</span>
                        </nav>
                        <h1 class="text-2xl font-bold text-gray-900">Dog Management</h1>
                        <p class="mt-1 text-sm text-gray-600 max-w-xl">Track and manage all registered dogs, monitor health records, vaccination status, and adoption readiness.</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 mt-4 lg:mt-0">
                    <a href="{{ path('app_dogs_new') }}"
                       class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Dog
                    </a>
                    <button @click="showGridOnly = !showGridOnly"
                            type="button"
                            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                        </svg>
                        <span x-text="showGridOnly ? 'Show Table' : 'Grid Only'"></span>
                    </button>
                </div>
            </div>
        </div>

        <!-- FILTERS INLINE WITH SEARCH BAR -->
        <div class="flex flex-col gap-2 mb-8">
            <div class="flex flex-1 items-center gap-4 max-w-5xl">
                <!-- Filters -->
                <span class="text-sm font-semibold text-gray-700">Filters:</span>
                <div class="relative">
                    <select id="adoptionStatusFilter" 
                            class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                        <option value="">All Adoption Status</option>
                        <option value="Available">Available</option>
                        <option value="Reserved">Reserved</option>
                        <option value="Adopted">Adopted</option>
                        <option value="Streetdog">Streetdog</option>
                    </select>
                </div>
                <div class="relative">
                    <select id="healthStatusFilter" 
                            class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                        <option value="">All Health Status</option>
                        <option value="Healthy">Healthy</option>
                        <option value="Minor issues">Minor issues</option>
                        <option value="Chronic">Chronic</option>
                    </select>
                </div>
                <div class="relative">
                    <select id="genderFilter" 
                            class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                        <option value="">All Gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                </div>
                <div class="flex gap-2">
                    <button type="button" 
                            id="applyFilters"
                            class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors min-w-[150px]">
                        Apply Filters
                    </button>
                    <button type="button" 
                            id="clearFilters"
                            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors min-w-[150px]">
                        Clear Filters
                    </button>
                </div>
                <!-- Search -->
                  <input type="text" 
                      id="search" 
                      placeholder="Search dogs by name, breed, or microchip number..."
                      class="w-full min-w-[300px] max-w-[400px] rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
            </div>
            {% set has_active_filter = app.request.get('adoptionStatus') or app.request.get('healthStatus') or app.request.get('gender') %}
            {% if has_active_filter %}
            <div class="flex items-center gap-2">
                <span class="text-sm text-gray-600">Active filters:</span>
                {% if app.request.get('adoptionStatus') %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
                        Adoption Status: {{ app.request.get('adoptionStatus') }}
                        <a href="{{ path('app_dogs_filter', {
                            healthStatus: app.request.get('healthStatus'),
                            gender: app.request.get('gender')
                        }) }}" class="text-blue-500 hover:text-blue-700">&times;</a>
                    </span>
                {% endif %}
                {% if app.request.get('healthStatus') %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
                        Health Status: {{ app.request.get('healthStatus') }}
                        <a href="{{ path('app_dogs_filter', {
                            adoptionStatus: app.request.get('adoptionStatus'),
                            gender: app.request.get('gender')
                        }) }}" class="text-green-500 hover:text-green-700">&times;</a>
                    </span>
                {% endif %}
                {% if app.request.get('gender') %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-700">
                        Gender: {{ app.request.get('gender') }}
                        <a href="{{ path('app_dogs_filter', {
                            adoptionStatus: app.request.get('adoptionStatus'),
                            healthStatus: app.request.get('healthStatus')
                        }) }}" class="text-yellow-500 hover:text-yellow-700">&times;</a>
                    </span>
                {% endif %}
            </div>
            {% endif %}
        </div>


        <!-- Overview Stats -->
        <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4" id="statsContainer" x-show="!showGridOnly">
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total Dogs</p>
                <p class="mt-2 text-2xl font-bold text-gray-900" id="totalCount">{{ total_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Available</p>
                <p class="mt-2 text-2xl font-bold text-green-600" id="availableCount">{{ available_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Reserved</p>
                <p class="mt-2 text-2xl font-bold text-yellow-600" id="reservedCount">{{ reserved_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Adopted</p>
                <p class="mt-2 text-2xl font-bold text-gray-600" id="adoptedCount">{{ adopted_records }}</p>
            </div>
        </div>

        <!-- Dogs Table -->
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm" id="dogsTable" x-show="!showGridOnly">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Dog</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Breed</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Age</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">gender</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="all">
                        {% if dogs is empty %}
                            <tr>
                                <td colspan="5" class="px-6 py-12 text-center">
                                    <p class="text-sm font-semibold text-gray-600">No dogs registered yet.</p>
                                    <p class="text-xs text-gray-400">Click "Add Dog" to create the first record.</p>
                                </td>
                            </tr>
                        {% else %}
                            {% for dog in dogs %}
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            {% if dog.image %}
                                                <img src="{{ dog.image }}" alt="{{ dog.name }}" class="h-10 w-10 rounded-full object-cover">
                                            {% else %}
                                                <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center text-sm font-bold text-gray-700">
                                                    {{ dog.name|slice(0, 1)|upper }}
                                                </div>
                                            {% endif %}
                                            <div>
                                                <p class="text-sm font-semibold text-gray-900">{{ dog.name }}</p>
                                                <p class="text-xs text-gray-500">{{ dog.gender }} • {{ dog.size }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ dog.breed }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ dog.age }} yrs</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold
                                            {% if dog.adoptionStatus == 'Available' %}bg-green-100 text-green-700
                                            {% elseif dog.adoptionStatus == 'Reserved' %}bg-yellow-100 text-yellow-700
                                            {% elseif dog.adoptionStatus == 'Adopted' %}bg-gray-100 text-gray-700
                                            {% else %}bg-blue-100 text-blue-700{% endif %}">
                                            {{ dog.adoptionStatus }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ dog.gender }}</td>
                                    <td class="px-6 py-4 text-right text-sm">
                                        <a href="{{ path('app_dogs_show', {'id': dog.id}) }}"
                                           class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                        <a href="{{ path('app_dogs_edit', {'id': dog.id}) }}"
                                           class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                        <button type="button"
                                                class="ml-4 text-red-600 hover:text-red-700 font-semibold"
                                                @click="openDelete('{{ path('app_dogs_delete', {'id': dog.id}) }}', '{{ csrf_token('delete' ~ dog.id) }}', '{{ dog.name|e('js') }}')">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                    <tbody id="searchtab" style="display: none;"></tbody>
                    <tbody id="filtertab" style="display: none;"></tbody> <!-- ADDED THIS FOR FILTER RESULTS -->
                </table>
            </div>
        </div>

        <!-- Dogs Grid -->
        <div class="mt-8" id="dogsGrid" x-show="showGridOnly" x-cloak style="display: none;">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-gray-900">Dogs Gallery</h2>
                <span class="text-sm text-gray-500">{{ total_records }} dogs</span>
            </div>

            {% if dogs is empty %}
                <div class="rounded-2xl border border-dashed border-gray-200 p-12 text-center bg-white">
                    <p class="text-sm font-semibold text-gray-600">No dogs registered yet.</p>
                    <p class="text-xs text-gray-400">Add your first dog to see the gallery.</p>
                </div>
            {% else %}
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="dogsGridContainer">
                    {% for dog in dogs %}
                        <div class="group overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:shadow-lg">
                            <div class="relative h-48 bg-gray-100">
                                {% if dog.image %}
                                    <img src="{{ dog.image }}" alt="{{ dog.name }}" class="h-full w-full object-cover">
                                {% else %}
                                    <div class="flex h-full w-full items-center justify-center text-5xl font-bold text-gray-300">
                                        {{ dog.name|slice(0, 1)|upper }}
                                    </div>
                                {% endif %}
                                <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700">
                                    {{ dog.adoptionStatus }}
                                </span>
                            </div>
                            <div class="p-5">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-lg font-semibold text-gray-900">{{ dog.name }}</h3>
                                    <span class="text-xs font-semibold text-gray-500">{{ dog.gender }}</span>
                                </div>
                                <p class="text-sm text-gray-500">{{ dog.breed }} • {{ dog.size }}</p>
                                <div class="mt-4 flex items-center justify-between text-xs text-gray-500">
                                    <span>Age: {{ dog.age }} yrs</span>
                                    <span>Weight: {{ dog.weight }} kg</span>
                                </div>
                                <div class="mt-4 flex gap-2">
                                    <a href="{{ path('app_dogs_show', {'id': dog.id}) }}"
                                       class="flex-1 rounded-lg border border-gray-200 px-3 py-2 text-xs font-semibold text-gray-700 hover:bg-gray-50 text-center">
                                        View
                                    </a>
                                    <a href="{{ path('app_dogs_edit', {'id': dog.id}) }}"
                                       class="flex-1 rounded-lg border border-orange-200 px-3 py-2 text-xs font-semibold text-orange-600 hover:bg-orange-50 text-center">
                                        Edit
                                    </a>
                                    <button type="button"
                                            @click="openDelete('{{ path('app_dogs_delete', {'id': dog.id}) }}', '{{ csrf_token('delete' ~ dog.id) }}', '{{ dog.name|e('js') }}')"
                                            class="flex-1 rounded-lg border border-red-200 px-3 py-2 text-xs font-semibold text-red-600 hover:bg-red-50">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Delete Modal -->
    <div x-show="deleteModalOpen"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
         @click.self="deleteModalOpen = false"
         @keydown.escape.window="deleteModalOpen = false"
         style="display: none;"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95">
        <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900">Delete Dog</h2>
                        <p class="mt-1 text-sm text-gray-600">Are you sure you want to delete <span class="font-semibold" x-text="deleteLabel"></span>?</p>
                    </div>
                    <button @click="deleteModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="px-8 py-6">
                <form method="post" :action="deleteAction">
                    <input type="hidden" name="_token" :value="deleteToken">
                    <div class="flex justify-end gap-3">
                        <button type="button" @click="deleteModalOpen = false"
                                class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-6 py-2.5 rounded-lg bg-red-600 text-sm font-semibold text-white shadow hover:bg-red-700">
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
$(document).ready(function() {

    // ────────────────────────────────────────────────
    //   SEARCH (AJAX → shows #searchtab)
    // ────────────────────────────────────────────────
    $("#search").on("keyup", function() {
        const value = $(this).val().trim();

        if (!value) {
            $('#dogsTable tbody#all').show();
            $('#dogsTable tbody#searchtab').hide().empty();
            return;
        }

        $.ajax({
            url: "{{ path('app_dogs_search_json') }}",
            type: "GET",
            data: { searchValue: value },
            dataType: "json",
            success: function(dogs) {
                const $searchBody = $('#dogsTable tbody#searchtab');
                $searchBody.empty();
                $('#dogsTable tbody#all').hide();

                if (dogs?.length > 0) {
                    dogs.forEach(dog => {
                        const statusClass = {
                            'Available': 'bg-green-100 text-green-700',
                            'Reserved' : 'bg-yellow-100 text-yellow-700',
                            'Adopted'  : 'bg-gray-100 text-gray-700'
                        }[dog.adoptionStatus] || 'bg-blue-100 text-blue-700';

                        const avatar = dog.image
                            ? `<img src="${dog.image}" alt="${dog.name || 'Dog'}" class="h-10 w-10 rounded-full object-cover">`
                            : `<div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center text-sm font-bold text-gray-700">
                                 ${dog.name?.charAt(0)?.toUpperCase() || 'D'}
                               </div>`;

                        const escapedName = (dog.name || '').replace(/'/g, "\\'");

                        const row = `
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        ${avatar}
                                        <div>
                                            <p class="text-sm font-semibold text-gray-900">${dog.name || ''}</p>
                                            <p class="text-xs text-gray-500">${dog.gender || ''} • ${dog.size || ''}</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">${dog.breed || ''}</td>
                                <td class="px-6 py-4 text-sm text-gray-600">${dog.age || ''} yrs</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold ${statusClass}">
                                        ${dog.adoptionStatus || 'Unknown'}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right text-sm">
                                    <a href="/dogs/${dog.id}" class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                    <a href="/dogs/${dog.id}/edit" class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                    <button type="button" class="ml-4 text-red-600 hover:text-red-700 font-semibold"
                                        onclick="Alpine.store('app').openDelete('/dogs/${dog.id}', '${dog.id}', '${escapedName}')">
                                        Delete
                                    </button>
                                </td>
                            </tr>`;

                        $searchBody.append(row);
                    });
                    $searchBody.show();
                } else {
                    $searchBody.html(`
                        <tr><td colspan="5" class="px-6 py-12 text-center">
                            <p class="text-sm font-semibold text-gray-600">No dogs found for "${value}"</p>
                        </td></tr>
                    `).show();
                }
            },
            error: function(xhr, status, err) {
                console.error("Search failed:", status, err, xhr.responseText);
                alert("Error searching dogs – check console");
            }
        });
    });


    // ────────────────────────────────────────────────
    //   APPLY FILTERS (page reload with ?params)
    // ────────────────────────────────────────────────
    $('#applyFilters').on('click', function() {
        const adoptionStatus = $('#adoptionStatusFilter').val()?.trim();
        const healthStatus   = $('#healthStatusFilter').val()?.trim();
        const gender         = $('#genderFilter').val()?.trim();

        const params = new URLSearchParams();

        if (adoptionStatus) params.set('adoptionStatus', adoptionStatus);
        if (healthStatus)   params.set('healthStatus',   healthStatus);
        if (gender)         params.set('gender',         gender);

        let url = "{{ path('app_dogs_filter') }}";
        if (params.toString()) {
            url += '?' + params.toString();
        }

        window.location.href = url;
    });


    // ────────────────────────────────────────────────
    //   CLEAR FILTERS
    // ────────────────────────────────────────────────
    $('#clearFilters').on('click', function() {
        window.location.href = "{{ path('app_dogs_filter') }}";
    });

});
</script>
{% endblock %}