{% extends 'layout.html.twig' %}

{% block main %}
    <style>
        .dash-shell {
            --brand-main: #d97706;
            --brand-dark: #92400e;
            --brand-soft: #fff7ed;
            --ink-900: #1f2937;
            --ink-600: #4b5563;
            --line: #e5e7eb;
        }
        .dash-panel {
            border: 1px solid var(--line);
            border-radius: 16px;
            background: #fff;
            box-shadow: 0 10px 30px rgba(17, 24, 39, 0.06);
        }
        .dash-kpi {
            border: 1px solid #fed7aa;
            border-radius: 14px;
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
        }
        .dog-card {
            border: 1px solid var(--line);
            border-radius: 16px;
            background: #fff;
            overflow: hidden;
            transition: transform 180ms ease, box-shadow 180ms ease;
        }
        .dog-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 28px rgba(17, 24, 39, 0.1);
        }
        .dog-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: #f3f4f6;
        }
        .fade-in {
            animation: dashFade 360ms ease-out both;
        }
        #streetdog-map {
            width: 100%;
            height: 460px;
            min-height: 460px;
        }
        @keyframes dashFade {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    <div class="dash-shell space-y-6">
        <section class="dash-panel p-6 relative overflow-hidden">
            <div class="absolute inset-y-0 right-0 w-1/3 hidden lg:block" style="background: radial-gradient(circle at center, rgba(217,119,6,.15), transparent 65%);"></div>
            <div class="relative z-10">
                <p class="text-xs font-semibold uppercase tracking-wider text-amber-700">Tracking Center</p>
                <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mt-1">Streetdog Dashboard</h1>
                <p class="text-sm text-gray-600 mt-2">Monitor location pings and key details for dogs with status <strong>Streetdog</strong>.</p>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-5">
                    <div class="dash-kpi p-4">
                        <p class="text-xs uppercase tracking-wide text-amber-700 font-semibold">Streetdogs</p>
                        <p class="text-2xl font-bold text-amber-900 mt-1">{{ dogs|length }}</p>
                    </div>
                    <div class="dash-kpi p-4">
                        <p class="text-xs uppercase tracking-wide text-amber-700 font-semibold">Mapped</p>
                        <p class="text-2xl font-bold text-amber-900 mt-1">{{ markers|length }}</p>
                    </div>
                    <div class="dash-kpi p-4">
                        <p class="text-xs uppercase tracking-wide text-amber-700 font-semibold">Without GPS</p>
                        <p class="text-2xl font-bold text-amber-900 mt-1">{{ dogs|length - markers|length }}</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <article class="dash-panel overflow-hidden xl:col-span-2 fade-in">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900">Leaflet Live Map</h2>
                        <p class="text-sm text-gray-500">Latest known positions from ziptag data.</p>
                    </div>
                    <span class="text-xs px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 font-semibold">{{ markers|length }} markers</span>
                </div>
                <div id="streetdog-map"></div>
            </article>

            <article class="dash-panel p-5 fade-in">
                <h3 class="text-base font-semibold text-gray-900">Quick Summary</h3>
                <div class="mt-4 space-y-3 text-sm text-gray-700">
                    <div class="flex items-center justify-between border-b border-gray-100 pb-2">
                        <span>Total tracked dogs</span>
                        <span class="font-semibold text-gray-900">{{ dogs|length }}</span>
                    </div>
                    <div class="flex items-center justify-between border-b border-gray-100 pb-2">
                        <span>Dogs with location</span>
                        <span class="font-semibold text-gray-900">{{ markers|length }}</span>
                    </div>
                    <div class="flex items-center justify-between border-b border-gray-100 pb-2">
                        <span>Dogs without location</span>
                        <span class="font-semibold text-gray-900">{{ dogs|length - markers|length }}</span>
                    </div>
                </div>
                <div class="mt-5 rounded-lg border border-amber-200 bg-amber-50 p-3 text-xs text-amber-800">
                    Tip: assign a ziptag and send location updates to increase map coverage.
                </div>
            </article>
        </section>

        <section class="dash-panel p-5 fade-in">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Streetdog Grid</h2>
                <span class="text-sm text-gray-500">{{ dogs|length }} dogs</span>
            </div>

            {% if dogs is empty %}
                <div class="rounded-lg border border-dashed border-gray-300 bg-gray-50 p-8 text-center text-sm text-gray-500">
                    No dogs with status <strong>Streetdog</strong> found.
                </div>
            {% else %}
                <div class="grid grid-cols-1 sm:grid-cols-2 2xl:grid-cols-4 gap-4">
                    {% for dog in dogs %}
                        {% set imageSrc = dog.image %}
                        {% if imageSrc and imageSrc starts with('data:image') %}
                            {% set displayImage = imageSrc %}
                        {% elseif imageSrc %}
                            {% set displayImage = asset(imageSrc) %}
                        {% else %}
                            {% set displayImage = 'https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&w=800&q=80' %}
                        {% endif %}

                        <article class="dog-card">
                            <img src="{{ displayImage }}" alt="{{ dog.name ?: 'Dog' }}" class="dog-image">
                            <div class="p-4">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <h3 class="text-base font-semibold text-[var(--ink-900)] leading-tight">{{ dog.name ?: 'Unknown' }}</h3>
                                        <p class="text-sm text-[var(--ink-600)]">{{ dog.breed ?: 'Unknown breed' }}</p>
                                    </div>
                                    <span class="text-[11px] px-2 py-1 rounded-full bg-orange-100 text-orange-800 font-semibold">{{ dog.adoptionStatus }}</span>
                                </div>

                                <div class="mt-3 grid grid-cols-2 gap-2 text-xs text-gray-700">
                                    <div class="rounded-md bg-gray-50 px-2 py-1"><span class="font-medium">Age:</span> {{ dog.age ?? 'N/A' }}</div>
                                    <div class="rounded-md bg-gray-50 px-2 py-1"><span class="font-medium">Gender:</span> {{ dog.gender ?? 'N/A' }}</div>
                                    <div class="rounded-md bg-gray-50 px-2 py-1"><span class="font-medium">Weight:</span> {{ dog.weight ?? 'N/A' }}</div>
                                    <div class="rounded-md bg-gray-50 px-2 py-1"><span class="font-medium">Vaccinated:</span> {{ dog.vaccinated ? 'Yes' : 'No' }}</div>
                                </div>

                                <p class="mt-3 text-xs text-gray-500">
                                    Ziptag: <span class="font-medium text-gray-700">{{ dog.ziptag ? dog.ziptag.serialNumber : 'Not assigned' }}</span>
                                </p>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </div>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        (function () {
            const markers = {{ markers|json_encode|raw }};
            const mapEl = document.getElementById('streetdog-map');
            if (!mapEl) {
                return;
            }

            const center = markers.length ? [markers[0].lat, markers[0].lng] : [36.8065, 10.1815];
            const map = L.map('streetdog-map').setView(center, markers.length ? 12 : 10);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            if (!markers.length) {
                L.popup()
                    .setLatLng(center)
                    .setContent('No ziptag location data for current Streetdog list.')
                    .openOn(map);
                return;
            }

            const bounds = [];
            markers.forEach((marker) => {
                const point = [marker.lat, marker.lng];
                bounds.push(point);
                L.marker(point).addTo(map).bindPopup(
                    '<strong>' + marker.name + '</strong><br>Dog #' + marker.id
                );
            });

            map.fitBounds(bounds, { padding: [30, 30] });
        })();
    </script>
{% endblock %}
