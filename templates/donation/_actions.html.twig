<div class="flex gap-2">
  <a href="{{ path('app_donation_show', { id: donation.id }) }}" 
     class="text-paw-orange hover:underline js-modal-link"
     data-title="Donation #{{ donation.id }}">
    View
  </a>
  <a href="{{ path('app_donation_edit', { id: donation.id }) }}" 
     class="text-blue-600 hover:underline js-modal-link"
     data-title="Modify donation #{{ donation.id }}">
    Modify
  </a>
  <form method="post" action="{{ path('app_donation_delete', { id: donation.id }) }}" class="inline js-delete-form">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ donation.id) }}">
    <button type="button" class="text-red-600 hover:underline js-delete-button" 
            data-message="Delete this donation?">
      Delete
    </button>
  </form>
</div>