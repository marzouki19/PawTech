{% extends 'layout.html.twig' %}

{% block title %}Donations | PawTech{% endblock %}

{% set active = 'donations' %}
{% set page_title = 'Donations' %}

{% block main %}
<div x-data="{
    searchQuery: '',
    deleteModalOpen: false,
    deleteAction: '',
    deleteToken: '',
    deleteLabel: '',
    openDelete(action, token, label) {
        this.deleteAction = action;
        this.deleteToken = token;
        this.deleteLabel = label;
        this.deleteModalOpen = true;
    }
}">
    <div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="flex items-start gap-4 flex-1">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100">
                        <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                    </div>
                    <div>
                        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                            <a href="#" class="hover:text-gray-700 transition">Dashboard</a>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            <span class="text-gray-900 font-medium">Donations</span>
                        </nav>
                        <h1 class="text-2xl font-bold text-gray-900">Donation Management</h1>
                        <p class="mt-1 text-sm text-gray-600 max-w-xl">Track all donations, donor details, payment references, and validation status.</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 mt-4 lg:mt-0">
                    <a href="{{ path('app_donation_new') }}"
                       class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Donation
                    </a>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-4 mb-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div class="flex items-center gap-4 flex-1">
                    <span class="text-sm font-semibold text-gray-700">Filters:</span>
                    <div class="relative">
                        <select id="statusFilter" class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                            <option value="" {{ not current_status ? 'selected' : '' }}>All Status</option>
                            <option value="validated" {{ current_status == 'validated' ? 'selected' : '' }}>Validated</option>
                            <option value="pending" {{ current_status == 'pending' ? 'selected' : '' }}>Pending</option>
                        </select>
                    </div>
                    <button type="button"
                            id="applyFilters"
                            class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors min-w-[150px]">
                        Apply Filters
                    </button>
                    {% if current_status %}
                        <a href="{{ path('app_donation_index') }}"
                           class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors min-w-[150px]">
                            Clear Filters
                        </a>
                    {% endif %}
                </div>
                <div class="relative flex-1 max-w-xl">
                    <input type="text"
                           id="search"
                           placeholder="Search donations by donor, email, reference..."
                           class="w-full min-w-[280px] max-w-[400px] rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                </div>
            </div>
            {% if current_status %}
                <div class="flex items-center gap-2">
                    <span class="text-sm text-gray-600">Active filters:</span>
                    <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
                        {{ current_status == 'validated' ? 'Validated' : 'Pending' }}
                        <a href="{{ path('app_donation_index') }}" class="text-blue-500 hover:text-blue-700">&times;</a>
                    </span>
                </div>
            {% endif %}
        </div>

        <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total Donations</p>
                <p class="mt-2 text-2xl font-bold text-gray-900">{{ total_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Validated</p>
                <p class="mt-2 text-2xl font-bold text-green-600">{{ validated_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Pending</p>
                <p class="mt-2 text-2xl font-bold text-yellow-600">{{ pending_records }}</p>
            </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm" id="donationTable">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">ID</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Amount</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Donor</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Email</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Reference</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="allRows">
                        {% if donations is empty %}
                            <tr>
                                <td colspan="8" class="px-6 py-12 text-center">
                                    <p class="text-sm font-semibold text-gray-600">No donations found.</p>
                                    <p class="text-xs text-gray-400">Click "Add Donation" to create the first record.</p>
                                </td>
                            </tr>
                        {% else %}
                            {% for donation in donations %}
                                {% set label = donation.donateur ?: ('Donation #' ~ donation.id) %}
                                <tr class="hover:bg-gray-50"
                                    data-search="{{ (donation.donateur ~ ' ' ~ donation.email ~ ' ' ~ donation.reference ~ ' ' ~ donation.montant)|lower }}">
                                    <td class="px-6 py-4 text-sm font-semibold text-gray-900">#{{ donation.id }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-700">{{ donation.montant|number_format(2, ',', ' ') }} TND</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ donation.date ? donation.date|date('d/m/Y') : '-' }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ donation.donateur ?: '-' }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ donation.email ?: '-' }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ donation.reference ?: '-' }}</td>
                                    <td class="px-6 py-4 text-sm">
                                        {% if donation.statut %}
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Validated</span>
                                        {% else %}
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4 text-right text-sm">
                                        <a href="{{ path('app_donation_show', {'id': donation.id}) }}" class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                        <a href="{{ path('app_donation_edit', {'id': donation.id}) }}" class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                        <button type="button"
                                                class="ml-4 text-red-600 hover:text-red-700 font-semibold"
                                                @click="openDelete('{{ path('app_donation_delete', {'id': donation.id}) }}', '{{ csrf_token('delete' ~ donation.id) }}', '{{ label|e('js') }}')">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                    <tbody id="searchRows" style="display:none;"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div x-show="deleteModalOpen"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
         @click.self="deleteModalOpen = false"
         @keydown.escape.window="deleteModalOpen = false"
         style="display: none;"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95">
        <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900">Delete Donation</h2>
                        <p class="mt-1 text-sm text-gray-600">Are you sure you want to delete <span class="font-semibold" x-text="deleteLabel"></span>?</p>
                    </div>
                    <button @click="deleteModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="px-8 py-6">
                <form method="post" :action="deleteAction">
                    <input type="hidden" name="_token" :value="deleteToken">
                    <div class="flex justify-end gap-3">
                        <button type="button" @click="deleteModalOpen = false"
                                class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-6 py-2.5 rounded-lg bg-red-600 text-sm font-semibold text-white shadow hover:bg-red-700">
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const searchInput = document.getElementById('search');
    const allRowsBody = document.getElementById('allRows');
    const searchRowsBody = document.getElementById('searchRows');
    const applyFiltersButton = document.getElementById('applyFilters');
    const statusFilter = document.getElementById('statusFilter');

    function resetSearchState() {
        if (!allRowsBody || !searchRowsBody) return;
        allRowsBody.style.display = '';
        searchRowsBody.style.display = 'none';
        searchRowsBody.innerHTML = '';
    }

    if (searchInput && allRowsBody && searchRowsBody) {
        searchInput.addEventListener('input', function () {
            const value = searchInput.value.trim().toLowerCase();

            if (!value) {
                resetSearchState();
                return;
            }

            const rows = Array.from(allRowsBody.querySelectorAll('tr[data-search]'));
            const matched = rows.filter((row) => (row.getAttribute('data-search') || '').includes(value));

            allRowsBody.style.display = 'none';
            searchRowsBody.style.display = '';
            searchRowsBody.innerHTML = '';

            if (matched.length === 0) {
                searchRowsBody.innerHTML = '<tr><td colspan="8" class="px-6 py-12 text-center"><p class="text-sm font-semibold text-gray-600">No donations found for "' + value.replace(/"/g, '&quot;') + '"</p></td></tr>';
                return;
            }

            matched.forEach((row) => searchRowsBody.appendChild(row.cloneNode(true)));
        });
    }

    if (applyFiltersButton && statusFilter) {
        applyFiltersButton.addEventListener('click', function () {
            const status = statusFilter.value;
            let url = '{{ path('app_donation_index') }}';

            if (status) {
                url += '?status=' + encodeURIComponent(status);
            }

            window.location.href = url;
        });
    }
});
</script>
{% endblock %}
