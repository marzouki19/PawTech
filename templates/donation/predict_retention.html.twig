{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} - PawTech{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-orange-50 via-white to-amber-50">
    <!-- Header Section -->
    <div class="bg-white border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-black text-gray-900">{{ page_title }}</h1>
                    <p class="mt-1 text-gray-500">AI-powered donor retention prediction using KNN machine learning</p>
                </div>
                <a href="{{ path('app_donation_index') }}" class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-xl hover:bg-orange-100 hover:text-orange-700 transition-all duration-200 font-medium">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Back to Donations
                </a>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Model Status -->
        <div class="mb-6 p-4 rounded-xl {% if model_available %}bg-green-50 border border-green-200{% else %}bg-red-50 border border-red-200{% endif %}">
            <div class="flex items-center">
                {% if model_available %}
                    <svg class="w-6 h-6 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="text-green-800 font-bold">ML Model is available and ready for predictions</span>
                {% else %}
                    <svg class="w-6 h-6 text-red-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                    <span class="text-red-800 font-bold">{{ error }}</span>
                {% endif %}
            </div>
        </div>

        {% if error %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl relative mb-6" role="alert">
                <strong class="font-bold">Error!</strong>
                <span class="block sm:inline">{{ error }}</span>
            </div>
        {% endif %}

        {% if prediction %}
            <!-- Stats Summary -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-orange-500">
                    <div class="text-3xl font-black text-orange-600">{{ prediction|length }}</div>
                    <div class="text-sm text-gray-500 font-medium mt-1">Total Donors Analyzed</div>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-green-500">
                    <div class="text-3xl font-black text-green-600">{{ prediction|filter(p => p.prediction.will_donate_again)|length }}</div>
                    <div class="text-sm text-gray-500 font-medium mt-1">Likely to Donate</div>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-red-500">
                    <div class="text-3xl font-black text-red-600">{{ prediction|filter(p => not p.prediction.will_donate_again)|length }}</div>
                    <div class="text-sm text-gray-500 font-medium mt-1">At Risk</div>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-yellow-500">
                    <div class="text-3xl font-black text-yellow-600">{{ (prediction|filter(p => p.prediction.risk_level == 'medium')|length) }}</div>
                    <div class="text-sm text-gray-500 font-medium mt-1">Medium Risk</div>
                </div>
            </div>

            <!-- Donors Table -->
            <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-100 bg-gradient-to-r from-orange-50 to-amber-50">
                    <h2 class="text-xl font-black text-gray-900">Donor Retention Predictions</h2>
                    <p class="text-sm text-gray-500 mt-1">Sorted by risk (highest risk first)</p>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Donor</th>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Total Donations</th>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Avg Amount</th>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Days Since Last</th>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Prediction</th>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Confidence</th>
                                <th class="px-6 py-4 text-left text-xs font-bold text-gray-600 uppercase tracking-wider">Risk Level</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            {% for donor in prediction %}
                                <tr class="{% if not donor.prediction.will_donate_again %}bg-red-50{% elseif donor.prediction.risk_level == 'medium' %}bg-yellow-50{% else %}bg-white{% endif %} hover:bg-orange-50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-12 w-12 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center">
                                                <span class="text-lg font-bold text-white">{{ donor.donateur|first|upper ?: 'A' }}</span>
                                            </div>
                                            <div class="ml-4">
                                                <div class="text-sm font-bold text-gray-900">{{ donor.donateur ?: 'Anonymous' }}</div>
                                                <div class="text-sm text-gray-500">{{ donor.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-bold text-gray-900">{{ donor.metrics.total_donations }}</div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-bold text-orange-600">${{ donor.metrics.avg_donation_amount|number_format(2) }}</div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm text-gray-900">{{ donor.metrics.days_since_last_donation }} days</div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        {% if donor.prediction.will_donate_again %}
                                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-green-100 text-green-800">
                                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                                Will Donate
                                            </span>
                                        {% else %}
                                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-red-100 text-red-800">
                                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                                Won't Donate
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-bold text-gray-900">{{ (donor.prediction.confidence * 100)|number_format(0) }}%</div>
                                        <div class="text-xs text-gray-500">
                                            Yes: {{ (donor.prediction.probability_will_donate * 100)|number_format(0) }}% / 
                                            No: {{ (donor.prediction.probability_wont_donate * 100)|number_format(0) }}%
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        {% if donor.prediction.risk_level == 'high' %}
                                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-red-100 text-red-800">
                                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                                </svg>
                                                High Risk
                                            </span>
                                        {% elseif donor.prediction.risk_level == 'medium' %}
                                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-yellow-100 text-yellow-800">
                                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                                </svg>
                                                Medium
                                            </span>
                                        {% else %}
                                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-green-100 text-green-800">
                                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                                Low Risk
                                            </span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ML Info -->
            <div class="mt-8 bg-white rounded-2xl shadow-lg border border-gray-100 p-6">
                <h3 class="text-lg font-black text-gray-900 mb-4">About This Prediction</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm text-gray-600">
                    <div class="bg-orange-50 rounded-xl p-4">
                        <h4 class="font-bold text-gray-800 mb-2 flex items-center">
                            <svg class="w-5 h-5 text-orange-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                            </svg>
                            Machine Learning Model
                        </h4>
                        <p>This prediction uses K-Nearest Neighbors (KNN) algorithm trained on {{ 2000 }} donor records with 96% accuracy.</p>
                    </div>
                    <div class="bg-amber-50 rounded-xl p-4">
                        <h4 class="font-bold text-gray-800 mb-2 flex items-center">
                            <svg class="w-5 h-5 text-amber-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                            </svg>
                            Features Used
                        </h4>
                        <ul class="list-disc list-inside space-y-1">
                            <li>Total donations count</li>
                            <li>Average donation amount</li>
                            <li>Donation frequency</li>
                            <li>Days since last donation</li>
                            <li>Donation consistency</li>
                        </ul>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
