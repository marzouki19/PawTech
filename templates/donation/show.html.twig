{# templates/donation/show.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Donation #{{ donation.id }}</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            font-family: Arial, sans-serif;
            background: #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        
        .window {
            width: 400px;
            background: white;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            padding: 25px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e0e0e0;
        }
        
        .header h1 {
            margin: 0;
            color: #333;
            font-size: 20px;
        }
        
        .amount {
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            color: #0066cc;
            margin: 20px 0;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 4px;
        }
        
        .info-line {
            display: flex;
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 1px dotted #eee;
        }
        
        .info-label {
            width: 100px;
            color: #666;
            font-weight: bold;
        }
        
        .info-value {
            flex: 1;
            color: #333;
        }
        
        .status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: bold;
        }
        
        .status-valid {
            background: #e6f4ea;
            color: #137333;
        }
        
        .status-pending {
            background: #fef7e0;
            color: #a36b00;
        }
        
        .footer {
            text-align: center;
            margin-top: 25px;
            color: #888;
            font-size: 12px;
        }
    </style>
</head>
<body>
    
  
        <div class="header">
            <h1>Donation Details</h1>
        </div>
        
        <div class="amount">
            {{ donation.montant|number_format(2, ',', ' ') }} TND
        </div>
        
        <div class="info-line">
            <div class="info-label">ID:</div>
            <div class="info-value">#{{ donation.id }}</div>
        </div>
        
        <div class="info-line">
            <div class="info-label">Date:</div>
            <div class="info-value">{{ donation.date|date('d/m/Y') }}</div>
        </div>
        
        <div class="info-line">
            <div class="info-label">Status:</div>
            <div class="info-value">
                <span class="status {{ donation.statut ? 'status-valid' : 'status-pending' }}">
                    {{ donation.statut ? 'Valid' : 'Pending' }}
                </span>
            </div>
        </div>
        
        {% if donation.donateur %}
        <div class="info-line">
            <div class="info-label">Donor:</div>
            <div class="info-value">{{ donation.donateur }}</div>
        </div>
        {% endif %}
        
        {% if donation.email %}
        <div class="info-line">
            <div class="info-label">Email:</div>
            <div class="info-value">{{ donation.email }}</div>
        </div>
        {% endif %}
        
        {% if donation.reference %}
        <div class="info-line">
            <div class="info-label">Ref:</div>
            <div class="info-value">{{ donation.reference }}</div>
        </div>
        {% endif %}
        
        
    

</body>
</html>