{% extends 'layout.html.twig' %}

{% block title %}Donation{% endblock %}

{% set active = 'donations' %}
{% set page_title = 'Donation' %}

{% block main %}
<div class="bg-white rounded-2xl shadow-2xl w-full">
    <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-bold text-gray-900">Donation Details</h2>
                <p class="mt-1 text-sm text-gray-600">Overview for donation <span class="font-semibold">#{{ donation.id }}</span></p>
            </div>
            <a href="{{ path('app_donation_index') }}" class="text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </a>
        </div>
    </div>

    <div class="px-8 py-6">
        <dl class="grid grid-cols-1 gap-4">
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">ID</dt>
                <dd class="mt-1 text-sm font-semibold text-gray-900">{{ donation.id }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Amount</dt>
                <dd class="mt-1 text-sm text-gray-700">{{ donation.montant|number_format(2, ',', ' ') }} TND</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Date</dt>
                <dd class="mt-1 text-sm text-gray-700">{{ donation.date ? donation.date|date('d/m/Y') : '-' }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Donor</dt>
                <dd class="mt-1 text-sm text-gray-700">{{ donation.donateur ?: '-' }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Email</dt>
                <dd class="mt-1 text-sm text-gray-700">{{ donation.email ?: '-' }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Reference</dt>
                <dd class="mt-1 text-sm text-gray-700">{{ donation.reference ?: '-' }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Status</dt>
                <dd class="mt-1 text-sm text-gray-700">{{ donation.statut ? 'Validated' : 'Pending' }}</dd>
            </div>
        </dl>

        <div class="flex flex-wrap items-center justify-between gap-3 mt-8 pt-6 border-t border-gray-200">
            <a href="{{ path('app_donation_index') }}"
               class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                Back to list
            </a>
            <div class="flex items-center gap-3">
                {{ include('donation/_delete_form.html.twig', {button_class: 'inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-red-200 text-sm font-semibold text-red-600 hover:bg-red-50 transition'}) }}
                <a href="{{ path('app_donation_edit', {'id': donation.id}) }}"
                   class="px-6 py-2.5 rounded-lg border border-orange-200 text-sm font-semibold text-orange-600 hover:bg-orange-50">
                    Edit
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
