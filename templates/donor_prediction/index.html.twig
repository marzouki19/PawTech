{% extends 'base.html.twig' %}

{% block title %}Donor Propensity Prediction{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-2">Donor Propensity Prediction</h1>
        <p class="text-gray-600">AI-powered prediction of user donation likelihood using Logistic Regression</p>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-lg shadow p-6">
            <div class="text-sm text-gray-500 mb-1">Total Users</div>
            <div class="text-3xl font-bold text-gray-800">{{ summary.total }}</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
            <div class="text-sm text-gray-500 mb-1">High Potential</div>
            <div class="text-3xl font-bold text-green-600">{{ summary.high_potential }}</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-yellow-500">
            <div class="text-sm text-gray-500 mb-1">Medium</div>
            <div class="text-3xl font-bold text-yellow-600">{{ summary.medium }}</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-red-500">
            <div class="text-sm text-gray-500 mb-1">Low</div>
            <div class="text-3xl font-bold text-red-600">{{ summary.low }}</div>
        </div>
    </div>

    <!-- Model Info -->
    {% if model_info and model_info.ok %}
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-8">
        <div class="flex items-center justify-between">
            <div>
                <span class="font-semibold text-blue-800">Model:</span>
                <span class="text-blue-700">{{ model_info.model }}</span>
            </div>
            <div>
                <span class="font-semibold text-blue-800">Accuracy:</span>
                <span class="text-blue-700">{{ model_info.accuracy }}%</span>
            </div>
            <div>
                <span class="font-semibold text-blue-800">Training Data:</span>
                <span class="text-blue-700">{{ model_info.dataset_records }} records</span>
            </div>
        </div>
    </div>
    {% else %}
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-8">
        <p class="text-red-700">
            <strong>AI Service not available.</strong> 
            Please start the Python API: <code class="bg-red-100 px-2 py-1 rounded">cd event_recommender && python app.py</code>
        </p>
    </div>
    {% endif %}

    <!-- Predictions Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-xl font-semibold text-gray-800">User Predictions</h2>
            <p class="text-sm text-gray-500">Sorted by propensity score (highest first)</p>
        </div>
        
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Propensity Score</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Participations</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Donation Events</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recommendation</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for prediction in predictions %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div>
                                    <div class="text-sm font-medium text-gray-900">{{ prediction.user_name }}</div>
                                    <div class="text-sm text-gray-500">{{ prediction.user_email }}</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="w-24 bg-gray-200 rounded-full h-2.5 mr-2">
                                    <div class="h-2.5 rounded-full {% if prediction.propensity_score >= 70 %}bg-green-500{% elseif prediction.propensity_score >= 40 %}bg-yellow-500{% else %}bg-red-500{% endif %}" 
                                         style="width: {{ prediction.propensity_score }}%"></div>
                                </div>
                                <span class="text-sm font-semibold">{{ prediction.propensity_score }}%</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            {% if prediction.category == 'High Potential' %}
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                    High Potential
                                </span>
                            {% elseif prediction.category == 'Medium' %}
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                    Medium
                                </span>
                            {% else %}
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                                    Low
                                </span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ prediction.stats.total_participations }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ prediction.stats.donation_events }}
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate" title="{{ prediction.recommendation }}">
                            {{ prediction.recommendation }}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-4 text-center text-gray-500">
                            No predictions available. Make sure the AI service is running.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Legend -->
    <div class="mt-8 bg-gray-50 rounded-lg p-4">
        <h3 class="font-semibold text-gray-700 mb-2">Category Legend</h3>
        <div class="flex flex-wrap gap-4 text-sm">
            <div class="flex items-center">
                <span class="w-3 h-3 bg-green-500 rounded-full mr-2"></span>
                <span><strong>High Potential (>= 70%):</strong> Priority targets for donation campaigns</span>
            </div>
            <div class="flex items-center">
                <span class="w-3 h-3 bg-yellow-500 rounded-full mr-2"></span>
                <span><strong>Medium (40-69%):</strong> Send personalized invitations</span>
            </div>
            <div class="flex items-center">
                <span class="w-3 h-3 bg-red-500 rounded-full mr-2"></span>
                <span><strong>Low (< 40%):</strong> Focus on engagement first</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
