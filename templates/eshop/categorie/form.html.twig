{# templates/eshop/categorie/form.html.twig #}
{% extends 'layout.html.twig' %}

{% block title %}{{ page_title }} - PawTech{% endblock %}

{% block main %}
<div class="container mx-auto px-4 py-8">
  <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-md p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ page_title }}</h1>
    
    {# Désactiver la validation HTML5 #}
    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    
    <div class="space-y-6">
      <div>
        {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
        {{ form_widget(form.nom, {'attr': {
          'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange focus:outline-none',
          'placeholder': 'Enter category name'
        }}) }}
        
        {# Afficher les erreurs de validation #}
        {{ form_errors(form.nom) }}
        
        <p class="mt-2 text-sm text-gray-500">
          Minimum 2 characters, maximum 255 characters.
        </p>
      </div>
    </div>
    
    <div class="flex gap-3 mt-8">
      <button type="submit" class="px-6 py-3 bg-paw-orange text-white font-semibold rounded-lg hover:bg-paw-orange-hover transition">
        {{ submit_label|default('Save') }}
      </button>
      <a href="{{ path('app_eshop_categorie_index') }}" class="px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition">
        Cancel
      </a>
    </div>
    
    {{ form_end(form) }}
  </div>
</div>
{% endblock %}