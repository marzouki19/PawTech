<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ page_title }}</h1>
  
  {{ form_start(form, {
    'attr': {
      'class': 'space-y-6',
      'id': 'commande-form'
    }
  }) }}
  
  {# Champ DATE #}
  <div>
    {% set date_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': 'dd/mm/yyyy', 'required': 'required'} %}
    {% if not form.date.vars.valid %}{% set date_attr = date_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.date, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    <div class="relative">
      {{ form_widget(form.date, {'attr': date_attr, 'errors': false}) }}
      <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
        <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
        </svg>
      </div>
    </div>
    {{ form_errors(form.date, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
    <p class="text-gray-500 text-xs mt-1">Format: dd/mm/yyyy</p>
  </div>
    
  {# Champ TOTAL #}
  <div>
    {% set total_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0.00', 'min': '0', 'step': '0.01', 'required': 'required'} %}
    {% if not form.total.vars.valid %}{% set total_attr = total_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.total, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.total, {'attr': total_attr, 'errors': false}) }}
    {{ form_errors(form.total, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ STATUT #}
  <div>
    <div class="flex items-center">
      {{ form_widget(form.statut, {'attr': {
        'class': 'h-4 w-4 text-paw-orange focus:ring-paw-orange border-gray-300 rounded'
      }, 'errors': false}) }}
      {{ form_label(form.statut, null, {'label_attr': {'class': 'ml-2 text-sm text-gray-700'}}) }}
    </div>
    {{ form_errors(form.statut, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
  
  <div class="flex gap-4 pt-6 border-t border-gray-200">
    <button type="submit" class="px-6 py-3 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange transition-colors duration-200">
      {{ submit_label|default('Save') }}
    </button>
    <a href="{{ path('app_eshop_commande_index') }}" class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 transition-colors duration-200">
      Cancel
    </a>
  </div>
  
  {{ form_end(form) }}
</div>
