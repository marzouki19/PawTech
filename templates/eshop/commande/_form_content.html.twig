<div class="max-w-xl">
  <h1 class="text-xl font-bold text-gray-800 mb-4">{{ page_title }}</h1>
  
  {{ form_start(form, {
    'attr': {
      'id': 'entity-modal-form'
    }, 
    'action': form_action|default(null)
  }) }}
  
  {# Afficher les erreurs globales #}
  {% if not form.vars.valid %}
    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
      <div class="text-red-800 font-medium mb-1">Please correct the following errors:</div>
      {{ form_errors(form) }}
    </div>
  {% endif %}
  
  <div class="space-y-4">
    {# Champ DATE avec aide au format #}
    <div>
      {{ form_label(form.date, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      <div class="relative">
        {{ form_widget(form.date, {'attr': {
          'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.date.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
          'placeholder': 'dd/mm/yyyy',
          'pattern': '\\d{2}/\\d{2}/\\d{4}'
        }}) }}
        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
          </svg>
        </div>
      </div>
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.date) }}
      </div>
      <p class="text-gray-500 text-xs mt-1">
        Format: dd/mm/yyyy (ex: 25/12/2023) • Maximum: {{ 'now'|date('d/m/Y') }}
      </p>
    </div>
    
    {# Champ TOTAL #}
    <div>
      {{ form_label(form.total, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.total, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.total.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
        'placeholder': '0.00'
      }}) }}
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.total) }}
      </div>
    </div>
    
    {# Champ STATUT #}
    <div>
      <div class="flex items-center">
        {{ form_widget(form.statut, {'attr': {
          'class': 'h-4 w-4 text-paw-orange focus:ring-paw-orange border-gray-300 rounded'
        }}) }}
        {{ form_label(form.statut, null, {'label_attr': {'class': 'ml-2 text-sm text-gray-700'}}) }}
      </div>
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.statut) }}
      </div>
    </div>
  </div>
  
  <div class="flex gap-3 mt-4">
    <button type="submit" class="px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange">
      {{ submit_label|default('Save') }}
    </button>
    <button type="button" class="px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 js-modal-cancel">Cancel</button>
  </div>
  
  {{ form_end(form) }}
</div>