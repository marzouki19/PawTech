<div class="space-y-4">
  <div class="flex justify-between items-center">
    <h1 class="text-xl font-bold text-gray-800">{{ page_title }}</h1>
    <div class="flex gap-2">
      <a href="{{ path('app_eshop_commande_edit', { id: commande.id }) }}" class="px-4 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover js-modal-link">Modify</a>
      <a href="#" class="px-4 py-2 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 js-modal-cancel">Back</a>
    </div>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div><dt class="text-sm text-gray-500">ID</dt><dd class="font-medium">{{ commande.id }}</dd></div>
      
      <div><dt class="text-sm text-gray-500">Total</dt><dd class="font-medium">{{ commande.total | number_format(2, ',', ' ') }} TND</dd></div>
      <div><dt class="text-sm text-gray-500">Status</dt><dd class="font-medium">{{ commande.statut ? 'Completed' : 'In progress' }}</dd></div>
    </dl>
  </div>
</div>
