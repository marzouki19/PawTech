<div class="max-w-xl">
  <h1 class="text-xl font-bold text-gray-800 mb-4">{{ page_title }}</h1>
  
  {{ form_start(form, {
    'attr': {
      'id': 'entity-modal-form'
    }, 
    'action': form_action|default(null)
  }) }}
  
  {# Afficher les erreurs globales #}
  {% if not form.vars.valid %}
    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
      <div class="text-red-800 font-medium mb-1">Please correct the following errors:</div>
      {{ form_errors(form) }}
    </div>
  {% endif %}
  
  <div class="space-y-4">
    {# Champ PRODUIT #}
    <div>
      {{ form_label(form.produit, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.produit, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.produit.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300')
      }}) }}
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.produit) }}
      </div>
    </div>
    
    {# Champ COMMANDE #}
    <div>
      {{ form_label(form.commande, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.commande, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.commande.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300')
      }}) }}
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.commande) }}
      </div>
    </div>
    
    {# Champ QUANTITE #}
    <div>
      {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.quantite, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.quantite.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
        'placeholder': '1'
      }}) }}
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.quantite) }}
      </div>
    </div>
    
    {# Champ PRIX UNITAIRE #}
    <div>
      {{ form_label(form.prixUnitaire, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.prixUnitaire, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.prixUnitaire.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
        'placeholder': '0.00'
      }}) }}
      <div class="text-red-600 text-sm mt-1">
        {{ form_errors(form.prixUnitaire) }}
      </div>
    </div>
  </div>
  
  <div class="flex gap-3 mt-4">
    <button type="submit" class="px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange">
      {{ submit_label|default('Save') }}
    </button>
    <button type="button" class="px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 js-modal-cancel">Cancel</button>
  </div>
  
  {{ form_end(form) }}
</div>