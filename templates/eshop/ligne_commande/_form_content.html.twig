{# templates/eshop/ligne_commande/_form_content.html.twig #}
<div class="max-w-xl">
  <h1 class="text-xl font-bold text-gray-800 mb-4">{{ page_title }}</h1>
  
  {# Afficher les erreurs globales #}
  {% if not form.vars.valid %}
    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
      <div class="text-red-800 font-medium mb-1">Veuillez corriger les erreurs suivantes :</div>
      <ul class="list-disc list-inside text-red-600 text-sm">
        {{ form_errors(form) }}
      </ul>
    </div>
  {% endif %}
  
  {{ form_start(form, {
    'attr': {
      'id': 'ligne-commande-form',
      'novalidate': 'novalidate',
      'class': 'space-y-4'
    }, 
    'action': form_action|default(null)
  }) }}
  
  <div class="space-y-4">
    {# Champ PRODUIT #}
    <div>
      {{ form_label(form.produit, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.produit, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.produit.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
        'required': 'required'
      }}) }}
      {% if form.produit.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.produit.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ COMMANDE #}
    <div>
      {{ form_label(form.commande, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.commande, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.commande.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
        'required': 'required'
      }}) }}
      {% if form.commande.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.commande.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ QUANTITE #}
    <div>
      {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.quantite, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.quantite.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
        'placeholder': '1',
        'required': 'required',
        'min': '1',
        'max': '999',
        'pattern': '[0-9]*'
      }}) }}
      {% if form.quantite.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.quantite.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
      <div class="text-xs text-gray-500 mt-1">
        Quantité minimale : 1, maximale : 999
      </div>
    </div>
    
    {# Champ PRIX UNITAIRE #}
    <div>
      {{ form_label(form.prixUnitaire, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      <div class="relative">
        <span class="absolute left-3 top-2.5 text-gray-500">$</span>
        {{ form_widget(form.prixUnitaire, {'attr': {
          'class': 'w-full pl-8 pr-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange' ~ (form.prixUnitaire.vars.errors|length > 0 ? ' border-red-500' : ' border-gray-300'),
          'placeholder': '0.00',
          'required': 'required',
          'min': '0.01',
          'step': '0.01',
          'pattern': '[0-9]+([\\.,][0-9]{1,2})?'
        }}) }}
      </div>
      {% if form.prixUnitaire.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.prixUnitaire.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
      <div class="text-xs text-gray-500 mt-1">
        Format : 0.00 (deux décimales maximum)
      </div>
    </div>
    
    {# Calcul du prix total (lecture seule) #}
    <div id="total-price-container" class="hidden">
      <div class="p-3 bg-gray-50 border border-gray-200 rounded-lg">
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-700">Prix total :</span>
          <span id="total-price" class="text-lg font-bold text-paw-orange">$0.00</span>
        </div>
      </div>
    </div>
  </div>
  
  <div class="flex gap-3 mt-4 pt-4 border-t border-gray-200">
    <button type="submit" class="px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange transition-colors duration-200">
      {{ submit_label|default('Enregistrer') }}
    </button>
    <button type="button" class="px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 transition-colors duration-200 js-modal-cancel">
      Annuler
    </button>
  </div>
  
  {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('ligne-commande-form');
  const quantiteInput = document.querySelector('[name$="[quantite]"]');
  const prixInput = document.querySelector('[name$="[prixUnitaire]"]');
  const totalContainer = document.getElementById('total-price-container');
  const totalElement = document.getElementById('total-price');
  
  // Calculer et afficher le prix total
  function calculateTotal() {
    const quantite = parseFloat(quantiteInput.value) || 0;
    const prix = parseFloat(prixInput.value) || 0;
    const total = quantite * prix;
    
    if (total > 0) {
      totalElement.textContent = '$' + total.toFixed(2);
      totalContainer.classList.remove('hidden');
    } else {
      totalContainer.classList.add('hidden');
    }
  }
  
  // Écouter les changements
  if (quantiteInput && prixInput) {
    quantiteInput.addEventListener('input', calculateTotal);
    quantiteInput.addEventListener('change', calculateTotal);
    prixInput.addEventListener('input', calculateTotal);
    prixInput.addEventListener('change', calculateTotal);
    
    // Calcul initial
    calculateTotal();
  }
  
  // Validation en temps réel
  if (form) {
    const requiredInputs = form.querySelectorAll('[required]');
    
    // Ajouter un message d'erreur personnalisé pour chaque champ
    requiredInputs.forEach(input => {
      input.addEventListener('invalid', function(e) {
        e.preventDefault();
        showFieldError(this, 'Ce champ est obligatoire');
      });
      
      input.addEventListener('input', function() {
        clearFieldError(this);
      });
      
      input.addEventListener('blur', function() {
        validateField(this);
      });
    });
    
    // Validation spécifique pour la quantité
    if (quantiteInput) {
      quantiteInput.addEventListener('blur', function() {
        const value = parseInt(this.value);
        if (value < 1) {
          showFieldError(this, 'La quantité doit être au moins 1');
        } else if (value > 999) {
          showFieldError(this, 'La quantité ne peut pas dépasser 999');
        }
      });
    }
    
    // Validation spécifique pour le prix
    if (prixInput) {
      prixInput.addEventListener('blur', function() {
        const value = parseFloat(this.value);
        if (value < 0.01) {
          showFieldError(this, 'Le prix doit être au moins $0.01');
        } else if (!/^\d+(\.\d{1,2})?$/.test(this.value)) {
          showFieldError(this, 'Format invalide. Utilisez 0.00 (deux décimales maximum)');
        }
      });
    }
    
    // Validation au submit
    form.addEventListener('submit', function(e) {
      if (!validateForm()) {
        e.preventDefault();
        showFirstError();
      }
    });
  }
  
  // Fonction de validation de champ
  function validateField(field) {
    clearFieldError(field);
    
    // Validation du champ requis
    if (field.hasAttribute('required') && !field.value.trim()) {
      showFieldError(field, 'Ce champ est obligatoire');
      return false;
    }
    
    // Validation des nombres
    if (field.type === 'number' || field.hasAttribute('pattern')) {
      const value = field.value.trim();
      if (value) {
        const numValue = parseFloat(value);
        
        // Vérifier si c'est un nombre valide
        if (isNaN(numValue)) {
          showFieldError(field, 'Veuillez entrer un nombre valide');
          return false;
        }
        
        // Vérifier les min/max
        if (field.hasAttribute('min')) {
          const min = parseFloat(field.getAttribute('min'));
          if (numValue < min) {
            showFieldError(field, `La valeur minimale est ${min}`);
            return false;
          }
        }
        
        if (field.hasAttribute('max')) {
          const max = parseFloat(field.getAttribute('max'));
          if (numValue > max) {
            showFieldError(field, `La valeur maximale est ${max}`);
            return false;
          }
        }
        
        // Validation spécifique pour le prix (2 décimales)
        if (field.name.includes('prixUnitaire')) {
          if (!/^\d+(\.\d{1,2})?$/.test(value)) {
            showFieldError(field, 'Format invalide. Utilisez 0.00 (deux décimales maximum)');
            return false;
          }
        }
      }
    }
    
    return true;
  }
  
  // Afficher une erreur sur un champ
  function showFieldError(field, message) {
    field.classList.remove('border-gray-300');
    field.classList.add('border-red-500');
    
    // Créer ou mettre à jour le message d'erreur
    let errorDiv = field.parentNode.querySelector('.field-error');
    if (!errorDiv) {
      errorDiv = document.createElement('div');
      errorDiv.className = 'text-red-600 text-sm mt-1 field-error';
      field.parentNode.appendChild(errorDiv);
    }
    
    errorDiv.innerHTML = `
      <div class="flex items-center">
        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        ${message}
      </div>
    `;
  }
  
  // Effacer l'erreur d'un champ
  function clearFieldError(field) {
    field.classList.remove('border-red-500');
    field.classList.add('border-gray-300');
    
    const errorDiv = field.parentNode.querySelector('.field-error');
    if (errorDiv) {
      errorDiv.remove();
    }
  }
  
  // Valider tout le formulaire
  function validateForm() {
    let isValid = true;
    const requiredInputs = form.querySelectorAll('[required]');
    
    requiredInputs.forEach(input => {
      if (!validateField(input)) {
        isValid = false;
      }
    });
    
    return isValid;
  }
  
  // Afficher la première erreur
  function showFirstError() {
    const firstErrorField = form.querySelector('.border-red-500');
    if (firstErrorField) {
      firstErrorField.scrollIntoView({ behavior: 'smooth', block: 'center' });
      firstErrorField.focus();
    } else {
      // S'il n'y a pas d'erreur visuelle, chercher le premier champ invalide
      const firstInvalid = form.querySelector(':invalid');
      if (firstInvalid) {
        firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
        firstInvalid.focus();
      }
    }
  }
  
  // Initialiser les champs avec des valeurs par défaut s'ils sont vides
  if (quantiteInput && !quantiteInput.value) {
    quantiteInput.value = '1';
  }
  
  if (prixInput && !prixInput.value) {
    prixInput.value = '0.00';
  }
});
</script>