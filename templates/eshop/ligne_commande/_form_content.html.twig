{# templates/eshop/ligne_commande/_form_content.html.twig #}
<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ page_title }}</h1>
  
  {{ form_start(form, {
    'attr': {
      'class': 'space-y-6',
      'id': 'ligne-commande-form'
    }
  }) }}
  
  {# Champ PRODUIT #}
  <div>
    {% set produit_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'required': 'required'} %}
    {% if not form.produit.vars.valid %}{% set produit_attr = produit_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.produit, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.produit, {'attr': produit_attr, 'errors': false}) }}
    {{ form_errors(form.produit, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ COMMANDE #}
  <div>
    {% set commande_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'required': 'required'} %}
    {% if not form.commande.vars.valid %}{% set commande_attr = commande_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.commande, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.commande, {'attr': commande_attr, 'errors': false}) }}
    {{ form_errors(form.commande, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ QUANTITE #}
  <div>
    {% set quantite_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '1', 'min': '1', 'max': '999', 'required': 'required'} %}
    {% if not form.quantite.vars.valid %}{% set quantite_attr = quantite_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.quantite, {'attr': quantite_attr, 'errors': false}) }}
    {{ form_errors(form.quantite, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
    <p class="text-xs text-gray-500 mt-1">Minimum: 1, Maximum: 999</p>
  </div>
    
  {# Champ PRIX UNITAIRE #}
  <div>
    {% set prixUnitaire_attr = {'class': 'w-full pl-8 pr-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0.00', 'min': '0.01', 'step': '0.01', 'required': 'required'} %}
    {% if not form.prixUnitaire.vars.valid %}{% set prixUnitaire_attr = prixUnitaire_attr|merge({'class': 'w-full pl-8 pr-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.prixUnitaire, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    <div class="relative">
      <span class="absolute left-3 top-3 text-gray-500">$</span>
      {{ form_widget(form.prixUnitaire, {'attr': prixUnitaire_attr, 'errors': false}) }}
    </div>
    {{ form_errors(form.prixUnitaire, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
  
  {# Calcul du prix total (lecture seule) #}
  <div id="total-price-container" class="hidden">
    <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-700">Total Price:</span>
        <span id="total-price" class="text-lg font-bold text-paw-orange">$0.00</span>
      </div>
    </div>
  </div>
  
  <div class="flex gap-4 pt-6 border-t border-gray-200">
    <button type="submit" class="px-6 py-3 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange transition-colors duration-200">
      {{ submit_label|default('Save') }}
    </button>
    <a href="{{ path('app_eshop_ligne_commande_index') }}" class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 transition-colors duration-200">
      Cancel
    </a>
  </div>
  
  {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const quantiteInput = document.querySelector('[name$="[quantite]"]');
  const prixInput = document.querySelector('[name$="[prixUnitaire]"]');
  const totalContainer = document.getElementById('total-price-container');
  const totalElement = document.getElementById('total-price');
  
  // Calculate and display total price
  function calculateTotal() {
    const quantite = parseFloat(quantiteInput?.value) || 0;
    const prix = parseFloat(prixInput?.value) || 0;
    const total = quantite * prix;
    
    if (total > 0) {
      totalElement.textContent = '$' + total.toFixed(2);
      totalContainer.classList.remove('hidden');
    } else {
      totalContainer.classList.add('hidden');
    }
  }
  
  // Listen for changes
  if (quantiteInput && prixInput) {
    quantiteInput.addEventListener('input', calculateTotal);
    quantiteInput.addEventListener('change', calculateTotal);
    prixInput.addEventListener('input', calculateTotal);
    prixInput.addEventListener('change', calculateTotal);
    
    // Initial calculation
    calculateTotal();
  }
  
  // Set default values
  if (quantiteInput && !quantiteInput.value) {
    quantiteInput.value = '1';
  }
  
  if (prixInput && !prixInput.value) {
    prixInput.value = '0.00';
  }
});
</script>
