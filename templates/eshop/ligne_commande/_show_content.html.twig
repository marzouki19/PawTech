<div class="space-y-4">
  <div class="flex justify-between items-center">
    <h1 class="text-xl font-bold text-gray-800">{{ page_title }}</h1>
    <div class="flex gap-2">
      <a href="{{ path('app_eshop_ligne_commande_edit', { id: ligne.id }) }}" class="px-4 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover js-modal-link">Modify</a>
      <a href="#" class="px-4 py-2 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 js-modal-cancel">Back</a>
    </div>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div><dt class="text-sm text-gray-500">ID</dt><dd class="font-medium">{{ ligne.id }}</dd></div>
      <div><dt class="text-sm text-gray-500">Product</dt><dd class="font-medium">{{ ligne.produit ? ligne.produit.nom : '-' }}</dd></div>
      <div><dt class="text-sm text-gray-500">Order</dt><dd class="font-medium">{% if ligne.commande %}#{{ ligne.commande.id }}{% else %}-{% endif %}</dd></div>
      <div><dt class="text-sm text-gray-500">Quantity</dt><dd class="font-medium">{{ ligne.quantite }}</dd></div>
      <div><dt class="text-sm text-gray-500">Unit price</dt><dd class="font-medium">{{ ligne.prixUnitaire|number_format(2, ',', ' ') }} TND</dd></div>
      <div><dt class="text-sm text-gray-500">Subtotal</dt><dd class="font-medium">{{ ligne.calculerSousTotal()|number_format(2, ',', ' ') }} TND</dd></div>
    </dl>
  </div>
</div>