{# templates/eshop/produit/_form_content.html.twig #}
<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ page_title }}</h1>
  
  {{ form_start(form, {
    'attr': {
      'enctype': 'multipart/form-data',
      'class': 'space-y-6',
      'id': 'product-form'
    }
  }) }}
  
  {# Champ NOM #}
  <div>
    {% set nom_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': 'Enter product name', 'required': 'required', 'minlength': '2'} %}
    {% if not form.nom.vars.valid %}{% set nom_attr = nom_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.nom, {'attr': nom_attr, 'errors': false}) }}
    {{ form_errors(form.nom, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ PRIX #}
  <div>
    {% set prix_attr = {'class': 'w-full pl-8 pr-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0.00', 'required': 'required', 'min': '0.01', 'step': '0.01'} %}
    {% if not form.prix.vars.valid %}{% set prix_attr = prix_attr|merge({'class': 'w-full pl-8 pr-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.prix, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    <div class="relative">
      <span class="absolute left-3 top-3 text-gray-500">$</span>
      {{ form_widget(form.prix, {'attr': prix_attr, 'errors': false}) }}
    </div>
    {{ form_errors(form.prix, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ CATEGORIE #}
  <div>
    {% set categorie_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'required': 'required'} %}
    {% if not form.categorie.vars.valid %}{% set categorie_attr = categorie_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.categorie, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.categorie, {'attr': categorie_attr, 'errors': false}) }}
    {{ form_errors(form.categorie, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ IMAGE #}
  <div>
    {% set image_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'accept': 'image/*', 'onchange': 'validateImage(this)'} %}
    {% if not form.image.vars.valid %}{% set image_attr = image_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.image, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    
    {# Afficher l'image actuelle si en mode édition #}
    {% if form.vars.data and form.vars.data.image %}
      <div class="mb-4 p-4 bg-gray-50 rounded-lg">
        <div class="text-sm font-medium text-gray-700 mb-2">Current image:</div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <img src="{{ asset('uploads/images/' ~ form.vars.data.image) }}" 
               alt="Product image" 
               class="h-32 w-32 object-cover rounded-lg border border-gray-300">
          <div class="flex-1">
            <div class="text-sm text-gray-600 mb-2">
              <span class="font-medium">File name:</span> {{ form.vars.data.image }}
            </div>
            <div class="text-xs text-gray-500">
              Select a new image to replace it
            </div>
          </div>
        </div>
      </div>
    {% endif %}
    
    <div class="space-y-2">
      <div class="relative">
        {{ form_widget(form.image, {'attr': image_attr, 'errors': false}) }}
      </div>
      
      <div class="text-xs text-gray-500">
        Accepted formats: JPG, PNG, GIF, WEBP (max. 5MB)
      </div>
      
      {# Aperçu de l'image sélectionnée #}
      <div id="image-preview-container" class="hidden mt-4">
        <div class="text-sm font-medium text-gray-700 mb-2">Preview:</div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <img id="image-preview" class="h-32 w-32 object-cover rounded-lg border border-gray-300">
          <div>
            <div id="image-filename" class="text-sm text-gray-600 mb-1"></div>
            <div id="image-size" class="text-xs text-gray-500"></div>
            <div id="image-error" class="text-xs text-red-600 mt-1 hidden"></div>
          </div>
        </div>
      </div>
    </div>
    {{ form_errors(form.image, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ QUANTITE #}
  <div>
    {% set quantite_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0', 'required': 'required', 'min': '0'} %}
    {% if not form.quantite.vars.valid %}{% set quantite_attr = quantite_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.quantite, {'attr': quantite_attr, 'errors': false}) }}
    {{ form_errors(form.quantite, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
  </div>
    
  {# Champ SEUIL ALERT #}
  <div>
    {% set seuilAlert_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0', 'required': 'required', 'min': '0'} %}
    {% if not form.seuilAlert.vars.valid %}{% set seuilAlert_attr = seuilAlert_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-paw-orange bg-gray-50 hover:bg-white'}) %}{% endif %}
    {{ form_label(form.seuilAlert, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.seuilAlert, {'attr': seuilAlert_attr, 'errors': false}) }}
    {{ form_errors(form.seuilAlert, {'attr': {'class': 'text-red-500 text-sm mt-1 font-medium'}}) }}
    <div class="text-xs text-gray-500 mt-1">
      An alert will be triggered when the quantity falls below this threshold
    </div>
  </div>
  
  <div class="flex gap-4 pt-6 border-t border-gray-200">
    <button type="submit" class="px-6 py-3 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange transition-colors duration-200">
      {{ submit_label|default('Save') }}
    </button>
    <a href="{{ path('app_eshop_produit_index') }}" class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 transition-colors duration-200">
      Cancel
    </a>
  </div>
  
  {{ form_end(form) }}
</div>

{# Script pour la validation et l'aperçu de l'image #}
<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('product-form');
  
  // Validation de l'image
  window.validateImage = function(input) {
    const errorElement = document.getElementById('image-error');
    if (errorElement) {
      errorElement.classList.add('hidden');
    }
    
    if (input.files && input.files[0]) {
      const file = input.files[0];
      const fileName = file.name;
      const fileSize = file.size;
      const fileSizeMB = (fileSize / 1024 / 1024).toFixed(2);
      const maxSize = 5 * 1024 * 1024; // 5MB
      
      // Validation de la taille du fichier
      if (fileSize > maxSize) {
        if (errorElement) {
          errorElement.textContent = `File is too large (${fileSizeMB} MB). Maximum size is 5 MB.`;
          errorElement.classList.remove('hidden');
        }
        input.value = '';
        hidePreview();
        return false;
      }
      
      // Validation du type de fichier
      const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
      if (!validTypes.includes(file.type)) {
        if (errorElement) {
          errorElement.textContent = 'Unsupported file format. Please select an image (JPG, PNG, GIF, WEBP).';
          errorElement.classList.remove('hidden');
        }
        input.value = '';
        hidePreview();
        return false;
      }
      
      // Mettre à jour les informations du fichier
      const filenameElement = document.getElementById('image-filename');
      const sizeElement = document.getElementById('image-size');
      
      if (filenameElement) {
        filenameElement.textContent = fileName;
      }
      if (sizeElement) {
        sizeElement.textContent = `${fileSizeMB} MB`;
      }
      
      // Afficher l'aperçu de l'image
      const reader = new FileReader();
      reader.onload = function(e) {
        const previewContainer = document.getElementById('image-preview-container');
        const previewImage = document.getElementById('image-preview');
        
        if (previewImage) {
          previewImage.src = e.target.result;
        }
        
        if (previewContainer) {
          previewContainer.classList.remove('hidden');
        }
      };
      reader.readAsDataURL(file);
      return true;
    }
    hidePreview();
    return false;
  };
  
  // Cacher l'aperçu
  function hidePreview() {
    const previewContainer = document.getElementById('image-preview-container');
    if (previewContainer) {
      previewContainer.classList.add('hidden');
    }
  }
});
</script>
