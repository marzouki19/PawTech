{# templates/eshop/produit/_form_content.html.twig #}
<div class="max-w-xl">
  <h1 class="text-xl font-bold text-gray-800 mb-4">{{ page_title }}</h1>
  
  {# Afficher les erreurs globales du formulaire #}
  {% if form.vars.errors|length > 0 %}
    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
      <div class="text-red-800 font-medium">Please correct the following errors:</div>
      {{ form_errors(form) }}
    </div>
  {% endif %}
  
  {{ form_start(form, {
    'attr': {
      'id': 'entity-modal-form',
      'novalidate': 'novalidate',
      'enctype': 'multipart/form-data'
    }, 
    'action': form_action|default(null)
  }) }}
  
  <div class="space-y-4">
    {# Champ NOM #}
    <div>
      {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.nom, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange ' ~ (form.nom.vars.errors|length > 0 ? 'border-red-500' : 'border-gray-300'),
        'placeholder': 'Enter product name'
      }}) }}
      {% if form.nom.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.nom.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ PRIX #}
    <div>
      {{ form_label(form.prix, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.prix, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange ' ~ (form.prix.vars.errors|length > 0 ? 'border-red-500' : 'border-gray-300'),
        'placeholder': '0.00'
      }}) }}
      {% if form.prix.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.prix.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ CATEGORIE #}
    <div>
      {{ form_label(form.categorie, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.categorie, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange ' ~ (form.categorie.vars.errors|length > 0 ? 'border-red-500' : 'border-gray-300')
      }}) }}
      {% if form.categorie.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.categorie.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ IMAGE - Version simplifiée avec input file visible #}
    <div>
      {{ form_label(form.image, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      
      {# Afficher l'image actuelle si en mode édition #}
      {% if form.vars.data and form.vars.data.image %}
        <div class="mb-3">
          <div class="text-sm text-gray-600 mb-1">Image actuelle :</div>
          <div class="flex items-center gap-3">
            <img src="{{ asset('uploads/images/' ~ form.vars.data.image) }}" 
                 alt="Image du produit" 
                 class="h-20 w-20 object-cover rounded border border-gray-300">
            <div>
              <div class="text-xs text-gray-500">
                {{ form.vars.data.image }}
              </div>
              <div class="mt-1 text-xs text-gray-400">
                Sélectionnez une nouvelle image pour la remplacer
              </div>
            </div>
          </div>
        </div>
      {% endif %}
      
      {# Zone de saisie du fichier - SIMPLE ET DIRECTE #}
      <div class="relative">
        {# Champ de fichier VISIBLE #}
        {{ form_widget(form.image, {'attr': {
          'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange ' ~ (form.image.vars.errors|length > 0 ? 'border-red-500' : 'border-gray-300'),
          'accept': 'image/*',
          'onchange': 'previewImage(this)'
        }}) }}
      </div>
      
      {# Aperçu de l'image sélectionnée #}
      <div id="image-preview-container" class="mt-2 hidden">
        <div class="text-sm text-gray-600 mb-1">Aperçu :</div>
        <img id="image-preview" class="h-24 w-24 object-cover rounded border border-gray-300">
        <div id="image-filename" class="text-xs text-gray-500 mt-1"></div>
      </div>
      
      {% if form.image.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.image.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ QUANTITE #}
    <div>
      {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.quantite, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange ' ~ (form.quantite.vars.errors|length > 0 ? 'border-red-500' : 'border-gray-300'),
        'placeholder': '0'
      }}) }}
      {% if form.quantite.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.quantite.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {# Champ SEUIL ALERT #}
    <div>
      {{ form_label(form.seuilAlert, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
      {{ form_widget(form.seuilAlert, {'attr': {
        'class': 'w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange ' ~ (form.seuilAlert.vars.errors|length > 0 ? 'border-red-500' : 'border-gray-300'),
        'placeholder': '0'
      }}) }}
      {% if form.seuilAlert.vars.errors|length > 0 %}
        <div class="text-red-600 text-sm mt-1">
          {% for error in form.seuilAlert.vars.errors %}
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              {{ error.message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
  
  <div class="flex gap-3 mt-4">
    <button type="submit" class="px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-paw-orange">
      {{ submit_label|default('Save') }}
    </button>
    <a href="#" class="px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 js-modal-cancel">Cancel</a>
  </div>
  
  {{ form_end(form) }}
</div>

{# Script pour l'aperçu de l'image #}
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Fonction pour afficher l'aperçu de l'image
  window.previewImage = function(input) {
    if (input.files && input.files[0]) {
      const fileName = input.files[0].name;
      const fileSize = (input.files[0].size / 1024 / 1024).toFixed(2); // MB
      
      // Mettre à jour le nom du fichier
      const filenameElement = document.getElementById('image-filename');
      if (filenameElement) {
        filenameElement.textContent = `${fileName} (${fileSize} MB)`;
      }
      
      // Afficher l'aperçu de l'image
      const reader = new FileReader();
      reader.onload = function(e) {
        const previewContainer = document.getElementById('image-preview-container');
        const previewImage = document.getElementById('image-preview');
        
        if (previewImage) {
          previewImage.src = e.target.result;
        }
        
        if (previewContainer) {
          previewContainer.classList.remove('hidden');
        }
      };
      reader.readAsDataURL(input.files[0]);
    }
  };
});
</script>