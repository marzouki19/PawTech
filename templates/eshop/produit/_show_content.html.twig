{# templates/eshop/produit/_show_content.html.twig #}
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-xl font-bold text-gray-800">{{ page_title }}</h1>
    <div class="flex gap-2">
      <a href="{{ path('app_eshop_produit_edit', { id: produit.id }) }}" 
         class="px-4 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover transition-colors js-modal-link">
        Modify
      </a>
      <a href="#" 
         class="px-4 py-2 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors js-modal-cancel">
        Back
      </a>
    </div>
  </div>
  
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6">
      <!-- Colonne de gauche : Image du produit -->
      <div class="space-y-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-800 mb-2">Product Image</h2>
          {% if produit.image %}
            {# Vérifier si c'est une URL externe ou un fichier local #}
            {% if produit.image matches '#^https?://#' %}
              {# URL externe (Imgur, etc.) #}
              <div class="relative group">
                <img src="{{ produit.image }}" 
                     alt="{{ produit.nom }}" 
                     class="w-full h-64 object-contain rounded-lg border border-gray-300 p-2 bg-gray-50"
                     id="product-main-image">
                <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 rounded-lg transition-opacity cursor-pointer"
                     onclick="openImageModal('{{ produit.image }}', '{{ produit.nom }}')">
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                    <span class="bg-black bg-opacity-75 text-white px-3 py-1 rounded text-sm">
                      Click to enlarge
                    </span>
                  </div>
                </div>
                <div class="mt-2 text-xs text-gray-500 text-center">
                  External image URL
                </div>
              </div>
            {% else %}
              {# Fichier local #}
              <div class="relative group">
                <img src="{{ asset('uploads/images/' ~ produit.image) }}" 
                     alt="{{ produit.nom }}" 
                     class="w-full h-64 object-contain rounded-lg border border-gray-300 p-2 bg-gray-50"
                     id="product-main-image">
                <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 rounded-lg transition-opacity cursor-pointer"
                     onclick="openImageModal('{{ asset('uploads/images/' ~ produit.image) }}', '{{ produit.nom }}')">
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                    <span class="bg-black bg-opacity-75 text-white px-3 py-1 rounded text-sm">
                      Click to enlarge
                    </span>
                  </div>
                </div>
                <div class="mt-2 text-xs text-gray-500 text-center">
                  {{ produit.image }}
                </div>
              </div>
            {% endif %}
          {% else %}
            <div class="flex flex-col items-center justify-center h-64 border-2 border-dashed border-gray-300 rounded-lg bg-gray-50">
              <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="mt-2 text-sm text-gray-500">No image available</span>
            </div>
          {% endif %}
        </div>
      </div>
      
      <!-- Colonne de droite : Informations du produit -->
      <div class="space-y-6">
        <div>
          <h2 class="text-lg font-semibold text-gray-800 mb-4">Product Details</h2>
          <dl class="grid grid-cols-1 gap-4">
            <div class="bg-gray-50 p-4 rounded-lg">
              <dt class="text-sm text-gray-500">ID</dt>
              <dd class="font-bold text-lg text-gray-800">{{ produit.id }}</dd>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <dt class="text-sm text-gray-500">Name</dt>
              <dd class="font-bold text-lg text-gray-800">{{ produit.nom }}</dd>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <dt class="text-sm text-gray-500">Price</dt>
              <dd class="font-bold text-lg text-green-600">{{ produit.prix|number_format(2, ',', ' ') }} TND</dd>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <dt class="text-sm text-gray-500">Category</dt>
              <dd class="font-medium">
                {% if produit.categorie %}
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                    {{ produit.categorie.nom }}
                  </span>
                {% else %}
                  <span class="text-gray-500">-</span>
                {% endif %}
              </dd>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <dt class="text-sm text-gray-500">Stock Information</dt>
              <dd>
                <div class="space-y-3">
                  <div class="flex items-center justify-between">
                    <span class="font-medium">Current Stock:</span>
                    <span class="text-lg font-bold {% if produit.quantite > 10 %}text-green-600{% elseif produit.quantite > 0 %}text-yellow-600{% else %}text-red-600{% endif %}">
                      {{ produit.quantite ?? '0' }} units
                    </span>
                  </div>
                  
                  <div class="flex items-center justify-between">
                    <span class="font-medium">Alert Threshold:</span>
                    <span class="text-lg font-medium text-gray-700">
                      {{ produit.seuilAlert ?? 'Not set' }}
                    </span>
                  </div>
                  
                  {% if produit.seuilAlert and produit.quantite <= produit.seuilAlert %}
                    <div class="mt-3 p-3 bg-yellow-50 border border-yellow-200 rounded-lg">
                      <div class="flex items-center">
                        <svg class="w-5 h-5 text-yellow-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                        </svg>
                        <span class="font-medium text-yellow-800">Low Stock Alert</span>
                      </div>
                      <p class="text-sm text-yellow-700 mt-1">
                        Quantity is at or below the alert threshold
                      </p>
                    </div>
                  {% elseif produit.quantite > 10 %}
                    <div class="mt-3 p-3 bg-green-50 border border-green-200 rounded-lg">
                      <div class="flex items-center">
                        <svg class="w-5 h-5 text-green-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        <span class="font-medium text-green-800">Good Stock Level</span>
                      </div>
                      <p class="text-sm text-green-700 mt-1">
                        Stock is above the alert threshold
                      </p>
                    </div>
                  {% endif %}
                </div>
              </dd>
            </div>
          </dl>
        </div>
        
        <!-- Statistiques supplémentaires -->
        <div class="bg-gray-50 p-4 rounded-lg">
          <h3 class="text-md font-semibold text-gray-700 mb-3">Product Status</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="text-center p-3 bg-white rounded-lg border border-gray-200">
              <div class="text-2xl font-bold text-gray-800">{{ produit.quantite ?? '0' }}</div>
              <div class="text-xs text-gray-500">Available Units</div>
            </div>
            <div class="text-center p-3 bg-white rounded-lg border border-gray-200">
              <div class="text-2xl font-bold text-paw-orange">{{ produit.prix|number_format(2, ',', ' ') }}</div>
              <div class="text-xs text-gray-500">Price per Unit</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal pour l'image agrandie -->
<div id="image-modal" class="fixed inset-0 bg-black bg-opacity-75 hidden items-center justify-center z-50 p-4">
  <div class="relative max-w-4xl max-h-full">
    <button onclick="closeImageModal()" 
            class="absolute top-4 right-4 text-white bg-black bg-opacity-50 rounded-full p-2 hover:bg-opacity-75 transition-colors z-10">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <div class="bg-white rounded-lg overflow-hidden">
      <div class="p-8">
        <img id="modal-image" src="" alt="" class="max-w-full max-h-[70vh] object-contain mx-auto">
        <div class="mt-4 text-center">
          <div id="modal-image-title" class="text-lg font-medium text-gray-800"></div>
          <div class="text-sm text-gray-500 mt-1">Product image</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Animation pour le modal */
#image-modal {
  animation: fadeIn 0.2s ease;
}

#image-modal img {
  animation: zoomIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes zoomIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* Style pour les images */
img {
  transition: transform 0.2s ease;
}

img:hover {
  cursor: pointer;
}
</style>

<script>
// Fonctions pour gérer le modal d'image
function openImageModal(imageUrl, productName) {
  const modal = document.getElementById('image-modal');
  const modalImage = document.getElementById('modal-image');
  const modalTitle = document.getElementById('modal-image-title');
  
  modalImage.src = imageUrl;
  modalImage.alt = productName;
  modalTitle.textContent = productName;
  
  modal.classList.remove('hidden');
  modal.classList.add('flex');
  
  // Empêcher le défilement de la page
  document.body.style.overflow = 'hidden';
}

function closeImageModal() {
  const modal = document.getElementById('image-modal');
  modal.classList.add('hidden');
  modal.classList.remove('flex');
  
  // Rétablir le défilement
  document.body.style.overflow = '';
}

// Fermer le modal avec la touche Échap
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    closeImageModal();
  }
});

// Fermer le modal en cliquant à l'extérieur
document.getElementById('image-modal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeImageModal();
  }
});

// Focus automatique sur le bouton de fermeture quand le modal s'ouvre
document.getElementById('image-modal').addEventListener('transitionend', function() {
  if (!this.classList.contains('hidden')) {
    this.querySelector('button').focus();
  }
});
</script>