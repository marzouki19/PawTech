{# templates/eshop/produit/index.html.twig #}
{% extends 'layout.html.twig' %}

{% block title %}Eshop - Produits | PawTech{% endblock %}

{% block main %}
<div data-controller="modal" class="space-y-4">
  <!-- Barre de recherche et filtres -->
  <div class="flex flex-wrap items-center gap-4 mb-4">
    <!-- Barre de recherche -->
    <form method="get" action="{{ path('app_eshop_produit_index') }}" class="relative flex-1 min-w-[200px]">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </span>
      <input 
        name="search" 
        type="search" 
        value="{{ app.request.query.get('search', '') }}" 
        placeholder="Search products by name..." 
        class="w-full pl-10 pr-10 py-2 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none"
        onkeydown="if(event.key === 'Enter') this.form.submit()">
      
      {% if app.request.query.get('search') %}
        <a href="{{ path('app_eshop_produit_index', app.request.query.all|filter((v, k) => k != 'search')) }}" 
           class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
           title="Clear search">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </a>
      {% endif %}
      
      <!-- Champs cachés pour conserver les autres filtres -->
      {% if app.request.query.get('category') %}
        <input type="hidden" name="category" value="{{ app.request.query.get('category') }}">
      {% endif %}
      {% if app.request.query.get('stock_status') %}
        <input type="hidden" name="stock_status" value="{{ app.request.query.get('stock_status') }}">
      {% endif %}
      {% if app.request.query.get('price_range') %}
        <input type="hidden" name="price_range" value="{{ app.request.query.get('price_range') }}">
      {% endif %}
      {% if app.request.query.get('sort') %}
        <input type="hidden" name="sort" value="{{ app.request.query.get('sort') }}">
      {% endif %}
    </form>
    
    <!-- Bouton de filtrage par catégorie -->
    <div class="relative">
      <button type="button" 
              class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50"
              onclick="toggleCategoryFilter()">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
        </svg>
        Filter by Category
        {% if app.request.query.get('category') %}
          <span class="ml-1 px-2 py-0.5 bg-paw-orange text-white text-xs rounded-full">
            {% set selected_category = categories_for_filter|filter(c => c.id == app.request.query.get('category'))|first %}
            {{ selected_category ? selected_category.nom|slice(0, 10) : 'Selected' }}
          </span>
        {% endif %}
      </button>
      
      <!-- Menu déroulant des catégories -->
      <div id="category-filter-dropdown" 
           class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-10 hidden">
        <div class="p-2">
          <div class="text-xs font-semibold text-gray-500 px-2 py-1">Filter by category</div>
          <div class="space-y-1 max-h-60 overflow-y-auto">
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({category: null})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if not app.request.query.get('category') %}bg-blue-50 text-blue-700{% endif %}">
              <span>All categories</span>
              {% if not app.request.query.get('category') %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            {% for category in categories_for_filter %}
              <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({category: category.id})) }}"
                 class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('category') == category.id %}bg-blue-50 text-blue-700{% endif %}">
                <span>{{ category.nom }}</span>
                {% if app.request.query.get('category') == category.id %}
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                {% endif %}
              </a>
            {% endfor %}
            {% if app.request.query.get('category') %}
              <div class="border-t border-gray-100 mt-1 pt-1">
                <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({category: null})) }}"
                   class="flex items-center px-3 py-2 rounded hover:bg-gray-100 text-red-600">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  Clear filter
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bouton de filtrage par statut de stock -->
    <div class="relative">
      <button type="button" 
              class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50"
              onclick="toggleStockFilter()">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
        </svg>
        Filter by Stock
        {% if app.request.query.get('stock_status') %}
          <span class="ml-1 px-2 py-0.5 bg-paw-orange text-white text-xs rounded-full">
            {% if app.request.query.get('stock_status') == 'in_stock' %}In Stock{% endif %}
            {% if app.request.query.get('stock_status') == 'low_stock' %}Low Stock{% endif %}
            {% if app.request.query.get('stock_status') == 'out_of_stock' %}Out of Stock{% endif %}
          </span>
        {% endif %}
      </button>
      
      <!-- Menu déroulant des statuts de stock -->
      <div id="stock-filter-dropdown" 
           class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-10 hidden">
        <div class="p-2">
          <div class="text-xs font-semibold text-gray-500 px-2 py-1">Filter by stock status</div>
          <div class="space-y-1">
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({stock_status: null})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if not app.request.query.get('stock_status') %}bg-blue-50 text-blue-700{% endif %}">
              <span>All status</span>
              {% if not app.request.query.get('stock_status') %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({stock_status: 'in_stock'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('stock_status') == 'in_stock' %}bg-blue-50 text-blue-700{% endif %}">
              <span>In Stock (> 10)</span>
              {% if app.request.query.get('stock_status') == 'in_stock' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({stock_status: 'low_stock'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('stock_status') == 'low_stock' %}bg-blue-50 text-blue-700{% endif %}">
              <span>Low Stock (1-10)</span>
              {% if app.request.query.get('stock_status') == 'low_stock' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({stock_status: 'out_of_stock'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('stock_status') == 'out_of_stock' %}bg-blue-50 text-blue-700{% endif %}">
              <span>Out of Stock</span>
              {% if app.request.query.get('stock_status') == 'out_of_stock' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            {% if app.request.query.get('stock_status') %}
              <div class="border-t border-gray-100 mt-1 pt-1">
                <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({stock_status: null})) }}"
                   class="flex items-center px-3 py-2 rounded hover:bg-gray-100 text-red-600">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  Clear filter
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bouton de filtrage par prix -->
    <div class="relative">
      <button type="button" 
              class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50"
              onclick="togglePriceFilter()">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
        </svg>
        Filter by Price
        {% if app.request.query.get('price_range') %}
          <span class="ml-1 px-2 py-0.5 bg-paw-orange text-white text-xs rounded-full">
            {% if app.request.query.get('price_range') == '0-50' %}0-50 TND{% endif %}
            {% if app.request.query.get('price_range') == '50-100' %}50-100 TND{% endif %}
            {% if app.request.query.get('price_range') == '100-200' %}100-200 TND{% endif %}
            {% if app.request.query.get('price_range') == '200+' %}200+ TND{% endif %}
          </span>
        {% endif %}
      </button>
      
      <!-- Menu déroulant des prix -->
      <div id="price-filter-dropdown" 
           class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-10 hidden">
        <div class="p-2">
          <div class="text-xs font-semibold text-gray-500 px-2 py-1">Filter by price range</div>
          <div class="space-y-1">
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({price_range: null})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if not app.request.query.get('price_range') %}bg-blue-50 text-blue-700{% endif %}">
              <span>All prices</span>
              {% if not app.request.query.get('price_range') %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({price_range: '0-50'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('price_range') == '0-50' %}bg-blue-50 text-blue-700{% endif %}">
              <span>0 - 50 TND</span>
              {% if app.request.query.get('price_range') == '0-50' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({price_range: '50-100'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('price_range') == '50-100' %}bg-blue-50 text-blue-700{% endif %}">
              <span>50 - 100 TND</span>
              {% if app.request.query.get('price_range') == '50-100' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({price_range: '100-200'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('price_range') == '100-200' %}bg-blue-50 text-blue-700{% endif %}">
              <span>100 - 200 TND</span>
              {% if app.request.query.get('price_range') == '100-200' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({price_range: '200+'})) }}"
               class="flex items-center justify-between px-3 py-2 rounded hover:bg-gray-100 {% if app.request.query.get('price_range') == '200+' %}bg-blue-50 text-blue-700{% endif %}">
              <span>200+ TND</span>
              {% if app.request.query.get('price_range') == '200+' %}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </a>
            {% if app.request.query.get('price_range') %}
              <div class="border-t border-gray-100 mt-1 pt-1">
                <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({price_range: null})) }}"
                   class="flex items-center px-3 py-2 rounded hover:bg-gray-100 text-red-600">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  Clear filter
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bouton Add New -->
    <a href="{{ path('app_eshop_produit_new') }}" 
       class="inline-flex items-center gap-2 px-4 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium js-modal-link" 
       data-title="New Product">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Product
    </a>
  </div>

  <!-- Indicateurs de filtres actifs -->
  {% set has_filters = app.request.query.get('search') or app.request.query.get('category') or app.request.query.get('stock_status') or app.request.query.get('price_range') %}
  
  {% if has_filters %}
    <div class="flex items-center gap-2 p-3 bg-blue-50 border border-blue-100 rounded-lg">
      <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
      </svg>
      <span class="text-sm text-blue-700">
        Active filters: 
        {% if app.request.query.get('search') %}
          <strong class="font-semibold">Search: "{{ app.request.query.get('search') }}"</strong>
          {% if app.request.query.get('category') or app.request.query.get('stock_status') or app.request.query.get('price_range') %} | {% endif %}
        {% endif %}
        {% if app.request.query.get('category') %}
          {% set selected_category = categories_for_filter|filter(c => c.id == app.request.query.get('category'))|first %}
          <strong class="font-semibold">Category: {{ selected_category ? selected_category.nom : 'Unknown' }}</strong>
          {% if app.request.query.get('stock_status') or app.request.query.get('price_range') %} | {% endif %}
        {% endif %}
        {% if app.request.query.get('stock_status') %}
          {% set stock_labels = {
            'in_stock': 'In Stock',
            'low_stock': 'Low Stock',
            'out_of_stock': 'Out of Stock'
          } %}
          <strong class="font-semibold">Stock: {{ stock_labels[app.request.query.get('stock_status')] }}</strong>
          {% if app.request.query.get('price_range') %} | {% endif %}
        {% endif %}
        {% if app.request.query.get('price_range') %}
          {% set price_labels = {
            '0-50': '0-50 TND',
            '50-100': '50-100 TND',
            '100-200': '100-200 TND',
            '200+': '200+ TND'
          } %}
          <strong class="font-semibold">Price: {{ price_labels[app.request.query.get('price_range')] }}</strong>
        {% endif %}
        {% if rows|length > 0 %}
          - Showing {{ rows|length }} of {{ total_records }} products
        {% endif %}
      </span>
      {% if has_filters %}
        <a href="{{ path('app_eshop_produit_index') }}" class="ml-auto text-sm text-blue-600 hover:text-blue-800 font-medium">
          Clear all filters
        </a>
      {% endif %}
    </div>
  {% endif %}
  
  <!-- Message si aucun résultat -->
  {% if rows|length == 0 %}
    <div class="text-center py-12 bg-white rounded-xl border border-gray-200">
      <div class="text-gray-400 text-6xl mb-4">📦</div>
      <p class="text-lg font-medium text-gray-700">No products found</p>
      <p class="mt-2 text-gray-500">
        {% if has_filters %}
          Try adjusting your search or filter criteria
        {% else %}
          No products have been created yet
        {% endif %}
      </p>
      {% if has_filters %}
        <a href="{{ path('app_eshop_produit_index') }}" class="mt-4 inline-block px-6 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover transition">
          Clear filters
        </a>
      {% else %}
        <a href="{{ path('app_eshop_produit_new') }}" 
           class="mt-4 inline-flex items-center gap-2 px-6 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover transition js-modal-link"
           data-title="New Product">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Create your first product
        </a>
      {% endif %}
    </div>
  {% else %}
    <!-- Tableau des produits avec images -->
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              {% for column in columns %}
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                  {{ column }}
                </th>
              {% endfor %}
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {% for row in rows %}
              <tr class="hover:bg-gray-50 transition-colors">
                {% for cell in row %}
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    {# Colonne Image (index 3) #}
                    {% if loop.index0 == 3 %}
                      {% if cell != '-' %}
                        <div class="flex items-center group relative">
                          <div class="flex-shrink-0">
                            <div class="relative">
                              {{ cell|raw }}
                              <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 rounded transition-opacity"></div>
                            </div>
                          </div>
                          <div class="ml-4">
                            <div class="text-sm font-medium text-gray-900">
                              Image
                            </div>
                            <div class="text-xs text-gray-500">
                              Hover to enlarge
                            </div>
                          </div>
                        </div>
                      {% else %}
                        <span class="text-gray-400">-</span>
                      {% endif %}
                    {# Colonne Stock (index 5) avec alerte #}
                    {% elseif loop.index0 == 5 %}
                      <div class="flex items-center">
                        <span>{{ cell|replace({' ⚠': ''}) }}</span>
                        {% if '⚠' in cell %}
                          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800" title="Low stock alert">
                            ⚠
                          </span>
                        {% endif %}
                      </div>
                    {# Autres colonnes #}
                    {% else %}
                      {{ cell|raw }}
                    {% endif %}
                  </td>
                {% endfor %}
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      
      <!-- Pagination -->
      {% if total_pages > 1 %}
        <div class="px-6 py-4 border-t border-gray-200">
          <div class="flex items-center justify-between">
            <div class="text-sm text-gray-700">
              Showing <span class="font-medium">{{ (page - 1) * per_page + 1 }}</span> to 
              <span class="font-medium">{{ min(page * per_page, total_records) }}</span> of 
              <span class="font-medium">{{ total_records }}</span> results
            </div>
            <div class="flex space-x-2">
              {% if page > 1 %}
                <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({page: page - 1})) }}" 
                   class="px-3 py-1 border border-gray-300 rounded text-gray-700 hover:bg-gray-50 transition-colors">
                  Previous
                </a>
              {% endif %}
              
              {% for p in range(max(1, page - 2), min(total_pages, page + 2)) %}
                <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({page: p})) }}" 
                   class="px-3 py-1 rounded transition-colors {% if p == page %}bg-paw-orange text-white{% else %}border border-gray-300 text-gray-700 hover:bg-gray-50{% endif %}">
                  {{ p }}
                </a>
              {% endfor %}
              
              {% if page < total_pages %}
                <a href="{{ path('app_eshop_produit_index', app.request.query.all|merge({page: page + 1})) }}" 
                   class="px-3 py-1 border border-gray-300 rounded text-gray-700 hover:bg-gray-50 transition-colors">
                  Next
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

<style>
/* Styles pour les images dans le tableau */
table img {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border-radius: 4px;
  object-fit: cover;
}

table img:hover {
  transform: scale(2.5);
  z-index: 50;
  box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.2), 0 10px 10px -5px rgba(0, 0, 0, 0.1);
  position: relative;
}

/* Styles pour les colonnes */
td {
  vertical-align: middle;
}

/* Style pour les alertes de stock */
.bg-yellow-100 {
  background-color: #fffbeb;
}

.text-yellow-800 {
  color: #92400e;
}

/* Effet de hover sur les lignes */
tr:hover {
  background-color: #f9fafb;
}
</style>

<script>
// Gestion des dropdowns de filtres
function toggleCategoryFilter() {
  const dropdown = document.getElementById('category-filter-dropdown');
  dropdown.classList.toggle('hidden');
}

function toggleStockFilter() {
  const dropdown = document.getElementById('stock-filter-dropdown');
  dropdown.classList.toggle('hidden');
}

function togglePriceFilter() {
  const dropdown = document.getElementById('price-filter-dropdown');
  dropdown.classList.toggle('hidden');
}

// Fermer les dropdowns si on clique ailleurs
document.addEventListener('click', function(event) {
  const categoryDropdown = document.getElementById('category-filter-dropdown');
  const categoryButton = document.querySelector('[onclick="toggleCategoryFilter()"]');
  
  const stockDropdown = document.getElementById('stock-filter-dropdown');
  const stockButton = document.querySelector('[onclick="toggleStockFilter()"]');
  
  const priceDropdown = document.getElementById('price-filter-dropdown');
  const priceButton = document.querySelector('[onclick="togglePriceFilter()"]');
  
  if (categoryDropdown && categoryButton) {
    if (!categoryDropdown.contains(event.target) && !categoryButton.contains(event.target)) {
      categoryDropdown.classList.add('hidden');
    }
  }
  
  if (stockDropdown && stockButton) {
    if (!stockDropdown.contains(event.target) && !stockButton.contains(event.target)) {
      stockDropdown.classList.add('hidden');
    }
  }
  
  if (priceDropdown && priceButton) {
    if (!priceDropdown.contains(event.target) && !priceButton.contains(event.target)) {
      priceDropdown.classList.add('hidden');
    }
  }
});

// Focus automatique sur le champ de recherche
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.querySelector('input[name="search"]');
  if (searchInput && searchInput.value) {
    searchInput.focus();
    searchInput.setSelectionRange(searchInput.value.length, searchInput.value.length);
  }
  
  // Ajouter un effet de tooltip aux images agrandies
  const images = document.querySelectorAll('table img');
  images.forEach(img => {
    img.addEventListener('mouseenter', function() {
      const tooltip = document.createElement('div');
      tooltip.className = 'fixed z-50 px-2 py-1 text-xs bg-black text-white rounded opacity-0 transition-opacity';
      tooltip.textContent = 'Click to view full size';
      document.body.appendChild(tooltip);
      
      const rect = this.getBoundingClientRect();
      tooltip.style.left = (rect.left + rect.width/2 - tooltip.offsetWidth/2) + 'px';
      tooltip.style.top = (rect.top - 30) + 'px';
      
      setTimeout(() => tooltip.classList.add('opacity-100'), 10);
      
      this._tooltip = tooltip;
    });
    
    img.addEventListener('mouseleave', function() {
      if (this._tooltip) {
        this._tooltip.remove();
      }
    });
    
    // Ajouter la fonctionnalité de clic pour agrandir
    img.addEventListener('click', function(e) {
      e.stopPropagation();
      const modal = document.createElement('div');
      modal.className = 'fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-50 p-4';
      modal.innerHTML = `
        <div class="relative max-w-4xl max-h-full bg-white rounded-lg overflow-hidden">
          <button class="absolute top-4 right-4 text-white bg-black bg-opacity-50 rounded-full p-2 hover:bg-opacity-75 z-10 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <div class="p-8">
            <img src="${this.src}" alt="Full size image" class="max-w-full max-h-[70vh] object-contain mx-auto">
            <div class="mt-4 text-center text-sm text-gray-600">
              Product image
            </div>
          </div>
        </div>
      `;
      
      modal.querySelector('button').addEventListener('click', function() {
        document.body.removeChild(modal);
      });
      
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          document.body.removeChild(modal);
        }
      });
      
      document.body.appendChild(modal);
    });
  });
});
</script>
{% endblock %}