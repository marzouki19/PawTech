{% extends 'layout.html.twig' %}

{% block title %}{{ 'events.edit_event'|trans }} | PawTech Admin{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto" data-controller="confirm">
    <div class="mb-6">
        <a href="{{ path('app_admin_events') }}" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-800">
            <svg class="w-5 h-5 {% if app.request.locale == 'ar' %}rtl-flip{% endif %}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            {{ 'events.back_to_events'|trans }}
        </a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h1 class="text-xl font-bold text-gray-800 mb-6">{{ 'events.edit_event'|trans }}</h1>

        {% for message in app.flashes('error') %}
            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">
                {{ message }}
            </div>
        {% endfor %}

        {% if errors is defined and errors|length > 0 %}
            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
                <p class="font-medium text-red-700 mb-2">Veuillez corriger les erreurs suivantes :</p>
                <ul class="list-disc list-inside text-red-600 text-sm">
                    {% for field, error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form id="editEventForm" method="POST" action="{{ path('app_admin_events_edit', {id: event.id}) }}" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.title'|trans }} *</label>
                <input type="text" name="titre" value="{{ event.titre }}" class="form-input w-full px-4 py-2.5 border {{ errors.titre is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" placeholder="{{ 'events.form.title_placeholder'|trans }}">
                {% if errors.titre is defined %}
                    <span class="text-red-500 text-sm mt-1">{{ errors.titre }}</span>
                {% endif %}
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.type'|trans }} *</label>
                    <select name="type" class="form-input w-full px-4 py-2.5 border {{ errors.type is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none">
                        {% for type in types %}
                            <option value="{{ type }}" {{ event.type == type ? 'selected' : '' }}>{{ ('events.type.' ~ type)|trans }}</option>
                        {% endfor %}
                    </select>
                    {% if errors.type is defined %}
                        <span class="text-red-500 text-sm mt-1">{{ errors.type }}</span>
                    {% endif %}
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.status'|trans }} *</label>
                    <select name="statut" class="form-input w-full px-4 py-2.5 border {{ errors.statut is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none">
                        {% for statut in statuts %}
                            <option value="{{ statut }}" {{ event.statut == statut ? 'selected' : '' }}>{{ ('events.status.' ~ statut)|trans }}</option>
                        {% endfor %}
                    </select>
                    {% if errors.statut is defined %}
                        <span class="text-red-500 text-sm mt-1">{{ errors.statut }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.start_date'|trans }} *</label>
                    <input type="datetime-local" name="dateDebut" value="{{ event.dateDebut|date('Y-m-d\\TH:i') }}" class="form-input w-full px-4 py-2.5 border {{ errors.dateDebut is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none">
                    {% if errors.dateDebut is defined %}
                        <span class="text-red-500 text-sm mt-1">{{ errors.dateDebut }}</span>
                    {% endif %}
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.end_date'|trans }}</label>
                    <input type="datetime-local" name="dateFin" value="{{ event.dateFin ? event.dateFin|date('Y-m-d\\TH:i') : '' }}" class="form-input w-full px-4 py-2.5 border {{ errors.dateFin is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none">
                    {% if errors.dateFin is defined %}
                        <span class="text-red-500 text-sm mt-1">{{ errors.dateFin }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.location'|trans }} *</label>
                    <input type="text" name="lieu" value="{{ event.lieu }}" class="form-input w-full px-4 py-2.5 border {{ errors.lieu is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" placeholder="{{ 'events.form.location_placeholder'|trans }}">
                    {% if errors.lieu is defined %}
                        <span class="text-red-500 text-sm mt-1">{{ errors.lieu }}</span>
                    {% endif %}
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.city'|trans }} *</label>
                    <input type="text" name="ville" value="{{ event.ville }}" class="form-input w-full px-4 py-2.5 border {{ errors.ville is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" placeholder="{{ 'events.form.city_placeholder'|trans }}">
                    {% if errors.ville is defined %}
                        <span class="text-red-500 text-sm mt-1">{{ errors.ville }}</span>
                    {% endif %}
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.description'|trans }}</label>
                <textarea name="description" rows="4" class="form-input w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" placeholder="{{ 'events.form.description_placeholder'|trans }}">{{ event.description }}</textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'events.form.max_capacity'|trans }}</label>
                <input type="number" name="capaciteMax" value="{{ event.capaciteMax }}" min="1" class="form-input w-full px-4 py-2.5 border {{ errors.capaciteMax is defined ? 'border-red-500' : 'border-gray-200' }} rounded-lg focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" placeholder="{{ 'events.form.max_capacity_placeholder'|trans }}">
                {% if errors.capaciteMax is defined %}
                    <span class="text-red-500 text-sm mt-1">{{ errors.capaciteMax }}</span>
                {% endif %}
            </div>

            <div class="flex gap-3 pt-4">
                <a href="{{ path('app_admin_events') }}" class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 text-center">
                    {{ 'common.cancel'|trans }}
                </a>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium">
                    {{ 'events.form.save_changes'|trans }}
                </button>
            </div>
        </form>

        <div class="mt-6 pt-6 border-t border-gray-200">
            <h3 class="text-sm font-medium text-red-600 mb-3">{{ 'common.danger_zone'|trans }}</h3>
            <form action="{{ path('app_admin_events_delete', {id: event.id}) }}" method="POST">
                <button type="button" 
                        class="px-4 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-700 font-medium"
                        data-action="click->confirm#show"
                        data-confirm-title="{{ 'events.confirm.delete_title'|trans }}"
                        data-confirm-message="{{ 'events.confirm.delete_message'|trans({'%title%': event.titre}) }}"
                        data-confirm-text="{{ 'events.confirm.delete_button'|trans }}"
                        data-confirm-class="bg-red-600 hover:bg-red-700">
                    {{ 'events.actions.delete_permanently'|trans }}
                </button>
            </form>
        </div>
    </div>

    {# Event Stats #}
    <div class="mt-6 bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">{{ 'events.stats.title'|trans }}</h2>
        <div class="grid grid-cols-3 gap-4">
            <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="text-2xl font-bold text-gray-800">{{ event.nbConfirmes }}</div>
                <div class="text-sm text-gray-500">{{ 'events.stats.confirmed'|trans }}</div>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="text-2xl font-bold text-gray-800">{{ event.nbEnAttente }}</div>
                <div class="text-sm text-gray-500">{{ 'events.stats.pending'|trans }}</div>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="text-2xl font-bold text-gray-800">{{ event.capaciteMax ?? '∞' }}</div>
                <div class="text-sm text-gray-500">{{ 'events.stats.capacity'|trans }}</div>
            </div>
        </div>
    </div>

    {# Participants Section #}
    <div class="mt-6 bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-gray-800">Participants</h2>
            <span class="text-sm text-gray-500">{{ participations|length }} registered</span>
        </div>

        {% if participations|length > 0 %}
            <div class="overflow-hidden">
                <table id="participantsTable" class="w-full">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Registered</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for participation in participations %}
                            <tr>
                                <td>
                                    <span class="font-medium text-gray-900">{{ participation.user.fullName }}</span>
                                </td>
                                <td>
                                    <a href="mailto:{{ participation.user.email }}" class="text-blue-600 hover:text-blue-800">
                                        {{ participation.user.email }}
                                    </a>
                                </td>
                                <td>
                                    {% if participation.user.phone %}
                                        <a href="tel:{{ participation.user.phone }}" class="text-gray-600 hover:text-gray-800">
                                            {{ participation.user.phone }}
                                        </a>
                                    {% else %}
                                        <span class="text-gray-400">—</span>
                                    {% endif %}
                                </td>
                                <td data-order="{{ participation.dateParticipation|date('Y-m-d H:i:s') }}">
                                    <div class="text-gray-900">{{ participation.dateParticipation|date('d/m/Y') }}</div>
                                    <div class="text-xs text-gray-500">{{ participation.dateParticipation|date('H:i') }}</div>
                                </td>
                                <td>
                                    {% set statusColors = {
                                        'CONFIRMEE': 'bg-green-100 text-green-800',
                                        'EN_ATTENTE': 'bg-yellow-100 text-yellow-800',
                                        'ANNULEE': 'bg-red-100 text-red-800'
                                    } %}
                                    <span class="px-2 py-1 rounded-full text-xs font-semibold {{ statusColors[participation.statut] ?? 'bg-gray-100 text-gray-800' }}">
                                        {{ participation.statut|replace({'_': ' '}) }}
                                    </span>
                                </td>
                                <td>
                                    <div class="flex items-center gap-1">
                                        {% if participation.statut != 'CONFIRMEE' %}
                                            <form action="{{ path('app_admin_participation_confirm', {eventId: event.id, id: participation.id}) }}" method="POST" class="inline">
                                                <button type="submit" 
                                                        class="p-2 text-green-600 hover:bg-green-50 rounded-lg transition-colors" 
                                                        title="Confirm Participation">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        {% endif %}
                                        {% if participation.statut != 'ANNULEE' %}
                                            <form action="{{ path('app_admin_participation_cancel', {eventId: event.id, id: participation.id}) }}" method="POST" class="inline">
                                                <button type="submit" 
                                                        class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" 
                                                        title="Cancel Participation">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-8 text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <p>No participants registered yet</p>
            </div>
        {% endif %}
    </div>
</div>

<script>
$(function() {
    // Initialize Participants DataTable
    if ($('#participantsTable').length) {
        $('#participantsTable').DataTable({
            paging: true,
            pageLength: 10,
            lengthMenu: [5, 10, 25, 50],
            ordering: true,
            order: [[3, 'desc']], // Sort by registration date descending
            searching: true,
            info: true,
            columnDefs: [
                { orderable: false, targets: 5 } // Disable sorting on Actions column
            ],
            language: {
                search: "Search:",
                lengthMenu: "Show _MENU_ participants",
                info: "Showing _START_ to _END_ of _TOTAL_ participants",
                infoEmpty: "No participants",
                paginate: {
                    first: "First",
                    last: "Last",
                    next: "Next",
                    previous: "Previous"
                },
                zeroRecords: "No matching participants found"
            }
        });
    }
});
</script>
{% endblock %}
