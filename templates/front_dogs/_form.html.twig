{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'space-y-6', 'data-turbo': 'false'}}) }}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    {% if not form.vars.valid %}
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            Please review the highlighted fields and try again.
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            {{ form_label(form.applicantAge, 'Applicant Age', {'label_attr': {'class': 'block text-xs font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.applicantAge, {'attr': {
                'placeholder': 'e.g. 28',
                'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition'
            }}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.applicantAge) }}</div>
        </div>

        <div>
            {{ form_label(form.income, 'Income', {'label_attr': {'class': 'block text-xs font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.income, {'attr': {
                'placeholder': 'e.g. 2500',
                'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition'
            }}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.income) }}</div>
        </div>

        <div>
            {{ form_label(form.housingType, 'Housing Type', {'label_attr': {'class': 'block text-xs font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.housingType, {'attr': {
                'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition'
            }}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.housingType) }}</div>
        </div>

        <div>
            {{ form_label(form.familySize, 'Family Size', {'label_attr': {'class': 'block text-xs font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.familySize, {'attr': {
                'placeholder': 'e.g. 3',
                'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition'
            }}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.familySize) }}</div>
        </div>

        <div class="md:col-span-2">
            {{ form_label(form.hoursAwayPerDay, 'Hours Away Per Day', {'label_attr': {'class': 'block text-xs font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.hoursAwayPerDay, {'attr': {
                'placeholder': 'e.g. 6',
                'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition'
            }}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.hoursAwayPerDay) }}</div>
        </div>
    </div>

    <div class="mt-6">
        <label class="block text-xs font-semibold text-gray-700 mb-2">Home Information</label>
        <label class="flex items-center gap-2 text-sm text-gray-700">
            {{ form_widget(form.hasYard, {'attr': {'class': 'h-4 w-4 rounded border-gray-300 text-orange-500 focus:ring-orange-200'}}) }}
            I have a yard
        </label>
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.hasYard) }}</div>
    </div>

    <div class="flex justify-end gap-4 mt-8 pt-6 border-t border-gray-200">
        <a href="{{ path('app_front_dogs') }}"
           class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg font-semibold hover:bg-gray-50 transition">
            Cancel
        </a>
        <button type="submit"
                class="px-8 py-3 bg-orange-500 hover:bg-orange-600 text-white rounded-lg font-semibold shadow-lg hover:shadow-xl transition-all duration-200">
            {{ button_label|default('Submit Application') }}
        </button>
    </div>
</div>

{% if form._token is defined %}
    {{ form_widget(form._token) }}
{% endif %}
{{ form_end(form, {'render_rest': false}) }}
