{% extends 'base_front.html.twig' %}

{% block title %}Apply for Adoption{% endblock %}

{% block body %}
<section class="relative overflow-hidden min-h-screen flex items-center py-12">
    <div class="absolute inset-0">
        <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-orange-200/70"></div>
        <div class="absolute top-24 right-24 h-80 w-80 rounded-full bg-orange-400/80"></div>
        <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-amber-200/70"></div>
    </div>

    <div class="relative container mx-auto px-4 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 items-start">
            <div class="space-y-6">
                <div>
                    <p class="text-orange-600 font-semibold tracking-wide uppercase text-sm mb-3 flex items-center gap-2">
                        <span class="w-8 h-0.5 bg-orange-600"></span>
                        Adoption Application
                    </p>
                    <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight text-gray-900 mb-4">
                        Apply to Adopt <span class="text-orange-600">{{ dog.name }}</span>
                    </h1>
                </div>

                <p class="text-gray-600 max-w-xl text-lg leading-relaxed">
                    Complete this short form to apply for adopting
                    <span class="font-semibold text-orange-600">{{ dog.name }}</span>.
                </p>

                <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-gray-100 shadow-lg max-w-md">
                    <div class="flex items-center gap-4">
                        {% if dog.image %}
                            <img src="{{ asset('uploads/dogs/' ~ dog.image) }}"
                                 alt="{{ dog.name }}"
                                 class="w-20 h-20 rounded-xl object-cover">
                        {% else %}
                            <div class="w-20 h-20 rounded-xl bg-gradient-to-br from-orange-100 to-amber-100 flex items-center justify-center">
                                <svg class="w-10 h-10 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                </svg>
                            </div>
                        {% endif %}
                        <div>
                            <h3 class="font-bold text-xl text-gray-900">{{ dog.name }}</h3>
                            <p class="text-gray-500">{{ dog.breed ?? 'Mixed Breed' }} - {{ dog.age ?? '?' }} years</p>
                        </div>
                    </div>
                </div>

                <a href="{{ path('app_front_dogs') }}" class="inline-flex items-center text-gray-600 hover:text-orange-600 transition-colors group">
                    <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Back to Dogs
                </a>
            </div>

            <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-r from-orange-500 to-amber-500 rounded-3xl blur-xl opacity-20"></div>
                <div class="relative bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-8 border border-gray-100">
                    <h2 class="text-2xl font-bold mb-8 bg-gradient-to-r from-orange-600 to-amber-600 bg-clip-text text-transparent">
                        Adoption Application Form
                    </h2>

                    {{ include('front_dogs/_form.html.twig', {form: form, button_label: 'Submit Application'}) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
