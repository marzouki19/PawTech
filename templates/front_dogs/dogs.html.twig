{% extends 'base_front.html.twig' %}

{% block title %}Dogs - PawTech{% endblock %}

{% block body %}
    <section class="relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-orange-200/70"></div>
            <div class="absolute top-24 right-24 h-80 w-80 rounded-full bg-orange-400/80"></div>
        </div>

        <div class="relative container mx-auto px-4 lg:px-8 py-12 lg:py-16 grid lg:grid-cols-2 gap-10 items-center">
            <div>
                <p class="text-orange-600 font-semibold tracking-wide uppercase text-xs mb-3">Adopt</p>
                <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight text-gray-900">Where Dogs Come First</h1>
                <p class="mt-4 text-gray-600 max-w-xl">
                    Browse available dogs by category and find your perfect companion.
                </p>
                <div class="mt-7 flex flex-wrap gap-3">
                    <a href="{{ path('app_contact') }}" class="inline-flex items-center rounded-full bg-gray-900 px-6 py-3 text-white font-semibold hover:bg-gray-800 transition">
                        Learn More
                    </a>
                </div>
            </div>

            <div class="relative">
                <div class="relative rounded-3xl bg-white shadow-xl p-6 border border-gray-100">
                    <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-orange-100 via-gray-50 to-orange-200 flex items-center justify-center">
                        <span class="text-gray-500 font-semibold">Find your new best friend</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {{ include('front_dogs/recommended_dog.html.twig') }}

    <section class="container mx-auto px-4 lg:px-8 pb-14" id="dogs">
        <div class="mb-8">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <p class="text-orange-600 font-semibold text-xs uppercase tracking-wide">Most Wanted</p>
                    <h3 class="text-xl lg:text-2xl font-extrabold text-gray-900 mt-1">Reserved Dogs</h3>
                </div>
            </div>
            {% set reservedDogs = reservedDogs|default([]) %}
            {% if reservedDogs is empty %}
                <div class="rounded-2xl border border-dashed border-gray-200 p-6 bg-white text-sm text-gray-500">
                    No reserved dogs at the moment.
                </div>
            {% else %}
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    {% for reservedDog in reservedDogs %}
                        <div class="rounded-xl border border-gray-100 bg-white p-3 shadow-sm">
                            <div class="h-32 rounded-lg bg-gray-100 overflow-hidden flex items-center justify-center">
                                {% if reservedDog.image %}
                                    <img src="{{ reservedDog.image }}" alt="{{ reservedDog.name }}" class="h-full w-full object-cover">
                                {% else %}
                                    <span class="text-3xl font-bold text-gray-300">{{ reservedDog.name|slice(0, 1)|upper }}</span>
                                {% endif %}
                            </div>
                            <div class="mt-3">
                                <p class="text-sm font-bold text-gray-900 truncate">{{ reservedDog.name }}</p>
                                <p class="text-xs text-gray-500 truncate">{{ reservedDog.breed }}</p>
                            </div>
                            <div class="mt-3 grid grid-cols-2 gap-2">
                                <a href="{{ path('app_front_dogs_show', {'id': reservedDog.id}) }}"
                                   class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:border-orange-300 hover:text-orange-600">
                                    Details
                                </a>
                                {% if sessionUser is defined and sessionUser %}
                                    <a href="{{ path('app_apply_adoption', {'id': reservedDog.id}) }}"
                                       class="inline-flex items-center justify-center rounded-lg bg-orange-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-orange-700">
                                        Apply
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_signin') }}"
                                       class="inline-flex items-center justify-center rounded-lg bg-orange-100 px-3 py-1.5 text-xs font-semibold text-orange-700 hover:bg-orange-200">
                                        Login
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="flex items-end justify-between gap-6">
            <div>
                <p class="text-orange-600 font-semibold text-xs uppercase tracking-wide">Adoption</p>
                <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mt-2">Available Dogs</h2>
            </div>
            <div class="flex items-center gap-2">
                <button class="h-10 w-10 rounded-full border border-gray-200 bg-white hover:border-orange-400 hover:text-orange-600 transition">‹</button>
                <button class="h-10 w-10 rounded-full border border-gray-200 bg-white hover:border-orange-400 hover:text-orange-600 transition">›</button>
            </div>
        </div>

        <div class="mt-6 mb-4 flex justify-end">
            <button type="button" id="openRecommendationModal"
                    class="rounded-xl bg-orange-600 px-4 py-3 text-sm font-semibold text-white hover:bg-orange-700 transition">
                Recommended Dog
            </button>
        </div>

        <div id="recommendedDogsSection" class="hidden mb-8">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 class="text-xl font-bold text-gray-900">Recommended For You</h3>
                    <p id="recommendedDogsInfo" class="text-sm text-gray-500"></p>
                </div>
            </div>
            <div id="recommendedDogsGrid" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6"></div>
        </div>

        <!-- Filters + Search -->
        <div class="mb-8">
            <div class="rounded-2xl border border-gray-200 bg-white p-3 shadow-sm">
                <div class="flex flex-col lg:flex-row lg:items-center gap-3">
                    <div class="w-full lg:w-64">
                        <label for="statusFilter" class="block text-xs font-semibold text-gray-600 mb-1">Status Filter</label>
                        <select id="statusFilter" name="status"
                                class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 focus:border-orange-400 focus:ring-2 focus:ring-orange-400/30">
                            <option value="" selected>Available</option>
                        </select>
                    </div>
                    <div class="w-full flex-1">
                        <label for="searchDogs" class="block text-xs font-semibold text-gray-600 mb-1">Search</label>
                        <div class="relative">
                            <input type="text"
                                   id="searchDogs"
                                   placeholder="Search dogs by name, breed, or characteristics..."
                                   class="w-full rounded-xl border border-gray-200 bg-white px-5 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-orange-400 focus:ring-2 focus:ring-orange-400/30">
                            <div class="absolute right-4 top-3">
                                <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loading Indicator -->
        <div id="searchLoading" class="hidden mt-8 text-center">
            <div class="flex justify-center items-center">
                <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-orange-600"></div>
                <span class="ml-3 text-gray-600">Searching dogs...</span>
            </div>
        </div>

        <!-- Original Dogs Grid (visible by default) -->
        <div class="mt-8" id="originalDogsSection">
            <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-6" id="originalDogsGrid">
                {% set dogs = dogs|default([
                    {id:1, name:'Nina', breed:'Husky', age:'2 years', gender:'Female', adoptionStatus:'Available', image:null},
                    {id:2, name:'Prince', breed:'Labrador', age:'1 year', gender:'Male', adoptionStatus:'Available', image:null},
                    {id:3, name:'Coco', breed:'Poodle', age:'3 years', gender:'Female', adoptionStatus:'Available', image:null},
                    {id:4, name:'Max', breed:'Pug', age:'2 years', gender:'Male', adoptionStatus:'Available', image:null},
                    {id:5, name:'Rocky', breed:'Husky', age:'4 years', gender:'Male', adoptionStatus:'Available', image:null},
                    {id:6, name:'Bella', breed:'Labrador', age:'2 years', gender:'Female', adoptionStatus:'Available', image:null},
                    {id:7, name:'Zoe', breed:'Poodle', age:'1 year', gender:'Female', adoptionStatus:'Available', image:null},
                    {id:8, name:'Milo', breed:'Pug', age:'3 years', gender:'Male', adoptionStatus:'Available', image:null}
                ]) %}

                {% for dog in dogs %}
                    <div class="rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition overflow-hidden">
                        <div class="aspect-[4/3] bg-gray-100 relative">
                            {% if dog.image is defined and dog.image %}
                                <img src="{{ dog.image }}" alt="{{ dog.name }}" class="h-full w-full object-cover">
                            {% else %}
                                <div class="flex h-full w-full items-center justify-center text-5xl font-bold text-gray-300">
                                    {{ dog.name|slice(0, 1)|upper }}
                                </div>
                            {% endif %}
                            <div class="absolute top-3 right-3 flex items-center gap-2">
                                <button class="h-9 w-9 rounded-full bg-white/90 border border-gray-200 hover:border-orange-400 transition" title="Favorite">♡</button>
                            </div>
                        </div>
                        <div class="p-4">
                            <div class="flex items-center justify-between">
                                <h3 class="font-extrabold text-gray-900">{{ dog.name }}</h3>
                                <span class="text-xs rounded-full bg-orange-50 text-orange-700 px-2 py-1 font-semibold">{{ dog.breed }}</span>
                            </div>
                            <div class="mt-2 text-sm text-gray-500 flex items-center justify-between">
                                <span>{{ dog.gender }}</span>
                                <span>{{ dog.age }}</span>
                            </div>
                            <div class="mt-4 grid grid-cols-2 gap-3">
                                <a href="{{ path('app_front_dogs_show', {'id': dog.id}) }}" class="inline-flex items-center justify-center rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-800 hover:border-orange-400 hover:text-orange-600 transition">
                                    Details
                                </a>
                                {% if dog.adoptionStatus == 'Adopted' %}
                                    <button disabled class="inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-400 cursor-not-allowed border border-gray-200">
                                        Adopted
                                    </button>
                                {% elseif dog.adoptionStatus == 'Reserved' %}
                                    <button disabled class="inline-flex items-center justify-center rounded-xl bg-yellow-100 px-4 py-2 text-sm font-semibold text-yellow-700 cursor-not-allowed border border-yellow-300">
                                        Reserved
                                    </button>
                                {% elseif sessionUser is defined and sessionUser %}
                                        <a href="{{ path('app_apply_adoption', {'id': dog.id}) }}" class="w-full inline-flex items-center justify-center rounded-xl bg-orange-600 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-700 hover:shadow-lg active:scale-95 transition-all duration-200">
                                            Apply for Adoption
                                        </a>
                                {% else %}
                                    <a href="{{ path('app_signin') }}" class="inline-flex items-center justify-center rounded-xl bg-orange-100 px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-200 transition shadow-sm" title="Login to adopt">
                                        Login
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- Search Results Container (hidden by default) -->
        <div id="searchResultsContainer" class="hidden mt-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900">Search Results</h3>
                    <p id="resultsCount" class="text-sm text-gray-500 mt-1"></p>
                </div>
                <button id="clearSearch" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-orange-600 hover:text-orange-700 border border-orange-200 hover:border-orange-300 rounded-xl transition">
                    <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Clear Search
                </button>
            </div>
            <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-6" id="searchResultsGrid">
                <!-- Search results will be dynamically inserted here -->
            </div>
        </div>

        <!-- No Results Message -->
        <div id="noResultsMessage" class="hidden mt-8 text-center">
            <div class="rounded-2xl border border-dashed border-gray-200 p-12 bg-white">
                <svg class="h-12 w-12 text-gray-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <p class="text-lg font-semibold text-gray-600">No dogs found matching your search</p>
                <p class="text-sm text-gray-400 mt-2">Try different search terms or browse all available dogs above</p>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
<script>
$(document).ready(function() {
    const sessionUser = {{ sessionUser is defined and sessionUser ? 'true' : 'false' }};
    let searchTimeout = null;

    function getDogStatus(dog) {
        return dog.adoptionStatus || dog.adoption_status || dog.status || 'Available';
    }

    function buildDogCard(dog) {
        const avatar = dog.image
            ? `<img src="${dog.image}" alt="${dog.name || 'Dog'}" class="h-full w-full object-cover">`
            : `<div class="flex h-full w-full items-center justify-center text-5xl font-bold text-gray-300">${dog.name ? dog.name.charAt(0).toUpperCase() : 'D'}</div>`;

        let adoptButtonHtml = '';
        if (sessionUser) {
            if (getDogStatus(dog) === 'Adopted') {
                adoptButtonHtml = `<button disabled class="inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-400 cursor-not-allowed border border-gray-200 w-full">Adopted</button>`;
            } else if (getDogStatus(dog) === 'Reserved') {
                adoptButtonHtml = `<button disabled class="inline-flex items-center justify-center rounded-xl bg-yellow-100 px-4 py-2 text-sm font-semibold text-yellow-700 cursor-not-allowed border border-yellow-300 w-full">Reserved</button>`;
            } else {
                adoptButtonHtml = `<a href="{{ path('app_apply_adoption', {'id': 'DOG_ID_PLACEHOLDER'}) }}" class="w-full inline-flex items-center justify-center rounded-xl bg-orange-600 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-700 hover:shadow-lg active:scale-95 transition-all duration-200">Apply for Adoption</a>`.replace('DOG_ID_PLACEHOLDER', dog.id);
            }
        } else {
            adoptButtonHtml = `<a href="{{ path('app_signin') }}" class="inline-flex items-center justify-center rounded-xl bg-orange-100 px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-200 transition shadow-sm w-full" title="Login to adopt">Login</a>`;
        }

        let ageDisplay = dog.age ?? '';
        if (ageDisplay !== null && ageDisplay !== undefined && ageDisplay !== '') {
            ageDisplay = String(ageDisplay);
        }
        if (ageDisplay && !ageDisplay.includes('year') && !ageDisplay.includes('month')) {
            ageDisplay = ageDisplay + (parseInt(ageDisplay, 10) === 1 ? ' year' : ' years');
        }

        return `<div class="rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition overflow-hidden">
            <div class="aspect-[4/3] bg-gray-100 relative">
                ${avatar}
                <div class="absolute top-3 right-3 flex items-center gap-2">
                    <button class="h-9 w-9 rounded-full bg-white/90 border border-gray-200 hover:border-orange-400 transition" title="Favorite">&#9825;</button>
                </div>
            </div>
            <div class="p-4">
                <div class="flex items-center justify-between">
                    <h3 class="font-extrabold text-gray-900">${dog.name || ''}</h3>
                    <span class="text-xs rounded-full bg-orange-50 text-orange-700 px-2 py-1 font-semibold">${dog.breed || ''}</span>
                </div>
                <div class="mt-2 text-sm text-gray-500 flex items-center justify-between">
                    <span>${dog.gender || ''}</span>
                    <span>${ageDisplay}</span>
                </div>
                <div class="mt-4 grid grid-cols-2 gap-3">
                    <a href="{{ path('app_front_dogs_show', {'id': 'DOG_ID_PLACEHOLDER'}) }}" class="inline-flex items-center justify-center rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-800 hover:border-orange-400 hover:text-orange-600 transition">Details</a>
                    ${adoptButtonHtml}
                </div>
            </div>
        </div>`.replace(/DOG_ID_PLACEHOLDER/g, dog.id);
    }

    function renderRecommendedDogs(dogs, ids) {
        const $section = $('#recommendedDogsSection');
        const $grid = $('#recommendedDogsGrid');
        const $info = $('#recommendedDogsInfo');
        $grid.empty();

        if (!dogs || dogs.length === 0) {
            $info.text('No recommended dogs found for this profile.');
            $section.removeClass('hidden');
            return;
        }

        dogs.forEach(dog => $grid.append(buildDogCard(dog)));
        $info.text(`Recommended IDs: ${ids.join(', ')}`);
        $section.removeClass('hidden');
    }

    function openRecommendationModal() {
        $('#recommendationModal').removeClass('hidden');
    }

    function closeRecommendationModal() {
        $('#recommendationModal').addClass('hidden');
    }

    $('#openRecommendationModal').on('click', function() {
        openRecommendationModal();
    });

    $('#closeRecommendationModal, #skipRecommendationModal').on('click', function() {
        closeRecommendationModal();
    });

    $('#recommended_dog').on('submit', function(e) {
        e.preventDefault();

        const payload = {
            user_profile: {
                user_living_type: $('#user_living_type').val(),
                user_has_cats: parseInt($('#user_has_cats').val(), 10),
                user_has_dogs: parseInt($('#user_has_dogs').val(), 10),
                user_activity_level: parseInt($('#user_activity_level').val(), 10),
                user_experience: $('#user_experience').val(),
                user_hours_alone: parseInt($('#user_hours_alone').val(), 10),
                user_preferred_size: $('#user_preferred_size').val()
            },
            filters: {
                desired_min_age: parseInt($('#desired_min_age').val(), 10),
                desired_max_age: parseInt($('#desired_max_age').val(), 10),
                desired_gender: $('#desired_gender').val(),
                require_vaccinated: parseInt($('#require_vaccinated').val(), 10),
                require_friendly_kids: parseInt($('#require_friendly_kids').val(), 10),
                require_friendly_dogs: parseInt($('#require_friendly_dogs').val(), 10),
                require_friendly_cats: parseInt($('#require_friendly_cats').val(), 10)
            }
        };

        $.ajax({
            url: "{{ path('app_recommended_dog') }}",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function(response) {
                renderRecommendedDogs(response.dogs || [], response.recommendations || []);
                closeRecommendationModal();
            },
            error: function(xhr) {
                console.error('dog_recommendation failed:', xhr.responseText);
                closeRecommendationModal();
            }
        });
    });

    function fetchDogsWithFilters() {
        const searchTerm = $('#searchDogs').val().trim();
        const selectedStatus = $('#statusFilter').val().trim();
        const $originalSection = $('#originalDogsSection');
        const $resultsContainer = $('#searchResultsContainer');
        const $resultsGrid = $('#searchResultsGrid');
        const $noResults = $('#noResultsMessage');
        const $loading = $('#searchLoading');

        if (searchTerm.length === 0 && selectedStatus.length === 0) {
            $originalSection.show();
            $resultsContainer.hide();
            $noResults.hide();
            $loading.hide();
            return;
        }

        $originalSection.hide();
        $resultsContainer.hide();
        $noResults.hide();
        $loading.show();

        $.ajax({
            url: "{{ path('app_dogs_search_json') }}",
            type: "GET",
            data: { searchValue: searchTerm, status: selectedStatus || undefined },
            dataType: "json",
            success: function(response) {
                $loading.hide();
                $resultsGrid.empty();

                let dogs = [];
                if (Array.isArray(response)) {
                    dogs = response;
                } else if (response.dogs && Array.isArray(response.dogs)) {
                    dogs = response.dogs;
                } else if (response.data && Array.isArray(response.data)) {
                    dogs = response.data;
                }

                dogs = dogs.filter(dog => getDogStatus(dog) === 'Available');

                if (dogs.length > 0) {
                    dogs.forEach(dog => $resultsGrid.append(buildDogCard(dog)));
                    $('#resultsCount').text(`Found ${dogs.length} dog${dogs.length > 1 ? 's' : ''}`);
                    $resultsContainer.show();
                    $noResults.hide();
                } else {
                    $resultsContainer.hide();
                    $noResults.show();
                }
            },
            error: function(xhr, status, err) {
                $loading.hide();
                console.error('Search failed:', status, err);
                console.error('Response:', xhr.responseText);
                $noResults.find('p:first-child').text('Error searching dogs');
                $noResults.find('p:last-child').text('Please try again later');
                $noResults.show();
                $resultsContainer.hide();
            }
        });
    }

    $('#searchDogs').on('keyup', function() {
        if (searchTimeout) clearTimeout(searchTimeout);
        searchTimeout = setTimeout(fetchDogsWithFilters, 300);
    });

    $('#statusFilter').on('change', function() {
        fetchDogsWithFilters();
    });

    $('#clearSearch').on('click', function() {
        $('#searchDogs').val('');
        $('#statusFilter').val('');
        fetchDogsWithFilters();
    });

    $(document).on('keydown', function(e) {
        if (e.key === 'Escape') {
            $('#searchDogs').val('');
            $('#statusFilter').val('');
            fetchDogsWithFilters();
        }
    });
});
</script>
{% endblock %}

