{% extends 'base_front.html.twig' %}

{% block title %}Dogs - PawTech{% endblock %}

{% block body %}
    <section class="relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-orange-200/70"></div>
            <div class="absolute top-24 right-24 h-80 w-80 rounded-full bg-orange-400/80"></div>
        </div>

        <div class="relative container mx-auto px-4 lg:px-8 py-12 lg:py-16 grid lg:grid-cols-2 gap-10 items-center">
            <div>
                <p class="text-orange-600 font-semibold tracking-wide uppercase text-xs mb-3">Adopt</p>
                <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight text-gray-900">Where Dogs Come First</h1>
                <p class="mt-4 text-gray-600 max-w-xl">
                    Browse available dogs by category and find your perfect companion.
                </p>
                <div class="mt-7 flex flex-wrap gap-3">
                    <a href="{{ path('app_contact') }}" class="inline-flex items-center rounded-full bg-gray-900 px-6 py-3 text-white font-semibold hover:bg-gray-800 transition">
                        Learn More
                    </a>
                </div>
            </div>

            <div class="relative">
                <div class="relative rounded-3xl bg-white shadow-xl p-6 border border-gray-100">
                    <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-orange-100 via-gray-50 to-orange-200 flex items-center justify-center">
                        <span class="text-gray-500 font-semibold">Find your new best friend</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container mx-auto px-4 lg:px-8 pb-14" id="dogs">
        <div class="flex items-end justify-between gap-6">
            <div>
                <p class="text-orange-600 font-semibold text-xs uppercase tracking-wide">Adoption</p>
                <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mt-2">Available Dogs</h2>
            </div>
            <div class="flex items-center gap-2">
                <button class="h-10 w-10 rounded-full border border-gray-200 bg-white hover:border-orange-400 hover:text-orange-600 transition">‹</button>
                <button class="h-10 w-10 rounded-full border border-gray-200 bg-white hover:border-orange-400 hover:text-orange-600 transition">›</button>
            </div>
        </div>

        <!-- Search Bar -->
        <div class="mt-6 mb-8">
            <div class="max-w-xl">
                <div class="relative">
                    <input type="text" 
                           id="searchDogs"
                           placeholder="Search dogs by name, breed, or characteristics..."
                           class="w-full rounded-xl border border-gray-200 bg-white px-5 py-3.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-orange-400 focus:ring-2 focus:ring-orange-400/30">
                    <div class="absolute right-4 top-3.5">
                        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                </div>
                <p class="mt-2 text-xs text-gray-500">Type to search through our available dogs...</p>
            </div>
        </div>

        <!-- Original Dogs Grid (hidden when searching) -->
        <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-4 gap-6" id="originalDogsGrid">
            {% set dogs = dogs|default([
                {id:1, name:'Nina', breed:'Husky', age:'2 years', gender:'Female', image:null},
                {id:2, name:'Prince', breed:'Labrador', age:'1 year', gender:'Male', image:null},
                {id:3, name:'Coco', breed:'Poodle', age:'3 years', gender:'Female', image:null},
                {id:4, name:'Max', breed:'Pug', age:'2 years', gender:'Male', image:null},
                {id:5, name:'Rocky', breed:'Husky', age:'4 years', gender:'Male', image:null},
                {id:6, name:'Bella', breed:'Labrador', age:'2 years', gender:'Female', image:null},
                {id:7, name:'Zoe', breed:'Poodle', age:'1 year', gender:'Female', image:null},
                {id:8, name:'Milo', breed:'Pug', age:'3 years', gender:'Male', image:null}
            ]) %}

            {% for dog in dogs %}
                <div class="rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition overflow-hidden">
                    <div class="aspect-[4/3] bg-gray-100 relative">
                        {% if dog.image is defined and dog.image %}
                            <img src="{{ dog.image }}" alt="{{ dog.name }}" class="h-full w-full object-cover">
                        {% else %}
                            <div class="flex h-full w-full items-center justify-center text-5xl font-bold text-gray-300">
                                {{ dog.name|slice(0, 1)|upper }}
                            </div>
                        {% endif %}
                        <div class="absolute top-3 right-3 flex items-center gap-2">
                            <button class="h-9 w-9 rounded-full bg-white/90 border border-gray-200 hover:border-orange-400 transition" title="Favorite">♡</button>
                        </div>
                    </div>
                    <div class="p-4">
                        <div class="flex items-center justify-between">
                            <h3 class="font-extrabold text-gray-900">{{ dog.name }}</h3>
                            <span class="text-xs rounded-full bg-orange-50 text-orange-700 px-2 py-1 font-semibold">{{ dog.breed }}</span>
                        </div>
                        <div class="mt-2 text-sm text-gray-500 flex items-center justify-between">
                            <span>{{ dog.gender }}</span>
                            <span>{{ dog.age }}</span>
                        </div>
                        <div class="mt-4 grid grid-cols-2 gap-3">
                            <a href="{{ path('app_front_dogs_show', {'id': dog.id}) }}" class="inline-flex items-center justify-center rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-800 hover:border-orange-400 hover:text-orange-600 transition">
                                Details
                            </a>
                            {% if sessionUser %}
                                {% if dog.adoptionStatus == 'Adopted' %}
                                    <button disabled class="inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-400 cursor-not-allowed border border-gray-200">
                                        Adopted
                                    </button>
                                {% else %}
                                    <form method="post" action="{{ path('app_dogs_adopt', {'id': dog.id}) }}" class="w-full">
                                        <input type="hidden" name="_token" value="{{ csrf_token('adopt' ~ dog.id) }}">
                                        <button type="submit" class="w-full inline-flex items-center justify-center rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600 hover:shadow-lg active:scale-95 transition-all duration-200">
                                            Adopt
                                        </button>
                                    </form>
                                {% endif %}
                            {% else %}
                                <a href="{{ path('app_signin') }}" class="inline-flex items-center justify-center rounded-xl bg-orange-100 px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-200 transition shadow-sm" title="Login to adopt">
                                    Login
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <!-- Search Results Container -->
        <div id="searchResultsContainer" class="mt-8 hidden">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Search Results</h3>
                <button id="clearSearch" class="text-sm text-orange-600 hover:text-orange-700 font-semibold">
                    Clear Search
                </button>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" id="searchResultsGrid">
                <!-- Search results will be dynamically inserted here -->
            </div>
        </div>

        <!-- No Results Message -->
        <div id="noResultsMessage" class="hidden mt-8 text-center">
            <div class="rounded-2xl border border-dashed border-gray-200 p-12 bg-white">
                <svg class="h-12 w-12 text-gray-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <p class="text-lg font-semibold text-gray-600">No dogs found matching your search</p>
                <p class="text-sm text-gray-400 mt-2">Try different search terms or browse all available dogs above</p>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
$(document).ready(function() {
    const sessionUser = {{ sessionUser is defined and sessionUser ? 'true' : 'false' }};
    const csrfToken = "{{ csrf_token('adopt') }}"; // Base CSRF token for adopt forms
    
    // Search functionality
    $("#searchDogs").on("keyup", function() {
        const value = $(this).val().trim();
        const $originalGrid = $('#originalDogsGrid');
        const $resultsContainer = $('#searchResultsContainer');
        const $resultsGrid = $('#searchResultsGrid');
        const $noResults = $('#noResultsMessage');

        if (!value) {
            // Show original grid, hide search results
            $originalGrid.show();
            $resultsContainer.hide();
            $noResults.hide();
            return;
        }

        // Hide original grid
        $originalGrid.hide();

        // AJAX search request
        $.ajax({
            url: "{{ path('app_dogs_search_json') }}", // You'll need to create this route
            type: "GET",
            data: { 
                searchValue: value,
                status: 'Available' // Only show available dogs on frontend
            },
            dataType: "json",
            success: function(dogs) {
                $resultsGrid.empty();

                if (dogs?.length > 0) {
                    // Display search results
                    dogs.forEach(dog => {
                        const avatar = dog.image
                            ? `<img src="${dog.image}" alt="${dog.name || 'Dog'}" class="h-full w-full object-cover">`
                            : `<div class="flex h-full w-full items-center justify-center text-5xl font-bold text-gray-300">
                                 ${dog.name?.charAt(0)?.toUpperCase() || 'D'}
                               </div>`;

                        // Determine which button to show based on user login status and dog adoption status
                        let adoptButtonHtml = '';
                        
                        if (sessionUser) {
                            // User is logged in
                            if (dog.adoptionStatus === 'Adopted') {
                                adoptButtonHtml = `
                                    <button disabled 
                                            class="inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-400 cursor-not-allowed border border-gray-200 w-full">
                                        Adopted
                                    </button>`;
                            } else {
                                // Dog is available for adoption
                                adoptButtonHtml = `
                                    <form method="post" action="/dogs/${dog.id}/adopt" class="w-full">
                                        <input type="hidden" name="_token" value="${csrfToken}">
                                        <button type="submit" 
                                                class="w-full inline-flex items-center justify-center rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600 hover:shadow-lg active:scale-95 transition-all duration-200">
                                            Adopt
                                        </button>
                                    </form>`;
                            }
                        } else {
                            // User is not logged in - show login button
                            adoptButtonHtml = `
                                <a href="{{ path('app_signin') }}" 
                                   class="inline-flex items-center justify-center rounded-xl bg-orange-100 px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-200 transition shadow-sm w-full"
                                   title="Login to adopt">
                                    Login
                                </a>`;
                        }

                        const card = `
                            <div class="rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition overflow-hidden">
                                <div class="aspect-[4/3] bg-gray-100 relative">
                                    ${avatar}
                                    <div class="absolute top-3 right-3 flex items-center gap-2">
                                        <button class="h-9 w-9 rounded-full bg-white/90 border border-gray-200 hover:border-orange-400 transition" title="Favorite">♡</button>
                                    </div>
                                </div>
                                <div class="p-4">
                                    <div class="flex items-center justify-between">
                                        <h3 class="font-extrabold text-gray-900">${dog.name || ''}</h3>
                                        <span class="text-xs rounded-full bg-orange-50 text-orange-700 px-2 py-1 font-semibold">${dog.breed || ''}</span>
                                    </div>
                                    <div class="mt-2 text-sm text-gray-500 flex items-center justify-between">
                                        <span>${dog.gender || ''}</span>
                                        <span>${dog.age || ''}${dog.age ? (typeof dog.age === 'string' && dog.age.includes('year') ? '' : ' yrs') : ''}</span>
                                    </div>
                                    <div class="mt-4 grid grid-cols-2 gap-3">
                                        <a href="/dogs/${dog.id}" class="inline-flex items-center justify-center rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-800 hover:border-orange-400 hover:text-orange-600 transition">
                                            Details
                                        </a>
                                        ${adoptButtonHtml}
                                    </div>
                                </div>
                            </div>`;

                        $resultsGrid.append(card);
                    });

                    $resultsContainer.show();
                    $noResults.hide();
                } else {
                    // No results found
                    $resultsContainer.hide();
                    $noResults.show();
                }
            },
            error: function(xhr, status, err) {
                console.error("Search failed:", status, err, xhr.responseText);
                // Fallback to showing original grid
                $originalGrid.show();
                $resultsContainer.hide();
                $noResults.hide();
                alert("Error searching dogs. Please try again.");
            }
        });
    });

    // Clear search button
    $('#clearSearch').on('click', function() {
        $('#searchDogs').val('');
        $('#originalDogsGrid').show();
        $('#searchResultsContainer').hide();
        $('#noResultsMessage').hide();
    });

    // Clear search when user clicks outside and input is empty
    $(document).on('click', function(e) {
        if (!$(e.target).closest('#searchDogs').length) {
            const $searchInput = $('#searchDogs');
            if ($searchInput.val().trim() === '') {
                $('#originalDogsGrid').show();
                $('#searchResultsContainer').hide();
                $('#noResultsMessage').hide();
            }
        }
    });

    // Clear search on escape key
    $(document).on('keydown', function(e) {
        if (e.key === 'Escape') {
            $('#searchDogs').val('');
            $('#originalDogsGrid').show();
            $('#searchResultsContainer').hide();
            $('#noResultsMessage').hide();
        }
    });
});
</script>
{% endblock %}