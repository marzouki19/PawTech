{% extends 'base.html.twig' %}

{% block body %}
<div class="flex min-h-screen bg-gray-100">
    {% include 'components/_sidebar.html.twig' with { active: active|default('dashboard') } %}
    <div class="flex-1 flex flex-col min-w-0">
        {% include 'components/_header.html.twig' with { page_title: page_title|default('Dashboard') } %}
        <main class="flex-1 p-6 overflow-auto">
            {% block main %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
