{# templates/ligne_commande/_form_content.html.twig #}
<div class="max-w-3xl mx-auto">
  <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-orange-500 to-orange-600 px-8 py-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h.01M12 7h.01M16 7h.01M21 11a8 8 0 11-16 0 8 8 0 0116 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15h.01"></path>
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white">{{ page_title }}</h1>
          <p class="text-orange-100 text-sm mt-1">Manage order line items</p>
        </div>
      </div>
    </div>

    <div class="p-8">
      {{ form_start(form, {
        'attr': {
          'class': 'space-y-6',
          'id': 'ligne-commande-form',
          'novalidate': 'novalidate'
        }
      }) }}

      {% if not form.vars.valid %}
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          Please review the highlighted fields and try again.
          {{ form_errors(form) }}
        </div>
      {% endif %}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {# Champ PRODUIT #}
        <div>
          {% set produit_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'data-field': 'produit'} %}
          {% if form.produit.vars.errors|length %}{% set produit_attr = produit_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.produit, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.produit, {'attr': produit_attr, 'errors': false}) }}
          {% set produit_errors = form.produit.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ produit_errors|length ? '' : 'hidden' }}" data-error-for="produit">
            {% for error in produit_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Sélection obligatoire.</div>
        </div>

        {# Champ COMMANDE #}
        <div>
          {% set commande_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'data-field': 'commande'} %}
          {% if form.commande.vars.errors|length %}{% set commande_attr = commande_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.commande, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.commande, {'attr': commande_attr, 'errors': false}) }}
          {% set commande_errors = form.commande.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ commande_errors|length ? '' : 'hidden' }}" data-error-for="commande">
            {% for error in commande_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Sélection obligatoire.</div>
        </div>

        {# Champ QUANTITE #}
        <div>
          {% set quantite_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '1', 'data-field': 'quantite'} %}
          {% if form.quantite.vars.errors|length %}{% set quantite_attr = quantite_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.quantite, {'attr': quantite_attr, 'errors': false}) }}
          {% set quantite_errors = form.quantite.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ quantite_errors|length ? '' : 'hidden' }}" data-error-for="quantite">
            {% for error in quantite_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <p class="text-xs text-gray-500 mt-1">Minimum: 1</p>
        </div>

        {# Champ PRIX UNITAIRE #}
        <div>
          {% set prixUnitaire_attr = {'class': 'w-full pl-8 pr-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0.00', 'data-field': 'prixUnitaire'} %}
          {% if form.prixUnitaire.vars.errors|length %}{% set prixUnitaire_attr = prixUnitaire_attr|merge({'class': 'w-full pl-8 pr-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.prixUnitaire, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          <div class="relative">
            <span class="absolute left-3 top-3 text-gray-500">$</span>
            {{ form_widget(form.prixUnitaire, {'attr': prixUnitaire_attr, 'errors': false}) }}
          </div>
          {% set prix_errors = form.prixUnitaire.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ prix_errors|length ? '' : 'hidden' }}" data-error-for="prixUnitaire">
            {% for error in prix_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Nombre > 0. Ex: 12.50</div>
        </div>
      </div>

      {# Calcul du prix total (lecture seule) #}
      <div id="total-price-container" class="hidden">
        <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
          <div class="flex justify-between items-center">
            <span class="text-sm font-medium text-gray-700">Total Price:</span>
            <span id="total-price" class="text-lg font-bold text-paw-orange">$0.00</span>
          </div>
        </div>
      </div>

      <div class="pt-6 border-t border-gray-100 flex flex-wrap gap-3">
        <a href="{{ path('app_eshop_ligne_commande_index') }}" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 hover:text-gray-800 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to list
        </a>
        <button type="submit" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-orange-500 rounded-lg hover:bg-orange-600 transition-all shadow-md hover:shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          {{ submit_label|default('Save') }}
        </button>
      </div>

      {{ form_end(form) }}
    </div>
  </div>
</div>

<script>
function initLigneCommandeFormValidation() {
  const form = document.getElementById('ligne-commande-form');
  if (!form || form.dataset.validationBound === 'true') {
    return;
  }
  form.dataset.validationBound = 'true';

  const fields = {
    produit: form.querySelector('[data-field="produit"]'),
    commande: form.querySelector('[data-field="commande"]'),
    quantite: form.querySelector('[data-field="quantite"]'),
    prixUnitaire: form.querySelector('[data-field="prixUnitaire"]'),
  };

  const totalContainer = document.getElementById('total-price-container');
  const totalElement = document.getElementById('total-price');

  function setError(field, message) {
    const input = fields[field];
    const container = form.querySelector('[data-error-for="' + field + '"]');
    if (container) {
      if (message) {
        container.innerHTML = '<div>' + message + '</div>';
        container.classList.remove('hidden');
      } else {
        container.innerHTML = '';
        container.classList.add('hidden');
      }
    }
    if (input) {
      input.classList.toggle('border-red-500', !!message);
      input.classList.toggle('bg-red-50', !!message);
      input.classList.toggle('focus:ring-red-500', !!message);
      input.classList.toggle('focus:border-red-500', !!message);
      input.setAttribute('aria-invalid', message ? 'true' : 'false');
    }
  }

  function normalizeNumber(value) {
    return value.replace(',', '.').trim();
  }

  function validateField(field) {
    const input = fields[field];
    if (!input) return true;
    const value = (input.value || '').trim();
    let ok = true;
    let message = '';

    if (field === 'produit' || field === 'commande') {
      ok = value !== '';
      if (!ok) message = 'Ce champ est obligatoire.';
    } else if (field === 'quantite') {
      ok = /^\d+$/.test(value) && Number(value) >= 1;
      if (!ok) message = 'La quantité doit être un entier >= 1.';
    } else if (field === 'prixUnitaire') {
      const numberValue = Number(normalizeNumber(value));
      ok = !Number.isNaN(numberValue) && numberValue > 0;
      if (!ok) message = 'Le prix unitaire doit être un nombre > 0.';
    }

    if (ok) {
      setError(field, '');
      return true;
    }
    setError(field, message);
    return false;
  }

  function calculateTotal() {
    const quantite = Number(normalizeNumber(fields.quantite?.value || '0')) || 0;
    const prix = Number(normalizeNumber(fields.prixUnitaire?.value || '0')) || 0;
    const total = quantite * prix;
    if (total > 0) {
      totalElement.textContent = '$' + total.toFixed(2);
      totalContainer.classList.remove('hidden');
    } else {
      totalContainer.classList.add('hidden');
    }
  }

  ['produit', 'commande', 'quantite', 'prixUnitaire'].forEach(function(field) {
    const input = fields[field];
    if (!input) return;
    input.addEventListener('input', function() { validateField(field); calculateTotal(); });
    input.addEventListener('change', function() { validateField(field); calculateTotal(); });
  });

  // Initial calculation
  calculateTotal();

  form.addEventListener('submit', function(event) {
    let firstInvalid = null;
    ['produit', 'commande', 'quantite', 'prixUnitaire'].forEach(function(field) {
      const ok = validateField(field);
      if (!ok && !firstInvalid) {
        firstInvalid = fields[field];
      }
    });
    if (firstInvalid) {
      event.preventDefault();
      firstInvalid.focus();
    }
  });
}

document.addEventListener('DOMContentLoaded', initLigneCommandeFormValidation);
document.addEventListener('turbo:load', initLigneCommandeFormValidation);
</script>
