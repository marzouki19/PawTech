{% extends 'base_front.html.twig' %}

{% block title %}Demand Forecasting - PawTech AI{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100">
    <!-- Header -->
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-black">Demand Forecasting AI</h1>
                    <p class="mt-2 text-indigo-100">Predict product demand and optimize your inventory</p>
                </div>
                <div class="text-right">
                    <div class="text-sm text-indigo-200">AI Confidence</div>
                    <div class="text-3xl font-black">{{ averageConfidence }}%</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Generate Forecast Form -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-6">
            <form method="POST" action="{{ path('app_demand_forecast_generate') }}" class="flex items-end gap-4">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Forecast Timeframe</label>
                    <select name="timeframe" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                        <option value="7days">Next 7 Days</option>
                        <option value="30days" selected>Next 30 Days</option>
                        <option value="90days">Next 90 Days</option>
                        <option value="180days">Next 6 Months</option>
                        <option value="365days">Next Year</option>
                    </select>
                </div>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Generate Forecast
                </button>
            </form>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-6">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl bg-indigo-100 flex items-center justify-center">
                        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-slate-500">Products Analyzed</div>
                        <div class="text-2xl font-black text-slate-900">{{ productsAnalyzed }}</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-6">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-slate-500">Predicted Demand</div>
                        <div class="text-2xl font-black text-slate-900">{{ totalPredictedDemand }}</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-6">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-slate-500">High Demand</div>
                        <div class="text-2xl font-black text-slate-900">{{ highDemandProducts|length }}</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-6">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-slate-500">Rising Trend</div>
                        <div class="text-2xl font-black text-slate-900">{{ risingTrendProducts|length }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- High Demand Products -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
        <div class="bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden">
            <div class="bg-gradient-to-r from-orange-500 to-red-500 px-6 py-4">
                <h2 class="text-xl font-black text-white flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
                    </svg>
                    🔥 High Demand Products
                </h2>
                <p class="text-orange-100 text-sm mt-1">Products predicted to have high sales in the coming period</p>
            </div>
            
            <div class="p-6">
                {% if highDemandProducts|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="border-b border-slate-200">
                                    <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">Product</th>
                                    <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">Category</th>
                                    <th class="text-center py-3 px-4 text-sm font-bold text-slate-600">Predicted Demand</th>
                                    <th class="text-center py-3 px-4 text-sm font-bold text-slate-600">Confidence</th>
                                    <th class="text-center py-3 px-4 text-sm font-bold text-slate-600">Trend</th>
                                    <th class="text-center py-3 px-4 text-sm font-bold text-slate-600">Growth Rate</th>
                                    <th class="text-center py-3 px-4 text-sm font-bold text-slate-600">Current Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for forecast in highDemandProducts %}
                                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                                        <td class="py-4 px-4">
                                            <div class="font-bold text-slate-900">{{ forecast.produit.nom }}</div>
                                        </td>
                                        <td class="py-4 px-4">
                                            {% if forecast.produit.categorie %}
                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-indigo-100 text-indigo-700">
                                                    {{ forecast.produit.categorie.nom }}
                                                </span>
                                            {% else %}
                                                <span class="text-slate-400">-</span>
                                            {% endif %}
                                        </td>
                                        <td class="py-4 px-4 text-center">
                                            <span class="inline-flex items-center px-4 py-2 rounded-xl bg-orange-100 text-orange-700 font-bold text-lg">
                                                {{ forecast.predictedDemand }}
                                            </span>
                                        </td>
                                        <td class="py-4 px-4 text-center">
                                            <div class="flex items-center justify-center gap-2">
                                                <div class="w-16 bg-slate-200 rounded-full h-2">
                                                    <div class="bg-indigo-600 h-2 rounded-full" style="width: {{ forecast.confidence }}%"></div>
                                                </div>
                                                <span class="text-sm font-medium text-slate-600">{{ forecast.confidence }}%</span>
                                            </div>
                                        </td>
                                        <td class="py-4 px-4 text-center">
                                            {% if forecast.trend == 'rising' %}
                                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-bold bg-green-100 text-green-700">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
                                                    </svg>
                                                    Rising
                                                </span>
                                            {% elseif forecast.trend == 'falling' %}
                                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-bold bg-red-100 text-red-700">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                                                    </svg>
                                                    Falling
                                                </span>
                                            {% else %}
                                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-bold bg-slate-100 text-slate-700">
                                                    Stable
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td class="py-4 px-4 text-center">
                                            <span class="font-bold {% if forecast.growthRate > 0 %}text-green-600{% elseif forecast.growthRate < 0 %}text-red-600{% else %}text-slate-600{% endif %}">
                                                {{ forecast.growthRate > 0 ? '+' : '' }}{{ forecast.growthRate|number_format(1) }}%
                                            </span>
                                        </td>
                                        <td class="py-4 px-4 text-center">
                                            {% set stock = forecast.produit.quantite ?? 0 %}
                                            {% set risk = stock < forecast.predictedDemand %}
                                            <span class="font-bold {% if risk %}text-red-600{% else %}text-green-600{% endif %}">
                                                {{ stock }}
                                                {% if risk %}
                                                    <span class="text-xs text-red-500 block">⚠️ Reorder needed</span>
                                                {% endif %}
                                            </span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-12">
                        <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                        <p class="text-slate-500">No forecast data available. Generate forecasts to see predictions.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Rising Trend Products -->
    {% if risingTrendProducts|length > 0 %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
        <div class="bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden">
            <div class="bg-gradient-to-r from-green-500 to-teal-500 px-6 py-4">
                <h2 class="text-xl font-black text-white flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                    📈 Rising Trend Products
                </h2>
                <p class="text-green-100 text-sm mt-1">Products with increasing popularity - consider stocking up</p>
            </div>
            
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {% for forecast in risingTrendProducts|slice(0, 6) %}
                        <div class="border border-slate-200 rounded-xl p-4 hover:shadow-md transition-shadow">
                            <div class="flex items-center justify-between mb-2">
                                <span class="font-bold text-slate-900 truncate">{{ forecast.produit.nom }}</span>
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">
                                    +{{ forecast.growthRate|number_format(0) }}%
                                </span>
                            </div>
                            <div class="flex items-center justify-between text-sm">
                                <span class="text-slate-500">Predicted: <span class="font-bold text-slate-900">{{ forecast.predictedDemand }}</span></span>
                                <span class="text-slate-500">Stock: <span class="font-bold {% if (forecast.produit.quantite ?? 0) < forecast.predictedDemand %}text-red-600{% else %}text-green-600{% endif %}">{{ forecast.produit.quantite ?? 0 }}</span></span>
                            </div>
                            <div class="mt-3">
                                <div class="flex items-center gap-2">
                                    <div class="flex-1 bg-slate-200 rounded-full h-2">
                                        <div class="bg-green-500 h-2 rounded-full" style="width: {{ min(100, (forecast.growthRate + 50)) }}%"></div>
                                    </div>
                                    <span class="text-xs font-medium text-green-600">{{ forecast.confidence }}% confidence</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
