<button type="button"
    class="px-3 py-1.5 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors inline-flex items-center gap-1.5"
    onclick="document.getElementById('delete-modal-{{ station.id }}').classList.remove('hidden')">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
    </svg>
    Delete
</button>

<!-- Delete Confirmation Modal -->
<div id="delete-modal-{{ station.id }}" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Backdrop -->
        <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity" onclick="document.getElementById('delete-modal-{{ station.id }}').classList.add('hidden')"></div>

        <!-- Modal Panel -->
        <div class="relative inline-block bg-white rounded-2xl shadow-2xl text-left overflow-hidden transform transition-all sm:my-8 sm:max-w-md sm:w-full">
            <!-- Icon Header -->
            <div class="bg-red-50 px-6 py-5 flex items-center justify-center">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center">
                    <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                </div>
            </div>

            <!-- Content -->
            <div class="px-6 pt-4 pb-6 sm:pb-4">
                <div class="text-center">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2" id="modal-title">Delete Station</h3>
                    <p class="text-gray-500 text-sm">Are you sure you want to delete this observation station? This action cannot be undone.</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="px-6 pb-6 sm:px-6 sm:flex sm:flex-row-reverse gap-3">
                <form method="post" action="{{ path('app_admin_stations_delete', {'id': station.id }) }}" class="flex-1">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ station.id) }}">
                    <button type="submit" 
                        class="w-full inline-flex justify-center items-center px-4 py-2.5 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-300 transition-all shadow-md hover:shadow-lg">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                        Delete
                    </button>
                </form>
                <button type="button"
                    class="mt-3 sm:mt-0 flex-1 inline-flex justify-center items-center px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-300 transition-all"
                    onclick="document.getElementById('delete-modal-{{ station.id }}').classList.add('hidden')">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>
