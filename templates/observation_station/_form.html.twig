{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'space-y-6'}}) }}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="form-group">
            <label for="{{ form.code.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
                {{ form_label(form.code) }}
            </label>
            {% set code_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Enter station code'} %}
            {% if not form.code.vars.valid %}{% set code_attr = code_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
            {{ form_widget(form.code, {'attr': code_attr, 'errors': false}) }}
            <div class="text-red-500 text-sm mt-1 font-medium" style="color: #ef4444;">{{ form_errors(form.code) }}</div>
        </div>
        <div class="form-group">
            <label for="{{ form.zone.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                </svg>
                {{ form_label(form.zone) }}
            </label>
            {% set zone_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Enter zone name'} %}
            {% if not form.zone.vars.valid %}{% set zone_attr = zone_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
            {{ form_widget(form.zone, {'attr': zone_attr, 'errors': false}) }}
            <div class="text-red-500 text-sm mt-1 font-medium" style="color: #ef4444;">{{ form_errors(form.zone) }}</div>
        </div>
        <div class="form-group">
            <label for="{{ form.localisation.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                {{ form_label(form.localisation) }}
            </label>
            {% set localisation_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white', 'placeholder': 'Enter location'} %}
            {% if not form.localisation.vars.valid %}{% set localisation_attr = localisation_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
            {{ form_widget(form.localisation, {'attr': localisation_attr, 'errors': false}) }}
            <div class="text-red-500 text-sm mt-1 font-medium" style="color: #ef4444;">{{ form_errors(form.localisation) }}</div>
        </div>
        <div class="form-group">
            <label for="{{ form.statut.vars.id }}" class="block text-sm font-medium text-gray-700 mb-2">
                <svg class="w-4 h-4 inline-block mr-1 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                {{ form_label(form.statut) }}
            </label>
            {% set statut_attr = {'class': 'w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-orange-500 transition-colors bg-gray-50 hover:bg-white'} %}
            {% if not form.statut.vars.valid %}{% set statut_attr = statut_attr|merge({'class': 'w-full px-4 py-2.5 border border-red-500 rounded-lg focus:ring-2 focus:ring-red-500 transition-colors bg-gray-50 hover:bg-white'}) %}{% endif %}
            {{ form_widget(form.statut, {'attr': statut_attr, 'errors': false}) }}
            <div class="text-red-500 text-sm mt-1 font-medium" style="color: #ef4444;">{{ form_errors(form.statut) }}</div>
        </div>
    </div>
</div>

<div class="flex items-center justify-between pt-4">
    <a href="{{ path('app_admin_stations') }}" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 hover:text-gray-800 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to list
    </a>
    <button type="submit" class="inline-flex items-center px-6 py-2.5 text-sm font-medium text-white bg-orange-500 rounded-lg hover:bg-orange-600 focus:ring-4 focus:ring-orange-200 transition-all shadow-md hover:shadow-lg">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        {{ button_label|default('Save') }}
    </button>
</div>

{{ form_end(form) }}
