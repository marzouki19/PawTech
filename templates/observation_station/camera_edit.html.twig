{% extends 'layout.html.twig' %}

{% block title %}{{ page_title }} | PawTech{% endblock %}

{% block main %}
<div class="px-4 sm:px-6 lg:px-8 py-8 max-w-[1600px] mx-auto">
    <!-- Header -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6 shadow-sm">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div class="flex items-start gap-4 flex-1">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-blue-500 to-blue-600">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <div>
                    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                        <a href="{{ path('app_admin_stations') }}" class="hover:text-gray-700 transition">Stations</a>
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <a href="{{ path('app_admin_station_dashboard', {'id': station.id}) }}" class="hover:text-gray-700 transition">{{ station.code }}</a>
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <a href="{{ path('app_admin_station_cameras', {'id': station.id}) }}" class="hover:text-gray-700 transition">Cameras</a>
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-gray-900 font-medium">Edit</span>
                    </nav>
                    <h1 class="text-2xl font-bold text-gray-900">Edit Camera</h1>
                    <p class="mt-1 text-sm text-gray-600">Station: {{ station.code }} ({{ station.zone }})</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">
            {{ message }}
        </div>
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Form -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        {{ form_label(form.name, 'Camera Name', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                        {{ form_errors(form.name, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.model, 'Model', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.model, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'placeholder': 'e.g., QC5-1080P'}}) }}
                        {{ form_errors(form.model, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.ipAddress, 'IP Address', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.ipAddress, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'placeholder': '192.168.1.100'}}) }}
                        {{ form_errors(form.ipAddress, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.port, 'Port', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.port, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                        {{ form_errors(form.port, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.username, 'Username', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.username, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                        {{ form_errors(form.username, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.password, 'Password', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.password, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                        {{ form_errors(form.password, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>
                </div>

                <!-- Stream URLs -->
                <div class="border-t border-gray-200 pt-6 mt-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Stream Configuration</h3>
                    <div class="grid grid-cols-1 gap-6">
                        <div>
                            {{ form_label(form.streamUrl, 'Stream URL (RTSP/HTTP)', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.streamUrl, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'placeholder': 'rtsp://192.168.1.100:554/stream or /stream'}}) }}
                            {{ form_errors(form.streamUrl, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.rtspUrl, 'RTSP URL', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.rtspUrl, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'placeholder': 'rtsp://192.168.1.162:554/stream'}}) }}
                            {{ form_errors(form.rtspUrl, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.snapshotUrl, 'Snapshot URL', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.snapshotUrl, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500', 'placeholder': '/snapshot.jpg'}}) }}
                            {{ form_errors(form.snapshotUrl, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>
                    </div>
                </div>

                <!-- Additional Settings -->
                <div class="border-t border-gray-200 pt-6 mt-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Additional Settings</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            {{ form_label(form.resolution, 'Resolution', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.resolution, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                            {{ form_errors(form.resolution, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.status, 'Status', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.status, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                            {{ form_errors(form.status, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.station, 'Station', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.station, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'}}) }}
                            {{ form_errors(form.station, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-between gap-3 pt-6 border-t border-gray-200">
                    <form method="post" action="{{ path('app_admin_station_camera_delete', {'stationId': station.id, 'id': camera.id}) }}" onsubmit="return confirm('Are you sure you want to delete this camera?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_camera' ~ camera.id) }}">
                        <button type="submit" class="px-4 py-2 text-sm font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100">
                            Delete Camera
                        </button>
                    </form>
                    <div class="flex items-center gap-3">
                        <a href="{{ path('app_admin_station_cameras', {'id': station.id}) }}" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">
                            Cancel
                        </a>
                        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-500 rounded-lg hover:bg-blue-600">
                            Update Camera
                        </button>
                    </div>
                </div>

                {{ form_end(form) }}
            </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
            <!-- Camera Preview -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Camera Preview</h3>
                <div class="aspect-video bg-gray-900 rounded-lg overflow-hidden">
                    {% if camera.streamUrl %}
                        <iframe 
                            src="{{ camera.streamUrl }}" 
                            class="w-full h-full"
                            allowfullscreen>
                        </iframe>
                    {% else %}
                        <div class="flex items-center justify-center h-full text-gray-400">
                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Camera Info -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Camera Information</h3>
                <dl class="space-y-3">
                    <div class="flex justify-between">
                        <dt class="text-sm text-gray-500">Camera ID</dt>
                        <dd class="text-sm font-medium text-gray-900">{{ camera.id }}</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-sm text-gray-500">Created</dt>
                        <dd class="text-sm font-medium text-gray-900">{{ camera.createdAt|date('Y-m-d H:i') }}</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-sm text-gray-500">Last Connection</dt>
                        <dd class="text-sm font-medium text-gray-900">
                            {% if camera.lastConnection %}
                                {{ camera.lastConnection|date('Y-m-d H:i') }}
                            {% else %}
                                Never
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}
