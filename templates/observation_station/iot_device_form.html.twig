{% extends 'layout.html.twig' %}

{% block title %}{{ page_title }} | PawTech{% endblock %}

{% block main %}
<div class="px-4 sm:px-6 lg:px-8 py-8 max-w-[1600px] mx-auto">
    <!-- Header -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6 shadow-sm">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div class="flex items-start gap-4 flex-1">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-orange-500 to-orange-600">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                    </svg>
                </div>
                <div>
                    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                        <a href="{{ path('app_admin_stations') }}" class="hover:text-gray-700 transition">Stations</a>
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <a href="{{ path('app_admin_station_dashboard', {'id': station.id}) }}" class="hover:text-gray-700 transition">{{ station.code }}</a>
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <a href="{{ path('app_admin_station_iot_devices', {'id': station.id}) }}" class="hover:text-gray-700 transition">IoT Devices</a>
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-gray-900 font-medium">{{ device.id ? 'Edit' : 'Add' }}</span>
                    </nav>
                    <h1 class="text-2xl font-bold text-gray-900">
                        {{ device.id ? 'Edit IoT Device' : 'Add New IoT Device' }}
                    </h1>
                    <p class="mt-1 text-sm text-gray-600">Station: {{ station.code }} ({{ station.zone }})</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Form -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        {{ form_label(form.name, 'Device Name', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500'}}) }}
                        {{ form_errors(form.name, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.deviceType, 'Device Type', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.deviceType, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500'}}) }}
                        {{ form_errors(form.deviceType, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.deviceId, 'Device ID', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.deviceId, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 font-mono'}}) }}
                        {{ form_errors(form.deviceId, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.status, 'Status', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.status, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500'}}) }}
                        {{ form_errors(form.status, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>

                    <div>
                        {{ form_label(form.firmwareVersion, 'Firmware Version', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.firmwareVersion, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500'}}) }}
                        {{ form_errors(form.firmwareVersion, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                    </div>
                </div>

                <!-- WiFi Configuration -->
                <div class="border-t border-gray-200 pt-6 mt-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">WiFi Configuration</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            {{ form_label(form.wifiSsid, 'WiFi SSID', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.wifiSsid, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500'}}) }}
                            {{ form_errors(form.wifiSsid, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.wifiPassword, 'WiFi Password', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.wifiPassword, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500'}}) }}
                            {{ form_errors(form.wifiPassword, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>
                    </div>
                </div>

                <!-- API Configuration -->
                <div class="border-t border-gray-200 pt-6 mt-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">API Configuration</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            {{ form_label(form.apiServerUrl, 'API Server URL', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.apiServerUrl, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500', 'placeholder': 'http://192.168.1.117:8000'}}) }}
                            {{ form_errors(form.apiServerUrl, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.apiEndpoint, 'API Endpoint', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.apiEndpoint, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500', 'placeholder': '/admin/api/iot/data'}}) }}
                            {{ form_errors(form.apiEndpoint, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>
                    </div>
                </div>

                <!-- Reporting Intervals -->
                <div class="border-t border-gray-200 pt-6 mt-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Reporting Intervals</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            {{ form_label(form.reportingInterval, 'Reporting Interval (seconds)', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.reportingInterval, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500', 'placeholder': '60'}}) }}
                            {{ form_errors(form.reportingInterval, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>

                        <div>
                            {{ form_label(form.heartbeatInterval, 'Heartbeat Interval (seconds)', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.heartbeatInterval, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500', 'placeholder': '300'}}) }}
                            {{ form_errors(form.heartbeatInterval, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
                    <a href="{{ path('app_admin_station_iot_devices', {'id': station.id}) }}" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">
                        Cancel
                    </a>
                    <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-orange-500 rounded-lg hover:bg-orange-600">
                        {{ device.id ? 'Update Device' : 'Add Device' }}
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
            <!-- Device Info -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Device Information</h3>
                <dl class="space-y-3">
                    <div class="flex justify-between">
                        <dt class="text-sm text-gray-500">Station</dt>
                        <dd class="text-sm font-medium text-gray-900">{{ station.code }}</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-sm text-gray-500">Zone</dt>
                        <dd class="text-sm font-medium text-gray-900">{{ station.zone }}</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-sm text-gray-500">Station Status</dt>
                        <dd class="text-sm font-medium">
                            {% if station.statut == 'active' %}
                                <span class="text-green-600">Active</span>
                            {% else %}
                                <span class="text-gray-600">{{ station.statut }}</span>
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            </div>

            <!-- ESP32 Configuration Guide -->
            <div class="bg-orange-50 rounded-xl border border-orange-200 shadow-sm p-6">
                <h3 class="text-lg font-semibold text-orange-900 mb-4">ESP32 Configuration</h3>
                <p class="text-sm text-orange-800 mb-4">
                    To configure your ESP32 device, update the code with the following:
                </p>
                <div class="bg-white rounded-lg p-4 font-mono text-xs text-gray-700 overflow-x-auto">
                    <p class="text-gray-500">// In your ESP32 code</p>
                    <p>const char* DEVICE_ID = "{{ device.deviceId|default('YOUR_DEVICE_ID') }}";</p>
                </div>
                <p class="text-sm text-orange-800 mt-4">
                    The device will automatically fetch its configuration from the server on startup.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
