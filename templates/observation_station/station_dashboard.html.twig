{% block javascripts %}
{{ parent() }}
<!-- Leaflet CSS & JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const stationId = {{ station.id }};
const stationDataUrl = `/admin/stations/${stationId}/data`;
const stationCameraIds = [{% for camera in cameras|slice(0, 2) %}{{ camera.id }}{% if not loop.last %}, {% endif %}{% endfor %}];

// Time range for IoT data
let iotTimeRange = 'hour'; // hour, day, week
const APP_TIMEZONE = {{ (app_timezone|default('UTC'))|json_encode|raw }};
const IOT_REFRESH_INTERVAL = 1000;
const CAMERA_FRAME_INTERVAL = 90;
const CAMERA_FRAME_RETRY_INTERVAL = 450;
const STREAM_START_RETRY_MS = 10000;
const PTZ_REFRESH_INTERVAL = 2500;
const PTZ_TIMEOUT_SECONDS = 3;

let stationLiveStatusInterval = null;
let stationIotInterval = null;
let stationIotChart = null;
const stationCameraState = {};
const stationPtzState = {};

function setCameraFallback(cameraId, show) {
    const fallback = document.getElementById(`camera-frame-fallback-${cameraId}`);
    if (!fallback) return;
    fallback.classList.toggle('hidden', !show);
    fallback.classList.toggle('flex', show);
}

function scheduleNextCameraFrame(cameraId, delayMs) {
    const state = stationCameraState[cameraId];
    if (!state) return;
    if (state.frameTimer) clearTimeout(state.frameTimer);
    state.frameTimer = setTimeout(() => requestCameraFrame(cameraId), delayMs);
}

function requestCameraFrame(cameraId) {
    const state = stationCameraState[cameraId];
    const image = document.getElementById(`camera-frame-${cameraId}`);
    if (!state || !image || state.inFlight) return;
    state.inFlight = true;
    image.src = `/admin/cameras/${cameraId}/frame.jpg?t=${Date.now()}`;
}

function startCameraStream(cameraId) {
    return fetch(`/admin/stations/cameras/${cameraId}/stream/start`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
    })
    .then((response) => response.json())
    .then((payload) => payload.success === true)
    .catch(() => false);
}

function initCameraPreview(cameraId) {
    const image = document.getElementById(`camera-frame-${cameraId}`);
    if (!image) return;

    stationCameraState[cameraId] = {
        inFlight: false,
        failures: 0,
        frameTimer: null,
        lastStartAttempt: 0,
    };

    image.addEventListener('load', () => {
        const state = stationCameraState[cameraId];
        if (!state) return;
        state.inFlight = false;
        state.failures = 0;
        setCameraFallback(cameraId, false);
        scheduleNextCameraFrame(cameraId, CAMERA_FRAME_INTERVAL);
    });

    image.addEventListener('error', () => {
        const state = stationCameraState[cameraId];
        if (!state) return;

        state.inFlight = false;
        state.failures += 1;

        const now = Date.now();
        if (now - state.lastStartAttempt > STREAM_START_RETRY_MS) {
            state.lastStartAttempt = now;
            startCameraStream(cameraId);
        }

        if (state.failures >= 3) {
            setCameraFallback(cameraId, true);
        }

        scheduleNextCameraFrame(cameraId, CAMERA_FRAME_RETRY_INTERVAL);
    });

    requestCameraFrame(cameraId);
}

function sendPtzCommand(cameraId, action, timeout = null) {
    const body = { action };
    if (timeout) {
        body.timeout = timeout;
    }

    return fetch(`/admin/stations/cameras/${cameraId}/control`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
    })
    .then((response) => response.json())
    .then((data) => {
        if (!data.success) {
            const errorMessage = data.error || data.message || 'PTZ command failed';
            throw new Error(errorMessage);
        }
        return data;
    })
    .catch((error) => {
        console.error(`PTZ error for camera ${cameraId}:`, error);
        return null;
    });
}

function startPtzHold(cameraId, action) {
    const state = stationPtzState[cameraId] || { interval: null, action: null };
    if (state.interval) {
        clearInterval(state.interval);
    }

    state.action = action;
    sendPtzCommand(cameraId, action, PTZ_TIMEOUT_SECONDS);
    state.interval = setInterval(() => {
        if (state.action) {
            sendPtzCommand(cameraId, state.action, PTZ_TIMEOUT_SECONDS);
        }
    }, PTZ_REFRESH_INTERVAL);

    stationPtzState[cameraId] = state;
}

function stopPtzHold(cameraId) {
    const state = stationPtzState[cameraId];
    if (!state) return;

    if (state.interval) {
        clearInterval(state.interval);
        state.interval = null;
    }

    if (state.action) {
        sendPtzCommand(cameraId, 'ptz_stop');
        state.action = null;
    }
}

function initStationPtzControls() {
    const buttons = document.querySelectorAll('[data-ptz-camera-id][data-ptz-action]');
    buttons.forEach((button) => {
        const cameraId = Number(button.dataset.ptzCameraId);
        const action = button.dataset.ptzAction;
        const isHoldButton = button.dataset.ptzHold === 'true';

        if (!Number.isFinite(cameraId) || !action) return;

        if (!isHoldButton) {
            button.addEventListener('click', (event) => {
                event.preventDefault();
                sendPtzCommand(cameraId, action);
            });
            return;
        }

        const start = (event) => {
            event.preventDefault();
            startPtzHold(cameraId, action);
        };

        const stop = () => stopPtzHold(cameraId);

        button.addEventListener('mousedown', start);
        button.addEventListener('mouseup', stop);
        button.addEventListener('mouseleave', stop);
        button.addEventListener('touchstart', start, { passive: false });
        button.addEventListener('touchend', stop);
        button.addEventListener('touchcancel', stop);
    });

    document.addEventListener('mouseup', () => {
        stationCameraIds.forEach((cameraId) => stopPtzHold(cameraId));
    });
    document.addEventListener('touchend', () => {
        stationCameraIds.forEach((cameraId) => stopPtzHold(cameraId));
    }, { passive: true });
}

function updateStationCameraLiveStatus(cameraId, data) {
    const badge = document.getElementById(`camera-live-status-${cameraId}`);
    if (!badge) return;

    const dogCount = Number(data?.dogCount || 0);
    const detections = Array.isArray(data?.detections) ? data.detections : [];
    const illCount = detections.filter(d => (d.health_label || '').toLowerCase() === 'ill').length;
    const stale = Boolean(data?.stale);

    badge.className = 'mt-2 text-xs inline-flex items-center px-2 py-1 rounded';
    if (stale) {
        badge.classList.add('bg-yellow-100', 'text-yellow-800');
        badge.textContent = 'AI: stale';
        return;
    }
    if (illCount > 0) {
        badge.classList.add('bg-red-100', 'text-red-700');
    } else if (dogCount > 0) {
        badge.classList.add('bg-green-100', 'text-green-700');
    } else {
        badge.classList.add('bg-gray-100', 'text-gray-600');
    }
    badge.textContent = `AI: dogs ${dogCount} | ill ${illCount}`;
}

function pollStationLiveStatus() {
    stationCameraIds.forEach((cameraId) => {
        fetch(`/admin/stations/cameras/${cameraId}/live-detections`, { cache: 'no-store' })
            .then(response => response.json())
            .then(data => updateStationCameraLiveStatus(cameraId, data))
            .catch(() => {
                const badge = document.getElementById(`camera-live-status-${cameraId}`);
                if (!badge) return;
                badge.className = 'mt-2 text-xs inline-flex items-center px-2 py-1 rounded bg-gray-100 text-gray-600';
                badge.textContent = 'AI: offline';
            });
    });
}

function setElementText(id, value) {
    const element = document.getElementById(id);
    if (!element) return;
    element.textContent = value;
}

function toNumeric(value) {
    const n = Number(value);
    return Number.isFinite(n) ? n : null;
}

function formatMetric(value, suffix = '') {
    if (value === null || value === undefined || value === '') return 'N/A';
    const n = toNumeric(value);
    if (n === null) return `${value}${suffix}`;
    return `${n.toFixed(1)}${suffix}`;
}

function parseTimestamp(value) {
    if (!value) return null;
    const date = new Date(value);
    if (!Number.isNaN(date.getTime())) return date;

    if (typeof value === 'string') {
        const fallback = new Date(value.replace(' ', 'T'));
        if (!Number.isNaN(fallback.getTime())) return fallback;
    }
    return null;
}

function formatTimestamp(value) {
    const date = parseTimestamp(value);
    if (!date) return '--';
    return date.toLocaleString('en-US', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour12: false,
    });
}

function formatAlertTimestamp(value) {
    const date = parseTimestamp(value);
    if (!date) return '--';
    try {
        const parts = new Intl.DateTimeFormat('en-GB', {
            timeZone: APP_TIMEZONE,
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: false,
        }).formatToParts(date);

        const token = {};
        for (const part of parts) {
            if (part.type !== 'literal') {
                token[part.type] = part.value;
            }
        }

        return `${token.day}/${token.month}/${token.year} ${token.hour}:${token.minute}:${token.second}`;
    } catch (error) {
        return formatTimestamp(value);
    }
}

function escapeHtml(value) {
    return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function updateIotConnectionBadge(latestRow) {
    const badge = document.getElementById('iot-connection-badge');
    if (!badge) return;

    badge.className = 'inline-flex items-center px-2 py-1 rounded';
    if (!latestRow) {
        badge.classList.add('bg-red-100', 'text-red-700');
        badge.textContent = 'ESP32: offline';
        return;
    }

    const timestamp = parseTimestamp(latestRow.createdAtIso || latestRow.createdAt);
    if (!timestamp) {
        badge.classList.add('bg-yellow-100', 'text-yellow-800');
        badge.textContent = 'ESP32: unknown time';
        return;
    }

    const ageSeconds = Math.max(0, (Date.now() - timestamp.getTime()) / 1000);
    if (ageSeconds <= 30) {
        badge.classList.add('bg-green-100', 'text-green-700');
        badge.textContent = 'ESP32: online';
    } else if (ageSeconds <= 120) {
        badge.classList.add('bg-yellow-100', 'text-yellow-800');
        badge.textContent = `ESP32: stale (${Math.round(ageSeconds)}s)`;
    } else {
        badge.classList.add('bg-red-100', 'text-red-700');
        badge.textContent = `ESP32: offline (${Math.round(ageSeconds)}s)`;
    }
}

