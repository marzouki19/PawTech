}

// Time range function
function setIotTimeRange(range, btn = null) {
    iotTimeRange = range;
    
    // Update button styles
    document.querySelectorAll('.time-range-btn').forEach(btn => {
        btn.classList.remove('bg-orange-500', 'text-white');
        btn.classList.add('bg-gray-100', 'text-gray-700');
    });
    if (btn) {
        btn.classList.remove('bg-gray-100', 'text-gray-700');
        btn.classList.add('bg-orange-500', 'text-white');
    }
    
    // Refresh data
    refreshStationIotData();
}

function updateIotChart(rows) {
    const chart = ensureIotChart();
    if (!chart) return;

    // Determine max data points based on time range
    let maxPoints = 60; // default for 1 hour
    if (iotTimeRange === 'day') maxPoints = 288; // 24 hours * 12 (every 5 min)
    if (iotTimeRange === 'week') maxPoints = 336; // 7 days * 48
    
    const ordered = [...rows].reverse().slice(-maxPoints);
    const labels = ordered.map((row) => {
        const date = parseTimestamp(row.createdAtIso || row.createdAt);
        if (!date) return '--';
        if (iotTimeRange === 'week') {
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }
        return date.toLocaleTimeString('en-US', {
            hour: '2-digit',
            minute: '2-digit',
            second: iotTimeRange === 'hour' ? '2-digit' : undefined,
            hour12: false,
        });
    });

    chart.data.labels = labels;
    chart.data.datasets[0].data = ordered.map(row => toNumeric(row.temperature));
    chart.data.datasets[1].data = ordered.map(row => toNumeric(row.humidity));
    chart.data.datasets[2].data = ordered.map(row => toNumeric(row.ultrasonicDistanceCm ?? row.distance));
    chart.data.datasets[3].data = ordered.map(row => toNumeric(row.batteryLevel));
    
    // Update point count display
    const pointCountEl = document.getElementById('data-point-count');
    if (pointCountEl) {
        pointCountEl.textContent = ordered.length;
    }
    
    chart.update('none');
}

function updateIotCards(latestRow) {
    const hasData = Boolean(latestRow);
    const emptyState = document.getElementById('iot-empty-state');
    if (emptyState) {
        emptyState.classList.toggle('hidden', hasData);
    }

    setElementText('iot-temp', hasData ? formatMetric(latestRow.temperature, '°C') : 'N/A');
    setElementText('iot-humidity', hasData ? formatMetric(latestRow.humidity, '%') : 'N/A');
    setElementText('iot-pressure', hasData ? formatMetric(latestRow.pressure, ' hPa') : 'N/A');
    setElementText('iot-battery', hasData ? formatMetric(latestRow.batteryLevel, '%') : 'N/A');
    setElementText('iot-signal', hasData ? formatMetric(latestRow.signalStrength) : 'N/A');
    setElementText('iot-distance', hasData ? formatMetric(latestRow.ultrasonicDistanceCm ?? latestRow.distance, ' cm') : 'N/A');
    setElementText(
        'iot-dog',
        hasData ? (latestRow.dogDetected === true ? 'Yes' : latestRow.dogDetected === false ? 'No' : 'N/A') : 'N/A'
    );
    setElementText(
        'iot-food',
        hasData ? (latestRow.foodDispensed === true ? 'Yes' : latestRow.foodDispensed === false ? 'No' : 'N/A') : 'N/A'
    );

    setElementText('iot-device-type', hasData ? (latestRow.deviceType || 'ESP32') : 'ESP32');
    setElementText('iot-device-id', hasData ? (latestRow.deviceId || 'N/A') : 'N/A');
    setElementText('iot-firmware', hasData ? (latestRow.firmwareVersion || 'N/A') : 'N/A');
    setElementText('iot-last-update', hasData ? formatTimestamp(latestRow.createdAtIso || latestRow.createdAt) : '--');
    updateIotConnectionBadge(latestRow);
}

function updateQuickStats(totals) {
    const iotReadings = Number(totals?.iotReadings);
    const detections = Number(totals?.detections);
    const healthAlerts = Number(totals?.healthAlerts);

    if (Number.isFinite(iotReadings)) {
        setElementText('stat-iot-readings', String(iotReadings));
    }
    if (Number.isFinite(detections)) {
        setElementText('stat-detections', String(detections));
    }
    if (Number.isFinite(healthAlerts)) {
        setElementText('stat-health-alerts', String(healthAlerts));
    }
}

function renderHealthAlerts(alerts) {
    const listEl = document.getElementById('health-alerts-list');
    const emptyEl = document.getElementById('health-alerts-empty');
    if (!listEl || !emptyEl) return;

    if (!Array.isArray(alerts) || alerts.length === 0) {
        listEl.innerHTML = '';
        listEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        return;
    }

    const rows = alerts.slice(0, 5).map((alert) => {
        const status = (alert?.status || 'unread').toLowerCase() === 'read' ? 'Read' : 'Unread';
        const statusClasses = status === 'Read' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700';
        const message = alert?.message ? escapeHtml(alert.message) : 'Health alert';
        const dateText = formatAlertTimestamp(alert?.dateIso || alert?.date);

        return `
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 hover:bg-gray-50">
                <div class="flex-shrink-0 h-10 w-10 rounded-full bg-red-100 flex items-center justify-center">
                    <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">${message}</p>
                    <p class="text-xs text-gray-500">${escapeHtml(dateText)}</p>
                </div>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${statusClasses}">
                    ${status}
                </span>
            </div>
        `;
    });

    listEl.innerHTML = rows.join('');
    listEl.classList.remove('hidden');
    emptyEl.classList.add('hidden');
}

function refreshStationIotData() {
    // Build URL with time range parameter
    let url = stationDataUrl;
    const separator = url.includes('?') ? '&' : '?';
    
    // Add time range parameter
    let hoursBack = 1; // default 1 hour
    if (iotTimeRange === 'day') hoursBack = 24;
    if (iotTimeRange === 'week') hoursBack = 168;
    
    url = `${url}${separator}hours=${hoursBack}&limit=500`;
    
    fetch(url, { cache: 'no-store' })
        .then(response => response.json())
        .then(payload => {
            const rows = Array.isArray(payload?.data) ? payload.data : [];
            const latestRow = rows.length > 0 ? rows[0] : null;
            updateQuickStats(payload?.totals || null);
            if (Array.isArray(payload?.healthAlerts)) {
                renderHealthAlerts(payload.healthAlerts);
            }
            updateIotCards(latestRow);
            updateIotChart(rows);
        })
        .catch(() => {
            updateIotCards(null);
        });
}

// Servo Control Functions
function setServoCommand(command) {
    const deviceId = document.getElementById('iot-device-id')?.textContent || 'IOT_699a3e49033c8';
    const url = `/admin/stations/iot/servo/${deviceId}/set`;
    
    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ command: command })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Update status display
            const statusEl = document.getElementById('servo-status');
            if (statusEl) {
                statusEl.textContent = command.charAt(0).toUpperCase() + command.slice(1);
            }
            
            // Show enhanced notification
            showServoNotification(command);
        } else {
            showServoNotification(command, true);
        }
    })
    .catch(error => {
        console.error('Error sending servo command:', error);
        showServoNotification(command, true);
    });
}

function showServoNotification(command, isError = false) {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = `fixed top-4 right-4 z-50 px-4 py-3 rounded-lg shadow-lg transition-all duration-300 transform translate-y-0 ${isError ? 'bg-red-50 border-l-4 border-red-500' : 'bg-green-50 border-l-4 border-green-500'}`;
    
    // Icon based on command
    let icon = '';
    let title = '';
    let message = '';
    
    switch(command) {
        case 'open':
            icon = '🔓';
            title = 'Servo Opened';
            message = 'Food dispenser is now OPEN. Food will be dispensed.';
            break;
        case 'close':
            icon = '🔒';
            title = 'Servo Closed';
            message = 'Food dispenser is now CLOSED and locked.';
            break;
        case 'auto':
            icon = '🤖';
            title = 'Auto Mode Enabled';
            message = 'Servo will automatically dispense food when a dog is detected.';
            break;
        default:
            icon = '⚙️';
            title = 'Command Sent';
            message = `Servo command '${command}' has been sent.`;
    }
    
    notification.innerHTML = `
        <div class="flex items-start gap-3">
            <div class="text-2xl">${icon}</div>
            <div>
                <h4 class="font-semibold text-sm ${isError ? 'text-red-700' : 'text-green-800'}">${title}</h4>
                <p class="text-xs ${isError ? 'text-red-600' : 'text-green-700'} mt-1">${message}</p>
                <p class="text-xs text-gray-500 mt-2">Status: ${command.toUpperCase()} | ${new Date().toLocaleTimeString()}</p>
            </div>
            <button onclick="this.parentElement.parentElement.remove()" class="ml-2 text-gray-400 hover:text-gray-600">
                ✕
            </button>
        </div>
    `;
    
    document.body.appendChild(notification);
    
    // Auto-remove after 5 seconds
    setTimeout(() => {
        notification.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => notification.remove(), 300);
    }, 5000);
}

function showNotification(message, type) {
    // Legacy function - redirects to showServoNotification
    showServoNotification(message, type === 'error');
}

document.addEventListener('DOMContentLoaded', function() {
    // Initialize Map
    const mapEl = document.getElementById('stationMap');
    if (mapEl && mapEl.dataset.lat && mapEl.dataset.lng) {
        const lat = parseFloat(mapEl.dataset.lat);
        const lng = parseFloat(mapEl.dataset.lng);
        if (Number.isFinite(lat) && Number.isFinite(lng)) {
            const map = L.map('stationMap').setView([lat, lng], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);
            L.marker([lat, lng]).addTo(map)
                .bindPopup(mapEl.dataset.code)
                .openPopup();
        }
    }

    refreshStationIotData();
    stationIotInterval = setInterval(refreshStationIotData, IOT_REFRESH_INTERVAL);

    initStationPtzControls();

    if (stationCameraIds.length > 0) {
        stationCameraIds.forEach((cameraId) => initCameraPreview(cameraId));
        pollStationLiveStatus();
        stationLiveStatusInterval = setInterval(pollStationLiveStatus, 2000);
    }
});

window.addEventListener('beforeunload', function() {
    if (stationLiveStatusInterval) clearInterval(stationLiveStatusInterval);
    if (stationIotInterval) clearInterval(stationIotInterval);
    stationCameraIds.forEach((cameraId) => {
        const state = stationCameraState[cameraId];
        if (state && state.frameTimer) {
            clearTimeout(state.frameTimer);
        }
        stopPtzHold(cameraId);
    });
});
</script>
{% endblock %}
