                                position: 'start'
                            }
                        },
                        tempLow: {
                            type: 'line',
                            yMin: 5,
                            yMax: 5,
                            borderColor: 'rgb(59, 130, 246)',
                            borderWidth: 2,
                            borderDash: [6, 6],
                            label: {
                                display: true,
