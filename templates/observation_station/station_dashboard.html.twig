    if (!chartEl) return null;

    stationIotChart = new Chart(chartEl, {
        type: 'line',
        data: {
            labels: [],
            datasets: [
                {
                    label: 'Temperature (°C)',
                    data: [],
                    yAxisID: 'yTemp',
                    borderColor: 'rgb(59, 130, 246)',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    tension: 0.3,
                    fill: false,
                    pointRadius: 2,
                    pointHoverRadius: 6,
                },
                {
                    label: 'Humidity (%)',
                    data: [],
                    yAxisID: 'yPercent',
                    borderColor: 'rgb(34, 197, 94)',
                    backgroundColor: 'rgba(34, 197, 94, 0.1)',
                    tension: 0.3,
                    fill: false,
                    pointRadius: 2,
                    pointHoverRadius: 6,
                },
                {
                    label: 'Distance (cm)',
                    data: [],
                    yAxisID: 'yDistance',
                    borderColor: 'rgb(168, 85, 247)',
                    backgroundColor: 'rgba(168, 85, 247, 0.1)',
                    borderDash: [5, 5],
                    tension: 0.3,
                    fill: false,
                    pointRadius: 2,
                    pointHoverRadius: 6,
                },
                {
                    label: 'Battery (%)',
                    data: [],
                    yAxisID: 'yPercent',
                    borderColor: 'rgb(234, 179, 😎',
                    backgroundColor: 'rgba(234, 179, 8, 0.1)',
                    borderDash: [3, 3],
                    tension: 0.3,
                    fill: false,
                    pointRadius: 1,
                    pointHoverRadius: 5,
                },
