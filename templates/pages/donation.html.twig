{% extends 'frontend/base.html.twig' %}

{% block title %}Donation - PawTech{% endblock %}

{% block body %}
    <section class="relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-orange-200/70"></div>
            <div class="absolute top-24 right-24 h-80 w-80 rounded-full bg-orange-400/80"></div>
        </div>

        <div class="relative container mx-auto px-4 lg:px-8 py-12 lg:py-16 grid lg:grid-cols-2 gap-10 items-center">
            <div>
                <p class="text-orange-600 font-semibold tracking-wide uppercase text-xs mb-3">Support</p>
                <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight text-gray-900">
                    Help dogs find<br> a better life
                </h1>
                <p class="mt-4 text-gray-600 max-w-xl">
                    Your donation supports rescue, medical care, food, and adoption programs.
                </p>
            </div>
            <div class="relative">
                <div class="relative rounded-3xl bg-white shadow-xl p-6 border border-gray-100">
                    <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-orange-100 via-gray-50 to-orange-200 flex items-center justify-center">
                        <span class="text-gray-500 font-semibold">Donation header image</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container mx-auto px-4 lg:px-8 pb-14">
        <div class="grid lg:grid-cols-2 gap-8 items-start">
            <div class="rounded-3xl bg-white border border-gray-100 shadow-sm p-7">
                <h2 class="text-xl font-extrabold text-gray-900">Make a donation</h2>
                <p class="mt-3 text-gray-600">Choose an amount and fill in the form. Your donation will be recorded.</p>

                {% for message in app.flashes('donation_success') %}
                    <div class="mt-4 p-4 rounded-2xl bg-green-50 border border-green-200 text-green-800 text-sm font-medium" role="alert">
                        {{ message }}
                    </div>
                {% endfor %}

                <!-- Formulaire de donation -->
                {{ form_start(form, { 'attr': { 'class': 'mt-6 space-y-4' } }) }}
                
                <div>
                    <label class="text-sm font-semibold text-gray-700">{{ form.donateur.vars.label }}</label>
                    {{ form_widget(form.donateur, { 'attr': { 'class': 'mt-2 w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400' } }) }}
                    {{ form_errors(form.donateur) }}
                </div>
                
                <div>
                    <label class="text-sm font-semibold text-gray-700">{{ form.email.vars.label }}</label>
                    {{ form_widget(form.email, { 'attr': { 'class': 'mt-2 w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400' } }) }}
                    {{ form_errors(form.email) }}
                </div>
                
                <div>
                    <label class="text-sm font-semibold text-gray-700">{{ form.reference.vars.label }}</label>
                    {{ form_widget(form.reference, { 'attr': { 'class': 'mt-2 w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400', 'rows': 3 } }) }}
                    {{ form_errors(form.reference) }}
                </div>
                
                <!-- Champ de date -->
                {% if form.date is defined %}
                <div>
                    <label class="text-sm font-semibold text-gray-700">{{ form.date.vars.label|default('Date') }}</label>
                    {{ form_widget(form.date, { 'attr': { 'class': 'mt-2 w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400' } }) }}
                    {{ form_errors(form.date) }}
                </div>
                {% endif %}

                <!-- Montant de donation -->
                <div class="mt-6">
                    <label class="text-sm font-semibold text-gray-700">{{ form.montant.vars.label|default('Donation Amount (TND)') }}</label>
                    
                    <!-- Boutons pour choisir le montant -->
                    <div class="mb-4">
                        <p class="text-sm font-medium text-gray-700 mb-3">Select donation amount (TND)</p>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                            {% set amounts = [10, 50, 100, 1000] %}
                            {% for amount in amounts %}
                                <button 
                                    type="button" 
                                    class="amount-btn py-3 px-4 rounded-xl border-2 {% if amount == 50 %}border-orange-500 bg-orange-50 text-orange-700{% else %}border-gray-300 bg-white text-gray-700{% endif %} font-semibold hover:border-orange-400 hover:bg-orange-50 hover:text-orange-700 transition"
                                    onclick="document.getElementById('{{ form.montant.vars.id }}').value = {{ amount }}">
                                    {{ amount }} TND
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                    
                    <!-- Champ de montant -->
                    <div class="relative">
                        {{ form_widget(form.montant, { 'attr': { 
                            'class': 'w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400',
                            'placeholder': 'Enter amount in TND',
                            'min': '1'
                        } }) }}
                        <span class="absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-500">TND</span>
                    </div>
                    {{ form_errors(form.montant) }}
                    
                    {% if form.montant.vars.help is defined %}
                        <p class="mt-1 text-xs text-gray-500">{{ form.montant.vars.help }}</p>
                    {% endif %}
                </div>

                <!-- Informations de paiement -->
                <div class="mt-6 p-5 border border-gray-200 rounded-2xl bg-gray-50">
                    <h3 class="text-lg font-bold text-gray-900 mb-4">Payment Information</h3>
                    
                    <!-- Champ pour la méthode de paiement -->
                    {% if form.methodePaiement is defined %}
                    <div class="mb-4">
                        <label class="text-sm font-medium text-gray-700 mb-2 block">{{ form.methodePaiement.vars.label|default('Payment Method') }}</label>
                        {{ form_widget(form.methodePaiement, { 'attr': { 
                            'class': 'w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400'
                        } }) }}
                        {{ form_errors(form.methodePaiement) }}
                    </div>
                    {% endif %}
                    
                    <!-- Champ pour le numéro de transaction -->
                    {% if form.numeroTransaction is defined %}
                    <div class="mb-4">
                        <label class="text-sm font-medium text-gray-700 mb-2 block">{{ form.numeroTransaction.vars.label|default('Transaction Number') }}</label>
                        {{ form_widget(form.numeroTransaction, { 'attr': { 
                            'class': 'w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400',
                            'placeholder': 'Enter transaction number if applicable'
                        } }) }}
                        {{ form_errors(form.numeroTransaction) }}
                    </div>
                    {% endif %}
                    
                    <!-- Champ pour la date de paiement -->
                    {% if form.datePaiement is defined %}
                    <div class="mb-4">
                        <label class="text-sm font-medium text-gray-700 mb-2 block">{{ form.datePaiement.vars.label|default('Payment Date') }}</label>
                        {{ form_widget(form.datePaiement, { 'attr': { 
                            'class': 'w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-orange-400'
                        } }) }}
                        {{ form_errors(form.datePaiement) }}
                    </div>
                    {% endif %}
                    
                    {% for message in app.flashes('success') %}
                        <div class="mb-4 p-3 rounded-xl bg-green-100 border border-green-300 text-green-800 text-sm font-medium">
                            {{ message }}
                        </div>
                    {% endfor %}
                    
                    <!-- Informations de paiement manuel -->
                    <div class="mt-4 p-4 bg-white rounded-xl border border-gray-200">
                        <h4 class="font-semibold text-gray-900 mb-2">Payment Instructions</h4>
                        <p class="text-sm text-gray-600 mb-2">
                            After submitting your donation, you can pay via:
                        </p>
                        <ul class="text-sm text-gray-600 list-disc pl-5 space-y-1">
                            <li>Bank Transfer: CIH Bank - Account: TN59 1234 5678 9012 3456 7890</li>
                            <li>Cash at our shelter location</li>
                            <li>Check payable to "PawTech Association"</li>
                        </ul>
                    </div>
                </div>

                <!-- Bouton de soumission -->
                <button type="submit" class="w-full rounded-2xl bg-orange-500 px-6 py-3 text-white font-extrabold hover:bg-orange-600 transition mt-4">
                    Submit Donation
                </button>
                
                {{ form_end(form) }}
            </div>

            <div class="space-y-6">
                <div class="rounded-3xl bg-white border border-gray-100 shadow-sm p-7">
                    <h2 class="text-xl font-extrabold text-gray-900">Where your money goes</h2>
                    <div class="mt-5 space-y-4">
                        {% for item in [
                            {label:'Medical care', pct:42},
                            {label:'Food & supplies', pct:28},
                            {label:'Rescue & transport', pct:18},
                            {label:'Shelter support', pct:12}
                        ] %}
                            <div>
                                <div class="flex items-center justify-between text-sm">
                                    <span class="font-semibold text-gray-900">{{ item.label }}</span>
                                    <span class="text-gray-500">{{ item.pct }}%</span>
                                </div>
                                <div class="mt-2 h-2 rounded-full bg-gray-100 overflow-hidden">
                                    <div class="h-full bg-orange-500" style="width: {{ item.pct }}%"></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="rounded-3xl bg-white border border-gray-100 shadow-sm p-7">
                    <h2 class="text-xl font-extrabold text-gray-900">Need help?</h2>
                    <p class="mt-3 text-gray-600">Want to donate supplies or volunteer? Contact us and we'll guide you.</p>
                    <div class="mt-6">
                        <a href="{{ path('app_contact') }}" class="inline-flex items-center rounded-full bg-gray-900 px-6 py-3 text-white font-semibold hover:bg-gray-800 transition">
                            Contact Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}