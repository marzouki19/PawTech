{# Event Recommendation Modal - KNN Based Recommendations #}
<div id="eventRecommendationModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg overflow-hidden">
            <div class="px-6 py-4 bg-gradient-to-r from-orange-500 to-orange-600 flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-bold text-white">Find Your Perfect Event</h3>
                    <p class="text-sm text-orange-100">Tell us your preferences for personalized recommendations</p>
                </div>
                <button type="button" id="closeRecommendationModal" class="h-9 w-9 rounded-full bg-white/20 text-white hover:bg-white/30 flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            
            <form id="eventRecommendationForm" class="px-6 py-5 space-y-5">
                {# Event Type Preference #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">What type of event interests you?</label>
                    <select name="preferred_type" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none">
                        <option value="any">All types</option>
                        <option value="VACCINATION">Vaccination - Pet health campaigns</option>
                        <option value="ADOPTION">Adoption - Find a new family member</option>
                        <option value="SENSIBILISATION">Awareness - Education & outreach</option>
                        <option value="COLLECTE_DONS">Donation Drive - Support the cause</option>
                    </select>
                </div>

                {# City Preference #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Preferred location?</label>
                    <select name="preferred_city" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none">
                        <option value="any">Any city - I can travel</option>
                        {% for ville in villes|default([]) %}
                            <option value="{{ ville }}">{{ ville }}</option>
                        {% endfor %}
                    </select>
                </div>

                {# Time Preference #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">When would you like to attend?</label>
                    <div class="grid grid-cols-2 gap-3">
                        <label class="relative">
                            <input type="radio" name="preferred_timeframe" value="this_week" class="peer sr-only">
                            <div class="px-4 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-sm font-medium">This Week</p>
                            </div>
                        </label>
                        <label class="relative">
                            <input type="radio" name="preferred_timeframe" value="this_month" class="peer sr-only" checked>
                            <div class="px-4 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-sm font-medium">This Month</p>
                            </div>
                        </label>
                        <label class="relative">
                            <input type="radio" name="preferred_timeframe" value="next_month" class="peer sr-only">
                            <div class="px-4 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-sm font-medium">Next Month</p>
                            </div>
                        </label>
                        <label class="relative">
                            <input type="radio" name="preferred_timeframe" value="anytime" class="peer sr-only">
                            <div class="px-4 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-sm font-medium">Anytime</p>
                            </div>
                        </label>
                    </div>
                </div>

                {# Group Size Preference #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Preferred event size?</label>
                    <div class="grid grid-cols-3 gap-3">
                        <label class="relative">
                            <input type="radio" name="group_size" value="small" class="peer sr-only">
                            <div class="px-3 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-xs font-medium">Small</p>
                                <p class="text-xs text-gray-500">&lt; 30</p>
                            </div>
                        </label>
                        <label class="relative">
                            <input type="radio" name="group_size" value="medium" class="peer sr-only" checked>
                            <div class="px-3 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-xs font-medium">Medium</p>
                                <p class="text-xs text-gray-500">30-100</p>
                            </div>
                        </label>
                        <label class="relative">
                            <input type="radio" name="group_size" value="large" class="peer sr-only">
                            <div class="px-3 py-3 border border-gray-200 rounded-xl text-center cursor-pointer peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-700 hover:border-gray-300 transition">
                                <p class="text-xs font-medium">Large</p>
                                <p class="text-xs text-gray-500">100+</p>
                            </div>
                        </label>
                    </div>
                </div>

                {# Submit Buttons #}
                <div class="flex gap-3 pt-2">
                    <button type="button" id="skipRecommendationModal" class="flex-1 px-4 py-3 rounded-xl border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 transition">
                        Skip
                    </button>
                    <button type="submit" class="flex-1 px-4 py-3 rounded-xl bg-orange-500 text-white font-semibold hover:bg-orange-600 transition flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                        </svg>
                        Get Recommendations
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
