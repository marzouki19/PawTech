<script>
var cart = JSON.parse(localStorage.getItem('pawtech_cart')) || [];

document.addEventListener('DOMContentLoaded', function() {
    updateCartBadge();
    renderCartItems();
    loadRecommendations();
    calculateShipping();
    
    var btns = document.querySelectorAll('.add-to-cart-btn');
    for (var i = 0; i < btns.length; i++) {
        btns[i].addEventListener('click', function(e) {
            e.preventDefault();
            var product = {
                id: this.getAttribute('data-product-id'),
                name: this.getAttribute('data-product-name'),
                price: parseFloat(this.getAttribute('data-product-price')),
                stock: parseInt(this.getAttribute('data-product-stock')),
                image: this.getAttribute('data-product-image') || ''
            };
            addToCart(product);
        });
    }

    var buyBtns = document.querySelectorAll('.buy-button');
    for (var i = 0; i < buyBtns.length; i++) {
        buyBtns[i].addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.getAttribute('data-product-id');
            var productName = this.getAttribute('data-product-name');
            var productPrice = this.getAttribute('data-product-price');
            var productStock = this.getAttribute('data-product-stock');
            
            if (parseInt(productStock) <= 0) {
                showToast('This product is out of stock!', 'error');
                return;
            }
            
            // Show custom modal instead of confirm
            showPurchaseModal(productId, productName, productPrice);
        });
    }
    
    var sliders = document.querySelectorAll('.price-slider');
    for (var i = 0; i < sliders.length; i++) {
        sliders[i].addEventListener('input', function() {
            updatePriceFilterDisplay();
        });
    }
});

function addToCart(product) {
    var existingItem = null;
    for (var i = 0; i < cart.length; i++) {
        if (cart[i].id === product.id) {
            existingItem = cart[i];
            break;
        }
    }
    if (existingItem) {
        if (existingItem.quantity < product.stock) {
            existingItem.quantity++;
            showToast(existingItem.name + ' quantity updated!', 'success');
        } else {
            showToast('Maximum stock reached!', 'error');
            return;
        }
    } else {
        cart.push({ id: product.id, name: product.name, price: product.price, stock: product.stock, quantity: 1, image: product.image || '' });
        showToast(product.name + ' added to cart!', 'success');
    }
    saveCart();
    updateCartBadge();
    renderCartItems();
}

function removeFromCart(productId) {
    var itemName = '';
    var newCart = [];
    for (var i = 0; i < cart.length; i++) {
        if (cart[i].id !== productId) {
            newCart.push(cart[i]);
        } else {
            itemName = cart[i].name;
        }
    }
    cart = newCart;
    saveCart();
    updateCartBadge();
    renderCartItems();
    if (itemName) {
        showToast(itemName + ' removed from cart', 'success');
    }
}

function updateCartQuantity(productId, change) {
    for (var i = 0; i < cart.length; i++) {
        if (cart[i].id === productId) {
            var newQty = cart[i].quantity + change;
            if (newQty > 0 && newQty <= cart[i].stock) {
                cart[i].quantity = newQty;
            } else if (newQty <= 0) {
                removeFromCart(productId);
                return;
            }
            break;
        }
    }
    saveCart();
    updateCartBadge();
    renderCartItems();
}

// Toast notification for cart actions
function showToast(message, type = 'success') {
    var toast = document.createElement('div');
    var bgColor = type === 'success' ? 'bg-green-500' : 'bg-red-500';
    var icon = type === 'success' 
        ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'
        : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
    
    toast.className = 'fixed top-6 right-6 z-50 flex items-center gap-3 px-5 py-4 ' + bgColor + ' text-white rounded-2xl shadow-xl transform transition-all duration-300 translate-x-full';
    toast.innerHTML = '<span>' + icon + '</span><span class="font-bold">' + message + '</span>';
    
    document.body.appendChild(toast);
    
    // Animate in
    setTimeout(function() {
        toast.classList.remove('translate-x-full');
    }, 10);
    
    // Animate out
    setTimeout(function() {
        toast.classList.add('translate-x-full');
        setTimeout(function() {
            toast.remove();
        }, 300);
    }, 2500);
}

function saveCart() {
    localStorage.setItem('pawtech_cart', JSON.stringify(cart));
}

function updateCartBadge() {
    var totalItems = 0;
    for (var i = 0; i < cart.length; i++) {
        totalItems += cart[i].quantity;
    }
    var badge = document.getElementById('cartBadge');
    if (badge) {
        badge.textContent = totalItems;
        // Add animation
        badge.classList.add('scale-125');
        setTimeout(function() {
            badge.classList.remove('scale-125');
        }, 200);
    }
}

var SHIPPING_RATES = {
    'tunis': { cost: 8, days: '1-2', multiplier: 1 },
    'north': { cost: 12, days: '2-3', multiplier: 1.5 },
    'south': { cost: 16, days: '3-5', multiplier: 2 },
    'international': { cost: 28, days: '7-14', multiplier: 3.5 }
};
var FREE_SHIPPING_THRESHOLD = 200;

// Show purchase confirmation modal
var currentProductToBuy = null;

function showPurchaseModal(productId, productName, productPrice) {
    currentProductToBuy = productId;
    var modal = document.getElementById('customConfirmModal');
    var modalContent = document.getElementById('customConfirmModalContent');
    var messageEl = document.getElementById('confirmModalMessage');
    
    messageEl.innerHTML = 'Buy <strong>' + productName + '</strong> for <span class="text-orange-600 font-bold text-xl">' + productPrice + ' EUR</span>?';
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    // Animate in
    setTimeout(function() {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
    }, 10);
}
var PER_PRODUCT_SURCHARGE = 2;

function getShippingCost(subtotal, zone, itemCount) {
    var zoneData = SHIPPING_RATES[zone] || SHIPPING_RATES['tunis'];
    if (subtotal >= FREE_SHIPPING_THRESHOLD) return 0;
    return zoneData.cost + (itemCount * PER_PRODUCT_SURCHARGE);
}

function calculateShipping() {
    var zoneEl = document.getElementById('shippingZone');
    var zone = zoneEl ? zoneEl.value : 'tunis';
    var subtotal = 0;
    for (var i = 0; i < cart.length; i++) subtotal += cart[i].price * cart[i].quantity;
    var itemCount = 0;
    for (var i = 0; i < cart.length; i++) itemCount += cart[i].quantity;
    var shippingCostEl = document.getElementById('shippingCost');
    var freeShippingProgress = document.getElementById('freeShippingProgress');
    var freeShippingAmount = document.getElementById('freeShippingAmount');
    var freeShippingBar = document.getElementById('freeShippingBar');
    var shippingCost = getShippingCost(subtotal, zone, itemCount);
    if (subtotal >= FREE_SHIPPING_THRESHOLD) {
        if (freeShippingProgress) freeShippingProgress.classList.add('hidden');
    } else {
        if (freeShippingProgress) freeShippingProgress.classList.remove('hidden');
        var amountNeeded = FREE_SHIPPING_THRESHOLD - subtotal;
        var progress = (subtotal / FREE_SHIPPING_THRESHOLD) * 100;
        if (freeShippingAmount) freeShippingAmount.textContent = amountNeeded.toFixed(2) + ' TND more for FREE shipping!';
        if (freeShippingBar) freeShippingBar.style.width = progress + '%';
    }
    if (shippingCostEl) shippingCostEl.textContent = shippingCost.toFixed(2) + ' TND';
    updateCartTotal(subtotal, shippingCost);
}

function updateCartTotal(passedSubtotal, passedShippingCost) {
    var subtotal = 0;
    for (var i = 0; i < cart.length; i++) subtotal += cart[i].price * cart[i].quantity;
    var zoneEl = document.getElementById('shippingZone');
    var zone = zoneEl ? zoneEl.value : 'tunis';
    var itemCount = 0;
    for (var i = 0; i < cart.length; i++) itemCount += cart[i].quantity;
    var shippingCost = passedShippingCost !== null ? passedShippingCost : getShippingCost(subtotal, zone, itemCount);
    var totalEl = document.getElementById('cartTotal');
    var subtotalEl = document.getElementById('cartSubtotal');
    var shippingEl = document.getElementById('cartShipping');
    var checkoutBtn = document.getElementById('checkoutBtn');
    
    if (subtotalEl) subtotalEl.textContent = subtotal.toFixed(2) + ' TND';
    if (shippingEl) shippingEl.textContent = shippingCost.toFixed(2) + ' TND';
    
    if (cart.length === 0) {
        if (totalEl) { totalEl.textContent = '0.00'; animatePrice(totalEl); }
    } else {
        var total = subtotal + shippingCost;
        if (totalEl) {
            totalEl.textContent = total.toFixed(2);
            animatePrice(totalEl);
        }
    }
    if (checkoutBtn) checkoutBtn.disabled = cart.length === 0;
}

function renderCartItems() {
    var cartItemsEl = document.getElementById('cartItems');
    var cartTotalEl = document.getElementById('cartTotal');
    var cartItemCountEl = document.getElementById('cartItemCount');
    var cartSubtotalEl = document.getElementById('cartSubtotal');
    var cartShippingEl = document.getElementById('cartShipping');
    var checkoutBtn = document.getElementById('checkoutBtn');
    if (!cartItemsEl) return;
    
    if (cart.length === 0) {
        cartItemsEl.innerHTML = '<div class="text-center py-12"><div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center"><svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></div><p class="text-gray-400 font-medium">Your cart is empty</p><p class="text-gray-300 text-sm mt-1">Add some items to get started</p></div>';
        if (cartTotalEl) { cartTotalEl.textContent = '0.00'; animatePrice(cartTotalEl); }
        if (cartSubtotalEl) cartSubtotalEl.textContent = '0.00 TND';
        if (cartShippingEl) cartShippingEl.textContent = '8.00 TND';
        if (cartItemCountEl) cartItemCountEl.textContent = '0 items';
        if (checkoutBtn) checkoutBtn.disabled = true;
        calculateShipping();
        return;
    }
    
    var subtotal = 0;
    var itemCount = 0;
    var html = '<div class="space-y-3">';
    
    for (var i = 0; i < cart.length; i++) {
        var item = cart[i];
        var itemTotal = item.price * item.quantity;
        subtotal += itemTotal;
        itemCount += item.quantity;
        
        // Get image source
        var imageSrc = '/default.png';
        if (item.image) {
            if (item.image.startsWith('http')) {
                imageSrc = item.image;
            } else {
                imageSrc = '/uploads/images/' + item.image;
            }
        }
        
        html += '<div class="flex items-center gap-3 p-3 bg-gradient-to-r from-gray-50 to-white rounded-xl border border-gray-100 hover:border-orange-200 hover:shadow-md transition-all duration-300" style="animation: slideIn 0.3s ease-out ' + (i * 0.05) + 's both;">';
        
        // Product image
        html += '<div class="w-16 h-16 rounded-xl bg-gray-100 overflow-hidden flex-shrink-0 shadow-sm">';
        html += '<img src="' + imageSrc + '" alt="' + item.name + '" class="w-full h-full object-cover" onerror="this.src=\'/default.png\'">';
        html += '</div>';
        
        // Product info
        html += '<div class="flex-1 min-w-0">';
        html += '<p class="font-bold text-gray-900 text-sm truncate hover:text-orange-600 transition-colors">' + item.name + '</p>';
        html += '<p class="text-xs text-gray-500 mt-1">' + item.price.toFixed(2) + ' TND each</p>';
        html += '</div>';
        
        // Quantity controls
        html += '<div class="flex flex-col items-center gap-1">';
        html += '<div class="flex items-center gap-1 bg-white rounded-lg border border-gray-200 p-1">';
        html += '<button onclick="updateCartQuantity(\'' + item.id + '\', -1)" class="w-6 h-6 rounded-md bg-gray-100 hover:bg-orange-100 hover:text-orange-600 flex items-center justify-center text-xs font-bold transition-all">';
        html += '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>';
        html += '</button>';
        html += '<span class="w-6 text-center font-black text-gray-900 text-sm">' + item.quantity + '</span>';
        html += '<button onclick="updateCartQuantity(\'' + item.id + '\', 1)" class="w-6 h-6 rounded-md bg-gray-100 hover:bg-orange-100 hover:text-orange-600 flex items-center justify-center text-xs font-bold transition-all">';
        html += '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>';
        html += '</button>';
        html += '</div>';
        html += '<button onclick="removeFromCart(\'' + item.id + '\')" class="text-xs text-gray-400 hover:text-red-500 transition-colors">Remove</button>';
        html += '</div>';
        
        // Item total
        html += '<div class="text-right flex-shrink-0">';
        html += '<p class="font-black text-orange-600 text-sm">' + itemTotal.toFixed(2) + '</p>';
        html += '<p class="text-xs text-gray-400">TND</p>';
        html += '</div>';
        
        html += '</div>';
    }
    
    html += '</div>';
    
    cartItemsEl.innerHTML = html;
    
    // Calculate shipping
    var zoneEl = document.getElementById('shippingZone');
    var zone = zoneEl ? zoneEl.value : 'tunis';
    var shippingCost = getShippingCost(subtotal, zone, itemCount);
    
    if (cartSubtotalEl) cartSubtotalEl.textContent = subtotal.toFixed(2) + ' TND';
    if (cartShippingEl) cartShippingEl.textContent = shippingCost.toFixed(2) + ' TND';
    if (cartTotalEl) {
        var total = subtotal + shippingCost;
        cartTotalEl.textContent = total.toFixed(2);
        animatePrice(cartTotalEl);
    }
    if (cartItemCountEl) cartItemCountEl.textContent = itemCount + ' item' + (itemCount !== 1 ? 's' : '');
    if (checkoutBtn) checkoutBtn.disabled = false;
}

// Animated price counter
function animatePrice(element) {
    if (!element) return;
    element.classList.add('animate-pulse');
    setTimeout(function() {
        element.classList.remove('animate-pulse');
    }, 300);
}

function openCartSidebar() {
    var sidebar = document.getElementById('cartSidebar');
    var overlay = document.getElementById('cartOverlay');
    if (sidebar) {
        sidebar.classList.remove('opacity-0', 'pointer-events-none');
        sidebar.classList.add('opacity-100');
    }
    if (overlay) overlay.classList.remove('hidden');
}

function closeCartSidebar() {
    var sidebar = document.getElementById('cartSidebar');
    var overlay = document.getElementById('cartOverlay');
    if (sidebar) {
        sidebar.classList.add('opacity-0', 'pointer-events-none');
        sidebar.classList.remove('opacity-100');
    }
    if (overlay) overlay.classList.add('hidden');
}

function getSelectedPaymentMethod() {
    var pmEl = document.getElementById('paymentMethod');
    return pmEl ? pmEl.value : 'local';
}

function loadRecommendations() {
    var grid = document.getElementById('recommendationsGrid');
    if (!grid) return;
    var xhr = new XMLHttpRequest();
    xhr.open('GET', '/api/recommendations/knn?limit=6', true);
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4 && xhr.status === 200) {
            try {
                var products = JSON.parse(xhr.responseText);
                if (products.length === 0) {
                    grid.innerHTML = '<div class="col-span-full text-center py-8 text-gray-500">No recommendations available</div>';
                    return;
                }
                var html = '';
                for (var i = 0; i < products.length; i++) {
                    var product = products[i];
                    var imageSrc = product.image ? (product.image.startsWith('http') ? product.image : '/uploads/images/' + product.image) : '/default.png';
                    var isOutOfStock = product.quantite <= 0;
                    var rating = product.rating || 0;
                    var ratingCount = product.rating_count || 0;
                    var stars = getStarRating(rating);
                    html += '<div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">';
                    html += '<div class="aspect-[4/3] bg-gray-100 relative">';
                    html += '<img src="' + imageSrc + '" alt="' + product.nom + '" class="w-full h-full object-cover">';
                    if (isOutOfStock) html += '<div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center"><span class="text-white font-bold">OUT OF STOCK</span></div>';
                    html += '</div>';
                    html += '<div class="p-4">';
                    html += '<h3 class="font-semibold text-gray-900 truncate">' + product.nom + '</h3>';
                    html += '<div class="flex items-center gap-1 mt-1">';
                    html += '<span class="text-yellow-500 text-sm">' + stars + '</span>';
                    html += '<span class="text-xs text-gray-500">(' + ratingCount + ')</span>';
                    html += '</div>';
                    html += '<p class="text-orange-600 font-bold mt-1">' + product.prix + ' EUR</p>';
                    html += '<p class="text-sm text-gray-500 mt-1">Stock: ' + product.quantite + '</p>';
                    html += '<button type="button" class="snipcart-add-item mt-3 w-full px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition font-semibold"';
                    html += ' data-item-id="' + product.id + '"';
                    html += ' data-item-price="' + product.prix + '"';
                    html += ' data-item-name="' + product.nom + '"';
                    html += ' data-item-url="{{ path('app_shop') }}"';
                    if (isOutOfStock) html += ' disabled';
                    html += '>';
                    html += isOutOfStock ? 'OUT OF STOCK' : 'Add to Cart';
                    html += '</button></div></div>';
                }
                grid.innerHTML = html;
                var newBtns = grid.querySelectorAll('.add-to-cart-btn');
                for (var i = 0; i < newBtns.length; i++) {
                    newBtns[i].addEventListener('click', function(e) {
                        e.preventDefault();
                        var product = {
                            id: this.getAttribute('data-product-id'),
                            name: this.getAttribute('data-product-name'),
                            price: parseFloat(this.getAttribute('data-product-price')),
                            stock: parseInt(this.getAttribute('data-product-stock'))
                        };
                        addToCart(product);
                    });
                }
            } catch (error) {
                console.error('Error loading recommendations:', error);
                grid.innerHTML = '<div class="col-span-full text-center py-8 text-gray-500">Error loading recommendations</div>';
            }
        }
    };
    xhr.send();
}

function getStarRating(rating) {
    var fullStars = Math.floor(rating);
    var hasHalfStar = rating % 1 >= 0.5;
    var stars = '';
    for (var i = 0; i < 5; i++) {
        if (i < fullStars) stars += '<i class="fas fa-star text-yellow-400"></i>';
        else if (i === fullStars && hasHalfStar) stars += '<i class="fas fa-star-half-alt text-yellow-400"></i>';
        else stars += '<i class="far fa-star text-gray-300"></i>';
    }
    return stars;
}

