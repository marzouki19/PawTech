{% extends 'base_front.html.twig' %}

{% block title %}Shop - PawTech{% endblock %}

{% block body %}
    <style>
        /* Custom Range Slider Styling */
        .price-slider {
            -webkit-appearance: none;
            appearance: none;
            height: 8px;
            background: #f3f4f6;
            border-radius: 4px;
            outline: none;
        }
        
        .price-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 2px 6px rgba(249, 115, 22, 0.4);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        
        .price-slider::-webkit-slider-thumb:hover {
            transform: scale(1.15);
            box-shadow: 0 4px 12px rgba(249, 115, 22, 0.5);
        }
        
        .price-slider::-moz-range-thumb {
            width: 20px;
            height: 20px;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            border-radius: 50%;
            cursor: pointer;
            border: none;
            box-shadow: 0 2px 6px rgba(249, 115, 22, 0.4);
        }
        
        /* Smooth scroll behavior */
        html {
            scroll-behavior: smooth;
        }
        
        /* Enhanced animations */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        
        @keyframes pulse-ring {
            0% { transform: scale(0.8); opacity: 1; }
            100% { transform: scale(1.3); opacity: 0; }
        }
        
        @keyframes float-particle {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
            50% { transform: translateY(-20px) rotate(180deg); opacity: 1; }
        }
        
        .animate-float {
            animation: float 3s ease-in-out infinite;
        }
        
        .animate-slide-in {
            animation: slideIn 0.5s ease-out forwards;
        }
        
        .animate-shimmer {
            background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%);
            background-size: 200% 100%;
            animation: shimmer 2s infinite;
        }
        
        /* Product card hover effects */
        .product-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .product-card:hover {
            transform: translateY(-8px);
        }
        
        .product-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 1.5rem;
            padding: 2px;
            background: linear-gradient(135deg, rgba(249, 115, 22, 0.3), transparent, rgba(249, 115, 22, 0.1));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .product-card:hover::before {
            opacity: 1;
        }
        
        /* Sidebar category hover */
        .category-item {
            transition: all 0.2s ease;
        }
        
        .category-item:hover {
            padding-left: 12px;
        }
        
        /* Button press effect */
        .btn-press:active {
            transform: scale(0.98);
        }
        
        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #f97316;
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #ea580c;
        }
        
        /* Enhanced glass morphism */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }
        
        /* Gradient text */
        .text-gradient {
            background: linear-gradient(135deg, #f97316, #ea580c, #fb923c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* Enhanced product image zoom */
        .product-image-container {
            overflow: hidden;
        }
        
        .product-image-container img {
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .product-card:hover .product-image-container img {
            transform: scale(1.12);
        }
        
        /* Quick action buttons */
        .quick-action {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .quick-action:hover {
            transform: scale(1.1);
        }
        
        /* Filter section enhancement */
        .filter-section {
            position: relative;
        }
        
        .filter-section::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(249, 115, 22, 0.2), transparent);
        }
        
        /* Price tag highlight */
        .price-tag {
            position: relative;
        }
        
        .price-tag::before {
            content: '';
            position: absolute;
            inset: -4px -8px;
            background: rgba(249, 115, 22, 0.05);
            border-radius: 8px;
            transform: skewX(-5deg);
            transition: all 0.3s ease;
        }
        
        .product-card:hover .price-tag::before {
            background: rgba(249, 115, 22, 0.1);
            inset: -6px -10px;
        }
        
        /* Stagger animation for products */
        .product-grid .product-card {
            opacity: 0;
            animation: slideIn 0.5s ease-out forwards;
        }
        
        .product-grid .product-card:nth-child(1) { animation-delay: 0.05s; }
        .product-grid .product-card:nth-child(2) { animation-delay: 0.1s; }
        .product-grid .product-card:nth-child(3) { animation-delay: 0.15s; }
        .product-grid .product-card:nth-child(4) { animation-delay: 0.2s; }
        .product-grid .product-card:nth-child(5) { animation-delay: 0.25s; }
        .product-grid .product-card:nth-child(6) { animation-delay: 0.3s; }
        .product-grid .product-card:nth-child(7) { animation-delay: 0.35s; }
        .product-grid .product-card:nth-child(8) { animation-delay: 0.4s; }
    </style>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-orange-50 via-white to-amber-50">
        <div class="absolute inset-0 overflow-hidden">
            <div class="absolute -top-40 -right-40 h-[500px] w-[500px] rounded-full bg-orange-200/30 blur-3xl animate-pulse"></div>
            <div class="absolute top-40 -left-20 h-80 w-80 rounded-full bg-amber-200/40 blur-3xl" style="animation: float 4s ease-in-out infinite;"></div>
            <div class="absolute bottom-0 right-1/4 h-60 w-60 rounded-full bg-orange-100/50 blur-3xl" style="animation: float 5s ease-in-out infinite; animation-delay: 1s;"></div>
            
            <!-- Floating particles -->
            <div class="absolute top-1/4 left-1/4 w-3 h-3 bg-orange-300/40 rounded-full" style="animation: float-particle 6s ease-in-out infinite;"></div>
            <div class="absolute top-1/3 right-1/3 w-2 h-2 bg-amber-400/50 rounded-full" style="animation: float-particle 4s ease-in-out infinite; animation-delay: 0.5s;"></div>
            <div class="absolute bottom-1/3 left-1/2 w-2.5 h-2.5 bg-orange-400/30 rounded-full" style="animation: float-particle 5s ease-in-out infinite; animation-delay: 1.5s;"></div>
        </div>

        <div class="relative container mx-auto px-4 lg:px-8 py-16 lg:py-24">
            <div class="max-w-3xl">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-orange-100 text-orange-700 text-sm font-semibold mb-6 animate-slide-in">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/></svg>
                    Pet Shop
                </span>
                <h1 class="text-5xl lg:text-6xl font-black leading-tight text-gray-900 tracking-tight animate-slide-in" style="animation-delay: 0.1s;">
                    The Friendly & <span class="text-gradient">Caring</span> Store
                </h1>
                <p class="mt-6 text-xl text-gray-600 max-w-xl leading-relaxed animate-slide-in" style="animation-delay: 0.2s;">
                    Everything your dog needs: premium food, fun toys, comfortable carriers, bowls & more.
                </p>
                <div class="mt-8 flex flex-wrap gap-4 animate-slide-in" style="animation-delay: 0.3s;">
                    <a href="#products" class="inline-flex items-center gap-2 px-8 py-4 bg-orange-600 text-white font-bold rounded-2xl shadow-lg shadow-orange-600/30 hover:bg-orange-700 hover:shadow-xl hover:shadow-orange-600/40 transition-all duration-300 transform hover:-translate-y-1 group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                        Browse Products
                    </a>
                    <div class="flex items-center gap-3 px-6 py-4 bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-gray-100">
                        <div class="flex -space-x-2">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center text-white text-sm font-bold border-2 border-white">🐕</div>
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-sm font-bold border-2 border-white">🐶</div>
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gray-700 to-gray-900 flex items-center justify-center text-white text-sm font-bold border-2 border-white">🦴</div>
                        </div>
                        <span class="text-sm font-medium text-gray-600">500+ Happy Dogs</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Decorative wave -->
        <div class="absolute bottom-0 left-0 right-0">
            <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
            </svg>
        </div>
    </section>

    <!-- Recommended Products Section -->
    {% if recommendedProducts is defined and recommendedProducts|length > 0 %}
    <section class="bg-white py-12 border-b border-gray-100">
        <div class="container mx-auto px-4 lg:px-8">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-xs font-bold uppercase tracking-wider mb-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        Top Rated
                    </span>
                    <h2 class="text-3xl font-black text-gray-900">Recommended For You</h2>
                    <p class="text-gray-500 mt-1">Based on customer ratings and popular choices</p>
                </div>
                <a href="#products" class="hidden sm:flex items-center gap-2 px-5 py-2.5 bg-gray-900 text-white font-bold rounded-xl hover:bg-gray-800 transition hover:scale-105">
                    View All
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                {% for p in recommendedProducts %}
                    <a href="#product-{{ p.id }}" class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-orange-200 transition-all duration-300 hover:-translate-y-1">
                        <div class="aspect-square bg-gradient-to-br from-orange-50 to-amber-50 rounded-t-2xl overflow-hidden relative">
                            {% if p.image %}
                                {% if p.image matches '#^https?://#' %}
                                    <img src="{{ p.image }}" alt="{{ p.nom }}" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                {% else %}
                                    <img src="{{ asset('uploads/images/' ~ p.image) }}" alt="{{ p.nom }}" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                {% endif %}
                            {% else %}
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="text-4xl font-black text-orange-200">{{ p.nom|slice(0, 1) }}</span>
                                </div>
                            {% endif %}
                            <div class="absolute top-2 right-2">
                                <span class="flex items-center gap-1 px-2 py-1 bg-white/90 backdrop-blur-sm rounded-lg text-xs font-bold text-orange-600 shadow-sm">
                                    <svg class="w-3 h-3 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/></svg>
                                    {{ p.purchaseCount|default(0) }}
                                </span>
                            </div>
                        </div>
                        <div class="p-3">
                            <p class="font-bold text-gray-900 text-sm truncate group-hover:text-orange-600 transition">{{ p.nom }}</p>
                            <p class="text-lg font-black text-orange-600 mt-1">{{ p.prix|number_format(2, ',', ' ') }} TND</p>
                        </div>
                    </a>
                {% endfor %}
            </div>
            
            <div class="mt-8 text-center sm:hidden">
                <a href="#products" class="inline-flex items-center gap-2 px-6 py-3 bg-gray-900 text-white font-bold rounded-xl hover:bg-gray-800 transition hover:scale-105">
                    View All Products
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>
    </section>
    {% endif %}

    <section class="container mx-auto px-4 xl:px-12 pb-14">
    
    <div class="grid lg:grid-cols-12 gap-8">
            <aside class="lg:col-span-2 xl:col-span-2">
                <div class="rounded-2xl bg-white border border-gray-100 shadow-sm p-5 sticky top-6 glass-card">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center shadow-lg shadow-orange-500/30">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
                        </div>
                        <h2 class="font-extrabold text-gray-900 text-lg">Filter</h2>
                    </div>

                    <div class="mt-5 filter-section pb-5">
                        <h3 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
                            <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                            By categories
                        </h3>
                        <div class="space-y-3">
                            {% set seen_cats = [] %}
                            {% for p in produits %}
                                {% set catName = p.categorie ? p.categorie.nom : '' %}
                                {% set catId = p.categorie ? p.categorie.id : '' %}
                                {% if catName not in seen_cats and catName != '' %}
                                    {% set seen_cats = seen_cats|merge([catName]) %}
                                    <label class="flex items-center gap-3 cursor-pointer group category-item">
                                        <input type="checkbox" 
                                               name="categories" 
                                               value="{{ catId }}"
                                               class="category-checkbox w-5 h-5 rounded border-gray-300 text-orange-500 focus:ring-orange-500 cursor-pointer"
                                               {% if selectedCategorie == catId %}checked{% endif %}
                                               onchange="applyCategoryFilter()">
                                        <span class="text-sm text-gray-600 group-hover:text-orange-600 transition flex-1">{{ catName }}</span>
                                        <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full group-hover:bg-orange-100 group-hover:text-orange-600 transition">{{ produits|filter(p => p.categorie and p.categorie.id == catId)|length }}</span>
                                    </label>
                                {% endif %}
                            {% endfor %}
                            {% if seen_cats is empty %}
                                <p class="text-gray-400 text-sm">No categories</p>
                            {% endif %}
                        </div>
                    </div>

                    <div class="mt-6 filter-section pb-5">
                        <h3 class="text-sm font-bold text-gray-900 flex items-center gap-2">
                            <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Filter by Price
                        </h3>
                        <div class="mt-4">
                            <div class="flex items-center justify-between mb-4 text-sm text-gray-600">
                                <span class="font-semibold bg-orange-50 px-3 py-1 rounded-lg"><span id="min-price-display">{{ minPrice|default(0) }}</span> TND</span>
                                <span class="text-gray-400">—</span>
                                <span class="font-semibold bg-orange-50 px-3 py-1 rounded-lg"><span id="max-price-display">{{ maxPrice|default(300) }}</span> TND</span>
                            </div>
                            
                            <!-- Dual Range Slider -->
                            <div class="relative h-6 flex items-center">
                                <!-- Track background -->
                                <div class="absolute w-full h-2 bg-gray-200 rounded-full"></div>
                                <!-- Active range -->
                                <div id="price-range" class="absolute h-2 bg-gradient-to-r from-orange-400 to-orange-500 rounded-full" style="left: {{ (minPrice|default(0) / 300 * 100) }}%; right: {{ (100 - (maxPrice|default(300) / 300 * 100)) }}%;"></div>
                                
                                <!-- Min thumb -->
                                <input type="range" 
                                       name="min_price" 
                                       min="0" 
                                       max="300" 
                                       value="{{ minPrice|default(0) }}" 
                                       class="absolute w-full h-2 appearance-none bg-transparent pointer-events-none z-20 range-thumb"
                                       id="min-price-slider"
                                       oninput="updateDualSlider()">
                                <!-- Max thumb -->
                                <input type="range" 
                                       name="max_price" 
                                       min="0" 
                                       max="300" 
                                       value="{{ maxPrice|default(300) }}" 
                                       class="absolute w-full h-2 appearance-none bg-transparent pointer-events-none z-20 range-thumb"
                                       id="max-price-slider"
                                       oninput="updateDualSlider()">
                                
                                <!-- Custom thumb indicators -->
                                <div class="dual-slider-thumb" 
                                     id="min-thumb"
                                     style="left: {{ (minPrice|default(0) / 300 * 100) }}%;">
                                </div>
                                <div class="dual-slider-thumb" 
                                     id="max-thumb"
                                     style="left: {{ (maxPrice|default(300) / 300 * 100) }}%;">
                                </div>
                            </div>
                            
                            <form method="get" action="{{ path('app_shop') }}" id="price-filter-form" class="hidden">
                                <input type="hidden" name="categorie" value="{{ selectedCategorie }}">
                                <input type="hidden" name="search" value="{{ search }}">
                                <input type="hidden" name="sort" value="{{ sort }}">
                                <input type="hidden" name="min_price" id="min-price-input" value="{{ minPrice|default('') }}">
                                <input type="hidden" name="max_price" id="max-price-input" value="{{ maxPrice|default('') }}">
                            </form>
                            
                            <button onclick="applyPriceFilter()" 
                                    class="mt-5 w-full rounded-xl bg-gradient-to-r from-orange-500 to-amber-500 px-4 py-3 text-white text-sm font-bold hover:from-orange-600 hover:to-amber-600 transition shadow-lg shadow-orange-500/30">
                                Apply Price Filter
                            </button>
                        </div>
                    </div>
                </div>
            </aside>

            <div class="lg:col-span-9 xl:col-span-10" id="products">
                <!-- Search & Sort Bar -->
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-4 mb-8 glass-card">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <p class="text-sm font-medium text-gray-500 flex items-center gap-2">
                            <span class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-500 to-amber-500 text-white flex items-center justify-center">{{ produits|length }}</span>
                            {% if produits|length > 0 %}
                                Product{% if produits|length != 1 %}s{% endif %} found
                            {% else %}
                                No products found
                            {% endif %}
                        </p>
                        <div class="flex items-center gap-3">
                            <form method="get" action="{{ path('app_shop') }}" class="flex items-center gap-3 flex-1">
                                <input type="hidden" name="categorie" value="{{ selectedCategorie }}">
                                <input type="hidden" name="min_price" value="{{ minPrice|default('') }}">
                                <input type="hidden" name="max_price" value="{{ maxPrice|default('') }}">
                                
                                <div class="relative flex-1 max-w-xs">
                                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-orange-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                                    <input type="text" 
                                           name="search" 
                                           value="{{ search }}" 
                                           class="w-full rounded-2xl border border-gray-200 bg-gray-50 px-5 py-3 pl-12 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:bg-white transition group-focus-within:border-orange-300" 
                                           placeholder="Search products...">
                                </div>
                                
                                <select name="sort" 
                                        class="rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 focus:bg-white transition cursor-pointer hover:border-orange-300"
                                        onchange="this.form.submit()">
                                    <option value="latest" {% if sort == 'latest' %}selected{% endif %}>Newest</option>
                                    <option value="price_low" {% if sort == 'price_low' %}selected{% endif %}>Price: Low → High</option>
                                    <option value="price_high" {% if sort == 'price_high' %}selected{% endif %}>Price: High → Low</option>
                                    <option value="name_asc" {% if sort == 'name_asc' %}selected{% endif %}>Name: A-Z</option>
                                    <option value="name_desc" {% if sort == 'name_desc' %}selected{% endif %}>Name: Z-A</option>
                                </select>
                            </form>
                            
                            <!-- Snipcart Cart Button -->
                            <button class="snipcart-checkout relative flex items-center justify-center w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-white rounded-2xl shadow-lg shadow-orange-500/30 hover:shadow-xl hover:shadow-orange-500/40 transition-all duration-300 hover:-translate-y-1 group">
                                <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                                <span class="snipcart-items-count absolute -top-1 -right-1 bg-red-500 text-white text-xs w-6 h-6 rounded-full flex items-center justify-center font-bold shadow-md">0</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Product Grid -->
                <div class="product-grid grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    {% for p in produits %}
                        <div class="product-card group relative bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-300 hover:-translate-y-2 overflow-hidden">
                            <!-- Product Image -->
                            <div class="product-image-container aspect-[4/3] bg-gradient-to-br from-orange-50 to-amber-50 relative overflow-hidden">
                                {% if p.image %}
                                    {% if p.image matches '#^https?://#' %}
                                        <img src="{{ p.image }}" 
                                             alt="{{ p.nom }}" 
                                             class="w-full h-full object-cover">
                                    {% else %}
                                        <img src="{{ asset('uploads/images/' ~ p.image) }}" 
                                             alt="{{ p.nom }}" 
                                             class="w-full h-full object-cover">
                                    {% endif %}
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center">
                                        <span class="text-7xl font-black text-orange-200 group-hover:text-orange-300 transition">{{ p.nom|slice(0, 1) }}</span>
                                    </div>
                                {% endif %}

                                {% if p.categorie %}
                                    <span class="absolute top-3 left-3 inline-flex items-center rounded-full bg-white/95 backdrop-blur-sm border border-gray-100 px-3 py-1.5 text-xs font-bold text-gray-700 shadow-sm">
                                        {{ p.categorie.nom }}
                                    </span>
                                {% endif %}
                                
                                <!-- Sale badge -->
                                {% if p.prix > 50 %}
                                <div class="absolute top-3 right-3">
                                    <span class="flex items-center gap-1 px-2.5 py-1 bg-gradient-to-r from-red-500 to-rose-500 text-white text-xs font-bold rounded-full shadow-lg">
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm2.5 3a1.5 1.5 0 100 3 1.5 1.5 0 000-3zm6.207.293a1 1 0 00-1.414 0l-6 6a1 1 0 101.414 1.414l6-6a1 1 0 000-1.414zM12.5 10a1.5 1.5 0 100 3 1.5 1.5 0 000-3z" clip-rule="evenodd"/></svg>
                                        HOT
                                    </span>
                                </div>
                                {% endif %}
                                
                                <!-- Quick Add Button -->
                                <div class="absolute bottom-3 right-3 opacity-0 group-hover:opacity-100 transition duration-300 transform translate-y-2 group-hover:translate-y-0 flex gap-2">
                                    <a href="{{ path('app_product_detail', {id: p.id}) }}"
                                            class="quick-action p-3 bg-white rounded-xl shadow-lg hover:bg-orange-500 hover:text-white transition-all duration-200"
                                            title="View details">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                    <button type="button"
                                            class="quick-action snipcart-add-item add-to-cart-btn p-3 bg-white rounded-xl shadow-lg hover:bg-orange-500 hover:text-white transition-all duration-200"
                                            data-item-id="{{ p.id }}"
                                            data-item-price="{{ p.prix }}"
                                            data-item-name="{{ p.nom }}"
                                            data-item-description="{{ p.description|default('') }}"
                                            data-item-url="{{ path('app_shop') }}"
                                            title="Add to cart">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Product Info -->
                            <div class="p-5">
                                <p class="font-black text-lg text-gray-900 group-hover:text-orange-600 transition">{{ p.nom }}</p>
                                <div class="flex items-center gap-1 mt-2">
                                    {% set purchaseCount = p.purchaseCount|default(0) %}
                                    {% set purchaseStars = p.purchaseStars|default(1) %}
                                    {% for i in 1..5 %}
                                        {% if i <= purchaseStars %}
                                            <i class="fas fa-star text-yellow-400 text-sm"></i>
                                        {% else %}
                                            <i class="far fa-star text-gray-300 text-sm"></i>
                                        {% endif %}
                                    {% endfor %}
                                    <span class="text-xs text-gray-500 ml-1">({{ purchaseCount }} sold)</span>
                                </div>
                                <div class="flex items-baseline gap-2 mt-3 price-tag">
                                    <p class="text-2xl font-black text-orange-600">{{ p.prix|number_format(2, ',', ' ') }}</p>
                                    <span class="text-sm font-medium text-gray-400">EUR</span>
                                </div>
                                
                                {% if p.quantite is not null %}
                                    {% set alerte = (p.seuilAlert is not null and p.seuilAlert > 0 and p.quantite <= p.seuilAlert) %}
                                    <p class="mt-2 text-xs font-medium {% if alerte %}text-red-500{% else %}text-gray-400{% endif %}">
                                        {% if alerte %}
                                            <span class="inline-flex items-center gap-1">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                                Low stock: {{ p.quantite }} left
                                            </span>
                                        {% else %}
                                            Stock: {{ p.quantite }}
                                        {% endif %}
                                    </p>
                                {% endif %}
                                
                                <button type="button" 
                                        class="snipcart-add-item w-full mt-4 px-4 py-3.5 text-sm bg-gradient-to-r from-gray-900 to-gray-800 text-white rounded-2xl font-bold hover:from-gray-800 hover:to-gray-700 transition-all duration-200 hover:shadow-lg hover:shadow-gray-900/30 buy-button {% if p.quantite <= 0 %}opacity-50 cursor-not-allowed grayscale{% endif %}"
                                        {% if p.quantite <= 0 %}disabled{% endif %}
                                        data-item-id="{{ p.id }}"
                                        data-item-price="{{ p.prix }}"
                                        data-item-name="{{ p.nom }}"
                                        data-item-description="{{ p.description|default('') }}"
                                        data-item-url="{{ path('app_shop') }}">
                                        {% if p.quantite <= 0 %}
                                            <span class="flex items-center justify-center gap-2">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                                OUT OF STOCK
                                            </span>
                                        {% else %}
                                            <span class="flex items-center justify-center gap-2">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                                                BUY NOW
                                            </span>
                                        {% endif %}
                                    </button>
                            </div>
                        </div>
                    {% else %}
                        <div class="lg:col-span-3 text-center py-16">
                            <div class="relative">
                                <div class="w-32 h-32 mx-auto bg-gradient-to-br from-orange-100 to-amber-100 rounded-full flex items-center justify-center mb-6 shadow-inner">
                                    <svg class="w-16 h-16 text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </div>
                                <div class="absolute top-0 right-1/4 w-6 h-6 bg-amber-200 rounded-full animate-pulse"></div>
                                <div class="absolute bottom-4 left-1/4 w-4 h-4 bg-orange-200 rounded-full animate-pulse" style="animation-delay: 0.5s"></div>
                            </div>
                            <h3 class="text-2xl font-black text-gray-900 mb-2">No Products Found</h3>
                            <p class="text-gray-500 mb-8 max-w-sm mx-auto">We couldn't find any products matching your criteria. Try adjusting your filters or search terms.</p>
                            <a href="{{ path('app_shop') }}" class="inline-flex items-center gap-2 px-8 py-4 bg-orange-600 text-white font-bold rounded-2xl shadow-lg shadow-orange-600/30 hover:bg-orange-700 hover:shadow-xl hover:shadow-orange-600/40 hover:scale-105 transition-all duration-300">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                Clear all filters
                            </a>
                        </div>
                    {% endfor %}
                </div>

                {% if produits|length > 12 %}
                <div class="mt-12 flex items-center justify-center gap-2">
                    <button class="h-12 w-12 rounded-2xl border-2 border-gray-100 bg-white hover:border-orange-400 hover:text-orange-600 hover:shadow-lg transition-all duration-200 flex items-center justify-center font-bold text-gray-600 hover:scale-110">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <button class="h-12 w-12 rounded-2xl border-2 border-orange-500 bg-orange-500 text-white font-bold shadow-lg shadow-orange-500/30 hover:scale-110 transition-transform">1</button>
                    <button class="h-12 w-12 rounded-2xl border-2 border-gray-100 bg-white hover:border-orange-400 hover:text-orange-600 hover:shadow-lg transition-all duration-200 flex items-center justify-center font-bold text-gray-600 hover:scale-110">2</button>
                    <button class="h-12 w-12 rounded-2xl border-2 border-gray-100 bg-white hover:border-orange-400 hover:text-orange-600 hover:shadow-lg transition-all duration-200 flex items-center justify-center font-bold text-gray-600 hover:scale-110">3</button>
                    <button class="h-12 w-12 rounded-2xl border-2 border-gray-100 bg-white hover:border-orange-400 hover:text-orange-600 hover:shadow-lg transition-all duration-200 flex items-center justify-center font-bold text-gray-600 hover:scale-110">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                </div>
                {% endif %}

                <!-- Features Cards -->
                <div class="mt-16 grid md:grid-cols-2 gap-6">
                    <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-orange-50 to-amber-50 border border-orange-100 p-8 hover:shadow-xl hover:shadow-orange-200/30 transition-all duration-300">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-orange-200/30 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:scale-150 transition duration-500"></div>
                        <div class="relative">
                            <div class="w-16 h-16 rounded-3xl bg-orange-500 text-white flex items-center justify-center mb-6 shadow-lg shadow-orange-500/30">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                            </div>
                            <h3 class="text-2xl font-black text-gray-900">Available Products</h3>
                            <p class="mt-2 text-gray-600">Browse our complete collection of premium pet supplies</p>
                        </div>
                    </div>
                    <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-gray-50 to-slate-50 border border-gray-100 p-8 hover:shadow-xl hover:shadow-gray-200/30 transition-all duration-300">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-gray-200/30 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:scale-150 transition duration-500"></div>
                        <div class="relative">
                            <div class="w-16 h-16 rounded-3xl bg-gray-800 text-white flex items-center justify-center mb-6 shadow-lg shadow-gray-800/30">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            </div>
                            <h3 class="text-2xl font-black text-gray-900">Real-time Stock</h3>
                            <p class="mt-2 text-gray-600">Inventory updates instantly - never miss out!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    </div>

    <script>
    // Slide in animation for cart items
    (function() {
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideIn {
                from {
                    opacity: 0;
                    transform: translateX(-20px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }
        `;
        document.head.appendChild(style);
    })();

    // Snipcart Settings
    window.SnipcartSettings = {
        publicApiKey: 'ODc2ZWE3MjMtMmI1Yy00M2FlLWExNDItZDcxZjhmNzliZDlhNjM5MDc3OTgwNzg0MTEzNzA4',
        loadStrategy: 'on-user-interaction',
    };

    // Snipcart custom styling to match the website
    (function() {
        const snipcartStyles = document.createElement('style');
        snipcartStyles.textContent = `
            /* Dual Range Slider Styles - Hide native thumbs */
            .range-thumb {
                -webkit-appearance: none;
                appearance: none;
                width: 100%;
                height: 8px;
                background: transparent;
                cursor: pointer;
                pointer-events: auto;
            }
            
            .range-thumb::-webkit-slider-thumb {
                -webkit-appearance: none;
                appearance: none;
                width: 0;
                height: 0;
                background: transparent;
                border: none;
                pointer-events: none;
            }
            
            .range-thumb::-moz-range-thumb {
                width: 0;
                height: 0;
                background: transparent;
                border: none;
                pointer-events: none;
            }
            
            .range-thumb::-webkit-slider-runnable-track {
                background: transparent;
                height: 8px;
            }
            
            .range-thumb::-moz-range-track {
                background: transparent;
                height: 8px;
            }
            
            .range-thumb:focus {
                outline: none;
            }
            
            /* Custom thumb styling */
            .dual-slider-thumb {
                position: absolute;
                width: 20px;
                height: 20px;
                background: white;
                border: 3px solid #f97316;
                border-radius: 50%;
                cursor: grab;
                box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
                transition: transform 0.1s ease;
                z-index: 10;
            }
            
            .dual-slider-thumb:hover {
                transform: scale(1.15);
            }
            
            .dual-slider-thumb:active {
                cursor: grabbing;
                transform: scale(1.2);
            }
            
            /* Snipcart Modal Custom Styles - Matching PawTech Theme */
            .snipcart-modal__container {
                font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            }
            
            /* Primary color - Orange/Amber from PawTech */
            .snipcart-button-primary,
            .snipcart-item-line__actions .snipcart-item-line__remove,
            .snipcart-checkout__button--primary {
                background: linear-gradient(to right, #f97316, #d97706) !important;
                border-color: #f97316 !important;
            }
            
            .snipcart-button-primary:hover,
            .snipcart-checkout__button--primary:hover {
                background: linear-gradient(to right, #ea580c, #b45309) !important;
                box-shadow: 0 4px 12px rgba(249, 115, 22, 0.4) !important;
            }
            
            /* Secondary buttons */
            .snipcart-button-secondary,
            .snipcart-checkout__button--secondary {
                background: white !important;
                color: #374151 !important;
                border-color: #e5e7eb !important;
            }
            
            .snipcart-button-secondary:hover {
                background: #f9fafb !important;
                border-color: #d1d5db !important;
            }
            
            /* Item line styling */
            .snipcart-item-line {
                padding: 16px !important;
                border-bottom: 1px solid #f3f4f6 !important;
            }
            
            .snipcart-item-line__title {
                color: #111827 !important;
                font-weight: 700 !important;
            }
            
            .snipcart-item-line__unit-price {
                color: #6b7280 !important;
                font-size: 14px !important;
            }
            
            /* Summary and totals */
            .snipcart-summary__title,
            .snipcart-summary__item {
                color: #111827 !important;
            }
            
            .snipcart-summary__total {
                color: #f97316 !important;
                font-weight: 800 !important;
                font-size: 1.25rem !important;
            }
            
            /* Quantity selector */
            .snipcart-quantity-selector {
                border: 1px solid #e5e7eb !important;
                border-radius: 8px !important;
            }
            
            .snipcart-quantity-selector__button {
                background: #f3f4f6 !important;
                color: #374151 !important;
            }
            
            .snipcart-quantity-selector__button:hover {
                background: #e5e7eb !important;
            }
            
            /* Input fields */
            .snipcart-input {
                border: 1px solid #e5e7eb !important;
                border-radius: 12px !important;
                padding: 12px 16px !important;
            }
            
            .snipcart-input:focus {
                border-color: #f97316 !important;
                box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1) !important;
                outline: none !important;
            }
            
            /* Labels */
            .snipcart-form__label {
                color: #374151 !important;
                font-weight: 600 !important;
            }
            
            /* Header */
            .snipcart-modal__header {
                border-bottom: 1px solid #f3f4f6 !important;
                padding: 20px 24px !important;
            }
            
            .snipcart-modal__title {
                color: #111827 !important;
                font-weight: 800 !important;
            }
            
            /* Footer */
            .snipcart-modal__footer {
                border-top: 1px solid #f3f4f6 !important;
                padding: 20px 24px !important;
            }
            
            /* Icon colors */
            .snipcart-icon--blue {
                fill: #f97316 !important;
            }
            
            /* Badge */
            .snipcart-badge__count {
                background: #ef4444 !important;
            }
            
            /* Close button */
            .snipcart-modal__close {
                color: #9ca3af !important;
            }
            
            .snipcart-modal__close:hover {
                color: #4b5563 !important;
            }
            
            /* Empty cart */
            .snipcart-empty-cart__title {
                color: #6b7280 !important;
            }
            
            /* Form sections */
            .snipcart-form__section {
                margin-bottom: 20px !important;
            }
            
            .snipcart-form__row {
                gap: 16px !important;
            }
            
            /* Payment methods */
            .snipcart-payment-methods__item--selected {
                border-color: #f97316 !important;
                background: rgba(249, 115, 22, 0.05) !important;
            }
            
            /* Steps indicator */
            .snipcart-step__icon--current {
                background: #f97316 !important;
                border-color: #f97316 !important;
            }
        `;
        document.head.appendChild(snipcartStyles);
    })();

