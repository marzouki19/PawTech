// Dual range slider functionality
function updateDualSlider() {
    var minSlider = document.getElementById('min-price-slider');
    var maxSlider = document.getElementById('max-price-slider');
    var minThumb = document.getElementById('min-thumb');
    var maxThumb = document.getElementById('max-thumb');
    var rangeTrack = document.getElementById('price-range');
    var minDisplay = document.getElementById('min-price-display');
    var maxDisplay = document.getElementById('max-price-display');
    
    if (!minSlider || !maxSlider) return;
    
    var minVal = parseInt(minSlider.value);
    var maxVal = parseInt(maxSlider.value);
    var maxRange = parseInt(maxSlider.max);
    
    // Ensure min doesn't exceed max
    if (minVal > maxVal) {
        if (this === minSlider) {
            maxSlider.value = minVal;
        } else {
            minSlider.value = maxVal;
        }
    }
    
    // Update display values
    if (minDisplay) minDisplay.textContent = minSlider.value;
    if (maxDisplay) maxDisplay.textContent = maxSlider.value;
    
    // Update custom thumb positions
    if (minThumb) {
        minThumb.style.left = (minVal / maxRange * 100) + '%';
    }
    if (maxThumb) {
        maxThumb.style.left = (maxVal / maxRange * 100) + '%';
    }
    
    // Update range track
    if (rangeTrack) {
        rangeTrack.style.left = (minVal / maxRange * 100) + '%';
        rangeTrack.style.right = (100 - (maxVal / maxRange * 100)) + '%';
    }
    
    // Update hidden inputs
    var minInput = document.getElementById('min-price-input');
    var maxInput = document.getElementById('max-price-input');
    if (minInput) minInput.value = minSlider.value;
    if (maxInput) maxInput.value = maxSlider.value;
}

// Make custom thumb draggable
(function() {
    var minThumb = document.getElementById('min-thumb');
    var maxThumb = document.getElementById('max-thumb');
    var minSlider = document.getElementById('min-price-slider');
    var maxSlider = document.getElementById('max-price-slider');
    
    if (!minThumb || !maxThumb || !minSlider || !maxSlider) return;
    
    var isDragging = false;
    var currentThumb = null;
    var sliderRect = null;
    var maxRange = parseInt(minSlider.max);
    
    function initDrag(e, thumb, slider) {
        isDragging = true;
        currentThumb = thumb;
        sliderRect = slider.getBoundingClientRect();
        e.preventDefault();
    }
    
    function doDrag(e) {
        if (!isDragging || !currentThumb || !sliderRect) return;
        
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var percent = (clientX - sliderRect.left) / sliderRect.width;
        percent = Math.max(0, Math.min(1, percent));
        var value = Math.round(percent * maxRange);
        
        if (currentThumb === minThumb) {
            if (value <= parseInt(maxSlider.value)) {
                minSlider.value = value;
            }
        } else {
            if (value >= parseInt(minSlider.value)) {
                maxSlider.value = value;
            }
        }
        
        updateDualSlider();
    }
    
    function stopDrag() {
        isDragging = false;
        currentThumb = null;
    }
    
    // Add event listeners to thumbs
    minThumb.addEventListener('mousedown', function(e) { initDrag(e, minThumb, minSlider); });
    maxThumb.addEventListener('mousedown', function(e) { initDrag(e, maxThumb, maxSlider); });
    minThumb.addEventListener('touchstart', function(e) { initDrag(e, minThumb, minSlider); });
    maxThumb.addEventListener('touchstart', function(e) { initDrag(e, maxThumb, maxSlider); });
    
    document.addEventListener('mousemove', doDrag);
    document.addEventListener('touchmove', doDrag);
    document.addEventListener('mouseup', stopDrag);
    document.addEventListener('touchend', stopDrag);
})();

function applyPriceFilter() {
    var minSlider = document.getElementById('min-price-slider');
    var maxSlider = document.getElementById('max-price-slider');
    var minInput = document.getElementById('min-price-input');
    var maxInput = document.getElementById('max-price-input');
    var form = document.getElementById('price-filter-form');
    if (minSlider && maxSlider && minInput && maxInput && form) {
        minInput.value = minSlider.value;
        maxInput.value = maxSlider.value;
        form.submit();
    }
}
