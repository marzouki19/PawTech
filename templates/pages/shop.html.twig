    // Inline checkout function that works without the main script
    function checkoutCart() {
        var cart = JSON.parse(localStorage.getItem('pawtech_cart')) || [];
        if (cart.length === 0) {
            alert('Your cart is empty!');
            return;
        }
        
        var checkoutBtn = document.getElementById('checkoutBtn');
        var originalBtnContent = checkoutBtn.innerHTML;
        if (checkoutBtn) {
            checkoutBtn.disabled = true;
            checkoutBtn.innerHTML = '<span class="flex items-center justify-center gap-2"><svg class="w-6 h-6 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Processing...</span>';
        }
        
        var paymentMethodEl = document.getElementById('paymentMethod');
        var paymentMethod = paymentMethodEl ? paymentMethodEl.value : 'local';
        
        var shippingZoneEl = document.getElementById('shippingZone');
        var shippingZone = shippingZoneEl ? shippingZoneEl.value : 'tunis';
        
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/dashboard/eshop/produits/cart/checkout', true);
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                if (xhr.status === 200) {
                    try {
                        var data = JSON.parse(xhr.responseText);
                        if (data.success) {
                            if (data.payment_type === 'stripe') {
                                var orderId = data.order_id || '';
                                var amount = data.total || data.amount || 0;
                                window.location.href = '/stripe/checkout?order_id=' + orderId + '&amount=' + amount;
                            } else {
                                localStorage.setItem('pawtech_cart', '[]');
