<div class="flex gap-2">
  <a href="{{ path('app_eshop_produit_show', { id: produit.id }) }}" class="text-paw-orange hover:underline js-modal-link">View</a>
  <a href="{{ path('app_eshop_produit_edit', { id: produit.id }) }}" class="text-blue-600 hover:underline js-modal-link">Modify</a>
  <form method="post" action="{{ path('app_eshop_produit_delete', { id: produit.id }) }}" class="inline js-delete-form">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
    <button type="button" class="text-red-600 hover:underline js-delete-button" data-message="Delete this product?">Delete</button>
  </form>
</div>
