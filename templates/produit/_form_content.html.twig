{# templates/produit/_form_content.html.twig #}
<div class="max-w-3xl mx-auto">
  <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-orange-500 to-orange-600 px-8 py-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white">{{ page_title }}</h1>
          <p class="text-orange-100 text-sm mt-1">Manage product information</p>
        </div>
      </div>
    </div>

    <div class="p-8">
      {{ form_start(form, {
        'attr': {
          'enctype': 'multipart/form-data',
          'class': 'space-y-6',
          'id': 'product-form',
          'novalidate': 'novalidate'
        }
      }) }}

      {% if not form.vars.valid %}
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          Please review the highlighted fields and try again.
          {{ form_errors(form) }}
        </div>
      {% endif %}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {# Champ NOM #}
        <div>
          {% set nom_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': 'Enter product name', 'data-field': 'nom'} %}
          {% if form.nom.vars.errors|length %}{% set nom_attr = nom_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.nom, {'attr': nom_attr, 'errors': false}) }}
          {% set nom_errors = form.nom.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ nom_errors|length ? '' : 'hidden' }}" data-error-for="nom">
            {% for error in nom_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">2 à 255 caractères.</div>
        </div>

        {# Champ PRIX #}
        <div>
          {% set prix_attr = {'class': 'w-full pl-8 pr-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0.00', 'data-field': 'prix'} %}
          {% if form.prix.vars.errors|length %}{% set prix_attr = prix_attr|merge({'class': 'w-full pl-8 pr-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.prix, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          <div class="relative">
            <span class="absolute left-3 top-3 text-gray-500">$</span>
            {{ form_widget(form.prix, {'attr': prix_attr, 'errors': false}) }}
          </div>
          {% set prix_errors = form.prix.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ prix_errors|length ? '' : 'hidden' }}" data-error-for="prix">
            {% for error in prix_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Nombre positif. Ex: 12.50</div>
        </div>

        {# Champ CATEGORIE #}
        <div>
          {% set categorie_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'data-field': 'categorie'} %}
          {% if form.categorie.vars.errors|length %}{% set categorie_attr = categorie_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.categorie, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.categorie, {'attr': categorie_attr, 'errors': false}) }}
          {% set categorie_errors = form.categorie.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ categorie_errors|length ? '' : 'hidden' }}" data-error-for="categorie">
            {% for error in categorie_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Sélection obligatoire.</div>
        </div>

        {# Champ QUANTITE #}
        <div>
          {% set quantite_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0', 'data-field': 'quantite'} %}
          {% if form.quantite.vars.errors|length %}{% set quantite_attr = quantite_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.quantite, {'attr': quantite_attr, 'errors': false}) }}
          {% set quantite_errors = form.quantite.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ quantite_errors|length ? '' : 'hidden' }}" data-error-for="quantite">
            {% for error in quantite_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Entier ≥ 0.</div>
        </div>

        {# Champ SEUIL ALERT #}
        <div>
          {% set seuilAlert_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'placeholder': '0', 'data-field': 'seuilAlert'} %}
          {% if form.seuilAlert.vars.errors|length %}{% set seuilAlert_attr = seuilAlert_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.seuilAlert, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
          {{ form_widget(form.seuilAlert, {'attr': seuilAlert_attr, 'errors': false}) }}
          {% set seuil_errors = form.seuilAlert.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ seuil_errors|length ? '' : 'hidden' }}" data-error-for="seuilAlert">
            {% for error in seuil_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Entier ≥ 0. Alerte si quantité &lt;= seuil.</div>
        </div>

        {# Champ IMAGE #}
        <div class="md:col-span-2">
          {% set image_attr = {'class': 'w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-paw-orange focus:border-paw-orange bg-gray-50 hover:bg-white', 'onchange': 'validateImage(this)', 'data-field': 'image'} %}
          {% if form.image.vars.errors|length %}{% set image_attr = image_attr|merge({'class': 'w-full px-4 py-3 border border-red-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-red-50'}) %}{% endif %}
          {{ form_label(form.image, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}

          {% if form.vars.data and form.vars.data.image %}
            <div class="mb-4 p-4 bg-gray-50 rounded-lg">
              <div class="text-sm font-medium text-gray-700 mb-2">Current image:</div>
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <img src="{{ asset('uploads/images/' ~ form.vars.data.image) }}"
                     alt="Product image"
                     class="h-24 w-24 object-cover rounded-lg border border-gray-300">
                <div class="flex-1">
                  <div class="text-sm text-gray-600 mb-2">
                    <span class="font-medium">File name:</span> {{ form.vars.data.image }}
                  </div>
                  <div class="text-xs text-gray-500">Select a new image to replace it</div>
                </div>
              </div>
            </div>
          {% endif %}

          <div class="space-y-2">
            <div class="relative">
              {{ form_widget(form.image, {'attr': image_attr, 'errors': false}) }}
            </div>
            <div class="text-xs text-gray-500">Accepted formats: JPG, PNG, GIF, WEBP (max. 5MB)</div>

            <div id="image-preview-container" class="hidden mt-4">
              <div class="text-sm font-medium text-gray-700 mb-2">Preview:</div>
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <img id="image-preview" class="h-24 w-24 object-cover rounded-lg border border-gray-300">
                <div>
                  <div id="image-filename" class="text-sm text-gray-600 mb-1"></div>
                  <div id="image-size" class="text-xs text-gray-500"></div>
                </div>
              </div>
            </div>
          </div>
          {% set image_errors = form.image.vars.errors %}
          <div class="text-red-500 text-sm mt-1 font-medium {{ image_errors|length ? '' : 'hidden' }}" data-error-for="image">
            {% for error in image_errors %}
              <div>{{ error.message }}</div>
            {% endfor %}
          </div>
          <div class="text-xs text-gray-500 mt-1">Optionnel. JPG, PNG, GIF, WEBP. Taille max 5MB.</div>
        </div>
      </div>

      <div class="pt-6 border-t border-gray-100 flex flex-wrap gap-3">
        <a href="{{ path('app_eshop_produit_index') }}" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 hover:text-gray-800 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to list
        </a>
        <button type="submit" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-orange-500 rounded-lg hover:bg-orange-600 transition-all shadow-md hover:shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          {{ submit_label|default('Save') }}
        </button>
      </div>

      {{ form_end(form) }}
    </div>
  </div>
</div>

<script>
function initProduitFormValidation() {
  const form = document.getElementById('product-form');
  if (!form || form.dataset.validationBound === 'true') {
    return;
  }
  form.dataset.validationBound = 'true';

  const fieldInputs = {
    nom: form.querySelector('[data-field="nom"]'),
    prix: form.querySelector('[data-field="prix"]'),
    categorie: form.querySelector('[data-field="categorie"]'),
    image: form.querySelector('[data-field="image"]'),
    quantite: form.querySelector('[data-field="quantite"]'),
    seuilAlert: form.querySelector('[data-field="seuilAlert"]'),
  };

  function getErrorContainer(field) {
    return form.querySelector('[data-error-for="' + field + '"]');
  }

  function setFieldError(field, message) {
    const input = fieldInputs[field];
    const container = getErrorContainer(field);

    if (container) {
      if (message) {
        container.innerHTML = '<div>' + message + '</div>';
        container.classList.remove('hidden');
      } else {
        container.innerHTML = '';
        container.classList.add('hidden');
      }
    }

    if (input) {
      input.classList.toggle('border-red-500', !!message);
      input.classList.toggle('bg-red-50', !!message);
      input.classList.toggle('focus:ring-red-500', !!message);
      input.classList.toggle('focus:border-red-500', !!message);
      input.setAttribute('aria-invalid', message ? 'true' : 'false');
    }
  }

  function normalizeNumber(value) {
    return value.replace(',', '.').trim();
  }

  function validateField(field) {
    const input = fieldInputs[field];
    if (!input) {
      return true;
    }

    const value = (input.value || '').trim();
    let isValid = true;
    let message = '';

    if (field === 'nom') {
      isValid = value.length >= 2;
      if (!isValid) message = 'Le nom doit contenir au moins 2 caractères.';
    } else if (field === 'prix') {
      const normalized = normalizeNumber(value);
      const numberValue = normalized === '' ? NaN : Number(normalized);
      isValid = !Number.isNaN(numberValue) && numberValue > 0;
      if (!isValid) message = 'Le prix doit être un nombre supérieur à 0.';
    } else if (field === 'categorie') {
      isValid = value !== '';
      if (!isValid) message = 'Veuillez sélectionner une catégorie.';
    } else if (field === 'quantite') {
      isValid = /^\d+$/.test(value);
      if (!isValid) message = 'La quantité doit être un entier positif ou zéro.';
    } else if (field === 'seuilAlert') {
      isValid = /^\d+$/.test(value);
      if (!isValid) message = 'Le seuil d\'alerte doit être un entier positif ou zéro.';
    }

    if (isValid) {
      setFieldError(field, '');
      return true;
    }

    setFieldError(field, message);
    return false;
  }

  // Validation de l'image
  window.validateImage = function(input) {
    setFieldError('image', '');

    if (input.files && input.files[0]) {
      const file = input.files[0];
      const fileSize = file.size;
      const fileSizeMB = (fileSize / 1024 / 1024).toFixed(2);
      const maxSize = 5 * 1024 * 1024; // 5MB

      if (fileSize > maxSize) {
        setFieldError('image', 'Fichier trop volumineux (' + fileSizeMB + ' MB). Taille max: 5 MB.');
        input.value = '';
        hidePreview();
        return false;
      }

      const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
      if (!validTypes.includes(file.type)) {
        setFieldError('image', 'Format non supporté. Utilisez JPG, PNG, GIF ou WEBP.');
        input.value = '';
        hidePreview();
        return false;
      }

      const filenameElement = document.getElementById('image-filename');
      const sizeElement = document.getElementById('image-size');

      if (filenameElement) {
        filenameElement.textContent = file.name;
      }
      if (sizeElement) {
        sizeElement.textContent = fileSizeMB + ' MB';
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        const previewContainer = document.getElementById('image-preview-container');
        const previewImage = document.getElementById('image-preview');

        if (previewImage) {
          previewImage.src = e.target.result;
        }

        if (previewContainer) {
          previewContainer.classList.remove('hidden');
        }
      };
      reader.readAsDataURL(file);
      return true;
    }
    hidePreview();
    setFieldError('image', '');
    return false;
  };

  function hidePreview() {
    const previewContainer = document.getElementById('image-preview-container');
    if (previewContainer) {
      previewContainer.classList.add('hidden');
    }
  }

  ['nom', 'prix', 'categorie', 'quantite', 'seuilAlert'].forEach(function(field) {
    const input = fieldInputs[field];
    if (!input) return;
    input.addEventListener('input', function() { validateField(field); });
    input.addEventListener('change', function() { validateField(field); });
  });

  form.addEventListener('submit', function(event) {
    let firstInvalid = null;
    ['nom', 'prix', 'categorie', 'quantite', 'seuilAlert'].forEach(function(field) {
      const ok = validateField(field);
      if (!ok && !firstInvalid) {
        firstInvalid = fieldInputs[field];
      }
    });

    const imageInput = fieldInputs.image;
    if (imageInput && imageInput.files && imageInput.files[0]) {
      const imageOk = window.validateImage(imageInput);
      if (!imageOk && !firstInvalid) {
        firstInvalid = imageInput;
      }
    }

    if (firstInvalid) {
      event.preventDefault();
      firstInvalid.focus();
    }
  });
}

document.addEventListener('DOMContentLoaded', initProduitFormValidation);
document.addEventListener('turbo:load', initProduitFormValidation);
</script>
