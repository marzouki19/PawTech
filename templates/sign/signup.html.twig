                            'class': 'form-input w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition',
                            'placeholder': 'Last Name'
                        }}) }}
                        <span class="text-red-600">{{ form_errors(form.nom) }}</span>
                    </div>
                </div>
                <div>
