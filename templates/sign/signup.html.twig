<script>
// Face Scan Modal Logic (one straight face only)
document.addEventListener('DOMContentLoaded', function() {
    let faceImage = null;
    
    function openFaceScanModal() {
        const modal = document.getElementById('faceScanModal');
        const status = document.getElementById('face-modal-status');
        if (modal) modal.classList.remove('hidden');
        faceImage = null;
        if (status) status.textContent = 'Look straight ahead';
        startFaceModalCamera();
    }
    function closeFaceScanModal() {
        const modal = document.getElementById('faceScanModal');
        if (modal) modal.classList.add('hidden');
        stopFaceModalCamera();
    }

    let faceModalStream = null;
    function startFaceModalCamera() {
        const video = document.getElementById('face-modal-video');
        if (!video) {
            console.error('Video element not found');
            return;
        }
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
            navigator.mediaDevices.getUserMedia({ video: true })
                .then(function(stream) {
                    faceModalStream = stream;
                    video.srcObject = stream;
                    video.play();
                })
                .catch(function(err) {
                    console.error('Camera access error:', err);
                    const status = document.getElementById('face-modal-status');
                    if (status) status.textContent = 'Unable to access camera: ' + err.message;
                });
        }
    }
    function stopFaceModalCamera() {
        if (faceModalStream) {
            faceModalStream.getTracks().forEach(track => track.stop());
            faceModalStream = null;
        }
    }
    
    const captureBtn = document.getElementById('face-modal-capture-btn');
    if (captureBtn) {
        captureBtn.onclick = function() {
            const video = document.getElementById('face-modal-video');
            const canvas = document.getElementById('face-modal-canvas');
            const faceInput = document.getElementById('face-image-input');
            if (!video || !canvas) return;
            canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
            faceImage = canvas.toDataURL('image/png');
            
            // Set the face image in the hidden input
            if (faceInput) {
                faceInput.value = faceImage;
            }
            
            // Show preview
            const preview = document.getElementById('face-preview');
            const previewContainer = document.getElementById('face-preview-container');
            const status = document.getElementById('face-capture-status');
            if (preview) preview.src = faceImage;
            if (previewContainer) previewContainer.classList.remove('hidden');
            if (status) status.innerHTML = '<span class="text-green-600"><i class="fas fa-check-circle"></i> Face captured! It will be saved with your account.</span>';
            
            closeFaceScanModal();
        };
    }
    
    // Expose functions to global scope
    window.openFaceScanModal = openFaceScanModal;
    window.closeFaceScanModal = closeFaceScanModal;
});
</script>

                <script>
                // Face capture logic - wait for DOM to be ready
                document.addEventListener('DOMContentLoaded', function() {
                    const video = document.getElementById('face-modal-video');
                    const canvas = document.getElementById('face-modal-canvas');
                    const captureBtn = document.getElementById('capture-face-btn');
                    const faceInput = document.getElementById('face-image-input');
                    const statusSpan = document.getElementById('face-capture-status');

                    // Check if video element exists
                    if (!video) {
                        if (statusSpan) statusSpan.textContent = 'Video element not found.';
                        return;
                    }

                    // Request webcam access
                    if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                        navigator.mediaDevices.getUserMedia({ video: true })
                            .then(function(stream) {
                                video.srcObject = stream;
                                video.play();
                            })
                            .catch(function(err) {
                                statusSpan.textContent = 'Unable to access camera: ' + err.message;
                            });
                    } else {
                        statusSpan.textContent = 'Camera not supported on this browser.';
                    }

                    captureBtn.addEventListener('click', function() {
                        canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
                        const dataUrl = canvas.toDataURL('image/png');
                        faceInput.value = dataUrl;
                        canvas.classList.remove('hidden');
                        video.classList.add('hidden');
                        statusSpan.textContent = 'Face captured!';
                    });
                });
                </script>
                
                {# Sign in link #}
                <div class="text-center mt-6 pt-5 border-t border-gray-100">
                    <p class="text-gray-600 text-sm">
                        Already have an account?
                        <a href="{{ path('app_signin') }}" class="font-semibold text-orange-600 hover:text-orange-700">Sign in</a>
                    </p>
                </div>
            </div>
            
            {# Error Container at Bottom #}
            <div id="error-container" class="error-container hidden rounded-b-2xl p-4 mt-2">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-triangle text-red-600 mt-1 mr-2"></i>
                    <div id="error-messages" class="text-red-700 text-sm space-y-1"></div>
                </div>
            </div>
        </div>
    </div>
    
