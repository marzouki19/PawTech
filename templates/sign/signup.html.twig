<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - PawTech</title>
    
    {# Tailwind CSS #}
    <script src="https://cdn.tailwindcss.com"></script>
    
    {# Font Awesome for icons #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* Clean background */
        .page-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #f8f9fa;
            z-index: -1;
        }
        
        /* Clean card styling */
        .clean-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
        
        /* Form input styling */
        .form-input {
            transition: all 0.2s;
            border: 1px solid #d1d5db;
        }
        
        .form-input:focus {
            outline: none;
            border-color: #f97316;
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
        }
        
        /* Validation styling */
        .is-invalid {
            border-color: #ef4444 !important;
        }
        
        .invalid-feedback {
            color: #ef4444;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        
        /* Error container */
        .error-container {
            background: #fef2f2;
            border: 1px solid #fecaca;
            padding: 1rem;
            border-radius: 0.5rem;
        }
        
        /* Password strength indicator */
        .password-strength {
            height: 4px;
            border-radius: 2px;
            transition: all 0.3s;
        }
        
        .strength-weak { background: #f56565; width: 25%; }
        .strength-fair { background: #ed8936; width: 50%; }
        .strength-good { background: #48bb78; width: 75%; }
        .strength-strong { background: #38a169; width: 100%; }
        
        /* No scrollbars */
        * {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
        *::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<body class="fixed inset-0">
    
    {# Clean background #}
    <div class="page-bg"></div>
    
    {# Close button #}
    <button onclick="window.location.href='{{ path('app_home') }}'" 
            class="fixed top-6 right-6 z-50 w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center shadow-sm hover:shadow-md hover:bg-gray-50 transition-all duration-200">
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
    
    {# Main container #}
    <div class="fixed inset-0 flex items-center justify-center p-4">
        <div class="clean-card rounded-xl w-full max-w-md overflow-hidden max-h-[90vh] overflow-y-auto">
            
            <div class="p-8">
                {# Logo and title #}
                <div class="text-center mb-6">
                    <div class="flex justify-center mb-3">
                        <img src="{{ asset('logo.png') }}" alt="PawTech" class="h-12" >
                    </div>
                    <h1 class="text-xl font-semibold text-gray-900">Create account</h1>
                    <p class="text-gray-500 mt-1 text-sm">Join PawTech community</p>
                </div>

                {# Social and Face Login #}
                <div class="space-y-3 mb-5">
                    {# Google Sign Up #}
                    <a href="{{ path('app_google_auth_start') }}" class="w-full flex items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-700 font-medium hover:bg-gray-50 hover:border-gray-400 transition">
                        <svg class="h-5 w-5" viewBox="0 0 48 48" aria-hidden="true">
                            <path fill="#FFC107" d="M43.6 20.4H42V20H24v8h11.3C33.9 32.7 29.4 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.6z"/>
                            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 15.1 18.9 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4c-7.7 0-14.4 3.9-18 10.7z"/>
                            <path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.6-5.2l-6.3-5.3c-1.9 1.3-4.3 2.1-7.3 2.1-5.4 0-10-3.3-11.6-7.9l-6.5 5C9.5 39.9 16.3 44 24 44z"/>
                            <path fill="#1976D2" d="M43.6 20.4H42V20H24v8h11.3c-1.1 2.9-3.4 5.2-6.3 6.6l6.3 5.3C39 36.4 44 30.8 44 24c0-1.3-.1-2.7-.4-3.6z"/>
                        </svg>
                        <span>Continue with Google</span>
                    </a>
                    
                    {# Face Scan Button #}
                    <div class="flex justify-center">
                        <button type="button" onclick="openFaceScanModal()" class="flex flex-col items-center gap-2 text-gray-500 hover:text-orange-500 transition">
                            <div class="w-14 h-14 rounded-full bg-white border-2 border-gray-200 flex items-center justify-center shadow-sm hover:border-orange-400 hover:shadow-md transition">
                                <svg class="h-7 w-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                    <circle cx="12" cy="8" r="2.5" fill="currentColor"/>
                                    <path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                </svg>
                            </div>
                            <span class="text-xs font-medium">Sign up with Face</span>
                        </button>
                    </div>
                    
                    {# Hidden input for face image #}
                    {{ form_widget(form.user_face, {'attr': {
                        'id': 'face-image-input'
                    }}) }}
                    
                    {# Face capture status #}
                    <div id="face-capture-status" class="text-sm text-center"></div>
                    
                    {# Face preview container #}
                    <div id="face-preview-container" class="hidden flex justify-center">
                        <img id="face-preview" src="" alt="Face preview" class="w-16 h-16 rounded-full border-2 border-orange-500 object-cover">
                    </div>
                    
                    {# Face Scan Modal #}
                    <div id="faceScanModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 hidden">
                        <div class="bg-white rounded-xl p-6 relative flex flex-col items-center max-w-sm">
                            <button onclick="closeFaceScanModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-2xl font-bold">&times;</button>
                            <h2 class="text-lg font-semibold mb-2 text-gray-900">Face Recognition</h2>
                            <p class="text-sm text-gray-500 mb-4">Look straight at the camera</p>
                            <video id="face-modal-video" width="280" height="210" autoplay playsinline class="rounded-lg border border-gray-200 mb-4" style="object-fit: cover;"></video>
                            <canvas id="face-modal-canvas" width="280" height="210" class="hidden"></canvas>
                            <button id="face-modal-capture-btn" class="w-full bg-orange-500 text-white py-2.5 rounded-lg font-medium hover:bg-orange-600 transition">Capture</button>
                        </div>
                    </div>
                    
                    <script>
                    let faceModalStream = null;
                    
                    function openFaceScanModal() {
                        document.getElementById('faceScanModal').classList.remove('hidden');
                        startFaceModalCamera();
                    }
                    
                    function closeFaceScanModal() {
                        document.getElementById('faceScanModal').classList.add('hidden');
                        stopFaceModalCamera();
                    }
                    
                    function startFaceModalCamera() {
                        const video = document.getElementById('face-modal-video');
                        if (!video) return;
                        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                            navigator.mediaDevices.getUserMedia({ video: true })
                                .then(function(stream) {
                                    faceModalStream = stream;
                                    video.srcObject = stream;
                                    video.play();
                                })
                                .catch(function(err) {
                                    console.error('Camera access error:', err);
                                    document.getElementById('face-capture-status').innerHTML = '<span class="text-red-500"><i class="fas fa-exclamation-circle"></i> Camera access denied</span>';
                                });
                        }
                    }
                    
                    function stopFaceModalCamera() {
                        if (faceModalStream) {
                            faceModalStream.getTracks().forEach(track => track.stop());
                            faceModalStream = null;
                        }
                    }
                    
                    document.addEventListener('DOMContentLoaded', function() {
                        const captureBtn = document.getElementById('face-modal-capture-btn');
                        if (captureBtn) {
                            captureBtn.onclick = function() {
                                const video = document.getElementById('face-modal-video');
                                const canvas = document.getElementById('face-modal-canvas');
                                const faceInput = document.getElementById('face-image-input');
                                if (!video || !canvas) return;
                                canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
                                const faceImage = canvas.toDataURL('image/png');
                                
                                if (faceInput) {
                                    faceInput.value = faceImage;
                                }
                                
                                const preview = document.getElementById('face-preview');
                                const previewContainer = document.getElementById('face-preview-container');
                                const status = document.getElementById('face-capture-status');
                                if (preview) preview.src = faceImage;
                                if (previewContainer) previewContainer.classList.remove('hidden');
                                if (status) status.innerHTML = '<span class="text-green-600"><i class="fas fa-check-circle"></i> Face captured!</span>';
                                
                                closeFaceScanModal();
                            };
                        }
                    });
                    
                    window.openFaceScanModal = openFaceScanModal;
                    window.closeFaceScanModal = closeFaceScanModal;
                    </script>
                    
                    {# Divider #}
                    <div class="flex items-center gap-3 pt-2">
                        <span class="h-px flex-1 bg-gray-200"></span>
                        <span class="text-xs text-gray-400 font-medium">or</span>
                        <span class="h-px flex-1 bg-gray-200"></span>
                    </div>
                </div>
                
                {# Signup form #}
                {{ form_start(form, {'attr': {'class': 'space-y-4', 'id': 'signup-form'}}) }}
                
                {# Show form errors #}
                {% if form is defined %}
                    {% if form_errors(form) %}
                        <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700">
                            <span class="text-red-600">{{ form_errors(form) }}</span>
                        </div>
                    {% endif %}
                {% endif %}
                
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                        {{ form_widget(form.prenom, {'attr': {
                            'class': 'form-input w-full rounded-lg px-3 py-2 text-gray-900 placeholder-gray-400',
                            'placeholder': 'First name'
                        }}) }}
                        <span class="text-red-500 text-xs">{{ form_errors(form.prenom) }}</span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                        {{ form_widget(form.nom, {'attr': {
                            'class': 'form-input w-full rounded-lg px-3 py-2 text-gray-900 placeholder-gray-400',
                            'placeholder': 'Last name'
                        }}) }}
                        <span class="text-red-500 text-xs">{{ form_errors(form.nom) }}</span>
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    {{ form_widget(form.email, {'attr': {
                        'class': 'form-input w-full rounded-lg px-3 py-2 text-gray-900 placeholder-gray-400',
                        'placeholder': 'you@example.com'
                    }}) }}
                    <span class="text-red-500 text-xs">{{ form_errors(form.email) }}</span>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                    {{ form_widget(form.telephone, {'attr': {
                        'class': 'form-input w-full rounded-lg px-3 py-2 text-gray-900 placeholder-gray-400',
                        'placeholder': '12345678'
                    }}) }}
                    <span class="text-red-500 text-xs">{{ form_errors(form.telephone) }}</span>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    {{ form_widget(form.password.first, {'attr': {
                        'class': 'form-input w-full rounded-lg px-3 py-2 text-gray-900 placeholder-gray-400',
                        'placeholder': 'Create a password',
                        'id': 'password'
                    }}) }}
                    <span class="text-red-500 text-xs">{{ form_errors(form.password.first) }}</span>
                    <div class="mt-1.5">
                        <div class="password-strength strength-weak" id="password-strength"></div>
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                    {{ form_widget(form.password.second, {'attr': {
                        'class': 'form-input w-full rounded-lg px-3 py-2 text-gray-900 placeholder-gray-400',
                        'placeholder': 'Confirm password',
                        'id': 'confirm-password'
                    }}) }}
                    <span class="text-red-500 text-xs">{{ form_errors(form.password.second) }}</span>
                </div>
                
                <div class="flex items-start gap-2 pt-1">
                    {{ form_widget(form.agreeTerms, {'attr': {
                        'class': 'mt-0.5 rounded border-gray-300 text-orange-500 focus:ring-orange-500 h-4 w-4',
                        'id': 'agree-terms'
                    }}) }}
                    <span class="text-red-500 text-xs">{{ form_errors(form.agreeTerms) }}</span>
                    <label class="text-sm text-gray-600 leading-tight">
                        I agree to the <a href="#" class="text-orange-600 hover:text-orange-700 font-medium">Terms</a> and <a href="#" class="text-orange-600 hover:text-orange-700 font-medium">Privacy Policy</a>
                    </label>
                </div>
                
                <button type="submit" class="w-full rounded-lg bg-orange-500 py-2.5 px-4 font-medium text-white hover:bg-orange-600 transition-all duration-200">
                    Create account
                </button>
                
                {{ form_end(form) }}
                
                {# Sign in link #}
                <div class="text-center mt-5">
                    <p class="text-gray-600 text-sm">
                        Already have an account?
                        <a href="{{ path('app_signin') }}" class="font-medium text-orange-600 hover:text-orange-700">Sign in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    {# Prevent scrolling #}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.body.style.overflow = 'hidden';
            document.documentElement.style.overflow = 'hidden';
            
            document.addEventListener('wheel', function(e) {
                e.preventDefault();
            }, { passive: false });
            
            document.addEventListener('touchmove', function(e) {
                e.preventDefault();
            }, { passive: false });
        });
    </script>
</body>
</html>