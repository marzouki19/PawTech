{% extends 'layout.html.twig' %}

{% block main %}
<div class="bg-white rounded-xl shadow p-6 max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Add New Follow-Up</h2>
    
    {# DÉSACTIVATION VALIDATION HTML5 COMME DANS LE WORKSHOP #}
    {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
    
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- État -->
            <div>
                {{ form_label(form.etat, 'État *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.etat, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.etat.vars.errors|length ? ' border-red-500' : '')}}) }}
                {% if form_errors(form.etat) %}
                    <div class="mt-1 text-sm text-red-600">
                        {{ form_errors(form.etat) }}
                    </div>
                {% endif %}
            </div>
            
            <!-- Type de suivi -->
            <div>
                {{ form_label(form.type, 'Type de suivi *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.type, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.type.vars.errors|length ? ' border-red-500' : '')}}) }}
                {% if form_errors(form.type) %}
                    <div class="mt-1 text-sm text-red-600">
                        {{ form_errors(form.type) }}
                    </div>
                {% endif %}
            </div>
            
            <!-- Date et heure -->
            <div class="md:col-span-2">
                {{ form_label(form.prochaineVisite, 'Date et heure de la prochaine visite', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.prochaineVisite, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.prochaineVisite.vars.errors|length ? ' border-red-500' : '')}}) }}
                {% if form_errors(form.prochaineVisite) %}
                    <div class="mt-1 text-sm text-red-600">
                        {{ form_errors(form.prochaineVisite) }}
                    </div>
                {% endif %}
            </div>
            
            <!-- Consultation -->
            <div class="md:col-span-2">
                {{ form_label(form.consultation, 'Consultation associée *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.consultation, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.consultation.vars.errors|length ? ' border-red-500' : '')}}) }}
                {% if form_errors(form.consultation) %}
                    <div class="mt-1 text-sm text-red-600">
                        {{ form_errors(form.consultation) }}
                    </div>
                {% endif %}
            </div>
            
            <!-- Recommandation -->
            <div class="md:col-span-2">
                {{ form_label(form.recommandation, 'Recommandation *', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.recommandation, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-paw-orange focus:border-paw-orange' ~ (form.recommandation.vars.errors|length ? ' border-red-500' : ''), 'rows': 5, 'placeholder': 'Recommandations...'}}) }}
                {% if form_errors(form.recommandation) %}
                    <div class="mt-1 text-sm text-red-600">
                        {{ form_errors(form.recommandation) }}
                    </div>
                {% endif %}
            </div>
        </div>
        
        <div class="pt-6 flex justify-end gap-3">
            <a href="{{ path('app_suivi_index') }}" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
                Cancel
            </a>
            {{ form_widget(form.save, {'label': 'Add Follow-Up'}) }}
        </div>
        
    {{ form_end(form) }}
</div>
{% endblock %}