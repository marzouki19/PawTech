{{ form_start(form, { attr: { class: 'space-y-6', novalidate: 'novalidate' } }) }}
    <div class="text-red-600 text-sm">
        {{ form_errors(form) }}
    </div>
    {% set raw_image = form.vars.value and form.vars.value.userImage ? form.vars.value.userImage : '' %}
    {% set preview_src = raw_image and raw_image != 'uploads/users/default-user.png' ? raw_image : '' %}
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-8" data-controller="image-preview">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.nom, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.nom, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.nom) }}</div>
            </div>
            <div>
                {{ form_label(form.prenom, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.prenom, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.prenom) }}</div>
            </div>
            <div>
                {{ form_label(form.email, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.email, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.email) }}</div>
            </div>
            <div>
                {{ form_label(form.telephone, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.telephone, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.telephone) }}</div>
            </div>
            <div>
                {{ form_label(form.role, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.role, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.role) }}</div>
            </div>
            <div>
                {{ form_label(form.status, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.status, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.status) }}</div>
            </div>
            <div>
                {{ form_label(form.password, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.password, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.password) }}</div>
            </div>
            <div>
                {{ form_label(form.order_number, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.order_number, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.order_number) }}</div>
            </div>
            <div>
                {{ form_label(form.matricule, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.matricule, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.matricule) }}</div>
            </div>
            <div>
                {{ form_label(form.zone_affectee, null, { label_attr: { class: 'block text-xs font-semibold text-gray-600 mb-1' } }) }}
                {{ form_widget(form.zone_affectee, { attr: { class: 'w-full px-4 py-2.5 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none' } }) }}
                <div class="text-red-600 text-xs mt-1">{{ form_errors(form.zone_affectee) }}</div>
            </div>
        </div>

        <div class="bg-gray-50 border border-dashed border-gray-300 rounded-2xl p-4 h-fit">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-gray-700">User photo</span>
                <span class="text-xs text-gray-400">Optional</span>
            </div>
            <label class="block">
                <div class="w-full aspect-square rounded-xl bg-white border border-gray-200 overflow-hidden flex items-center justify-center cursor-pointer hover:border-paw-orange transition">
                    <img
                        {% if preview_src %}src="{{ asset(preview_src) }}"{% endif %}
                        alt="User preview"
                        class="w-full h-full object-cover {{ preview_src ? '' : 'hidden' }}"
                        data-image-preview-target="preview"
                    />
                    <div data-image-preview-target="placeholder" class="flex flex-col items-center gap-2 text-gray-400 {{ preview_src ? 'hidden' : '' }}">
                        <span class="text-4xl font-light">+</span>
                        <span class="text-xs">Add photo</span>
                    </div>
                </div>
                {{ form_widget(form.user_image, { attr: { class: 'sr-only', 'data-image-preview-target': 'input', 'data-action': 'change->image-preview#preview' } }) }}
            </label>
            <div class="text-red-600 text-sm mt-2">{{ form_errors(form.user_image) }}</div>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <button class="px-5 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium">
            {{ button_label|default('Save') }}
        </button>
        <a href="{{ path('app_users_index') }}" class="px-5 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</a>
    </div>

{{ form_end(form) }}
