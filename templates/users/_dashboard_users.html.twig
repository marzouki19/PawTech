<div>
  <!-- Table View (copy from users/index.html.twig) -->
  <div id="user-table" class="mb-8">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      {% include 'components/_entity_table.html.twig' with {
        columns: columns,
        rows: rows,
        total_records: total_records,
        per_page: per_page,
        page: page,
        total_pages: total_pages,
        actions_enabled: true,
        actions_id_index: 0,
        actions_show_route: 'app_user_show',
        actions_edit_route: 'app_user_edit',
        actions_delete_route: 'app_user_delete',
        status_badge_index: 6
      } %}
    </div>
  </div>

  <!-- Cards View (copy from users/index.html.twig) -->
  <div id="user-cards" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    {% for row in card_rows %}
      {% set imagePath = row[7]|default('') %}
      {% set is_active = row[6]|lower == 'actif' or row[6]|lower == 'active' %}
      {% set is_admin = row[5]|lower == 'admin' or row[5]|lower == 'administrator' %}
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-lg transition group">
        <!-- Header with status badge and role icon -->
        <div class="px-5 pt-5 pb-3 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="relative">
              {% if imagePath %}
                <img src="{{ asset(imagePath) }}" 
                     alt="{{ row[1] }} {{ row[2] }}" 
                     class="w-14 h-14 rounded-full object-cover border-2 border-white shadow">
              {% else %}
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-paw-orange to-orange-400 flex items-center justify-center text-white font-semibold text-xl">
                  {{ row[1]|default('U')|slice(0, 1) }}{{ row[2]|default('')|slice(0, 1) }}
                </div>
              {% endif %}
              <!-- Status Dot -->
              <span class="absolute -bottom-1 -right-1 flex items-center">
                <span class="relative flex h-4 w-4">
                  <span class="absolute inline-flex h-full w-full rounded-full {{ is_active ? 'bg-green-400' : 'bg-red-400' }} opacity-75 animate-ping"></span>
                  <span class="relative inline-flex rounded-full h-4 w-4 {{ is_active ? 'bg-green-500' : 'bg-red-500' }}"></span>
                </span>
              </span>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                {{ row[1] }} {{ row[2] }}
                <!-- Role Icon -->
                {% if row[5]|lower == 'admin' or row[5]|lower == 'administrator' %}
                  <svg class="h-4 w-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c1.104 0 2-.896 2-2s-.896-2-2-2-2 .896-2 2 .896 2 2 2zm0 2c-2.21 0-4 1.79-4 4v1h8v-1c0-2.21-1.79-4-4-4z"/></svg>
                {% elseif row[5]|lower == 'veterinaire' %}
                  <svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                {% else %}
                  <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="2"/></svg>
                {% endif %}
              </h3>
              <p class="text-xs text-gray-500 mt-0.5">{{ row[5] }}</p>
            </div>
          </div>
          <span class="text-xs px-2.5 py-1 rounded-full font-medium flex items-center gap-1 {{ is_active ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600' }}">
            <span class="inline-block w-2 h-2 rounded-full {{ is_active ? 'bg-green-500' : 'bg-red-500' }}"></span>
            {{ row[6] }}
          </span>
        </div>
        <!-- User details -->
        <div class="px-5 py-3 border-t border-gray-100">
          <div class="space-y-2">
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="text-gray-600">{{ row[3] }}</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span class="text-gray-600">{{ row[4] }}</span>
            </div>
          </div>
        </div>
        <!-- Actions -->
        <div class="px-5 py-4 border-t border-gray-100 bg-gray-50">
          <div class="flex items-center gap-2">
            <a href="{{ path('app_user_show', {id: row[0]}) }}" 
               class="flex-1 px-3 py-2 rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-paw-orange hover:text-white text-sm font-medium text-center transition group-hover:scale-105">
              View
            </a>
            <a href="{{ path('app_user_edit', {id: row[0]}) }}" 
               class="flex-1 px-3 py-2 rounded-lg border border-paw-orange bg-white text-paw-orange hover:bg-paw-orange hover:text-white text-sm font-medium text-center transition group-hover:scale-105">
              Edit
            </a>
            <form method="post" 
                  action="{{ path('app_user_delete', {id: row[0]}) }}" 
                  class="flex-1"
                  data-action="submit->delete-confirm#confirm" 
                  data-delete-message="Delete {{ row[1] }} {{ row[2] }}?">
              <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ row[0]) }}">
              <button type="submit" 
                      class="w-full px-3 py-2 rounded-lg border border-red-300 bg-white text-red-500 hover:bg-red-500 hover:text-white text-sm font-medium transition group-hover:scale-105">
                Delete
              </button>
            </form>
          </div>
        </div>
      </div>
    {% else %}
      <div class="col-span-full bg-white rounded-2xl border border-gray-200 p-12 text-center">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5 0a6 6 0 00-13 0m13.5 0h.008v.008h-.008v-.008zm-13.5 0h.008v.008h-.008v-.008z"/>
        </svg>
        <h3 class="text-lg font-semibold text-gray-600 mb-2">No users found</h3>
        <p class="text-gray-400 mb-6">Get started by adding your first user</p>
        <a href="{{ path('app_users_create') }}" 
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add First User
        </a>
      </div>
    {% endfor %}
  </div>
</div>