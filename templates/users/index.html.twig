{% extends 'layout.html.twig' %}

{% block title %}Users | PawTech{% endblock %}

{% block main %}
  {% set is_edit = edit_mode|default(false) %}
  {% set form_view = edit_form is defined ? edit_form : form %}
  {% set show_form = show_form|default(false) %}
  
  <div class="space-y-8" id="users-page" data-controller="users-toggle delete-confirm">
    
    <!-- Page Header -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
      <div class="flex items-start gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100">
          <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5 0a6 6 0 00-13 0m13.5 0h.008v.008h-.008v-.008zm-13.5 0h.008v.008h-.008v-.008z" />
          </svg>
        </div>
        <div class="flex-1">
          <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_home') }}" class="hover:text-gray-700 transition">Dashboard</a>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-gray-900 font-medium">Users</span>
          </nav>
          <h1 class="text-2xl font-bold text-gray-900">User Management</h1>
          <p class="mt-1 text-sm text-gray-600">Manage all registered users, assign roles, and monitor user status across the platform.</p>
        </div>
        <a href="{{ path('app_users_create') }}" 
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium shadow-sm hover:shadow transition">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add User
        </a>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      {% set total_users = rows|length %}
      {% set active_users = rows|filter(row => row[6]|lower == 'actif' or row[6]|lower == 'active')|length %}
      {% set inactive_users = rows|filter(row => row[6]|lower == 'inactif' or row[6]|lower == 'inactive')|length %}
      {% set admin_users = rows|filter(row => row[5]|lower == 'admin' or row[5]|lower == 'administrator')|length %}
      
      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 font-medium">TOTAL USERS</p>
            <p class="text-2xl font-bold text-gray-900 mt-1">{{ total_users }}</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-paw-orange/10 flex items-center justify-center">
            <svg class="h-6 w-6 text-paw-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5 0a6 6 0 00-13 0m13.5 0h.008v.008h-.008v-.008zm-13.5 0h.008v.008h-.008v-.008z"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 font-medium">ACTIVE</p>
            <p class="text-2xl font-bold text-gray-900 mt-1">{{ active_users }}</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-green-50 flex items-center justify-center">
            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 font-medium">INACTIVE</p>
            <p class="text-2xl font-bold text-gray-900 mt-1">{{ inactive_users }}</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-red-50 flex items-center justify-center">
            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 font-medium">ADMINISTRATORS</p>
            <p class="text-2xl font-bold text-gray-900 mt-1">{{ admin_users }}</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-blue-50 flex items-center justify-center">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters and Search Section -->
    <div class="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-800">User Filters</h2>
          <p class="text-sm text-gray-500 mt-1">Search and filter users by different criteria</p>
        </div>
        
        <form method="get" action="{{ path('app_users_index') }}" class="flex flex-wrap items-center gap-3" data-controller="users-search" data-users-search-target="form">
          <div>
            <label for="user-filter-field" class="sr-only">Filter field</label>
            {% set current_field = search_field|default('all') %}
            <select id="user-filter-field" name="field" class="h-10 px-3 border border-gray-200 rounded-lg bg-white text-gray-700 focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none text-sm" data-users-search-target="field" data-action="change->users-search#submitNow">
              <option value="all" {{ current_field == 'all' ? 'selected' : '' }}>All fields</option>
              <option value="first_name" {{ current_field == 'first_name' ? 'selected' : '' }}>First name</option>
              <option value="last_name" {{ current_field == 'last_name' ? 'selected' : '' }}>Last name</option>
              <option value="email" {{ current_field == 'email' ? 'selected' : '' }}>Email</option>
              <option value="phone" {{ current_field == 'phone' ? 'selected' : '' }}>Phone</option>
              <option value="role" {{ current_field == 'role' ? 'selected' : '' }}>Role</option>
              <option value="status" {{ current_field == 'status' ? 'selected' : '' }}>Status</option>
            </select>
          </div>
          
          <div>
            <label for="user-sort" class="sr-only">Sort</label>
            {% set current_sort = sort_dir|default('asc') %}
            <select id="user-sort" name="sort" class="h-10 px-3 border border-gray-200 rounded-lg bg-white text-gray-700 focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none text-sm" data-action="change->users-search#submitNow">
              <option value="asc" {{ current_sort == 'asc' ? 'selected' : '' }}>Ascending</option>
              <option value="desc" {{ current_sort == 'desc' ? 'selected' : '' }}>Descending</option>
            </select>
          </div>
          
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </span>
            <input type="search" 
                   name="q" 
                   value="{{ search_query|default('') }}" 
                   placeholder="Search users by name, email, or role..." 
                   class="w-64 pl-10 pr-4 py-2 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none text-sm"
                   data-users-search-target="input"
                   data-action="input->users-search#queue">
          </div>
          
          <button type="submit" class="inline-flex items-center gap-2 px-4 py-2.5 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
            </svg>
            Apply Filters
          </button>
          
          <a href="{{ path('app_users_index') }}" class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50 text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            Clear Filters
          </a>
        </form>
      </div>
    </div>

    <!-- View Toggle -->
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-800">Users Gallery</h2>
      <button type="button" 
              class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50 text-sm font-medium"
              data-action="users-toggle#toggleTable">
        
       <!-- <span data-users-toggle-target="tableLabel">Show Cards</span>-->
      </button>
    </div>

    <!-- Table View -->
    <div>
  <!-- Table View (copy from users/index.html.twig) -->
  <div id="user-table" class="mb-8">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      {% include 'components/_entity_table.html.twig' with {
        columns: columns,
        rows: rows,
        total_records: total_records,
        per_page: per_page,
        page: page,
        total_pages: total_pages,
        actions_enabled: true,
        actions_id_index: 0,
        actions_show_route: 'app_user_show',
        actions_edit_route: 'app_user_edit',
        actions_delete_route: 'app_user_delete',
        status_badge_index: 6
      } %}
    </div>
  </div>

  <!-- Cards View removed: Table only -->
</div>

    <!-- Form Section (Edit/Add) -->
    <div id="user-form" class="{{ (is_edit or show_form) ? '' : 'hidden' }}" data-users-toggle-target="form">
      {% if is_edit %}
        <!-- Edit Form Header -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100">
              <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            <div class="flex-1">
              <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="{{ path('app_users_index') }}" class="hover:text-gray-700 transition">Users</a>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
                <span class="text-gray-900 font-medium">Edit User</span>
              </nav>
              <h2 class="text-xl font-bold text-gray-900">Edit User Profile</h2>
              <p class="mt-1 text-sm text-gray-600">Update user information and account settings</p>
            </div>
            <a href="{{ path('app_users_index') }}"
               class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 text-sm font-medium">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
              </svg>
              Back to list
            </a>
          </div>
        </div>
      {% endif %}
      
      <!-- Form Container -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-8 py-6">
          {{ include('user/_form.html.twig', { 
            button_label: is_edit ? 'Update User' : 'Create User', 
            form: form_view,
            is_edit: is_edit
          }) }}
        </div>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div data-delete-confirm-target="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/30">
      <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Confirm deletion</h3>
        <p class="text-sm text-gray-600" data-delete-confirm-target="message">Are you sure you want to delete this item?</p>
        <div class="mt-6 flex gap-3">
          <button type="button" 
                  class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 text-sm font-medium"
                  data-action="delete-confirm#close">
            Cancel
          </button>
          <button type="button" 
                  class="flex-1 px-4 py-2.5 bg-red-500 text-white rounded-lg hover:bg-red-600 text-sm font-medium"
                  data-action="delete-confirm#submit">
            Delete
          </button>
        </div>
      </div>
    </div>

  </div>

{% endblock %}