{% extends 'layout.html.twig' %}

{% block title %}Users | PawTech{% endblock %}

{% block main %}
  {% set is_edit = edit_mode|default(false) %}
  {% set form_view = edit_form is defined ? edit_form : form %}
  <div class="space-y-6" id="users-page" data-controller="users-toggle delete-confirm">
    <div class="flex flex-wrap items-center justify-between gap-6">
      <div>
        <h1 class="text-2xl font-semibold text-gray-900">Users</h1>
        <p class="text-sm text-gray-500">Manage registered users, roles, and access in one place.</p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <form method="get" action="{{ path('app_users_index') }}" class="flex items-center gap-3" data-controller="users-search" data-users-search-target="form">
          <div>
            <label for="user-filter-field" class="sr-only">Filter field</label>
            {% set current_field = search_field|default('all') %}
            <select id="user-filter-field" name="field" class="h-10 px-3 border border-gray-200 rounded-lg bg-white text-gray-700 focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" data-users-search-target="field" data-action="change->users-search#submitNow">
              <option value="all" {{ current_field == 'all' ? 'selected' : '' }}>All fields</option>
              <option value="id" {{ current_field == 'id' ? 'selected' : '' }}>ID</option>
              <option value="first_name" {{ current_field == 'first_name' ? 'selected' : '' }}>First name</option>
              <option value="last_name" {{ current_field == 'last_name' ? 'selected' : '' }}>Last name</option>
              <option value="email" {{ current_field == 'email' ? 'selected' : '' }}>Email</option>
              <option value="phone" {{ current_field == 'phone' ? 'selected' : '' }}>Phone</option>
              <option value="role" {{ current_field == 'role' ? 'selected' : '' }}>Role</option>
              <option value="status" {{ current_field == 'status' ? 'selected' : '' }}>Status</option>
            </select>
          </div>
          
          <div>
            <label for="user-sort" class="sr-only">Sort</label>
            {% set current_sort = sort_dir|default('asc') %}
            <select id="user-sort" name="sort" class="h-10 px-3 border border-gray-200 rounded-lg bg-white text-gray-700 focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" data-action="change->users-search#submitNow">
              <option value="asc" {{ current_sort == 'asc' ? 'selected' : '' }}>Ask</option>
              <option value="desc" {{ current_sort == 'desc' ? 'selected' : '' }}>Desk</option>
            </select>
          </div>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </span>
            <input type="search" name="q" value="{{ search_query|default('') }}" placeholder="Search users..." class="w-64 pl-10 pr-4 py-2 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-paw-orange focus:border-paw-orange outline-none" data-users-search-target="input" data-action="input->users-search#queue">
          </div>
        </form>
        <button type="button" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
          Filters
        </button>
        <button type="button" class="inline-flex items-center gap-2 px-4 py-2 bg-paw-orange text-white rounded-lg hover:bg-paw-orange-hover font-medium" data-action="users-toggle#showForm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add User
        </button>
        <button type="button" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg bg-white text-gray-700 hover:bg-gray-50" data-action="users-toggle#toggleTable">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          <span data-users-toggle-target="tableLabel">Show Cards</span>
        </button>
      </div>
    </div>

    <div class="flex items-center justify-between text-sm text-gray-500">
      <h2 class="font-semibold text-gray-800">Users Gallery</h2>
      <span>{{ card_rows|length }} users</span>
    </div>

    <div id="user-cards" class="{{ is_edit ? 'hidden ' : 'hidden ' }}grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" data-users-toggle-target="cards">
      {% for row in card_rows %}
        {% set imagePath = row[7]|default('') %}
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="h-40 bg-gradient-to-br from-orange-100 via-white to-orange-50 flex items-center justify-center">
            {% if imagePath %}
              <img src="{{ asset(imagePath) }}" alt="{{ row[1] }} {{ row[2] }}" class="w-full h-full object-cover" />
            {% else %}
              <div class="w-20 h-20 rounded-full bg-white shadow flex items-center justify-center text-xl font-semibold text-paw-orange">
                {{ row[1]|default('U')|slice(0, 1) }}{{ row[2]|default('')|slice(0, 1) }}
              </div>
            {% endif %}
          </div>
          <div class="p-5 space-y-3">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-semibold text-gray-900">{{ row[1] }} {{ row[2] }}</h3>
                <p class="text-sm text-gray-500">{{ row[3] }}</p>
              </div>
              {% set is_active = row[6]|lower == 'actif' or row[6]|lower == 'active' %}
              <span class="text-xs px-2 py-1 rounded-full font-medium {{ is_active ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600' }}">{{ row[6] }}</span>
            </div>
            <div class="grid grid-cols-2 gap-3 text-sm text-gray-600">
              <div>
                <span class="block text-xs text-gray-400">Role</span>
                <span class="font-medium text-gray-700">{{ row[5] }}</span>
              </div>
              <div>
                <span class="block text-xs text-gray-400">Phone</span>
                <span class="font-medium text-gray-700">{{ row[4] }}</span>
              </div>
            </div>
            <div class="flex items-center gap-3 pt-2">
              <a href="{{ path('app_user_show', {id: row[0]}) }}" class="flex-1 px-3 py-2 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 text-center">View</a>
              <a href="{{ path('app_users_edit', {id: row[0]}) }}" class="flex-1 px-3 py-2 rounded-lg border border-orange-200 text-paw-orange hover:bg-orange-50 text-center">Edit</a>
              <form method="post" action="{{ path('app_user_delete', {id: row[0]}) }}" class="flex-1" data-action="submit->delete-confirm#confirm" data-delete-message="Delete {{ row[1] }} {{ row[2] }}?">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ row[0]) }}">
                <button type="submit" class="w-full px-3 py-2 rounded-lg border border-red-200 text-red-500 hover:bg-red-50">Delete</button>
              </form>
            </div>
          </div>
        </div>
      {% else %}
        <div class="col-span-full bg-white rounded-2xl border border-gray-200 p-8 text-center text-gray-400">
          No users yet.
        </div>
      {% endfor %}
    </div>

    <div id="user-table" class="{{ is_edit ? 'hidden' : '' }}" data-users-toggle-target="table">
      {% include 'components/_entity_table.html.twig' with {
        columns: columns,
        rows: rows,
        total_records: total_records,
        per_page: per_page,
        page: page,
        total_pages: total_pages,
        actions_enabled: true,
        actions_id_index: 0,
        actions_show_route: 'app_user_show',
        actions_edit_route: 'app_users_edit',
        actions_delete_route: 'app_user_delete',
        status_badge_index: 6
      } %}
    </div>

    <div id="user-form" class="{{ is_edit ? '' : 'hidden' }}" data-users-toggle-target="form">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-800">{{ is_edit ? 'Edit User' : 'Add New User' }}</h2>
        {% if is_edit %}
          <a href="{{ path('app_users_index') }}" class="text-paw-orange hover:underline">Back to list</a>
        {% else %}
          <button type="button" class="text-paw-orange hover:underline" data-action="users-toggle#showCards">Back to list</button>
        {% endif %}
      </div>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        {{ include('user/_form.html.twig', { button_label: is_edit ? 'Update User' : 'Create User', form: form_view }) }}
      </div>
    </div>

    <div data-delete-confirm-target="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/30">
      <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Confirm deletion</h3>
        <p class="text-sm text-gray-600" data-delete-confirm-target="message">Are you sure you want to delete this item?</p>
        <div class="mt-6 flex gap-3">
          <button type="button" class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50" data-action="delete-confirm#close">Cancel</button>
          <button type="button" class="flex-1 px-4 py-2.5 bg-red-500 text-white rounded-lg hover:bg-red-600" data-action="delete-confirm#submit">Delete</button>
        </div>
      </div>
    </div>
  </div>

{% endblock %}
