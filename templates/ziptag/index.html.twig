{% extends 'layout.html.twig' %}

{% block title %}Ziptag | PawTech{% endblock %}

{% set active = 'ziptag' %}
{% set page_title = 'Ziptag' %}

{% block main %}
{% set total_records = ziptags|length %}
{% set assigned_records = ziptags|filter(z => z.dog)|length %}
{% set unassigned_records = total_records - assigned_records %}

<div x-data="{
    showGridOnly: false,
    searchQuery: '',
    deleteModalOpen: false,
    deleteAction: '',
    deleteToken: '',
    deleteLabel: '',
    openDelete(action, token, label) {
        this.deleteAction = action;
        this.deleteToken = token;
        this.deleteLabel = label;
        this.deleteModalOpen = true;
    }
}">
    <div class="px-4 sm:px-6 lg:px-8 py-8 max-w-7xl mx-auto">
        <!-- Page Header -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="flex items-start gap-4 flex-1">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100">
                        <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                    </div>
                    <div>
                        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                            <a href="#" class="hover:text-gray-700 transition">Dashboard</a>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            <span class="text-gray-900 font-medium">Ziptag</span>
                        </nav>
                        <div class="flex flex-col lg:flex-row lg:items-center lg:gap-4">
                            <div>
                                <h1 class="text-2xl font-bold text-gray-900">Ziptag Management</h1>
                                <p class="mt-1 text-sm text-gray-600 max-w-xl">Track and manage all Ziptag devices, monitor firmware versions, and device assignments.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 mt-4 lg:mt-0">
                    <a href="{{ path('app_ziptag_new') }}"
                       class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                        Add Ziptag
                    </a>
                    <button @click="showGridOnly = !showGridOnly"
                            type="button"
                            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                        </svg>
                        <span x-text="showGridOnly ? 'Show Table' : 'Grid Only'"></span>
                    </button>
                </div>
            </div>
        </div>

        <!-- FILTERS + SEARCH ROW (INLINE) -->
        <div class="flex flex-col gap-4 mb-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div class="flex items-center gap-4 flex-1">
                    <span class="text-sm font-semibold text-gray-700">Filters:</span>
                    <!-- Firmware Filter -->
                    <div class="relative">
                        <select name="firmware" 
                                id="firmwareFilter"
                                class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                            <option value="">All Firmware</option>
                            {% for version in firmware_versions|default([]) %}
                                <option value="{{ version }}" {{ current_firmware == version ? 'selected' : '' }}>
                                    {{ version }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <!-- Assignment Filter -->
                    <div class="relative">
                        <select name="assignment" 
                                id="assignmentFilter"
                                class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-900 focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                            <option value="">All Status</option>
                            <option value="assigned" {{ current_assignment == 'assigned' ? 'selected' : '' }}>Assigned</option>
                            <option value="unassigned" {{ current_assignment == 'unassigned' ? 'selected' : '' }}>Unassigned</option>
                        </select>
                    </div>
                    <button type="button" 
                            id="applyFilters"
                            class="inline-flex items-center gap-2 rounded-lg bg-paw-orange px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-paw-orange-hover transition-colors min-w-[150px]">
                        Apply Filters
                    </button>
                    {% if current_firmware or current_assignment %}
                        <a href="{{ path('app_ziptag_index') }}" 
                           class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors min-w-[150px]">
                            Clear Filters
                        </a>
                    {% endif %}
                </div>
                <div class="relative flex-1 max-w-xl">
                    <input type="text" 
                           id="search" 
                           placeholder="Search ziptags by serial number, model, or firmware..."
                           class="w-full min-w-[300px] max-w-[400px] rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-paw-orange focus:ring-2 focus:ring-paw-orange/30">
                </div>
            </div>
            <!-- Active Filters Display -->
            {% if current_firmware or current_assignment %}
                <div class="flex items-center gap-2">
                    <span class="text-sm text-gray-600">Active filters:</span>
                    {% if current_firmware %}
                        <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
                            Firmware: {{ current_firmware }}
                            <a href="{{ path('app_ziptag_index', {assignment: current_assignment}) }}" 
                               class="text-blue-500 hover:text-blue-700">&times;</a>
                        </span>
                    {% endif %}
                    {% if current_assignment %}
                        <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
                            {% if current_assignment == 'assigned' %}Assigned{% else %}Unassigned{% endif %}
                            <a href="{{ path('app_ziptag_index', {firmware: current_firmware}) }}" 
                               class="text-green-500 hover:text-green-700">&times;</a>
                        </span>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <!-- Overview Stats -->
        <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" id="statsContainer" x-show="!showGridOnly">
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total Tags</p>
                <p class="mt-2 text-2xl font-bold text-gray-900">{{ total_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Assigned</p>
                <p class="mt-2 text-2xl font-bold text-green-600">{{ assigned_records }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Unassigned</p>
                <p class="mt-2 text-2xl font-bold text-yellow-600">{{ unassigned_records }}</p>
            </div>
        </div>

        <!-- Ziptag Table -->
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm" id="ziptagTable" x-show="!showGridOnly">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Device</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Firmware</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Model</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Assigned Dog</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="all">
                        {% if ziptags is empty %}
                            <tr>
                                <td colspan="5" class="px-6 py-12 text-center">
                                    {% if current_firmware or current_assignment %}
                                        <p class="text-sm font-semibold text-gray-600">No ziptags match your filters.</p>
                                        <p class="text-xs text-gray-400">Try changing your filter criteria.</p>
                                    {% else %}
                                        <p class="text-sm font-semibold text-gray-600">No ziptags registered yet.</p>
                                        <p class="text-xs text-gray-400">Click "Add Ziptag" to create the first record.</p>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            {% for ziptag in ziptags %}
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4">
                                        <div>
                                            <p class="text-sm font-semibold text-gray-900">{{ ziptag.serialNumber }}</p>
                                            <p class="text-xs text-gray-500">ID #{{ ziptag.id }}</p>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ ziptag.firmwareVersion }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">{{ ziptag.model }}</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        {% if ziptag.dog %}
                                            {{ ziptag.dog.name }}
                                        {% else %}
                                            <span class="text-gray-400">Unassigned</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4 text-right text-sm">
                                        <a href="{{ path('app_ziptag_show', {'id': ziptag.id}) }}"
                                           class="text-gray-600 hover:text-gray-900 font-semibold">View</a>
                                        <a href="{{ path('app_ziptag_edit', {'id': ziptag.id}) }}"
                                           class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a>
                                        <button type="button"
                                                class="ml-4 text-red-600 hover:text-red-700 font-semibold"
                                                @click="openDelete('{{ path('app_ziptag_delete', {'id': ziptag.id}) }}', '{{ csrf_token('delete' ~ ziptag.id) }}', '{{ ziptag.serialNumber|e('js') }}')">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                    <tbody id="searchtab" style="display: none;"></tbody>
                </table>
            </div>
        </div>

        <!-- Ziptag Grid -->
        <div class="mt-8" id="ziptagGrid" x-show="showGridOnly" x-cloak style="display: none;">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-gray-900">Ziptag Gallery</h2>
                <span class="text-sm text-gray-500">{{ total_records }} tags</span>
            </div>

            {% if ziptags is empty %}
                <div class="rounded-2xl border border-dashed border-gray-200 p-12 text-center bg-white">
                    <p class="text-sm font-semibold text-gray-600">
                        {% if current_firmware or current_assignment %}
                            No ziptags match your filters.
                        {% else %}
                            No ziptags registered yet.
                        {% endif %}
                    </p>
                    <p class="text-xs text-gray-400">
                        {% if current_firmware or current_assignment %}
                            Try changing your filter criteria.
                        {% else %}
                            Add your first device to see the gallery.
                        {% endif %}
                    </p>
                </div>
            {% else %}
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="ziptagGridContainer">
                    {% for ziptag in ziptags %}
                        <div class="group overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:shadow-lg">
                            <div class="relative h-32 bg-gray-100">
                                <div class="flex h-full w-full items-center justify-center text-4xl font-bold text-gray-300">
                                    ZT
                                </div>
                                <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-700">
                                    {{ ziptag.model }}
                                </span>
                            </div>
                            <div class="p-5">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-lg font-semibold text-gray-900">{{ ziptag.serialNumber }}</h3>
                                    <span class="text-xs font-semibold text-gray-500">FW {{ ziptag.firmwareVersion }}</span>
                                </div>
                                <p class="text-sm text-gray-500">ID #{{ ziptag.id }}</p>
                                <div class="mt-4 text-xs text-gray-500">
                                    <span class="font-semibold text-gray-700">Assigned:</span>
                                    {% if ziptag.dog %}
                                        {{ ziptag.dog.name }}
                                    {% else %}
                                        Unassigned
                                    {% endif %}
                                </div>
                                <div class="mt-4 flex gap-2">
                                    <a href="{{ path('app_ziptag_show', {'id': ziptag.id}) }}"
                                       class="flex-1 rounded-lg border border-gray-200 px-3 py-2 text-xs font-semibold text-gray-700 hover:bg-gray-50 text-center">
                                        View
                                    </a>
                                    <a href="{{ path('app_ziptag_edit', {'id': ziptag.id}) }}"
                                       class="flex-1 rounded-lg border border-orange-200 px-3 py-2 text-xs font-semibold text-orange-600 hover:bg-orange-50 text-center">
                                        Edit
                                    </a>
                                    <button type="button"
                                            class="flex-1 rounded-lg border border-red-200 px-3 py-2 text-xs font-semibold text-red-600 hover:bg-red-50 text-center"
                                            @click="openDelete('{{ path('app_ziptag_delete', {'id': ziptag.id}) }}', '{{ csrf_token('delete' ~ ziptag.id) }}', '{{ ziptag.serialNumber|e('js') }}')">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div x-show="deleteModalOpen"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm"
         @click.self="deleteModalOpen = false"
         @keydown.escape.window="deleteModalOpen = false"
         style="display: none;"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95">
        <div @click.stop class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
            <div class="sticky top-0 bg-white border-b border-gray-200 px-8 py-6 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900">Delete Ziptag</h2>
                        <p class="mt-1 text-sm text-gray-600">Are you sure you want to delete <span class="font-semibold" x-text="deleteLabel"></span>?</p>
                    </div>
                    <button @click="deleteModalOpen = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="px-8 py-6">
                <form method="post" :action="deleteAction">
                    <input type="hidden" name="_token" :value="deleteToken">
                    <div class="flex justify-end gap-3">
                        <button type="button" @click="deleteModalOpen = false"
                                class="px-6 py-2.5 rounded-lg border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:bg-gray-50">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-6 py-2.5 rounded-lg bg-red-600 text-sm font-semibold text-white shadow hover:bg-red-700">
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script>
$(document).ready(function() {
    // Search functionality
    $("#search").keyup(function(e) {
        var value = $(this).val();
        
        if (value.trim() === '') {
            $('#ziptagTable tbody#all').show();
            $('#ziptagTable tbody#searchtab').hide().empty();
            return;
        }
        
        $.ajax({
            url: "{{ path('app_ziptag_search_json') }}",
            type: 'GET',
            data: { 'searchValue': value },
            dataType: 'json',
            success: function(retour) {
                console.log('Search results:', retour);
                
                if (retour && retour.length > 0) {
                    $('#ziptagTable tbody#searchtab').empty();
                    $('#ziptagTable tbody#all').hide();
                    
                    $.each(retour, function(i, ziptag) {
                        var dogName = ziptag.dog ? ziptag.dog.name : '<span class="text-gray-400">Unassigned</span>';
                        
                        var row = '<tr class="hover:bg-gray-50">' +
                            '<td class="px-6 py-4">' +
                                '<div>' +
                                    '<p class="text-sm font-semibold text-gray-900">' + ziptag.serialNumber + '</p>' +
                                    '<p class="text-xs text-gray-500">ID #' + ziptag.id + '</p>' +
                                '</div>' +
                            '</td>' +
                            '<td class="px-6 py-4 text-sm text-gray-600">' + (ziptag.firmwareVersion || '') + '</td>' +
                            '<td class="px-6 py-4 text-sm text-gray-600">' + (ziptag.model || '') + '</td>' +
                            '<td class="px-6 py-4 text-sm text-gray-600">' + dogName + '</td>' +
                            '<td class="px-6 py-4 text-right text-sm">' +
                                '<a href="/ziptag/' + ziptag.id + '" class="text-gray-600 hover:text-gray-900 font-semibold">View</a> ' +
                                '<a href="/ziptag/' + ziptag.id + '/edit" class="ml-4 text-paw-orange hover:text-paw-orange-hover font-semibold">Edit</a> ' +
                                '<button type="button" class="ml-4 text-red-600 hover:text-red-700 font-semibold"' +
                                    ' onclick="Alpine.store(\'app\').openDelete(\'/ziptag/' + ziptag.id + '\', \'' + ziptag.id + '\', \'' + ziptag.serialNumber.replace(/\'/g, "\\\'") + '\')">' +
                                    'Delete' +
                                '</button>' +
                            '</td>' +
                        '</tr>';
                        
                        $('#ziptagTable tbody#searchtab').append(row);
                    });
                    
                    $('#ziptagTable tbody#searchtab').show();
                } else {
                    $('#ziptagTable tbody#searchtab').empty();
                    $('#ziptagTable tbody#all').hide();
                    $('#ziptagTable tbody#searchtab').html('<tr><td colspan="5" class="px-6 py-12 text-center"><p class="text-sm font-semibold text-gray-600">No ziptags found for "' + value + '"</p></td></tr>').show();
                }
            },
            error: function(jqXHR, textStatus, errorThrown) {
                console.error('AJAX Error:', textStatus, errorThrown);
                console.error('Response:', jqXHR.responseText);
                alert('Error fetching data! Check console for details.');
            }
        });
        return false;
    });

    // Apply Filters button
    $('#applyFilters').on('click', function() {
        const firmware = $('#firmwareFilter').val();
        const assignment = $('#assignmentFilter').val();
        
        // Build URL with filters
        let url = "{{ path('app_ziptag_index') }}";
        const params = [];
        
        if (firmware) params.push(`firmware=${encodeURIComponent(firmware)}`);
        if (assignment) params.push(`assignment=${assignment}`);
        
        if (params.length > 0) {
            url += '?' + params.join('&');
        }
        
        window.location.href = url;
    });
});
</script>
{% endblock %}